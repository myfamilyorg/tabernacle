#!/bin/sh
# Build tabernacle from src/bin_config.inc + src/tabernacle.fam3.
# Usage: tools/build_node [output]
# If output is omitted, writes to bin/tabernacle.

SELF="$0"
[ -L "$SELF" ] && SELF="$(readlink -f "$SELF")"
SCRIPT_DIR="$(cd "$(dirname "$SELF")" && pwd)"
ROOT_DIR="$(dirname "$SCRIPT_DIR")"
ASM="$ROOT_DIR/bin/fam3"
CONFIG="$ROOT_DIR/src/bin_config.inc"
SRC="$ROOT_DIR/src/tabernacle.fam3"

if [ ! -e "$ASM" ]; then
	echo "Error: $ASM not found — run build.sh first"
	exit 1
fi
if [ ! -e "$CONFIG" ]; then
	echo "Error: $CONFIG not found"
	echo "Run: python3 tools/gen_bin_config.py <node_binary> src"
	exit 1
fi
# Validate BIN_SIZE is non-zero (placeholder has 0).
BIN_SZ=$(grep 'BIN_SIZE' "$CONFIG" | grep -oP '\d+' | head -1)
if [ -z "$BIN_SZ" ] || [ "$BIN_SZ" = "0" ]; then
	echo "Error: $CONFIG has BIN_SIZE=$BIN_SZ (placeholder?)"
	echo "Run: python3 tools/gen_bin_config.py <node_binary> src"
	exit 1
fi
if [ ! -e "$SRC" ]; then
	echo "Error: $SRC not found"
	exit 1
fi

if [ -n "$1" ]; then
	OUT="$1"
else
	OUT="$ROOT_DIR/bin/tabernacle"
fi

(cat "$CONFIG" "$SRC"; printf '\004') | qemu-system-riscv32 \
	-machine virt \
	-cpu rv32,m=false,a=false,f=false,d=false,c=false,zawrs=false,zfa=false,\
zfh=false,zfhmin=false,zcb=false,zcd=false,zcf=false,zcmp=false,\
zcmt=false,zicsr=false,zifencei=false \
	-nographic \
	-bios none \
	-device loader,file="$ASM",addr=0x80000000 \
	-serial mon:stdio 2>/dev/null > "$OUT"

if [ ! -s "$OUT" ]; then
	echo "Error: assembler produced no output"
	rm -f "$OUT"
	exit 1
fi

MAGIC=$(head -c 4 "$OUT" | xxd -p)
if [ "$MAGIC" != "13000000" ]; then
	cat "$OUT"
	rm -f "$OUT"
	exit 1
fi

echo "$OUT ($(wc -c < "$OUT") bytes)"
