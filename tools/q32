#!/bin/sh

SMP=1
CPU="rv32,m=false,a=false,f=false,d=false,c=false,\
zawrs=false,zfa=false,zfh=false,zfhmin=false,zcb=false,\
zcd=false,zcf=false,zcmp=false,zcmt=false,zicsr=false,zifencei=false"
FILE=""

for arg in "$@"; do
	case "$arg" in
		--cpu=*) CPU="${arg#--cpu=}" ;;
		--*) echo "Unknown option: $arg"; echo "Usage: $0 [--cpu=CPU] <path/to/bin>"; exit 1 ;;
		*) FILE="$arg" ;;
	esac
done

if [ -z "$FILE" ]; then
	echo "Usage: $0 [--cpu=CPU] <path/to/bin>"
	echo "Examples:"
	echo "  $0 program.bin                              # rv32i (default)"
	echo "  $0 --cpu=rv32i,zicsr=true program.bin       # + CSR support"
	echo "  $0 --cpu=rv32i,zicsr=true,m=true program.bin  # + M extension"
	exit 1
fi

if [ ! -e "$FILE" ]; then
	echo "Error: $FILE not found"
	exit 1
fi

MAGIC=$(head -c 4 "$FILE" | xxd -p)
if [ "$MAGIC" != "13000000" ]; then
	echo "Error: $FILE is not a valid binary (bad magic)"
	exit 1
fi

qemu-system-riscv32 \
	-machine virt \
	-cpu "$CPU" \
	-smp $SMP \
	-nographic \
	-bios none \
	-device loader,file="$FILE",addr=0x80000000 \
	-serial stdio \
	-monitor none 2>/dev/null
