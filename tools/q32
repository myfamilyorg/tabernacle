#!/bin/sh
# Run an RV32I binary in QEMU virt.
#
# Usage: q32 [options] <binary>
#   --cpu=CPU     CPU model (default: rv32i strict)
#   --net         Enable virtio-net (user-mode NAT)
#   --disk=FILE   Attach FILE as virtio-blk disk
#
# Examples:
#   q32 program.bin
#   q32 --net bin/tabernacle
#   q32 --net --disk=node.bin bin/tabernacle
#   printf '10.0.2.2:3737\004' | q32 --net bin/tabernacle

CPU="rv32,m=false,a=false,f=false,d=false,c=false,\
zawrs=false,zfa=false,zfh=false,zfhmin=false,zcb=false,\
zcd=false,zcf=false,zcmp=false,zcmt=false,zicsr=false,zifencei=false"
FILE=""
NET=0
DISK=""
HOSTFWD=""

for arg in "$@"; do
	case "$arg" in
		--cpu=*) CPU="${arg#--cpu=}" ;;
		--net) NET=1 ;;
		--disk=*) DISK="${arg#--disk=}" ;;
		--hostfwd=*) HOSTFWD="${arg#--hostfwd=}" ;;
		--help|-h)
			echo "Usage: $0 [--cpu=CPU] [--net] [--disk=FILE] [--hostfwd=SPEC] <binary>"
			echo "  --hostfwd=udp::HOST_PORT-:GUEST_PORT  expose guest UDP port to host"
			exit 0 ;;
		--*) echo "Unknown option: $arg"; exit 1 ;;
		*) FILE="$arg" ;;
	esac
done

if [ -z "$FILE" ]; then
	echo "Usage: $0 [--cpu=CPU] [--net] [--disk=FILE] <binary>"
	exit 1
fi

if [ ! -e "$FILE" ]; then
	echo "Error: $FILE not found"
	exit 1
fi

MAGIC=$(head -c 4 "$FILE" | xxd -p)
if [ "$MAGIC" != "13000000" ]; then
	echo "Error: $FILE is not a valid binary (bad magic)"
	exit 1
fi

# Build QEMU arguments
ARGS="-machine virt -cpu $CPU -nographic -bios none"
ARGS="$ARGS -device loader,file=$FILE,addr=0x80000000"
ARGS="$ARGS -serial stdio -monitor none"

if [ "$NET" = "1" ]; then
	ARGS="$ARGS -global virtio-mmio.force-legacy=true"
	if [ -n "$HOSTFWD" ]; then
		ARGS="$ARGS -netdev user,id=n0,hostfwd=$HOSTFWD"
	else
		ARGS="$ARGS -netdev user,id=n0"
	fi
	ARGS="$ARGS -device virtio-net-device,netdev=n0"
fi

if [ -n "$DISK" ]; then
	if [ ! -e "$DISK" ]; then
		echo "Error: disk image $DISK not found"
		exit 1
	fi
	ARGS="$ARGS -global virtio-mmio.force-legacy=true"
	ARGS="$ARGS -drive file=$DISK,format=raw,if=none,id=d0"
	ARGS="$ARGS -device virtio-blk-device,drive=d0"
fi

qemu-system-riscv32 $ARGS 2>/dev/null
