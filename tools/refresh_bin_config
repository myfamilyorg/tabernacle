#!/bin/sh
# Regenerate src/bin_config.inc from src/full_node.fam, then rebuild
# bin/tabernacle so its embedded hash/size match the new node.
#
# Self-hosted: uses bin/gen_bin_config (compiled from src/gen_bin_config.fam3
# by build.sh) to compute the gimli-hash. Requires QEMU only, no python.
#
# Typical workflow after editing src/full_node.fam:
#
#   bash build.sh                    # bootstrap, compile node + gen_bin_config
#   tools/refresh_bin_config         # regen bin_config + rebuild tabernacle
#   git add src/bin_config.inc       # commit the updated hash
#
# Anyone who doesn't touch full_node.fam can run just `bash build.sh`.
set -e

SELF="$0"
[ -L "$SELF" ] && SELF="$(readlink -f "$SELF")"
SCRIPT_DIR="$(cd "$(dirname "$SELF")" && pwd)"
ROOT_DIR="$(dirname "$SCRIPT_DIR")"

cd "$ROOT_DIR"

for f in bin/famc bin/fam3 bin/gen_bin_config; do
	if [ ! -f "$f" ]; then
		echo "tools/refresh_bin_config: $f missing — run build.sh first" >&2
		exit 1
	fi
done

CPU="rv32,m=false,a=false,f=false,d=false,c=false,\
zawrs=false,zfa=false,zfh=false,zfhmin=false,zcb=false,\
zcd=false,zcf=false,zcmp=false,zcmt=false,zicsr=false,zifencei=false"

# Compile full_node.fam + init.fam into bin/full_node.
# full_node.fam is first so its `fn main(...)` definition is seen before
# init.fam's `fn _bootstrap` references it. The init's top-level code
# (which advances gp past the image, sets sp/tp/s1, and calls
# _bootstrap) comes last and is what executes at program entry.
echo "Compiling src/full_node.fam + src/init.fam" >&2
(cat src/full_node.fam src/init.fam; printf '\004') | qemu-system-riscv32 \
	-machine virt -cpu "$CPU" \
	-nographic -bios none \
	-device loader,file=bin/famc,addr=0x80000000 > bin/full_node

# famc writes error messages to stdout (which we capture as the binary).
# A successful RV32 binary starts with the 0x00000013 nop; any error
# text begins with 'E' (0x45 = "Error..."). Catch that here so a compile
# failure halts the build instead of silently producing garbage bytes.
FIRST=$(head -c 1 bin/full_node)
if [ "$FIRST" = "E" ]; then
	echo "tools/refresh_bin_config: famc compile failed:" >&2
	head -c 512 bin/full_node >&2
	echo "" >&2
	rm -f bin/full_node
	exit 1
fi

# Append compressed bible to the binary
cat ./resources/bible.compressed >> ./bin/full_node

# Build the gen_bin_config input image: a 4-byte little-endian length
# prefix followed by bin/full_node. QEMU's `-device loader` copies the
# whole thing into guest RAM at 0x80100000 before the CPU starts, so
# gen_bin_config can hash straight out of memory instead of pulling
# every byte through the virt UART. On a 1.7 MiB payload this cuts
# generation from tens of seconds (and minutes on slow hosts) to well
# under a second — the UART MMIO-per-byte was the bottleneck, not the
# hash itself.
echo "Generating src/bin_config.inc from bin/full_node" >&2
SIZE=$(wc -c < bin/full_node)
{
	for i in 0 8 16 24; do
		byte=$(( (SIZE >> i) & 0xFF ))
		# POSIX printf: octal escapes are portable; hex isn't.
		printf "\\$(printf '%03o' $byte)"
	done
	cat bin/full_node
} > tmp/gen_input.bin

qemu-system-riscv32 \
	-machine virt -cpu "$CPU" \
	-nographic -bios none \
	-device loader,file=bin/gen_bin_config,addr=0x80000000 \
	-device loader,file=tmp/gen_input.bin,addr=0x80100000 \
	-serial stdio -monitor none 2>/dev/null > src/bin_config.inc

rm -f tmp/gen_input.bin

# Sanity-check: the output must start with a '#' comment header.
FIRST=$(head -c 1 src/bin_config.inc)
if [ "$FIRST" != "#" ]; then
	echo "tools/refresh_bin_config: gen_bin_config produced unexpected output" >&2
	head -c 200 src/bin_config.inc >&2
	exit 1
fi

# Rebuild tabernacle against the updated bin_config.
echo "Rebuilding bin/tabernacle" >&2
tools/build_node bin/tabernacle > /dev/null
