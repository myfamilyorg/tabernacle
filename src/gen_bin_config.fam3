# ══════════════════════════════════════════════════════════════════════════
hdr1:
	.ascii	"# bin_config.inc -- auto-generated by gen_bin_config\n"
	.byte	0
hdr2:
	.ascii	"# Hash function: gimli-hash (rate=16, capacity=32, output=32)\n"
	.byte	0
size_prefix:
	.ascii	".equ\tBIN_SIZE,\t\t"
	.byte	0
hash_prefix:
	.ascii	".equ\tBIN_HASH"
	.byte	0
hash_mid:
	.ascii	",\t\t0x"
	.byte	0
err_too_big:
	.ascii	"Error: input exceeds 14 MiB buffer\n"
	.byte	0
err_no_disk:
	.ascii	"Error: no virtio-blk device found\n"
	.byte	0
