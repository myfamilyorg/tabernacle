# ────────────────────────────────�
# file: fam1.S - stage 1 bootstrap assembler (GNU as reference)
# RISC-V 32-bit Hex-to-Binary with Labels and Branch Fixups
# ────────────────────────────────�
#
# Input format (superset of fam0):
#   Hex bytes:   "13 05 A0 00"      (same as fam0)
#   :NAME        define 4-char label at current output offset
#   @NAME        patch previous 4 bytes: encode B-type (0x63) or
#                J-type (0x6F) immediate to point to NAME
#   # ...        line comments       (same as fam0)
#   EOT (^D)     end of input        (same as fam0)
#
# After EOT, all @-fixups are resolved (supports forward references),
# then the assembled binary is output via UART.
#
# Memory layout (QEMU virt, loaded at 0x80000000):
#   0x80000000  code
#   0x80001000  label table   (512 entries × 8 bytes)
#   0x80002000  fixup table   (512 entries × 8 bytes)
#   0x80003000  output buffer
#
# Register map:
#   s1  = output buffer base / read ptr (output phase)
#   s2  = output buffer write ptr
#   s3  = nibble toggle (1=high expected, 0=low expected)
#   s4  = comment flag (0=no, 1=yes)
#   s5  = UART base (0x10000000)
#   s6  = constant 10 ('\n' and hex digit limit)
#   s7  = label table base
#   s8  = label table write ptr
#   s9  = fixup table base
#   s10 = fixup table write ptr
#   t4  = high nibble accumulator (across loop iterations)

# _start:
13 00 00 00	# addi	zero,zero,0 ; q32 magic

# ── Constants ──
13 0B A0 00	# addi	s6,zero,10 ; '\n' and hex limit
B7 0A 00 10	# lui	s5,0x10000 ; UART base 0x10000000

# ── State ──
13 0A 00 00	# addi	s4,zero,0 ; Comment flag off
93 09 10 00	# addi	s3,zero,1 ; Nibble toggle (1=high)

# ── Memory regions ──
B7 1B 00 80	# lui	s7,0x80001 ; Label table  @ 0x80001000
13 8C 0B 00	# addi	s8,s7,0
B7 2C 00 80	# lui	s9,0x80002 ; Fixup table  @ 0x80002000
13 8D 0C 00	# addi	s10,s9,0
B7 34 00 80	# lui	s1,0x80003 ; Output buffer @ 0x80003000
13 89 04 00	# addi	s2,s1,0

# loop:
03 CF 5A 00	# lbu	t5,5(s5) ; UART status
13 7F 1F 00	# andi	t5,t5,1 ; Data ready?
E3 0C 0F FE	# beq	t5,zero,loop
03 C3 0A 00	# lbu	t1,0(s5) ; Read character

# Newline clears comment
63 14 63 01	# bne	t1,s6,not_nl
13 0A 00 00	# addi	s4,zero,0

# '#' starts comment
# not_nl:
13 0E 30 02	# addi	t3,zero,35
63 14 C3 01	# bne	t1,t3,not_hash
13 0A 10 00	# addi	s4,zero,1

# EOT → resolve fixups and output
# not_hash:
13 0E 40 00	# addi	t3,zero,4
63 02 C3 0D	# beq	t1,t3,resolve

# In comment → skip
E3 1A 0A FC	# bne	s4,zero,loop

# ':' → label definition
13 0E A0 03	# addi	t3,zero,58
63 06 C3 05	# beq	t1,t3,label_def

# '@' → fixup reference
13 0E 00 04	# addi	t3,zero,64
63 0C C3 07	# beq	t1,t3,fixup_ref

# Whitespace / control → skip
13 0E 10 02	# addi	t3,zero,33
E3 4E C3 FB	# blt	t1,t3,loop

# Hex conversion
13 03 03 FD	# addi	t1,t1,-48 ; '0' → 0
63 6A 63 01	# bltu	t1,s6,store ; 0–9 valid
13 03 93 FF	# addi	t1,t1,-7 ; 'A' → 10
13 0E 00 01	# addi	t3,zero,16
63 64 C3 01	# bltu	t1,t3,store ; 10–15 valid
6F F0 5F FA	# jal	zero,loop ; invalid → skip

# store:
93 C9 19 00	# xori	s3,s3,1 ; Toggle high/low
63 96 09 00	# bne	s3,zero,store_low ; Was high → now store low
93 1E 43 00	# slli	t4,t1,0x4 ; Save high nibble
6F F0 5F F9	# jal	zero,loop

# store_low:
B3 EE 6E 00	# or	t4,t4,t1 ; Pack high | low
23 00 D9 01	# sb	t4,0(s2) ; Write byte
13 09 19 00	# addi	s2,s2,1
6F F0 5F F8	# jal	zero,loop

# label_def:
13 0E 00 00	# addi	t3,zero,0 ; Byte counter

# ld_poll:
03 CF 5A 00	# lbu	t5,5(s5)
13 7F 1F 00	# andi	t5,t5,1
E3 0C 0F FE	# beq	t5,zero,ld_poll
03 C3 0A 00	# lbu	t1,0(s5) ; Read name char
B3 02 CC 01	# add	t0,s8,t3
23 80 62 00	# sb	t1,0(t0) ; Store in table entry
13 0E 1E 00	# addi	t3,t3,1
93 02 40 00	# addi	t0,zero,4
E3 10 5E FE	# bne	t3,t0,ld_poll
23 22 2C 01	# sw	s2,4(s8) ; Record current output address
13 0C 8C 00	# addi	s8,s8,8 ; Advance table pointer
6F F0 1F F5	# jal	zero,loop

# fixup_ref:
13 0E 00 00	# addi	t3,zero,0 ; Byte counter

# fu_poll:
03 CF 5A 00	# lbu	t5,5(s5)
13 7F 1F 00	# andi	t5,t5,1
E3 0C 0F FE	# beq	t5,zero,fu_poll
03 C3 0A 00	# lbu	t1,0(s5) ; Read name char
B3 02 CD 01	# add	t0,s10,t3
23 80 62 00	# sb	t1,0(t0) ; Store in table entry
13 0E 1E 00	# addi	t3,t3,1
93 02 40 00	# addi	t0,zero,4
E3 10 5E FE	# bne	t3,t0,fu_poll
93 02 C9 FF	# addi	t0,s2,-4 ; Instruction = last 4 bytes written
23 22 5D 00	# sw	t0,4(s10) ; Record instruction address
13 0D 8D 00	# addi	s10,s10,8 ; Advance table pointer
6F F0 9F F1	# jal	zero,loop

# resolve:
93 8F 0C 00	# addi	t6,s9,0 ; t6 = fixup iterator

# res_loop:
63 8A AF 0F	# beq	t6,s10,output ; All fixups done → output
03 AE 0F 00	# lw	t3,0(t6) ; Fixup name (as word)
83 A3 4F 00	# lw	t2,4(t6) ; Instruction address in output buf

# Search label table for name
93 82 0B 00	# addi	t0,s7,0 ; t0 = label table scan ptr

# search:
63 8E 82 0D	# beq	t0,s8,res_next ; End of table → not found, skip
03 A3 02 00	# lw	t1,0(t0) ; Label name (as word)
63 06 C3 01	# beq	t1,t3,found
93 82 82 00	# addi	t0,t0,8
6F F0 1F FF	# jal	zero,search

# found:
03 A3 42 00	# lw	t1,4(t0) ; t1 = label address
33 03 73 40	# sub	t1,t1,t2 ; t1 = offset (label − instruction)

# Determine type from opcode byte
03 CE 03 00	# lbu	t3,0(t2) ; Opcode byte of instruction
13 7E FE 07	# andi	t3,t3,127
93 02 30 06	# addi	t0,zero,99
63 08 5E 00	# beq	t3,t0,patch_b ; B-type branch
93 02 F0 06	# addi	t0,zero,111
63 0E 5E 04	# beq	t3,t0,patch_j ; J-type jump
6F 00 80 0A	# jal	zero,res_next ; Unknown → skip

# patch_b:
83 A2 03 00	# lw	t0,0(t2) ; Load instruction
13 0E 00 00	# addi	t3,zero,0 ; Build encoded immediate
93 5E C3 00	# srli	t4,t1,0xc ; imm[12] → inst[31]
93 FE 1E 00	# andi	t4,t4,1
93 9E FE 01	# slli	t4,t4,0x1f
33 6E DE 01	# or	t3,t3,t4
93 5E 53 00	# srli	t4,t1,0x5 ; imm[10:5] → inst[30:25]
93 FE FE 03	# andi	t4,t4,63
93 9E 9E 01	# slli	t4,t4,0x19
33 6E DE 01	# or	t3,t3,t4
93 5E 13 00	# srli	t4,t1,0x1 ; imm[4:1] → inst[11:8]
93 FE FE 00	# andi	t4,t4,15
93 9E 8E 00	# slli	t4,t4,0x8
33 6E DE 01	# or	t3,t3,t4
93 5E B3 00	# srli	t4,t1,0xb ; imm[11] → inst[7]
93 FE 1E 00	# andi	t4,t4,1
93 9E 7E 00	# slli	t4,t4,0x7
33 6E DE 01	# or	t3,t3,t4
B3 E2 C2 01	# or	t0,t0,t3 ; Merge immediate into instruction
23 A0 53 00	# sw	t0,0(t2) ; Store patched instruction
6F 00 40 05	# jal	zero,res_next

# patch_j:
83 A2 03 00	# lw	t0,0(t2) ; Load instruction
13 0E 00 00	# addi	t3,zero,0 ; Build encoded immediate
93 5E 43 01	# srli	t4,t1,0x14 ; imm[20] → inst[31]
93 FE 1E 00	# andi	t4,t4,1
93 9E FE 01	# slli	t4,t4,0x1f
33 6E DE 01	# or	t3,t3,t4
93 5E 13 00	# srli	t4,t1,0x1 ; imm[10:1] → inst[30:21]
93 FE FE 3F	# andi	t4,t4,1023
93 9E 5E 01	# slli	t4,t4,0x15
33 6E DE 01	# or	t3,t3,t4
93 5E B3 00	# srli	t4,t1,0xb ; imm[11] → inst[20]
93 FE 1E 00	# andi	t4,t4,1
93 9E 4E 01	# slli	t4,t4,0x14
33 6E DE 01	# or	t3,t3,t4
93 5E C3 00	# srli	t4,t1,0xc ; imm[19:12] → inst[19:12]
93 FE FE 0F	# andi	t4,t4,255
93 9E CE 00	# slli	t4,t4,0xc
33 6E DE 01	# or	t3,t3,t4
B3 E2 C2 01	# or	t0,t0,t3 ; Merge immediate into instruction
23 A0 53 00	# sw	t0,0(t2) ; Store patched instruction

# res_next:
93 8F 8F 00	# addi	t6,t6,8
6F F0 1F F1	# jal	zero,res_loop

# output:
63 80 24 03	# beq	s1,s2,shutdown ; Empty → exit
03 CE 04 00	# lbu	t3,0(s1) ; Load byte
93 84 14 00	# addi	s1,s1,1

# tx_poll:
03 C3 5A 00	# lbu	t1,5(s5) ; UART status
13 73 03 02	# andi	t1,t1,32 ; TX ready?
E3 0C 03 FE	# beq	t1,zero,tx_poll
23 80 CA 01	# sb	t3,0(s5) ; Send byte
6F F0 5F FE	# jal	zero,output

# shutdown:
B7 0A 10 00	# lui	s5,0x100 ; QEMU virt test device 0x100000
37 53 00 00	# lui	t1,0x5 ; 0x5000
13 03 53 55	# addi	t1,t1,1365 ; 0x5555 (power off)
23 A0 6A 00	# sw	t1,0(s5)
