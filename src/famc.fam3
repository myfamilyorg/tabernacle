# ══════════════════════════════════════════════════════════════════════════════
# emit_word — store a0 as 4 bytes at s5, advance s5.
#
# Call sites:
#    0: ew_li_s     (emit_li, single-addi path)
#    1: ew_li_lui   (emit_li, lui of big-imm path)
#    2: ew_li_add   (emit_li, addi of big-imm path)
#    3: ew_lws      (emit_lw_sp)
#    4: ew_sws      (emit_sw_sp)
#    5: ew_lwd      (emit_lw_deref)
#    6: ew_lbud     (emit_lbu_deref)
#    7: ew_push_addi (emit_push_a0 — addi sp,sp,-4)
#    8: ew_push_sw   (emit_push_a0 — sw a0,0(sp))
#    9: ew_pop_lw    (emit_pop_t0 — lw t0,0(sp))
#   10: ew_pop_addi  (emit_pop_t0 — addi sp,sp,4)
#   11: ew_add       (emit_add — add a0,t0,a0)
#   12: ew_sw_d      (emit_sw_deref — sw a0,0(t0))
#   13: ew_sb_d      (emit_sb_deref — sb a0,0(t0))
#   14: ew_sub       (emit_sub — sub a0,t0,a0)
#   15: ew_xor       (emit_xor — xor a0,t0,a0)
#   16: ew_addi1     (emit_addi_a0_1  — addi a0,a0,1)
#   17: ew_addim1    (emit_addi_a0_m1 — addi a0,a0,-1)
#   18: ew_sll       (emit_sll — sll a0,t0,a0)
#   19: ew_sra       (emit_sra — sra a0,t0,a0)
#   20: ew_and       (emit_and — and a0,t0,a0)
#   21: ew_or        (emit_or  — or  a0,t0,a0)
#   22: ew_xori_m1   (emit_xori_m1 — xori a0,a0,-1)
#   23: ew_neg       (emit_neg_a0 — sub a0,zero,a0)
#   24: ew_cmp       (emit_cmp_word — caller-supplied comparison word)
#   25: ew_srl       (emit_srl — srl a0,t0,a0)
#   26: ew_mul       (emit_mul — loop emitting the 11-word inline mul seq)
#   27: ew_divmod    (emit_divmod_body — loop emitting the 24-word divmod body)
#   28: ew_udivmod   (emit_udivmod_body — loop emitting the 13-word udivmod body)
# ══════════════════════════════════════════════════════════════════════════════
emit_word:
	# Bounds check: s5 must stay strictly below bin_end, else bail with
	# err 71. Using t6 because emit_word is called from everywhere and
	# t0..t5 are often live in callers.
	lla	t6, bin_end
	lw	t6, 0(t6)
	bgeu	s5, t6, bin_full
	sw	a0, 0(s5)
	addi	s5, s5, 4
	# Clear push_safe_marker (and the literal-only sub-marker) by
	# default. Safe-leaf emitters (emit_li, emit_lw_sp) re-set them
	# from their own dispatch return sites.
	lla	t6, push_safe_marker
	sw	zero, 0(t6)
	lla	t6, last_li_marker
	sw	zero, 0(t6)
	# a0_known_zero clear: only if the just-emitted instruction
	# writes rd=a0(=10). Decode opcode + rd at -4(s5).
	lw	t5, -4(s5)
	andi	t6, t5, 0x7F		# opcode (low 7 bits — bit7 is 0)
	# Stores (0x23), branches (0x63) — no rd, leave flag alone.
	addi	t4, zero, 0x23
	beq	t6, t4, ew_a0z_skip
	addi	t4, zero, 0x63
	beq	t6, t4, ew_a0z_skip
	# Has rd: extract bits[11:7] and compare to 10.
	srli	t6, t5, 7
	andi	t6, t6, 0x1F
	addi	t4, zero, 10
	bne	t6, t4, ew_a0z_skip
	lla	t6, a0_known_zero
	sw	zero, 0(t6)
ew_a0z_skip:
	j	emit_word_disp

bin_full:
	addi	a0, zero, 71		# err 71: binary output too large
	j	report_err

heap_full:
	addi	a0, zero, 72		# err 72: compiler heap exhausted
	j	report_err

