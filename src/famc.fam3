	addi	gp, gp, -1
	bnez	gp, pid_28
	j	pi_cs_macro
pid_28:
	addi	gp, gp, -1
	bnez	gp, pid_29
	j	pi_cs_macro_arg
pid_29:
	j	pi_cs_rept

# ══════════════════════════════════════════════════════════════════════════════
# parse_num — parse decimal or hex at s2, returns value in a0.
#   Single caller:  pn_ct (compile_term)
# ══════════════════════════════════════════════════════════════════════════════
parse_num:
	addi	a0, zero, 0
	# Sign flag in t6 (0 = positive, 1 = negative). A leading '-' here
	# lets asm immediates write `addi rd, rs, -1` etc. The expression
	# parser never reaches parse_num with a leading '-' (compile_unary
	# strips prefix `-` before recursing), so this only adds capability
	# for asm contexts.
	addi	t6, zero, 0
	bge	s2, s3, pn_dec
	lbu	t0, 0(s2)
	addi	t1, zero, '-'
	bne	t0, t1, pn_after_sign
	addi	s2, s2, 1		# consume '-'
	addi	t6, zero, 1
	bge	s2, s3, pn_done		# bare '-' yields 0 (caller validates)
pn_after_sign:
	lbu	t0, 0(s2)
	addi	t1, zero, 39		# '\''
	beq	t0, t1, pn_char
	addi	t1, zero, '0'
	bne	t0, t1, pn_dec
	addi	t2, s2, 1
	bge	t2, s3, pn_dec
	lbu	t0, 0(t2)
	addi	t1, zero, 'x'
	beq	t0, t1, pn_hex_begin
	addi	t1, zero, 'X'
	beq	t0, t1, pn_hex_begin
	j	pn_dec

pn_char:
	# Char literal: 'X' or '\X'. Reuses the same escape table as the
	# expression-side ct_char_lit (n/t/r/0/b/f/a/v/e/\\/\'/\").
	addi	s2, s2, 1		# consume opening '
	bge	s2, s3, pn_bad_char
	lbu	t0, 0(s2)
	addi	t1, zero, 92
	beq	t0, t1, pn_char_esc
	addi	s2, s2, 1
	addi	a0, t0, 0
	j	pn_char_close
pn_char_esc:
	addi	s2, s2, 1		# consume backslash
	bge	s2, s3, pn_bad_char
	lbu	t0, 0(s2)
	addi	s2, s2, 1
	addi	t1, zero, 'n'
	beq	t0, t1, pn_char_nl
	addi	t1, zero, 't'
	beq	t0, t1, pn_char_tab
	addi	t1, zero, 'r'
	beq	t0, t1, pn_char_cr
	addi	t1, zero, '0'
	beq	t0, t1, pn_char_nul
	addi	t1, zero, 'b'
	beq	t0, t1, pn_char_bs
	addi	t1, zero, 'f'
	beq	t0, t1, pn_char_ff
	addi	t1, zero, 'a'
	beq	t0, t1, pn_char_bel
	addi	t1, zero, 'v'
	beq	t0, t1, pn_char_vtab
	addi	t1, zero, 'e'
	beq	t0, t1, pn_char_esc_char
	addi	t1, zero, 92
	beq	t0, t1, pn_char_lit_ok
	addi	t1, zero, 39
	beq	t0, t1, pn_char_lit_ok
	addi	t1, zero, 34
	beq	t0, t1, pn_char_lit_ok
	j	pn_bad_char
pn_char_nl:
	addi	a0, zero, 10
	j	pn_char_close
pn_char_tab:
	addi	a0, zero, 9
	j	pn_char_close
pn_char_cr:
	addi	a0, zero, 13
	j	pn_char_close
pn_char_nul:
	addi	a0, zero, 0
	j	pn_char_close
pn_char_bs:
	addi	a0, zero, 8
	j	pn_char_close
pn_char_ff:
	addi	a0, zero, 12
	j	pn_char_close
pn_char_bel:
	addi	a0, zero, 7
	j	pn_char_close
pn_char_vtab:
	addi	a0, zero, 11
	j	pn_char_close
pn_char_esc_char:
	addi	a0, zero, 27
	j	pn_char_close
pn_char_lit_ok:
	addi	a0, t0, 0
pn_char_close:
	bge	s2, s3, pn_bad_char
	lbu	t0, 0(s2)
	addi	t1, zero, 39
	bne	t0, t1, pn_bad_char
	addi	s2, s2, 1
	j	pn_done
pn_bad_char:
	addi	a0, zero, 34		# err 34: unknown escape sequence
	j	report_err

pn_hex_begin:
	addi	s2, s2, 2
pn_hex_loop:
	bge	s2, s3, pn_done
	lbu	t0, 0(s2)
	addi	t1, zero, '0'
	blt	t0, t1, pn_done
	addi	t1, zero, 58
	blt	t0, t1, pn_hex_09
	addi	t1, zero, 'A'
	blt	t0, t1, pn_done
	addi	t1, zero, 71
	blt	t0, t1, pn_hex_uc
	addi	t1, zero, 'a'
	blt	t0, t1, pn_done
	addi	t1, zero, 103
	blt	t0, t1, pn_hex_lc
	j	pn_done
pn_hex_09:
	addi	t0, t0, -48
	j	pn_hex_acc
pn_hex_uc:
	addi	t0, t0, -65
	addi	t0, t0, 10
	j	pn_hex_acc
pn_hex_lc:
	addi	t0, t0, -97
	addi	t0, t0, 10
pn_hex_acc:
	# Overflow check: if any of the top 4 bits of a0 are set, shifting
	# left by 4 would drop them. Bail with err 73.
	srli	t2, a0, 28
	bnez	t2, pn_overflow
	slli	a0, a0, 4
	or	a0, a0, t0
	addi	s2, s2, 1
	j	pn_hex_loop

pn_dec:
pn_dec_loop:
	bge	s2, s3, pn_done
	lbu	t0, 0(s2)
	addi	t1, zero, '0'
	blt	t0, t1, pn_done
	addi	t1, zero, 58
	bge	t0, t1, pn_done
	addi	t0, t0, -48
	# Overflow check: detect if a0 * 10 + digit would exceed 2^32 - 1.
	# `slli t1, a0, 3` wraps iff a0 has a bit in [29..31]; catch that by
	# comparing the shifted value back. Likewise for the `t1 + t2` step
	# and the final `+ digit`, using unsigned carry detection.
	srli	t3, a0, 29
	bnez	t3, pn_overflow
	slli	t1, a0, 3		# a0 * 8
	slli	t2, a0, 1		# a0 * 2
	add	t3, t1, t2		# a0 * 10
	bltu	t3, t1, pn_overflow
	add	t3, t3, t0		# + digit
	bltu	t3, t0, pn_overflow
	addi	a0, t3, 0
	addi	s2, s2, 1
	j	pn_dec_loop

pn_overflow:
	addi	a0, zero, 73		# err 73: integer literal overflow
	j	report_err

pn_done:
	beqz	t6, pn_disp
	sub	a0, zero, a0		# apply leading '-' sign
pn_disp:
	bnez	gp, pn_d1
	j	pn_ct
pn_d1:
	addi	gp, gp, -1
	bnez	gp, pn_d2
	j	pn_cs_decl
pn_d2:
	addi	gp, gp, -1
	bnez	gp, pn_d3
	j	pn_asm_li
pn_d3:
	addi	gp, gp, -1
	bnez	gp, pn_d4
	j	pn_asm_utype
pn_d4:
	addi	gp, gp, -1
	bnez	gp, pn_d5
	j	pn_asm_itype
pn_d5:
	addi	gp, gp, -1
	bnez	gp, pn_d6
	j	pn_asm_memop
pn_d6:
	addi	gp, gp, -1
	bnez	gp, pn_d7
	j	pn_asm_dir
pn_d7:
	addi	gp, gp, -1
	bnez	gp, pn_d8
	j	pn_cs_rept_low
pn_d8:
	j	pn_cs_rept_high

# ══════════════════════════════════════════════════════════════════════════════
# lookup_or_alloc — find/allocate a variable slot.
#   Call sites:  0: la_ct (compile_term),  1: la_cs (compile_stmt)
# ══════════════════════════════════════════════════════════════════════════════
lookup_or_alloc:
	# Scan backwards from the newest entry toward s7 so that later symtab
	# entries shadow earlier ones. This is what makes `for x in … { … }`
	# introduce a fresh binding for `x` that's visible inside the body
	# without destroying the outer `x` — the for-loop allocates a new entry
	# via `j la_new` and, on exit, restores s8 to "forget" it.
	addi	t0, s8, -40		# scan ptr = last entry
la_scan:
	blt	t0, s7, la_new
	addi	t1, zero, 0
la_cmp:
	addi	t2, zero, 32
	beq	t1, t2, la_match
	add	t3, t0, t1
	lbu	t4, 0(t3)
	blt	t1, s11, la_in_tok
	bnez	t4, la_next
	addi	t1, t1, 1
	j	la_cmp
la_in_tok:
	add	t5, s10, t1
	lbu	t6, 0(t5)
	bne	t4, t6, la_next
	addi	t1, t1, 1
	j	la_cmp
la_match:
	lla	t1, last_ident_entry
	sw	t0, 0(t1)
	lla	t1, lookup_was_new
	sw	zero, 0(t1)		# existing entry
	lw	a0, 32(t0)
	j	lookup_or_alloc_disp
la_next:
	addi	t0, t0, -40
	j	la_scan

# ══════════════════════════════════════════════════════════════════════════════
# lookup — like lookup_or_alloc but errors with "undefined variable" when the
# name isn't in the symtab. Used by the Pratt nud (compile_unary's ct_id) for
# identifiers that appear in a read context (not as the target of a bare '=').
# Returns via lookup_or_alloc_disp — caller's return sites are shared.
# ══════════════════════════════════════════════════════════════════════════════
lookup:
	addi	t0, s8, -40
lo_scan:
	blt	t0, s7, lo_notfound
	addi	t1, zero, 0
lo_cmp:
	addi	t2, zero, 32
	beq	t1, t2, lo_match
	add	t3, t0, t1
	lbu	t4, 0(t3)
	blt	t1, s11, lo_in_tok
	bnez	t4, lo_next
	addi	t1, t1, 1
	j	lo_cmp
lo_in_tok:
	add	t5, s10, t1
	lbu	t6, 0(t5)
	bne	t4, t6, lo_next
	addi	t1, t1, 1
	j	lo_cmp
lo_match:
	lla	t1, last_ident_entry
	sw	t0, 0(t1)
	lw	a0, 32(t0)
	j	lookup_or_alloc_disp
lo_next:
	addi	t0, t0, -40
	j	lo_scan
lo_notfound:
	# Rewind s2 to the ident's start so the reported column points at
	# the offending name rather than past it.
	lla	t0, ident_start
	lw	s2, 0(t0)
	addi	a0, zero, 35		# err 35: undefined variable
	j	report_err

la_new:
	# Grow symtab if full (s8 has reached s0).
	# Growing doubles the capacity and copies the existing entries to a
	# fresh heap block at tp. No free — old block is leaked (bump alloc).
	bne	s8, s0, la_new_body
	sub	t0, s0, s7		# old_cap (bytes)
	slli	t1, t0, 1		# new_cap = 2 * old_cap
	# heap_end check: tp + new_cap must fit below heap_end.
	add	t5, tp, t1
	lla	t6, heap_end
	lw	t6, 0(t6)
	bgeu	t5, t6, heap_full
	addi	t2, tp, 0		# new_base = tp
	addi	t3, s7, 0		# src
	addi	t4, t2, 0		# dst
la_grow_cp:
	beq	t3, s8, la_grow_done
	lw	t5, 0(t3)
	sw	t5, 0(t4)
	addi	t3, t3, 4
	addi	t4, t4, 4
	j	la_grow_cp
la_grow_done:
	sub	t6, s8, s7		# used bytes
	addi	s7, t2, 0		# s7 = new base
	add	s8, s7, t6		# s8 = new write ptr
	add	s0, s7, t1		# s0 = new end
	add	tp, tp, t1		# bump heap past the new block
la_new_body:
	addi	t1, zero, 0
la_zero:
	addi	t2, zero, 40
	beq	t1, t2, la_zero_done
	add	t3, s8, t1
	sb	zero, 0(t3)
	addi	t1, t1, 1
	j	la_zero
la_zero_done:
	addi	t1, zero, 0
la_cp:
	beq	t1, s11, la_cp_done
	add	t2, s10, t1
	lbu	t3, 0(t2)
	add	t4, s8, t1
	sb	t3, 0(t4)
	addi	t1, t1, 1
	j	la_cp
la_cp_done:
	# Frame offsets support up to 2^20 bytes via multi-instruction load/
	# store sequences in emit_lw_sp / emit_sw_sp. Cap at 0x100000.
	# Unsigned compare: an earlier arithmetic wrap could make s9 look
	# negative to a signed check, so use bgeu.
	lui	t2, 0x100
	bgeu	s9, t2, la_bad_frame_too_big
	# New entry: store byte offset of this local in the frame (= current
	# frame_size). Byte 37 = mutability flag (0=immutable, 1=mutable) —
	# set by the caller after this function returns, based on = vs :=.
	sw	s9, 32(s8)		# offset field = s9 (= next free byte offset)
	# Save entry pointer and new-entry flag for mutability tracking.
	lla	t0, last_ident_entry
	sw	s8, 0(t0)
	lla	t0, lookup_was_new
	addi	t1, zero, 1
	sw	t1, 0(t0)		# new entry
	addi	a0, s9, 0		# return byte offset
	addi	s9, s9, 4		# advance frame_size by this var's size
	addi	s8, s8, 40
	j	lookup_or_alloc_disp
la_bad_frame_too_big:
	addi	a0, zero, 40		# err 40: frame too large
	j	report_err

lookup_or_alloc_disp:
	bnez	gp, la_d1
	j	la_ct
la_d1:
	addi	gp, gp, -1
	bnez	gp, la_d2
	j	la_cs
la_d2:
	addi	gp, gp, -1
	bnez	gp, la_d3
	j	la_cs_pp
la_d3:
	addi	gp, gp, -1
	bnez	gp, la_d4
	j	la_cs_mm
la_d4:
	addi	gp, gp, -1
	bnez	gp, la_d5
	j	la_ct_for
la_d5:
	addi	gp, gp, -1
	bnez	gp, la_d6
	j	la_cs_fn_param
la_d6:
	addi	gp, gp, -1
	bnez	gp, la_d7
	j	la_cs_decl
la_d7:
	addi	gp, gp, -1
	bnez	gp, la_d8
	j	la_ct_sa
la_d8:
	addi	gp, gp, -1
	bnez	gp, la_d9
	j	la_asm_out_tok1
la_d9:
	j	la_asm_in

# ══════════════════════════════════════════════════════════════════════════════
# emit_li — emit "li a0, imm". imm passed in a0.
#   Single caller:  eli_ret (compile_term)
# ══════════════════════════════════════════════════════════════════════════════
emit_li:
	addi	sp, sp, -8
	sw	a0, 0(sp)		# save imm
	sw	gp, 4(sp)		# save caller's gp (for emit_li_disp)
	# Track the start address (s5 before any emission) so a caller
	# doing const-folding can rewind to drop the entire li sequence.
	lla	t0, last_li_start
	sw	s5, 0(t0)
	lw	t0, 0(sp)
	addi	t1, zero, 2047
	bgt	t0, t1, eli_big
	addi	t1, zero, -2048
	blt	t0, t1, eli_big

	# addi a0, zero, imm   —   word = 0x00000013 | (rd=10 << 7) | (imm << 20)
	lw	t2, 0(sp)
	andi	t2, t2, 0xFFF
	slli	t2, t2, 20
	lui	a0, 0
	addi	a0, a0, 0x513		# 0x13 | (10 << 7) = 0x513
	or	a0, a0, t2
	addi	gp, zero, 0		# ew site 0 = ew_li_s
	j	emit_word
ew_li_s:
	j	eli_pop

eli_big:
	# upper20 = (imm + 0x800) >>> 12 (arith shift)
	lw	t0, 0(sp)
	lui	t1, 0x1
	srli	t1, t1, 1		# 0x800
	add	t2, t0, t1
	srai	t2, t2, 12		# upper

	# lui a0, upper   —   word = 0x00000037 | (rd=10 << 7) | (upper << 12)
	lui	a0, 0
	addi	a0, a0, 0x537		# 0x37 | (10<<7) = 0x537
	slli	t2, t2, 12
	or	a0, a0, t2
	addi	gp, zero, 1		# ew site 1 = ew_li_lui
	j	emit_word
ew_li_lui:

	# Compute lo12 = sign-extend(imm[11:0]). If lo12 == 0 the addi
	# would be a no-op — skip it (peephole: bare `lui` suffices).
	lw	t0, 0(sp)
	slli	t0, t0, 20
	srai	t0, t0, 20
	beqz	t0, eli_pop
	# addi a0, a0, lower12
	andi	t0, t0, 0xFFF
	slli	t0, t0, 20
	# word = 0x00050513   (addi a0, a0, 0) | imm
	lui	a0, 0x50
	addi	a0, a0, 0x513
	or	a0, a0, t0
	addi	gp, zero, 2		# ew site 2 = ew_li_add
	j	emit_word
ew_li_add:

eli_pop:
	# Stash the literal value in last_li_value so callers (e.g. an
	# assignment site doing const-folding) can read the constant
	# without re-decoding the emitted instructions.
	lw	t1, 0(sp)
	lla	t0, last_li_value
	sw	t1, 0(t0)
	lw	gp, 4(sp)		# restore caller's gp for emit_li_disp
	addi	sp, sp, 8
	# Mark the just-emitted load-immediate as safe-to-redirect: the
	# previous instruction is the final word of emit_li, which writes
	# to a0 with no other consumers (the caller uses it via push or
	# directly as a binop operand). Set the literal-only marker too
	# so const-folding sites can distinguish li from lw.
	lla	t0, push_safe_marker
	sw	s5, 0(t0)
	lla	t0, last_li_marker
	sw	s5, 0(t0)
	# Update a0_known_zero based on the literal value: set if 0,
	# clear otherwise. (emit_word's epilogue cleared it already since
	# the addi/lui writes a0; this re-sets when the value is 0.)
	lla	t0, last_li_value
	lw	t1, 0(t0)
	bnez	t1, eli_a0z_clear
	lla	t0, a0_known_zero
	addi	t1, zero, 1
	sw	t1, 0(t0)
	j	emit_li_disp
eli_a0z_clear:
	lla	t0, a0_known_zero
	sw	zero, 0(t0)
	j	emit_li_disp

emit_li_disp:
	bnez	gp, eli_d1
	j	eli_ret
eli_d1:
	addi	gp, gp, -1
	bnez	gp, eli_d2
	j	eli_ret_id_const
eli_d2:
	j	halt_err

# ══════════════════════════════════════════════════════════════════════════════
# emit_lw_sp — emit "lw a0, offset(fp)". offset (bytes, positive) in a0.
#   Loads the local whose byte offset from fp is a0. fp never moves, so this
#   is unaffected by push/pop during expression evaluation.
#   Multi-caller — caller must set gp to its dispatch site.
#   Call sites:  0: elws_ret          (compile_unary ct_id)
#                1: elws_cs_inc_stmt  (compile_stmt '++' inc in place)
#                2: elws_cs_dec_stmt  (compile_stmt '--' dec in place)
#                3: elws_cs_plus      (compile_stmt '+=')
#                4: elws_cs_minus     (compile_stmt '-=')
#                5: elws_cs_xor       (compile_stmt '^=')
#                6: elws_cs_lshift    (compile_stmt '<<=')
#                7: elws_cs_rshift    (compile_stmt '>>=')
#                8: elws_cs_and       (compile_stmt '&=')
#                9: elws_cs_or        (compile_stmt '|=')
#               10: elws_cs_mul       (compile_stmt '*=')
#               11: elws_cs_div       (compile_stmt '/=')
#               12: elws_cs_mod       (compile_stmt '%=')
# ══════════════════════════════════════════════════════════════════════════════
emit_lw_sp:
	addi	sp, sp, -4
	sw	gp, 0(sp)
	# a0 = byte offset (positive). If it fits in 12-bit signed (0..2047),
	# emit a single `lw a0, off(fp)`. Otherwise emit a 4-instruction
	# sequence using t0 as scratch to support any 32-bit offset.
	addi	t0, zero, 2048
	bgeu	a0, t0, elws_big
	# Small path: single lw a0, off(fp)
	slli	t0, a0, 20
	lui	a0, 0x42
	addi	a0, a0, 0x503
	or	a0, a0, t0
	addi	gp, zero, 3		# ew site 3 = ew_lws
	j	emit_word
ew_lws:
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	emit_lw_sp_disp
elws_big:
	# Big path: lui t0, hi20; addi t0, t0, lo12; add t0, fp, t0; lw a0, 0(t0)
	# Bounds check: we emit 16 bytes (4 words) inline without going through
	# emit_word, so do the bin_end check up front.
	addi	t6, s5, 16
	lla	t1, bin_end
	lw	t1, 0(t1)
	bgeu	t6, t1, bin_full
	# Compute hi20 and lo12 via (offset + 0x800) >> 12 trick so lo12 is
	# sign-extended 12-bit.
	addi	t1, zero, 1
	slli	t1, t1, 11		# 0x800
	add	t2, a0, t1
	srai	t2, t2, 12		# t2 = hi20 (signed)
	slli	t3, t2, 12
	sub	t4, a0, t3		# t4 = lo12 (sign-extended)
	# Emit lui t0, hi20 = 0x002B7 | (hi20 << 12)
	lui	a0, 0
	addi	a0, a0, 0x2B7
	or	a0, a0, t3
	sw	a0, 0(s5)
	addi	s5, s5, 4
	# Emit addi t0, t0, lo12 = 0x00028293 | (lo12[11:0] << 20)
	andi	t5, t4, 0xFFF
	slli	t5, t5, 20
	lui	a0, 0x28
	addi	a0, a0, 0x293
	or	a0, a0, t5
	sw	a0, 0(s5)
	addi	s5, s5, 4
	# Emit add t0, fp, t0  (word 0x005402B3)
	lui	a0, 0x540
	addi	a0, a0, 0x2B3
	sw	a0, 0(s5)
	addi	s5, s5, 4
	# Emit lw a0, 0(t0)  (word 0x0002A503)
	lui	a0, 0x2A
	addi	a0, a0, 0x503
	sw	a0, 0(s5)
	addi	s5, s5, 4
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	emit_lw_sp_disp

emit_lw_sp_disp:
	# Mark the just-emitted local load as safe-to-redirect. Both the
	# small path (`lw a0, off(fp)`) and the big path (final
	# `lw a0, 0(t0)`) reach here after their last emit, so the prev
	# instruction is always a load-into-a0 with no other consumer.
	lla	t0, push_safe_marker
	sw	s5, 0(t0)
	bnez	gp, elws_d1
	j	elws_ret
elws_d1:
	addi	gp, gp, -1
	bnez	gp, elws_d2
	j	elws_cs_inc_stmt
elws_d2:
	addi	gp, gp, -1
	bnez	gp, elws_d3
	j	elws_cs_dec_stmt
elws_d3:
	addi	gp, gp, -1
	bnez	gp, elws_d4
	j	elws_cs_plus
elws_d4:
	addi	gp, gp, -1
	bnez	gp, elws_d5
	j	elws_cs_minus
elws_d5:
	addi	gp, gp, -1
	bnez	gp, elws_d6
	j	elws_cs_xor
elws_d6:
	addi	gp, gp, -1
	bnez	gp, elws_d7
	j	elws_cs_lshift
elws_d7:
	addi	gp, gp, -1
	bnez	gp, elws_d8
	j	elws_cs_rshift
elws_d8:
	addi	gp, gp, -1
	bnez	gp, elws_d9
	j	elws_cs_and
elws_d9:
	addi	gp, gp, -1
	bnez	gp, elws_d10
	j	elws_cs_or
elws_d10:
	addi	gp, gp, -1
	bnez	gp, elws_d11
	j	elws_cs_mul
elws_d11:
	addi	gp, gp, -1
	bnez	gp, elws_d12
	j	elws_cs_div
elws_d12:
	addi	gp, gp, -1
	bnez	gp, elws_d13
	j	elws_cs_mod
elws_d13:
	addi	gp, gp, -1
	bnez	gp, elws_d14
	j	elws_ct_for_inc_load
elws_d14:
	addi	gp, gp, -1
	bnez	gp, elws_d15
	j	elws_ct_for_hi_load
elws_d15:
	addi	gp, gp, -1
	bnez	gp, elws_d16
	j	elws_ct_for_last_load
elws_d16:
	j	elws_ct_sa

# ══════════════════════════════════════════════════════════════════════════════
# emit_sw_sp — emit "sw a0, offset(fp)". offset (bytes, positive) in a0.
#   Stores a0 into the local whose byte offset from fp is passed in.
#   Multi-caller — caller must set gp to its dispatch site.
#   Call sites:  0: esws_ret           (compile_stmt IDENT = expr)
#                1: esws_pre_inc       (compile_unary prefix '++')
#                2: esws_pre_dec       (compile_unary prefix '--')
#                3: esws_post_inc      (compile_unary postfix '++')
#                4: esws_post_dec      (compile_unary postfix '--')
#                5: esws_cs_inc_stmt   (compile_stmt '++IDENT;' / 'IDENT++;')
#                6: esws_cs_dec_stmt   (compile_stmt '--IDENT;' / 'IDENT--;')
#                7: esws_cs_plus       (compile_stmt 'IDENT += expr;')
#                8: esws_cs_minus      (compile_stmt 'IDENT -= expr;')
#                9: esws_cs_xor        (compile_stmt 'IDENT ^= expr;')
#               10: esws_cs_lshift     (compile_stmt 'IDENT <<= expr;')
#               11: esws_cs_rshift     (compile_stmt 'IDENT >>= expr;')
#               12: esws_cs_and        (compile_stmt 'IDENT &= expr;')
#               13: esws_cs_or         (compile_stmt 'IDENT |= expr;')
#               14: esws_cs_mul        (compile_stmt 'IDENT *= expr;')
#               15: esws_cs_div        (compile_stmt 'IDENT /= expr;')
#               16: esws_cs_mod        (compile_stmt 'IDENT %= expr;')
#               17: esws_cep_asg       (compile_expr_p 'IDENT = expr')
# ══════════════════════════════════════════════════════════════════════════════
emit_sw_sp:
	addi	sp, sp, -4
	sw	gp, 0(sp)
	# a0 = byte offset (positive). Same pattern as emit_lw_sp: single
	# instruction for small offsets, multi-instruction sequence for large.
	addi	t0, zero, 2048
	bgeu	a0, t0, esws_big
	# Default sw word base: rs2=a0, 0x00A42023 (= `sw a0, 0(fp)`).
	lui	t0, 0xA42
	addi	t0, t0, 0x023
	# Zero-store peephole: if a0 is known to hold literal 0
	# (a0_known_zero == 1), encode the sw with rs2=zero (x0) instead
	# of rs2=a0. If the just-prior instruction was `addi a0, zero, 0`
	# from emit_li, also rewind it so we drop a dead instruction.
	# The flag survives across consecutive sw's so chains like
	# `x := y := 0` collapse fully.
	lla	t6, a0_known_zero
	lw	t6, 0(t6)
	beqz	t6, esws_no_zfold
	# Switch to zero-rs2 base.
	lui	t0, 0x42
	addi	t0, t0, 0x023
	# If the preceding emit was the addi 0 itself (last_li_marker
	# matches), rewind it as a dead instruction.
	lla	t6, last_li_marker
	lw	t6, 0(t6)
	bne	t6, s5, esws_no_zfold
	lla	t6, last_li_start
	lw	s5, 0(t6)
	lla	t6, push_safe_marker
	sw	zero, 0(t6)
	lla	t6, last_li_marker
	sw	zero, 0(t6)
esws_no_zfold:
	andi	t1, a0, 0x1F
	slli	t1, t1, 7
	or	t0, t0, t1
	srli	t1, a0, 5
	andi	t1, t1, 0x7F
	slli	t1, t1, 25
	or	t0, t0, t1
	addi	a0, t0, 0
	addi	gp, zero, 4		# ew site 4 = ew_sws
	j	emit_word
ew_sws:
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	emit_sw_sp_disp
esws_big:
	# Big path: lui t0, hi20; addi t0, t0, lo12; add t0, fp, t0; sw a0, 0(t0)
	# Bounds check for 16 bytes of inline emission.
	addi	t6, s5, 16
	lla	t1, bin_end
	lw	t1, 0(t1)
	bgeu	t6, t1, bin_full
	addi	t1, zero, 1
	slli	t1, t1, 11		# 0x800
	add	t2, a0, t1
	srai	t2, t2, 12		# hi20
	slli	t3, t2, 12
	sub	t4, a0, t3		# lo12
	# Emit lui t0, hi20
	lui	a0, 0
	addi	a0, a0, 0x2B7
	or	a0, a0, t3
	sw	a0, 0(s5)
	addi	s5, s5, 4
	# Emit addi t0, t0, lo12 = 0x00028293
	andi	t5, t4, 0xFFF
	slli	t5, t5, 20
	lui	a0, 0x28
	addi	a0, a0, 0x293
	or	a0, a0, t5
	sw	a0, 0(s5)
	addi	s5, s5, 4
	# Emit add t0, fp, t0 = 0x005402B3
	lui	a0, 0x540
	addi	a0, a0, 0x2B3
	sw	a0, 0(s5)
	addi	s5, s5, 4
	# Emit sw a0, 0(t0) = 0x00A2A023
	lui	a0, 0xA2A
	addi	a0, a0, 0x023
	sw	a0, 0(s5)
	addi	s5, s5, 4
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	emit_sw_sp_disp

emit_sw_sp_disp:
	bnez	gp, esws_d1
	j	esws_ret
esws_d1:
	addi	gp, gp, -1
	bnez	gp, esws_d2
	j	esws_pre_inc
esws_d2:
	addi	gp, gp, -1
	bnez	gp, esws_d3
	j	esws_pre_dec
esws_d3:
	addi	gp, gp, -1
	bnez	gp, esws_d4
	j	esws_post_inc
esws_d4:
	addi	gp, gp, -1
	bnez	gp, esws_d5
	j	esws_post_dec
esws_d5:
	addi	gp, gp, -1
	bnez	gp, esws_d6
	j	esws_cs_inc_stmt
esws_d6:
	addi	gp, gp, -1
	bnez	gp, esws_d7
	j	esws_cs_dec_stmt
esws_d7:
	addi	gp, gp, -1
	bnez	gp, esws_d8
	j	esws_cs_plus
esws_d8:
	addi	gp, gp, -1
	bnez	gp, esws_d9
	j	esws_cs_minus
esws_d9:
	addi	gp, gp, -1
	bnez	gp, esws_d10
	j	esws_cs_xor
esws_d10:
	addi	gp, gp, -1
	bnez	gp, esws_d11
	j	esws_cs_lshift
esws_d11:
	addi	gp, gp, -1
	bnez	gp, esws_d12
	j	esws_cs_rshift
esws_d12:
	addi	gp, gp, -1
	bnez	gp, esws_d13
	j	esws_cs_and
esws_d13:
	addi	gp, gp, -1
	bnez	gp, esws_d14
	j	esws_cs_or
esws_d14:
	addi	gp, gp, -1
	bnez	gp, esws_d15
	j	esws_cs_mul
esws_d15:
	addi	gp, gp, -1
	bnez	gp, esws_d16
	j	esws_cs_div
esws_d16:
	addi	gp, gp, -1
	bnez	gp, esws_d17
	j	esws_cs_mod
esws_d17:
	addi	gp, gp, -1
	bnez	gp, esws_d18
	j	esws_cep_asg
esws_d18:
	addi	gp, gp, -1
	bnez	gp, esws_d19
	j	esws_cep_compound
esws_d19:
	addi	gp, gp, -1
	bnez	gp, esws_d20
	j	esws_ct_for_x_init
esws_d20:
	addi	gp, gp, -1
	bnez	gp, esws_d21
	j	esws_ct_for_hi
esws_d21:
	addi	gp, gp, -1
	bnez	gp, esws_d22
	j	esws_ct_for_last_init
esws_d22:
	addi	gp, gp, -1
	bnez	gp, esws_d23
	j	esws_ct_for_x_inc
esws_d23:
	addi	gp, gp, -1
	bnez	gp, esws_d24
	j	esws_ct_for_body_save
esws_d24:
	addi	gp, gp, -1
	bnez	gp, esws_d25
	j	esws_cs_decl
esws_d25:
	j	esws_cep_postfix

# ══════════════════════════════════════════════════════════════════════════════
# emit_lw_deref  — emit "lw a0, 0(a0)"
# ══════════════════════════════════════════════════════════════════════════════
emit_lw_deref:
	# opcode=0x03, rd=10, f3=2, rs1=10, imm=0
	# word = 0x03 | (10<<7) | (2<<12) | (10<<15) = 0x03 | 0x500 | 0x2000 | 0x50000
	#      = 0x00052503
	lui	a0, 0x52
	addi	a0, a0, 0x503
	addi	gp, zero, 5		# ew site 5 = ew_lwd
	j	emit_word
ew_lwd:
	j	elwd_ret

# ══════════════════════════════════════════════════════════════════════════════
# emit_lbu_deref — emit "lbu a0, 0(a0)"
# ══════════════════════════════════════════════════════════════════════════════
emit_lbu_deref:
	# opcode=0x03, f3=4, rd=10, rs1=10, imm=0
	# word = 0x03 | (10<<7) | (4<<12) | (10<<15) = 0x03 | 0x500 | 0x4000 | 0x50000
	#      = 0x00054503
	lui	a0, 0x54
	addi	a0, a0, 0x503
	addi	gp, zero, 6		# ew site 6 = ew_lbud
	j	emit_word
ew_lbud:
	j	elbud_ret

# ══════════════════════════════════════════════════════════════════════════════
# emit_push_a0 — emit "addi sp,sp,-4 ; sw a0,0(sp)"   (pushes a0 onto the
#   compiled program's stack).  Multi-caller (compile_expr, cs_star, cs_at),
#   so we save/restore gp around the inner emit_word calls.
#
# Call sites:  0: push_ca (compile_add '+'/'-' loop)
#              1: push_cs_star (cs_star, save address)
#              2: push_cs_at   (cs_at, save address)
#              3: push_ce     (compile_expr '^' loop)
#              4: push_cs_plus  (compile_stmt '+=' — save old LHS)
#              5: push_cs_minus (compile_stmt '-=' — save old LHS)
#              6: push_cs_xor   (compile_stmt '^=' — save old LHS)
#              7: push_csh      (compile_shift '<<'/'>>' loop)
#              8: push_cs_lshift (compile_stmt '<<=')
#              9: push_cs_rshift (compile_stmt '>>=')
#             10: push_cand     (compile_and '&' loop)
#             11: push_cs_and   (compile_stmt '&=')
#             12: push_cor      (compile_or '|' loop)
#             13: push_cs_or    (compile_stmt '|=')
#             14: push_ccmp     (compile_rel comparison loop)
#             15: push_ceq      (compile_expr equality '==' / '!=' loop)
#             16: push_cmul     (compile_mul '*' / '/' / '%' loop)
#             17: push_cs_mul   (compile_stmt '*=')
#             18: push_cs_div   (compile_stmt '/=')
#             19: push_cs_mod   (compile_stmt '%=')
#             20: push_cep      (compile_expr_p — Pratt binop pre-rhs)
#             21: push_cep_asg  (compile_expr_p — '@expr = val' / '*expr = val')
# ══════════════════════════════════════════════════════════════════════════════
emit_push_a0:
	# Value-stack push. For depth < 9 emit `mv s[2+depth], a0` (the s-reg
	# pool); for depth ≥ 9 spill to the runtime stack via the classic
	# `addi sp,-4; sw a0,0(sp)` pair. expr_max_depth tracks the s-reg
	# high-water mark only (memory slots don't need a save in the fn
	# prologue's save block).
	addi	sp, sp, -4
	sw	gp, 0(sp)
	lla	t0, expr_depth
	lw	t1, 0(t0)
	addi	t2, zero, 9
	bge	t1, t2, epa_mem_push
	# ── s-reg push ──
	# Peephole: if the previous emit was a "safe leaf" (literal or
	# local load) tagged via push_safe_marker, rewrite its rd field
	# from a0(=10) to s[2+depth] and skip the `mv`. Only safe-leaf
	# emitters set the marker; emit_word's epilogue clears it. This
	# guarantees we never rewrite an instruction at a control-flow
	# merge (e.g. `&&`/`||`/ternary's tail value).
	lla	t3, push_safe_marker
	lw	t4, 0(t3)
	bne	t4, s5, epa_emit_mv
	# Marker matches → previous insn is safe to redirect.
	lw	t2, -4(s5)
	addi	t3, zero, 0x500
	sub	t2, t2, t3
	addi	t3, t1, 18
	slli	t3, t3, 7
	or	t2, t2, t3
	sw	t2, -4(s5)
	addi	t1, t1, 1
	sw	t1, 0(t0)
	lla	t0, expr_max_depth
	lw	t2, 0(t0)
	bge	t2, t1, epa_done
	sw	t1, 0(t0)
	j	epa_done
epa_emit_mv:
	addi	t2, s5, 4
	lla	t3, bin_end
	lw	t3, 0(t3)
	bgeu	t2, t3, bin_full
	addi	t4, t1, 18
	slli	t4, t4, 7
	lui	a0, 0x50
	addi	a0, a0, 0x13
	or	a0, a0, t4
	sw	a0, 0(s5)
	addi	s5, s5, 4
	addi	t1, t1, 1
	sw	t1, 0(t0)
	lla	t0, expr_max_depth
	lw	t2, 0(t0)
	bge	t2, t1, epa_done
	sw	t1, 0(t0)
	j	epa_done
epa_mem_push:
	# ── Memory spill: addi sp,sp,-4; sw a0,0(sp) ──
	addi	t2, s5, 8
	lla	t3, bin_end
	lw	t3, 0(t3)
	bgeu	t2, t3, bin_full
	lui	a0, 0xFFC10
	addi	a0, a0, 0x113
	sw	a0, 0(s5)
	addi	s5, s5, 4
	lui	a0, 0xA12
	addi	a0, a0, 0x023
	sw	a0, 0(s5)
	addi	s5, s5, 4
	addi	t1, t1, 1
	sw	t1, 0(t0)
epa_done:
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	emit_push_a0_disp

emit_push_a0_disp:
	bnez	gp, epa_d1
	j	push_ca
epa_d1:
	addi	gp, gp, -1
	bnez	gp, epa_d2
	j	push_cs_star
epa_d2:
	addi	gp, gp, -1
	bnez	gp, epa_d3
	j	push_cs_at
epa_d3:
	addi	gp, gp, -1
	bnez	gp, epa_d4
	j	push_ce
epa_d4:
	addi	gp, gp, -1
	bnez	gp, epa_d5
	j	push_cs_plus
epa_d5:
	addi	gp, gp, -1
	bnez	gp, epa_d6
	j	push_cs_minus
epa_d6:
	addi	gp, gp, -1
	bnez	gp, epa_d7
	j	push_cs_xor
epa_d7:
	addi	gp, gp, -1
	bnez	gp, epa_d8
	j	push_csh
epa_d8:
	addi	gp, gp, -1
	bnez	gp, epa_d9
	j	push_cs_lshift
epa_d9:
	addi	gp, gp, -1
	bnez	gp, epa_d10
	j	push_cs_rshift
epa_d10:
	addi	gp, gp, -1
	bnez	gp, epa_d11
	j	push_cand
epa_d11:
	addi	gp, gp, -1
	bnez	gp, epa_d12
	j	push_cs_and
epa_d12:
	addi	gp, gp, -1
	bnez	gp, epa_d13
	j	push_cor
epa_d13:
	addi	gp, gp, -1
	bnez	gp, epa_d14
	j	push_cs_or
epa_d14:
	addi	gp, gp, -1
	bnez	gp, epa_d15
	j	push_ccmp
epa_d15:
	addi	gp, gp, -1
	bnez	gp, epa_d16
	j	push_ceq
epa_d16:
	addi	gp, gp, -1
	bnez	gp, epa_d17
	j	push_cmul
epa_d17:
	addi	gp, gp, -1
	bnez	gp, epa_d18
	j	push_cs_mul
epa_d18:
	addi	gp, gp, -1
	bnez	gp, epa_d19
	j	push_cs_div
epa_d19:
	addi	gp, gp, -1
	bnez	gp, epa_d20
	j	push_cs_mod
epa_d20:
	addi	gp, gp, -1
	bnez	gp, epa_d21
	j	push_cep
epa_d21:
	addi	gp, gp, -1
	bnez	gp, epa_d22
	j	push_cep_asg
epa_d22:
	addi	gp, gp, -1
	bnez	gp, epa_d23
	j	push_cep_compound
epa_d23:
	addi	gp, gp, -1
	bnez	gp, epa_d24
	j	push_ct_for_cond
epa_d24:
	addi	gp, gp, -1
	bnez	gp, epa_d25
	j	push_cep_compound_addr
epa_d25:
	addi	gp, gp, -1
	bnez	gp, epa_d26
	j	push_ct_call_arg
epa_d26:
	addi	gp, gp, -1
	bnez	gp, epa_d27
	j	push_ct_idx
epa_d27:
	addi	gp, gp, -1
	bnez	gp, epa_d28
	j	push_ct_stl
epa_d28:
	addi	gp, gp, -1
	bnez	gp, epa_d29
	j	push_ct_sa_base
epa_d29:
	addi	gp, gp, -1
	bnez	gp, epa_d30
	j	push_ct_sa_idx_val
epa_d30:
	j	push_cep_postfix

# ══════════════════════════════════════════════════════════════════════════════
# emit_pop_t0 — emit "lw t0,0(sp) ; addi sp,sp,4"  (pops top of the compiled
#   program's stack into its t0 register).  Multi-caller.
#
# Call sites:  0: pop_ca (compile_add, pop LHS for add/sub)
#              1: pop_cs_star (cs_star, pop address before sw)
#              2: pop_cs_at   (cs_at, pop address before sb)
#              3: pop_ce     (compile_expr '^' loop)
#              4: pop_cs_plus  (compile_stmt '+=' — pop old LHS)
#              5: pop_cs_minus (compile_stmt '-=' — pop old LHS)
#              6: pop_cs_xor   (compile_stmt '^=' — pop old LHS)
#              7: pop_csh      (compile_shift '<<'/'>>' loop)
#              8: pop_cs_lshift (compile_stmt '<<=')
#              9: pop_cs_rshift (compile_stmt '>>=')
#             10: pop_cand     (compile_and '&' loop)
#             11: pop_cs_and   (compile_stmt '&=')
#             12: pop_cor      (compile_or '|' loop)
#             13: pop_cs_or    (compile_stmt '|=')
#             14: pop_ccmp     (compile_rel comparison loop)
#             15: pop_ceq      (compile_expr equality '==' / '!=' loop)
#             16: pop_cmul     (compile_mul '*' / '/' / '%' loop)
#             17: pop_cs_mul   (compile_stmt '*=')
#             18: pop_cs_div   (compile_stmt '/=')
#             19: pop_cs_mod   (compile_stmt '%=')
#             20: pop_cep      (compile_expr_p — Pratt binop post-rhs)
#             21: pop_cep_asg  (compile_expr_p — deref assign, pop address)
# ══════════════════════════════════════════════════════════════════════════════
emit_pop_t0:
	# Value-stack pop. Decrements expr_depth. If the new top lives in
	# an s-register (new_depth < 9), stashes that register number
	# (18..26) in popped_src_reg and emits nothing. If it lives in
	# memory (new_depth >= 9), emits `lw t0, 0(sp); addi sp, sp, 4`
	# and sets popped_src_reg = 5 (t0).
	lla	t0, expr_depth
	lw	t1, 0(t0)
	beqz	t1, ept_underflow
	addi	t1, t1, -1
	sw	t1, 0(t0)
	addi	t2, zero, 9
	bge	t1, t2, ept_mem_pop
	addi	t1, t1, 18
	lla	t0, popped_src_reg
	sw	t1, 0(t0)
	j	emit_pop_t0_disp
ept_mem_pop:
	addi	t2, s5, 8
	lla	t3, bin_end
	lw	t3, 0(t3)
	bgeu	t2, t3, bin_full
	lui	a0, 0x12
	addi	a0, a0, 0x283
	sw	a0, 0(s5)
	addi	s5, s5, 4
	lui	a0, 0x410
	addi	a0, a0, 0x113
	sw	a0, 0(s5)
	addi	s5, s5, 4
	addi	t0, zero, 5
	lla	t1, popped_src_reg
	sw	t0, 0(t1)
	j	emit_pop_t0_disp
ept_underflow:
	addi	a0, zero, 88		# err 88: pop underflow
	j	report_err


emit_pop_t0_disp:
	bnez	gp, ept_d1
	j	pop_ca
ept_d1:
	addi	gp, gp, -1
	bnez	gp, ept_d2
	j	pop_cs_star
ept_d2:
	addi	gp, gp, -1
	bnez	gp, ept_d3
	j	pop_cs_at
ept_d3:
	addi	gp, gp, -1
	bnez	gp, ept_d4
	j	pop_ce
ept_d4:
	addi	gp, gp, -1
	bnez	gp, ept_d5
	j	pop_cs_plus
ept_d5:
	addi	gp, gp, -1
	bnez	gp, ept_d6
	j	pop_cs_minus
ept_d6:
	addi	gp, gp, -1
	bnez	gp, ept_d7
	j	pop_cs_xor
ept_d7:
	addi	gp, gp, -1
	bnez	gp, ept_d8
	j	pop_csh
ept_d8:
	addi	gp, gp, -1
	bnez	gp, ept_d9
	j	pop_cs_lshift
ept_d9:
	addi	gp, gp, -1
	bnez	gp, ept_d10
	j	pop_cs_rshift
ept_d10:
	addi	gp, gp, -1
	bnez	gp, ept_d11
	j	pop_cand
ept_d11:
	addi	gp, gp, -1
	bnez	gp, ept_d12
	j	pop_cs_and
ept_d12:
	addi	gp, gp, -1
	bnez	gp, ept_d13
	j	pop_cor
ept_d13:
	addi	gp, gp, -1
	bnez	gp, ept_d14
	j	pop_cs_or
ept_d14:
	addi	gp, gp, -1
	bnez	gp, ept_d15
	j	pop_ccmp
ept_d15:
	addi	gp, gp, -1
	bnez	gp, ept_d16
	j	pop_ceq
ept_d16:
	addi	gp, gp, -1
	bnez	gp, ept_d17
	j	pop_cmul
ept_d17:
	addi	gp, gp, -1
	bnez	gp, ept_d18
	j	pop_cs_mul
ept_d18:
	addi	gp, gp, -1
	bnez	gp, ept_d19
	j	pop_cs_div
ept_d19:
	addi	gp, gp, -1
	bnez	gp, ept_d20
	j	pop_cs_mod
ept_d20:
	addi	gp, gp, -1
	bnez	gp, ept_d21
	j	pop_cep
ept_d21:
	addi	gp, gp, -1
	bnez	gp, ept_d22
	j	pop_cep_asg
ept_d22:
	addi	gp, gp, -1
	bnez	gp, ept_d23
	j	pop_cep_compound
ept_d23:
	addi	gp, gp, -1
	bnez	gp, ept_d24
	j	pop_ct_for_cond
ept_d24:
	addi	gp, gp, -1
	bnez	gp, ept_d25
	j	pop_cep_compound_addr_w
ept_d25:
	addi	gp, gp, -1
	bnez	gp, ept_d26
	j	pop_cep_compound_addr_b
ept_d26:
	addi	gp, gp, -1
	bnez	gp, ept_d27
	j	pop_ct_idx
ept_d27:
	addi	gp, gp, -1
	bnez	gp, ept_d28
	j	pop_cep_compound_addr_h
ept_d28:
	addi	gp, gp, -1
	bnez	gp, ept_d29
	j	pop_ct_sa_idx_val	# site 28 unused, routed to next
ept_d29:
	addi	gp, gp, -1
	bnez	gp, ept_d30
	j	pop_ct_sa_idx_val
ept_d30:
	addi	gp, gp, -1
	bnez	gp, ept_d31
	j	pop_ct_sa_base
ept_d31:
	j	pop_cep_postfix

# ══════════════════════════════════════════════════════════════════════════════
# emit_add — emit "add a0, t0, a0"    (caller just popped LHS into t0).
#   R-type: opcode=0x33, rd=10, rs1=5(t0), rs2=10(a0), f3=0, f7=0
#   word = 0x00A28533
# Call sites: 0: ea_ret      (compile_add '+' loop)
#             1: ea_cs_plus  (compile_stmt '+=')
#             2: ea_cep      (compile_expr_p '+' Pratt op)
# ══════════════════════════════════════════════════════════════════════════════
emit_add:
	# Encodes `add a0, sN, a0` where sN is the popped source from the
	# preceding emit_pop_t0 (popped_src_reg holds N).
	addi	sp, sp, -4
	sw	gp, 0(sp)
	lla	t0, popped_src_reg
	lw	t0, 0(t0)
	slli	t0, t0, 15
	lui	a0, 0xA00
	addi	a0, a0, 0x533
	or	a0, a0, t0
	addi	gp, zero, 11		# ew site 11 = ew_add
	j	emit_word
ew_add:
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	emit_add_disp

emit_add_disp:
	bnez	gp, ead_1
	j	ea_ret
ead_1:
	addi	gp, gp, -1
	bnez	gp, ead_2
	j	ea_cs_plus
ead_2:
	addi	gp, gp, -1
	bnez	gp, ead_3
	j	ea_cep
ead_3:
	addi	gp, gp, -1
	bnez	gp, ead_4
	j	ea_ct_idx
ead_4:
	j	ea_ct_sa

# ══════════════════════════════════════════════════════════════════════════════
# emit_sub — emit "sub a0, t0, a0"    (caller popped LHS into t0).
#   R-type: word = 0x40A28533
# Call sites: 0: es_ret       (compile_add '-' loop)
#             1: es_cs_minus  (compile_stmt '-=')
#             2: es_cep       (compile_expr_p '-' Pratt op)
# ══════════════════════════════════════════════════════════════════════════════
emit_sub:
	addi	sp, sp, -4
	sw	gp, 0(sp)
	lla	t0, popped_src_reg
	lw	t0, 0(t0)
	slli	t0, t0, 15
	lui	a0, 0x40A00
	addi	a0, a0, 0x533
	or	a0, a0, t0
	addi	gp, zero, 14		# ew site 14 = ew_sub
	j	emit_word
ew_sub:
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	emit_sub_disp

emit_sub_disp:
	bnez	gp, esd_1
	j	es_ret
esd_1:
	addi	gp, gp, -1
	bnez	gp, esd_2
	j	es_cs_minus
esd_2:
	j	es_cep

# ══════════════════════════════════════════════════════════════════════════════
# emit_xor — emit "xor a0, t0, a0"    (caller popped LHS into t0).
#   R-type: word = 0x00A2C533
# Call sites: 0: ex_ret     (compile_expr '^' loop)
#             1: ex_cs_xor  (compile_stmt '^=')
#             2: ex_cep     (compile_expr_p '^' Pratt op)
# ══════════════════════════════════════════════════════════════════════════════
emit_xor:
	addi	sp, sp, -4
	sw	gp, 0(sp)
	lla	t0, popped_src_reg
	lw	t0, 0(t0)
	slli	t0, t0, 15
	lui	a0, 0xA04
	addi	a0, a0, 0x533
	or	a0, a0, t0
	addi	gp, zero, 15		# ew site 15 = ew_xor
	j	emit_word
ew_xor:
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	emit_xor_disp

emit_xor_disp:
	bnez	gp, exd_1
	j	ex_ret
exd_1:
	addi	gp, gp, -1
	bnez	gp, exd_2
	j	ex_cs_xor
exd_2:
	j	ex_cep

# ══════════════════════════════════════════════════════════════════════════════
# emit_sll — emit "sll a0, t0, a0"    (caller popped LHS into t0).
#   R-type: opcode=0x33, rd=10, rs1=5(t0), rs2=10(a0), f3=1, f7=0
#   word = 0x33 | (10<<7) | (1<<12) | (5<<15) | (10<<20) = 0x00A29533
# Call sites: 0: esll_csh_ret   (compile_shift '<<' path)
#             1: esll_cs_lshift (compile_stmt '<<=')
#             2: esll_cep       (compile_expr_p '<<' Pratt op)
# ══════════════════════════════════════════════════════════════════════════════
emit_sll:
	addi	sp, sp, -4
	sw	gp, 0(sp)
	lla	t0, popped_src_reg
	lw	t0, 0(t0)
	slli	t0, t0, 15
	lui	a0, 0xA01
	addi	a0, a0, 0x533
	or	a0, a0, t0
	addi	gp, zero, 18		# ew site 18 = ew_sll
	j	emit_word
ew_sll:
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	emit_sll_disp

emit_sll_disp:
	bnez	gp, esll_d1
	j	esll_csh_ret
esll_d1:
	addi	gp, gp, -1
	bnez	gp, esll_d2
	j	esll_cs_lshift
esll_d2:
	j	esll_cep

# ══════════════════════════════════════════════════════════════════════════════
# emit_sra — emit "sra a0, t0, a0"    (caller popped LHS into t0).
#   R-type: opcode=0x33, rd=10, rs1=5(t0), rs2=10(a0), f3=5, f7=0x20
#   word = 0x33 | (10<<7) | (5<<12) | (5<<15) | (10<<20) | (0x20<<25) = 0x40A2D533
# Call sites: 0: esra_csh_ret   (compile_shift '>>' path)
#             1: esra_cs_rshift (compile_stmt '>>=')
#             2: esra_cep       (compile_expr_p '>>' Pratt op)
# ══════════════════════════════════════════════════════════════════════════════
emit_sra:
	addi	sp, sp, -4
	sw	gp, 0(sp)
	lla	t0, popped_src_reg
	lw	t0, 0(t0)
	slli	t0, t0, 15
	lui	a0, 0x40A05
	addi	a0, a0, 0x533
	or	a0, a0, t0
	addi	gp, zero, 19		# ew site 19 = ew_sra
	j	emit_word
ew_sra:
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	emit_sra_disp

emit_sra_disp:
	bnez	gp, esra_d1
	j	esra_csh_ret
esra_d1:
	addi	gp, gp, -1
	bnez	gp, esra_d2
	j	esra_cs_rshift
esra_d2:
	j	esra_cep

# ══════════════════════════════════════════════════════════════════════════════
# emit_srl — emit "srl a0, t0, a0"    (logical/unsigned right shift).
#   R-type: opcode=0x33, rd=10, rs1=5(t0), rs2=10(a0), f3=5, f7=0
#   word = 0x33 | (10<<7) | (5<<12) | (5<<15) | (10<<20) = 0x00A2D533
# Call sites: 0: esrl_csh_ret  (compile_shift '>>u' path)
#             1: esrl_cep      (compile_expr_p '>>u' Pratt op)
# ══════════════════════════════════════════════════════════════════════════════
emit_srl:
	addi	sp, sp, -4
	sw	gp, 0(sp)
	lla	t0, popped_src_reg
	lw	t0, 0(t0)
	slli	t0, t0, 15
	lui	a0, 0xA05
	addi	a0, a0, 0x533
	or	a0, a0, t0
	addi	gp, zero, 25		# ew site 25 = ew_srl
	j	emit_word
ew_srl:
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	emit_srl_disp

emit_srl_disp:
	bnez	gp, esrl_d1
	j	esrl_csh_ret
esrl_d1:
	j	esrl_cep

# ══════════════════════════════════════════════════════════════════════════════
# emit_and — emit "and a0, t0, a0"    (caller popped LHS into t0).
#   R-type: opcode=0x33, rd=10, rs1=5(t0), rs2=10(a0), f3=7, f7=0
#   word = 0x33 | (10<<7) | (7<<12) | (5<<15) | (10<<20) = 0x00A2F533
# Call sites: 0: ean_cand_ret (compile_and '&' loop)
#             1: ean_cs_and   (compile_stmt '&=')
#             2: ean_cep      (compile_expr_p '&' Pratt op)
# ══════════════════════════════════════════════════════════════════════════════
emit_and:
	addi	sp, sp, -4
	sw	gp, 0(sp)
	lla	t0, popped_src_reg
	lw	t0, 0(t0)
	slli	t0, t0, 15
	lui	a0, 0xA07
	addi	a0, a0, 0x533
	or	a0, a0, t0
	addi	gp, zero, 20		# ew site 20 = ew_and
	j	emit_word
ew_and:
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	emit_and_disp

emit_and_disp:
	bnez	gp, eand_d1
	j	ean_cand_ret
eand_d1:
	addi	gp, gp, -1
	bnez	gp, eand_d2
	j	ean_cs_and
eand_d2:
	j	ean_cep

# ══════════════════════════════════════════════════════════════════════════════
# emit_or — emit "or a0, t0, a0"    (caller popped LHS into t0).
#   R-type: opcode=0x33, rd=10, rs1=5(t0), rs2=10(a0), f3=6, f7=0
#   word = 0x33 | (10<<7) | (6<<12) | (5<<15) | (10<<20) = 0x00A2E533
# Call sites: 0: eor_cor_ret (compile_expr/or '|' loop)
#             1: eor_cs_or   (compile_stmt '|=')
#             2: eor_cep     (compile_expr_p '|' Pratt op)
# ══════════════════════════════════════════════════════════════════════════════
emit_or:
	addi	sp, sp, -4
	sw	gp, 0(sp)
	lla	t0, popped_src_reg
	lw	t0, 0(t0)
	slli	t0, t0, 15
	lui	a0, 0xA06
	addi	a0, a0, 0x533
	or	a0, a0, t0
	addi	gp, zero, 21		# ew site 21 = ew_or
	j	emit_word
ew_or:
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	emit_or_disp

emit_or_disp:
	bnez	gp, eor_d1
	j	eor_cor_ret
eor_d1:
	addi	gp, gp, -1
	bnez	gp, eor_d2
	j	eor_cs_or
eor_d2:
	j	eor_cep

# ══════════════════════════════════════════════════════════════════════════════
# emit_xori_m1 — emit "xori a0, a0, -1"   (bitwise NOT of a0).
#   opcode=0x13, rd=10, f3=4, rs1=10, imm=0xFFF (-1 sign-extended)
#   word = 0x13 | (10<<7) | (4<<12) | (10<<15) | (0xFFF<<20) = 0xFFF54513
# Single caller: exori_ret (compile_unary cu_bnot).
# ══════════════════════════════════════════════════════════════════════════════
emit_xori_m1:
	lui	a0, 0xFFF54
	addi	a0, a0, 0x513
	addi	gp, zero, 22		# ew site 22 = ew_xori_m1
	j	emit_word
ew_xori_m1:
	j	exori_ret

# ══════════════════════════════════════════════════════════════════════════════
# emit_neg_a0 — emit "sub a0, zero, a0"   (two's-complement negation of a0).
#   R-type: opcode=0x33, rd=10, rs1=0(zero), rs2=10(a0), f3=0, f7=0x20
#   word = 0x33 | (10<<7) | (0<<15) | (10<<20) | (0x20<<25) = 0x40A00533
# Single caller: eneg_ret (compile_unary cu_uneg).
# ══════════════════════════════════════════════════════════════════════════════
emit_neg_a0:
	lui	a0, 0x40A00
	addi	a0, a0, 0x533
	addi	gp, zero, 23		# ew site 23 = ew_neg
	j	emit_word
ew_neg:
	j	eneg_ret

# ══════════════════════════════════════════════════════════════════════════════
# emit_cmp_word — store the instruction word in a0 and return to one of
#   several per-step continuations in compile_cmp. Used so comparisons can
#   emit 1- or 2-instruction sequences without needing a separate ew_* site
#   per step.
#
# Call sites (each is one step in a comparison's emit sequence):
#    0: ecw_lt_done   ('<'  after slt)
#    1: ecw_le_slt    ('<=' after slt-rev, before xori)
#    2: ecw_le_done   ('<=' after xori)
#    3: ecw_gt_done   ('>'  after slt-rev)
#    4: ecw_ge_slt    ('>=' after slt, before xori)
#    5: ecw_ge_done   ('>=' after xori)
#    6: ecw_eq_xor    ('==' after xor, before sltiu)
#    7: ecw_eq_done   ('==' after sltiu)
#    8: ecw_ne_xor    ('!=' after xor, before sltu)
#    9: ecw_ne_done   ('!=' after sltu)
#   10: ecw_ltu_done  ('<u' after sltu)
#   11: ecw_leu_sltu  ('<=u' after sltu-rev, before xori)
#   12: ecw_leu_done  ('<=u' after xori)
#   13: ecw_gtu_done  ('>u' after sltu-rev)
#   14: ecw_geu_sltu  ('>=u' after sltu, before xori)
#   15: ecw_geu_done  ('>=u' after xori)
#   16: ecw_cdiv_mv   (compile_mul '/' — after mv a0,t1)
#   17: ecw_cmod_mv   (compile_mul '%' — after mv a0,t2)
#   18: ecw_cs_div_mv (compile_stmt '/=' — after mv a0,t1)
#   19: ecw_cs_mod_mv (compile_stmt '%=' — after mv a0,t2)
#   20: ecw_cdivu_mv  (compile_mul '/u' — after mv a0,t1)
#   21: ecw_cmodu_mv  (compile_mul '%u' — after mv a0,t2)
#   22: ecw_cland_bne    (compile_land — after fixed bne +8)
#   23: ecw_cland_jal_sf (compile_land — after jal to SHORT_FALSE placeholder)
#   24: ecw_cland_sltu   (compile_land — after sltu normalize)
#   25: ecw_cland_jal_end (compile_land — after jal to END placeholder)
#   26: ecw_cland_addi   (compile_land — after addi a0,zero,0)
#   27: ecw_clor_beq     (compile_expr/|| — after fixed beq +8)
#   28: ecw_clor_jal_st  (compile_expr/|| — after jal to SHORT_TRUE placeholder)
#   29: ecw_clor_sltu    (compile_expr/|| — after sltu normalize)
#   30: ecw_clor_jal_end (compile_expr/|| — after jal to END placeholder)
#   31: ecw_clor_addi    (compile_expr/|| — after addi a0,zero,1)
#   32: ecw_ctern_bne     (compile_expr ternary — after fixed bne +8)
#   33: ecw_ctern_jal_else(compile_expr ternary — after jal to ELSE placeholder)
#   34: ecw_ctern_jal_end (compile_expr ternary — after jal to END placeholder)
#   35: ecw_ctern_addi    (compile_expr ternary — after addi for missing ':')
#   36: ecw_cep_div_mv    (compile_expr_p '/' — after mv a0,t1)
#   37: ecw_cep_mod_mv    (compile_expr_p '%' — after mv a0,t2)
#   38: ecw_cep_divu_mv   (compile_expr_p '/u' — after mv a0,t1)
#   39: ecw_cep_modu_mv   (compile_expr_p '%u' — after mv a0,t2)
#   40..55: Pratt comparison ops (each op's emit sequence done step-by-step)
#   40: ecw_cep_lt_done     (slt for '<')
#   41: ecw_cep_le_slt      (slt-rev for '<='; needs xori)
#   42: ecw_cep_le_done     (after xori for '<=')
#   43: ecw_cep_gt_done     (slt-rev for '>')
#   44: ecw_cep_ge_slt      (slt for '>='; needs xori)
#   45: ecw_cep_ge_done     (after xori for '>=')
#   46: ecw_cep_ltu_done    (sltu for '<u')
#   47: ecw_cep_leu_sltu    (sltu-rev for '<=u'; needs xori)
#   48: ecw_cep_leu_done    (after xori for '<=u')
#   49: ecw_cep_gtu_done    (sltu-rev for '>u')
#   50: ecw_cep_geu_sltu    (sltu for '>=u'; needs xori)
#   51: ecw_cep_geu_done    (after xori for '>=u')
#   52: ecw_cep_eq_xor      (xor for '=='; needs sltiu)
#   53: ecw_cep_eq_done     (after sltiu for '==')
#   54: ecw_cep_ne_xor      (xor for '!='; needs sltu-zero)
#   55: ecw_cep_ne_done     (after sltu-zero for '!=')
#   56..65: Pratt short-circuit && / ||
#   56: ecw_cep_land_bne    (&& — after fixed bne)
#   57: ecw_cep_land_jal_sf (&& — after jal SHORT_FALSE placeholder)
#   58: ecw_cep_land_sltu   (&& — after sltu normalize)
#   59: ecw_cep_land_jal_end(&& — after jal END placeholder)
#   60: ecw_cep_land_addi   (&& — after addi 0 for false-tail)
#   61: ecw_cep_lor_beq     (|| — after fixed beq)
#   62: ecw_cep_lor_jal_st  (|| — after jal SHORT_TRUE placeholder)
#   63: ecw_cep_lor_sltu    (|| — after sltu normalize)
#   64: ecw_cep_lor_jal_end (|| — after jal END placeholder)
#   65: ecw_cep_lor_addi    (|| — after addi 1 for true-tail)
#   66..69: Pratt ternary
#   66: ecw_cep_tern_bne    (? — after fixed bne)
#   67: ecw_cep_tern_jal_else (? — after jal ELSE placeholder)
#   68: ecw_cep_tern_jal_end  (? — after jal END placeholder)
#   69: ecw_cep_tern_addi   (? — after addi 0 for missing ':')
# ══════════════════════════════════════════════════════════════════════════════
emit_cmp_word:
	addi	sp, sp, -4
	sw	gp, 0(sp)
	addi	gp, zero, 24		# ew site 24 = ew_cmp
	j	emit_word
ew_cmp:
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	emit_cmp_word_disp

emit_cmp_word_disp:
	bnez	gp, ecw_d1
	j	ecw_lt_done
ecw_d1:
	addi	gp, gp, -1
	bnez	gp, ecw_d2
	j	ecw_le_slt
ecw_d2:
	addi	gp, gp, -1
	bnez	gp, ecw_d3
	j	ecw_le_done
ecw_d3:
	addi	gp, gp, -1
	bnez	gp, ecw_d4
	j	ecw_gt_done
ecw_d4:
	addi	gp, gp, -1
	bnez	gp, ecw_d5
	j	ecw_ge_slt
ecw_d5:
	addi	gp, gp, -1
	bnez	gp, ecw_d6
	j	ecw_ge_done
ecw_d6:
	addi	gp, gp, -1
	bnez	gp, ecw_d7
	j	ecw_eq_xor
ecw_d7:
	addi	gp, gp, -1
	bnez	gp, ecw_d8
	j	ecw_eq_done
ecw_d8:
	addi	gp, gp, -1
	bnez	gp, ecw_d9
	j	ecw_ne_xor
ecw_d9:
	addi	gp, gp, -1
	bnez	gp, ecw_d10
	j	ecw_ne_done
ecw_d10:
	addi	gp, gp, -1
	bnez	gp, ecw_d11
	j	ecw_ltu_done
ecw_d11:
	addi	gp, gp, -1
	bnez	gp, ecw_d12
	j	ecw_leu_sltu
ecw_d12:
	addi	gp, gp, -1
	bnez	gp, ecw_d13
	j	ecw_leu_done
ecw_d13:
	addi	gp, gp, -1
	bnez	gp, ecw_d14
	j	ecw_gtu_done
ecw_d14:
	addi	gp, gp, -1
	bnez	gp, ecw_d15
	j	ecw_geu_sltu
ecw_d15:
	addi	gp, gp, -1
	bnez	gp, ecw_d16
	j	ecw_geu_done
ecw_d16:
	addi	gp, gp, -1
	bnez	gp, ecw_d17
	j	ecw_cdiv_mv
ecw_d17:
	addi	gp, gp, -1
	bnez	gp, ecw_d18
	j	ecw_cmod_mv
ecw_d18:
	addi	gp, gp, -1
	bnez	gp, ecw_d19
	j	ecw_cs_div_mv
ecw_d19:
	addi	gp, gp, -1
	bnez	gp, ecw_d20
	j	ecw_cs_mod_mv
ecw_d20:
	addi	gp, gp, -1
	bnez	gp, ecw_d21
	j	ecw_cdivu_mv
ecw_d21:
	addi	gp, gp, -1
	bnez	gp, ecw_d22
	j	ecw_cmodu_mv
ecw_d22:
	addi	gp, gp, -1
	bnez	gp, ecw_d23
	j	ecw_cland_bne
ecw_d23:
	addi	gp, gp, -1
	bnez	gp, ecw_d24
	j	ecw_cland_jal_sf
ecw_d24:
	addi	gp, gp, -1
	bnez	gp, ecw_d25
	j	ecw_cland_sltu
ecw_d25:
	addi	gp, gp, -1
	bnez	gp, ecw_d26
	j	ecw_cland_jal_end
ecw_d26:
	addi	gp, gp, -1
	bnez	gp, ecw_d27
	j	ecw_cland_addi
ecw_d27:
	addi	gp, gp, -1
	bnez	gp, ecw_d28
	j	ecw_clor_beq
ecw_d28:
	addi	gp, gp, -1
	bnez	gp, ecw_d29
	j	ecw_clor_jal_st
ecw_d29:
	addi	gp, gp, -1
	bnez	gp, ecw_d30
	j	ecw_clor_sltu
ecw_d30:
	addi	gp, gp, -1
	bnez	gp, ecw_d31
	j	ecw_clor_jal_end
ecw_d31:
	addi	gp, gp, -1
	bnez	gp, ecw_d32
	j	ecw_clor_addi
ecw_d32:
	addi	gp, gp, -1
	bnez	gp, ecw_d33
	j	ecw_ctern_bne
ecw_d33:
	addi	gp, gp, -1
	bnez	gp, ecw_d34
	j	ecw_ctern_jal_else
ecw_d34:
	addi	gp, gp, -1
	bnez	gp, ecw_d35
	j	ecw_ctern_jal_end
ecw_d35:
	addi	gp, gp, -1
	bnez	gp, ecw_d36
	j	ecw_ctern_addi
ecw_d36:
	addi	gp, gp, -1
	bnez	gp, ecw_d37
	j	ecw_cep_div_mv
ecw_d37:
	addi	gp, gp, -1
	bnez	gp, ecw_d38
	j	ecw_cep_mod_mv
ecw_d38:
	addi	gp, gp, -1
	bnez	gp, ecw_d39
	j	ecw_cep_divu_mv
ecw_d39:
	addi	gp, gp, -1
	bnez	gp, ecw_d40
	j	ecw_cep_modu_mv
ecw_d40:
	addi	gp, gp, -1
	bnez	gp, ecw_d41
	j	ecw_cep_lt_done
ecw_d41:
	addi	gp, gp, -1
	bnez	gp, ecw_d42
	j	ecw_cep_le_slt
ecw_d42:
	addi	gp, gp, -1
	bnez	gp, ecw_d43
	j	ecw_cep_le_done
ecw_d43:
	addi	gp, gp, -1
	bnez	gp, ecw_d44
	j	ecw_cep_gt_done
ecw_d44:
	addi	gp, gp, -1
	bnez	gp, ecw_d45
	j	ecw_cep_ge_slt
ecw_d45:
	addi	gp, gp, -1
	bnez	gp, ecw_d46
	j	ecw_cep_ge_done
ecw_d46:
	addi	gp, gp, -1
	bnez	gp, ecw_d47
	j	ecw_cep_ltu_done
ecw_d47:
	addi	gp, gp, -1
	bnez	gp, ecw_d48
	j	ecw_cep_leu_sltu
ecw_d48:
	addi	gp, gp, -1
	bnez	gp, ecw_d49
	j	ecw_cep_leu_done
ecw_d49:
	addi	gp, gp, -1
	bnez	gp, ecw_d50
	j	ecw_cep_gtu_done
ecw_d50:
	addi	gp, gp, -1
	bnez	gp, ecw_d51
	j	ecw_cep_geu_sltu
ecw_d51:
	addi	gp, gp, -1
	bnez	gp, ecw_d52
	j	ecw_cep_geu_done
ecw_d52:
	addi	gp, gp, -1
	bnez	gp, ecw_d53
	j	ecw_cep_eq_xor
ecw_d53:
	addi	gp, gp, -1
	bnez	gp, ecw_d54
	j	ecw_cep_eq_done
ecw_d54:
	addi	gp, gp, -1
	bnez	gp, ecw_d55
	j	ecw_cep_ne_xor
ecw_d55:
	addi	gp, gp, -1
	bnez	gp, ecw_d56
	j	ecw_cep_ne_done
ecw_d56:
	addi	gp, gp, -1
	bnez	gp, ecw_d57
	j	ecw_cep_land_bne
ecw_d57:
	addi	gp, gp, -1
	bnez	gp, ecw_d58
	j	ecw_cep_land_jal_sf
ecw_d58:
	addi	gp, gp, -1
	bnez	gp, ecw_d59
	j	ecw_cep_land_sltu
ecw_d59:
	addi	gp, gp, -1
	bnez	gp, ecw_d60
	j	ecw_cep_land_jal_end
ecw_d60:
	addi	gp, gp, -1
	bnez	gp, ecw_d61
	j	ecw_cep_land_addi
ecw_d61:
	addi	gp, gp, -1
	bnez	gp, ecw_d62
	j	ecw_cep_lor_beq
ecw_d62:
	addi	gp, gp, -1
	bnez	gp, ecw_d63
	j	ecw_cep_lor_jal_st
ecw_d63:
