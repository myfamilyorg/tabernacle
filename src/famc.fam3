# ══════════════════════════════════════════════════════════════════════════════
# emit_addi_a0_1 — emit "addi a0, a0, 1"
#   opcode=0x13, rd=10, f3=0, rs1=10, imm=1
#   word = 0x13 | (10<<7) | (10<<15) | (1<<20) = 0x00150513
# Multi-caller. Call sites:
#   0: eaa1_pre_inc       (compile_unary prefix '++')
#   1: eaa1_post_inc      (compile_unary postfix '++' — emit new value)
#   2: eaa1_post_dec_undo (compile_unary postfix '--' — restore old value)
#   3: eaa1_cs_inc_stmt   (compile_stmt '++IDENT;' / 'IDENT++;')
# ══════════════════════════════════════════════════════════════════════════════
emit_addi_a0_1:
	addi	sp, sp, -4
	sw	gp, 0(sp)
	lui	a0, 0x150
	addi	a0, a0, 0x513
	addi	gp, zero, 16		# ew site 16 = ew_addi1
	j	emit_word
ew_addi1:
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	emit_addi_a0_1_disp

emit_addi_a0_1_disp:
	bnez	gp, eaa1_d1
	j	eaa1_pre_inc
eaa1_d1:
	addi	gp, gp, -1
	bnez	gp, eaa1_d2
	j	eaa1_post_inc
eaa1_d2:
	addi	gp, gp, -1
	bnez	gp, eaa1_d3
	j	eaa1_post_dec_undo
eaa1_d3:
	addi	gp, gp, -1
	bnez	gp, eaa1_d4
	j	eaa1_cs_inc_stmt
eaa1_d4:
	addi	gp, gp, -1
	bnez	gp, eaa1_d5
	j	eaa1_ct_for_inc
eaa1_d5:
	j	eaa1_cep_postinc

# ══════════════════════════════════════════════════════════════════════════════
# emit_addi_a0_m1 — emit "addi a0, a0, -1"
#   opcode=0x13, rd=10, f3=0, rs1=10, imm=0xFFF (-1 sign-extended)
#   word = 0x13 | (10<<7) | (10<<15) | (0xFFF<<20) = 0xFFF50513
# Multi-caller. Call sites:
#   0: eaam1_pre_dec       (compile_unary prefix '--')
#   1: eaam1_post_inc_undo (compile_unary postfix '++' — restore old value)
#   2: eaam1_post_dec      (compile_unary postfix '--' — emit new value)
#   3: eaam1_cs_dec_stmt   (compile_stmt '--IDENT;' / 'IDENT--;')
# ══════════════════════════════════════════════════════════════════════════════
emit_addi_a0_m1:
	addi	sp, sp, -4
	sw	gp, 0(sp)
	lui	a0, 0xFFF50
	addi	a0, a0, 0x513
	addi	gp, zero, 17		# ew site 17 = ew_addim1
	j	emit_word
ew_addim1:
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	emit_addi_a0_m1_disp

emit_addi_a0_m1_disp:
	bnez	gp, eaam1_d1
	j	eaam1_pre_dec
eaam1_d1:
	addi	gp, gp, -1
	bnez	gp, eaam1_d2
	j	eaam1_post_inc_undo
eaam1_d2:
	addi	gp, gp, -1
	bnez	gp, eaam1_d3
	j	eaam1_post_dec
eaam1_d3:
	addi	gp, gp, -1
	bnez	gp, eaam1_d4
	j	eaam1_cs_dec_stmt
eaam1_d4:
	addi	gp, gp, -1
	bnez	gp, eaam1_d5
	j	eaam1_ct_for_low
eaam1_d5:
	j	eaam1_cep_postinc

# ══════════════════════════════════════════════════════════════════════════════
# emit_sw_deref — emit "sw a0, 0(t0)"   (caller just popped addr into t0).
#   opcode=0x23, f3=2, rs1=5(t0), rs2=10(a0), imm=0
#   word = 0x23 | (2<<12) | (5<<15) | (10<<20) = 0x00A2A023
# Call sites: 0: esw_ret      (compile_stmt cs_star)
#             1: esw_cep_asg  (compile_expr_p '*expr = val')
# ══════════════════════════════════════════════════════════════════════════════
emit_sw_deref:
	# Encodes `sw a0, 0(sN)` where sN = popped_src_reg.
	addi	sp, sp, -4
	sw	gp, 0(sp)
	lla	t0, popped_src_reg
	lw	t0, 0(t0)
	slli	t0, t0, 15
	lui	a0, 0xA02
	addi	a0, a0, 0x023
	or	a0, a0, t0
	addi	gp, zero, 12		# ew site 12 = ew_sw_d
	j	emit_word
ew_sw_d:
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	emit_sw_deref_disp

emit_sw_deref_disp:
	bnez	gp, esw_d1
	j	esw_ret
esw_d1:
	addi	gp, gp, -1
	bnez	gp, esw_d2
	j	esw_cep_asg
esw_d2:
	addi	gp, gp, -1
	bnez	gp, esw_d3
	j	esw_cep_compound
esw_d3:
	j	esw_cep_postfix

# ══════════════════════════════════════════════════════════════════════════════
# emit_sb_deref — emit "sb a0, 0(t0)"
#   opcode=0x23, f3=0, rs1=5(t0), rs2=10(a0), imm=0
#   word = 0x23 | (0<<12) | (5<<15) | (10<<20) = 0x00A28023
# Call sites: 0: esb_ret      (compile_stmt cs_at)
#             1: esb_cep_asg  (compile_expr_p '@expr = val')
# ══════════════════════════════════════════════════════════════════════════════
emit_sb_deref:
	# Encodes `sb a0, 0(sN)` where sN = popped_src_reg.
	addi	sp, sp, -4
	sw	gp, 0(sp)
	lla	t0, popped_src_reg
	lw	t0, 0(t0)
	slli	t0, t0, 15
	lui	a0, 0xA00
	addi	a0, a0, 0x023
	or	a0, a0, t0
	addi	gp, zero, 13		# ew site 13 = ew_sb_d
	j	emit_word
ew_sb_d:
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	emit_sb_deref_disp

emit_sb_deref_disp:
	bnez	gp, esb_d1
	j	esb_ret
esb_d1:
	addi	gp, gp, -1
	bnez	gp, esb_d2
	j	esb_cep_asg
esb_d2:
	addi	gp, gp, -1
	bnez	gp, esb_d3
	j	esb_cep_compound
esb_d3:
	j	esb_cep_postfix

# ══════════════════════════════════════════════════════════════════════════════
# emit_stack_check — emit `bgeu sp, s1, +8 ; jal zero, panic_handler`.
# When s1=0 (guard disabled), bgeu always branches (nothing is unsigned < 0),
# so the jal never fires. When s1 = stack floor, sp < s1 skips the bgeu and
# hits the jal, branching to the panic handler emitted in the prologue.
#
# Call sites: 0: esc_ret_push (emit_push_a0, after sp decrement)
#             1: esc_ret_fn   (function prologue, after frame alloc)
# gp = return site (set by caller, NOT saved — no sub-calls here).
# ══════════════════════════════════════════════════════════════════════════════
emit_stack_check:
	# Emit bgeu sp, s1, +8 (constant word 0x00917463)
	# B-type: opcode=0x63 funct3=7 rs1=sp(2) rs2=s1(9) offset=+8
	# offset +8: imm[4:1]=0100→bits[11:8]=4→0x400
	lui	a0, 0x917
	addi	a0, a0, 0x463
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# Emit jal zero, panic_handler
	# offset = panic_handler_addr - s5
	lla	t0, panic_handler_addr
	lw	t0, 0(t0)
	sub	t0, t0, s5		# signed offset

	# J-type encoding: imm[20|10:1|11|19:12] rd opcode
	# base = 0x0000006F (jal zero, 0)
	# imm[10:1] → bits[30:21]
	srli	t1, t0, 1
	andi	t1, t1, 0x3FF
	slli	t1, t1, 21
	# imm[11] → bit[20]
	srli	t2, t0, 11
	andi	t2, t2, 1
	slli	t2, t2, 20
	# imm[19:12] → bits[19:12]
	srli	t3, t0, 12
	andi	t3, t3, 0xFF
	slli	t3, t3, 12
	# imm[20] → bit[31]
	srli	t4, t0, 20
	andi	t4, t4, 1
	slli	t4, t4, 31

	addi	a0, zero, 0x6F
	or	a0, a0, t1
	or	a0, a0, t2
	or	a0, a0, t3
	or	a0, a0, t4
	sw	a0, 0(s5)
	addi	s5, s5, 4

	bnez	gp, esc_d1
	j	esc_ret_push
esc_d1:
	j	esc_ret_fn

# ══════════════════════════════════════════════════════════════════════════════
# Expression compilation — precedence-climbing, three layers:
#
#   compile_expr  := compile_add ('^' compile_add)*            # xor layer
#   compile_add   := compile_unary (('+' | '-') compile_unary)*# additive layer
#   compile_unary := ('*' | '@') compile_unary | primary       # unary layer
#   primary       := NUM | IDENT
#
# Sub-step A (now): the three layers exist but only `+` is implemented (in
# compile_add). compile_expr is a degenerate wrapper with no body and
# compile_unary has the current compile_term logic. Sub-steps B/C/D/E will
# fill in `-`, `^`, `++`/`--`, and compound assignment.
#
# Dispatch site namespaces:
#   compile_unary:  cu_ca_first (from compile_add, before loop)
#                   cu_ca_next  (from compile_add, loop body)
#   compile_add:    ca_ce_first (from compile_expr; only one site today)
#   compile_expr:   ce_cs_rhs, ce_cs_addr1, ce_cs_val1, ce_cs_addr2, ce_cs_val2
# ══════════════════════════════════════════════════════════════════════════════

# ── compile_unary ────────────────────────────────────────────────────────────
# emits code that leaves a unary's value in a0.
#   unary := ('*' | '@' | '++' | '--' | '~' | '-') unary
#          | primary ('++' | '--')?
# Prefix/postfix '++'/'--' apply to bare identifiers only. Unary '~' and '-'
# re-enter compile_unary and emit their op after the nested call returns, so
# they compose and chain naturally (e.g. `-~x`, `~~x`).
#
# Frame (12 bytes):
#   0(sp): saved gp
#   4(sp): deref_kind   (0=none, 1=word '*', 2=byte '@')
#   8(sp): incdec_kind  (0=none, 1=prefix++, 2=prefix--)
#
# Call sites:  0: cu_cmul_first (compile_mul, first unary)
#              1: cu_cmul_next  (compile_mul, unary after '*')
#              2: cu_uneg       (compile_unary, after unary '-' recursion)
#              3: cu_bnot       (compile_unary, after unary '~' recursion)
#              4: cu_cep_nud    (compile_expr_p — Pratt nud call)
compile_unary:
	# Stack-depth guard: prefix operators (-, ~, !) recurse directly into
	# compile_unary without going through compile_expr_p, so the check has
	# to live here too.
	lla	t0, heap_end
	lw	t0, 0(t0)
	bgeu	t0, sp, heap_full
	addi	sp, sp, -12
	sw	gp, 0(sp)
	sw	zero, 4(sp)
	sw	zero, 8(sp)

	# Reset the lvalue marker at entry.
	lla	t0, lv_kind
	sw	zero, 0(t0)
	# Reset brace flag — set to 1 by block/loop/for on closing '}'.
	lla	t0, last_was_brace
	sw	zero, 0(t0)

	addi	gp, zero, 1
	j	skip_ws
sw_ct_pre:
	bge	s2, s3, ct_bad

	lbu	t0, 0(s2)
	addi	t1, zero, 42		# '*'
	beq	t0, t1, ct_is_star
	addi	t1, zero, 64		# '@'
	beq	t0, t1, ct_is_at
	addi	t1, zero, '#'
	beq	t0, t1, ct_is_hash
	addi	t1, zero, '+'
	beq	t0, t1, ct_chk_pp
	addi	t1, zero, '-'
	beq	t0, t1, ct_chk_minus
	addi	t1, zero, '~'
	beq	t0, t1, ct_uneg_tilde
	addi	t1, zero, '!'
	beq	t0, t1, ct_lnot
	j	ct_primary

ct_is_star:
	addi	s2, s2, 1
	addi	t1, zero, 1
	sw	t1, 4(sp)
	addi	gp, zero, 2
	j	skip_ws
sw_ct_star:
	j	ct_primary

ct_is_at:
	addi	s2, s2, 1
	addi	t1, zero, 2
	sw	t1, 4(sp)
	addi	gp, zero, 3
	j	skip_ws

ct_is_hash:
	# '#' — halfword deref prefix. deref_kind = 3.
	addi	s2, s2, 1
	addi	t1, zero, 3
	sw	t1, 4(sp)
	addi	gp, zero, 48		# skip_ws site 48 = sw_ct_hash
	j	skip_ws
sw_ct_hash:
	j	ct_primary
sw_ct_at:
	j	ct_primary

ct_chk_pp:
	# Need s2+1 < s3 and s2[1] == '+'; otherwise bare '+' is a parse error
	# (we have no unary plus).
	addi	t2, s2, 1
	bge	t2, s3, ct_bad
	lbu	t0, 0(t2)
	addi	t1, zero, '+'
	bne	t0, t1, ct_bad
	addi	s2, s2, 2
	addi	t1, zero, 1
	sw	t1, 8(sp)		# incdec_kind = 1 (prefix ++)
	addi	gp, zero, 12		# skip_ws site 12 = sw_ct_pp
	j	skip_ws
sw_ct_pp:
	j	ct_primary

ct_chk_minus:
	# Lookahead: '--' is prefix decrement, otherwise unary negation.
	addi	t2, s2, 1
	bge	t2, s3, ct_uneg
	lbu	t0, 0(t2)
	addi	t1, zero, '-'
	beq	t0, t1, ct_chk_mm
	j	ct_uneg

ct_chk_mm:
	addi	s2, s2, 2
	addi	t1, zero, 2
	sw	t1, 8(sp)		# incdec_kind = 2 (prefix --)
	addi	gp, zero, 13		# skip_ws site 13 = sw_ct_mm
	j	skip_ws
sw_ct_mm:
	j	ct_primary

ct_uneg:
	# Unary '-' : consume, recurse compile_unary, then emit neg.
	addi	s2, s2, 1
	addi	gp, zero, 2		# cu site 2 = cu_uneg
	j	compile_unary
cu_uneg:
	j	emit_neg_a0
eneg_ret:
	j	ct_done

ct_uneg_tilde:
	# Unary '~' : consume, recurse compile_unary, then emit bitwise NOT.
	addi	s2, s2, 1
	addi	gp, zero, 3		# cu site 3 = cu_bnot
	j	compile_unary
cu_bnot:
	j	emit_xori_m1
exori_ret:
	j	ct_done

ct_lnot:
	# Unary '!' (logical NOT): consume, recurse compile_unary, emit
	# `sltiu a0, a0, 1` — which sets a0 to 1 iff a0 == 0 (else 0).
	#   sltiu rd=a0 rs1=a0 imm=1 → word 0x00153513
	addi	s2, s2, 1
	addi	gp, zero, 5		# cu site 5 = cu_lnot
	j	compile_unary
cu_lnot:
	lui	a0, 0x153
	addi	a0, a0, 0x513
	addi	gp, zero, 42		# emit_word site 42 = ew_ct_lnot
	j	emit_word
ew_ct_lnot:
	# Logical NOT's result is never an lvalue.
	lla	t0, lv_kind
	sw	zero, 0(t0)
	j	ct_done

ct_primary:
	bge	s2, s3, ct_bad
	lbu	t0, 0(s2)
	# Digit?
	addi	t1, zero, '0'
	blt	t0, t1, ct_not_num
	addi	t1, zero, 58
	blt	t0, t1, ct_num
ct_not_num:
	# Letter or underscore?
	addi	t1, zero, 'a'
	blt	t0, t1, ct_not_lc
	addi	t1, zero, 123
	blt	t0, t1, ct_id
ct_not_lc:
	addi	t1, zero, 'A'
	blt	t0, t1, ct_not_uc
	addi	t1, zero, 91
	blt	t0, t1, ct_id
ct_not_uc:
	addi	t1, zero, '_'
	beq	t0, t1, ct_id
	addi	t1, zero, '('
	beq	t0, t1, ct_lparen
	addi	t1, zero, '{'
	beq	t0, t1, ct_lbrace
	addi	t1, zero, 39		# '\'' — char literal
	beq	t0, t1, ct_char_lit
	addi	t1, zero, 34		# '"' — string literal
	beq	t0, t1, ct_string_lit
	j	ct_bad

ct_num:
	# '++'/'--' are invalid on numeric literals.
	lw	t0, 8(sp)
	bnez	t0, ct_bad_literal_pp
	addi	gp, zero, 0
	j	parse_num
pn_ct:
	addi	gp, zero, 0		# eli site 0 = eli_ret
	j	emit_li
eli_ret:
	j	ct_deref
eli_ret_id_const:
	# Const-folded ct_id (la_ct → emit_li). Reuse the IDENT post-load
	# tail by jumping into elws_ret, which handles ++/--/postfix and
	# the deref/lvalue bookkeeping just like a normal lw fp local.
	j	elws_ret

# ── Character literal: 'x' or '\n' / '\t' / '\r' / '\0' / '\\' / '\''  ───────
# Produces an integer value in a0 (the char's byte), emitted via emit_li so the
# runtime register a0 holds it. Shares eli_ret → ct_deref as its tail.
ct_char_lit:
	# '++'/'--' are invalid on char literals.
	lw	t0, 8(sp)
	bnez	t0, ct_bad_literal_pp
	addi	s2, s2, 1		# consume opening '
	bge	s2, s3, ct_bad
	lbu	t0, 0(s2)
	addi	t1, zero, 92		# '\\'
	beq	t0, t1, ct_char_esc
	# Plain char: consume it, expect closing quote.
	addi	s2, s2, 1
	j	ct_char_close
ct_char_esc:
	addi	s2, s2, 1		# consume backslash
	bge	s2, s3, ct_bad
	lbu	t0, 0(s2)
	addi	t1, zero, 'n'
	beq	t0, t1, ct_char_nl
	addi	t1, zero, 't'
	beq	t0, t1, ct_char_tab
	addi	t1, zero, 'r'
	beq	t0, t1, ct_char_cr
	addi	t1, zero, '0'
	beq	t0, t1, ct_char_nul
	addi	t1, zero, 'b'
	beq	t0, t1, ct_char_bs
	addi	t1, zero, 'f'
	beq	t0, t1, ct_char_ff
	addi	t1, zero, 'a'
	beq	t0, t1, ct_char_bel
	addi	t1, zero, 'v'
	beq	t0, t1, ct_char_vtab
	addi	t1, zero, 'e'
	beq	t0, t1, ct_char_esc_char
	addi	t1, zero, 92		# literal backslash
	beq	t0, t1, ct_char_lit_ok
	addi	t1, zero, 39		# literal single quote
	beq	t0, t1, ct_char_lit_ok
	addi	t1, zero, 34		# literal double quote
	beq	t0, t1, ct_char_lit_ok
	j	ct_bad_char_esc
ct_char_nl:
	addi	t0, zero, 10		# \n  line feed
	j	ct_char_lit_ok
ct_char_tab:
	addi	t0, zero, 9		# \t  horizontal tab
	j	ct_char_lit_ok
ct_char_cr:
	addi	t0, zero, 13		# \r  carriage return
	j	ct_char_lit_ok
ct_char_nul:
	addi	t0, zero, 0		# \0  null byte
	j	ct_char_lit_ok
ct_char_bs:
	addi	t0, zero, 8		# \b  backspace
	j	ct_char_lit_ok
ct_char_ff:
	addi	t0, zero, 12		# \f  form feed
	j	ct_char_lit_ok
ct_char_bel:
	addi	t0, zero, 7		# \a  bell
	j	ct_char_lit_ok
ct_char_vtab:
	addi	t0, zero, 11		# \v  vertical tab
	j	ct_char_lit_ok
ct_char_esc_char:
	addi	t0, zero, 27		# \e  escape (ESC)
ct_char_lit_ok:
	addi	s2, s2, 1		# consume the escape char (t0 holds decoded value)
ct_char_close:
	bge	s2, s3, ct_bad
	lbu	t1, 0(s2)
	addi	t2, zero, 39
	bne	t1, t2, ct_bad
	addi	s2, s2, 1		# consume closing '
	# Emit `li a0, <t0>` via emit_li (it reads a0 as the immediate).
	addi	a0, t0, 0
	addi	gp, zero, 0		# eli site 0 = eli_ret
	j	emit_li

# ══════════════════════════════════════════════════════════════════════════════
# ct_string_lit — compile a `"..."` string literal.
#
# Emits: auipc a0, 0; addi a0, a0, 12; jal zero, 4+padded_len; <bytes\0 pad>
# Result: a0 = pointer to the null-terminated string in the code stream.
# lv_kind = 0 (not an lvalue).
# ══════════════════════════════════════════════════════════════════════════════
ct_string_lit:
	lw	t0, 8(sp)
	bnez	t0, ct_bad_literal_pp
	addi	s2, s2, 1		# consume opening '"'

	# ── Pass 1: scan to find string length (with escapes) ──────────
	addi	t0, s2, 0		# t0 = scan cursor
	addi	t1, zero, 0		# t1 = byte count (excl. null term)
ct_sl_scan:
	bge	t0, s3, ct_bad_str_unterminated
	lbu	t2, 0(t0)
	addi	t3, zero, 34		# '"' — closing quote
	beq	t2, t3, ct_sl_scan_done
	addi	t3, zero, 92		# '\\' — escape
	beq	t2, t3, ct_sl_scan_esc
	addi	t0, t0, 1
	addi	t1, t1, 1
	j	ct_sl_scan
ct_sl_scan_esc:
	addi	t0, t0, 2		# skip backslash + escape char
	addi	t1, t1, 1		# one decoded byte
	j	ct_sl_scan
ct_sl_scan_done:
	# t1 = string byte count (without null), t0 = ptr to closing '"'
	addi	t1, t1, 1		# +1 for null terminator
	# Padded length = (t1 + 3) & ~3
	addi	t4, t1, 3
	andi	t4, t4, -4		# t4 = padded byte count

	# Bounds check: we're about to emit 12 bytes of prefix code + t4 bytes
	# of literal data inline (bypassing emit_word), so verify up-front that
	# the whole thing fits below bin_end.
	add	t6, s5, t4
	addi	t6, t6, 12
	lla	t0, bin_end
	lw	t0, 0(t0)
	bgeu	t6, t0, bin_full

	# ── Emit: auipc a0, 0 = 0x00000517 ────────────────────────────
	lui	a0, 0
	addi	a0, a0, 0x517
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# ── Emit: addi a0, a0, 12 = 0x00C50513 ────────────────────────
	lui	a0, 0xC50
	addi	a0, a0, 0x513
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# ── Emit: jal zero, 4 + padded_len ────────────────────────────
	# offset = 4 + t4 (the jal itself is 4 bytes, then t4 bytes of data)
	addi	t5, t4, 4
	# J-type encoding: imm[20|10:1|11|19:12] rd=0 opcode=0x6F
	# offset is small and positive, so imm[20]=0, imm[19:12]=0, imm[11]=0
	# imm[10:1] = (offset >> 1) & 0x3FF → bits[30:21]
	srli	t6, t5, 1
	andi	t6, t6, 0x3FF
	slli	t6, t6, 21
	addi	a0, zero, 0x6F
	or	a0, a0, t6
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# ── Pass 2: copy string bytes to output buffer ─────────────────
ct_sl_copy:
	bge	s2, s3, ct_bad_str_unterminated
	lbu	t2, 0(s2)
	addi	t3, zero, 34		# '"'
	beq	t2, t3, ct_sl_copy_done
	addi	t3, zero, 92		# '\\'
	beq	t2, t3, ct_sl_copy_esc
	sb	t2, 0(s5)
	addi	s5, s5, 1
	addi	s2, s2, 1
	j	ct_sl_copy
ct_sl_copy_esc:
	addi	s2, s2, 1		# skip backslash
	bge	s2, s3, ct_bad_str_unterminated
	lbu	t2, 0(s2)
	addi	s2, s2, 1
	addi	t3, zero, 'n'
	beq	t2, t3, ct_sl_esc_nl
	addi	t3, zero, 't'
	beq	t2, t3, ct_sl_esc_tab
	addi	t3, zero, 'r'
	beq	t2, t3, ct_sl_esc_cr
	addi	t3, zero, '0'
	beq	t2, t3, ct_sl_esc_nul
	addi	t3, zero, 92		# '\\'
	beq	t2, t3, ct_sl_esc_ok
	addi	t3, zero, 34		# '"'
	beq	t2, t3, ct_sl_esc_ok
	j	ct_bad_str_esc
ct_sl_esc_nl:
	addi	t2, zero, 10
	j	ct_sl_esc_ok
ct_sl_esc_tab:
	addi	t2, zero, 9
	j	ct_sl_esc_ok
ct_sl_esc_cr:
	addi	t2, zero, 13
	j	ct_sl_esc_ok
ct_sl_esc_nul:
	addi	t2, zero, 0
ct_sl_esc_ok:
	sb	t2, 0(s5)
	addi	s5, s5, 1
	j	ct_sl_copy
ct_sl_copy_done:
	addi	s2, s2, 1		# consume closing '"'
	# Write null terminator + padding to fill t4 bytes total.
	# t4 = pre-computed padded byte count. t1 was the unpadded count
	# (chars + null). We've written t1-1 chars so far. Need to write
	# t4 - (t1-1) more bytes (null + padding), all zero.
	addi	t1, t1, -1		# t1 = chars written so far
	sub	t0, t4, t1		# t0 = remaining bytes to fill
ct_sl_pad:
	beqz	t0, ct_sl_pad_done
	sb	zero, 0(s5)
	addi	s5, s5, 1
	addi	t0, t0, -1
	j	ct_sl_pad
ct_sl_pad_done:
	j	ct_deref

ct_bad_str_unterminated:
	addi	a0, zero, 56		# err 56: unterminated string
	j	report_err
ct_bad_str_esc:
	addi	a0, zero, 57		# err 57: invalid string escape
	j	report_err

# ══════════════════════════════════════════════════════════════════════════════
# ct_kw_loop — compile a `loop { … }` expression.
#
# Entry: parse_ident already consumed "loop", s2 is past it. The compile_unary
# entry frame (12 bytes) is still on sp. `++`/`--`/deref prefixes are rejected
# (loop isn't a typical operand).
#
# Frame (144 bytes on top of compile_unary's 12):
#    0(sp): saved outer break_base (global)
#    4(sp): saved outer break_count (global)
#    8(sp): loop_start address (s5 at body start)
#   12..140(sp): break-list array, 32 × 4-byte absolute jal addrs
# ══════════════════════════════════════════════════════════════════════════════
ct_kw_loop:
	# Reject prefix ++/-- and deref combos against `loop`.
	lw	t0, 8(sp)		# incdec_kind (compile_unary frame +8 shifted? see below)
	# compile_unary frame layout at this point (no la_ct push yet):
	#   0(sp): saved gp, 4(sp): deref_kind, 8(sp): incdec_kind
	bnez	t0, ct_bad_literal_pp
	lw	t0, 4(sp)		# deref_kind
	bnez	t0, ct_bad_literal_pp

	addi	sp, sp, -144
	# Save outer loop context.
	lla	t0, break_base
	lw	t1, 0(t0)
	sw	t1, 0(sp)
	lla	t0, break_count
	lw	t1, 0(t0)
	sw	t1, 4(sp)
	lla	t0, loop_start
	lw	t1, 0(t0)
	sw	t1, 140(sp)		# saved outer loop_start (stash at end of frame)
	# Install new (empty) break list rooted at 12(sp).
	lla	t0, break_base
	addi	t1, sp, 12
	sw	t1, 0(t0)
	lla	t0, break_count
	sw	zero, 0(t0)

	# Expect '{' after "loop".
	addi	gp, zero, 32		# skip_ws site 32 = sw_ct_loop_lbrace
	j	skip_ws
sw_ct_loop_lbrace:
	bge	s2, s3, ct_bad_loop_lbrace
	lbu	t0, 0(s2)
	addi	t1, zero, '{'
	bne	t0, t1, ct_bad_loop_lbrace

	# Record loop_start = s5 (before we emit any body code).
	sw	s5, 8(sp)
	lla	t0, loop_start
	sw	s5, 0(t0)

	# Compile the body as a block primary. compile_expr_p with min_bp=0 will
	# see '{' next and dispatch into ct_lbrace, which parses the block.
	addi	t6, zero, 0
	addi	gp, zero, 26		# compile_expr site 26 = ce_ct_loop_body
	j	compile_expr_p
ce_ct_loop_body:
	# Body compiled; a0 holds the last expression's value (unused — loop only
	# produces a value via break). Emit a backward jal to loop_start.
	lui	a0, 0
	addi	a0, a0, 0x6F		# jal zero, 0 placeholder
	addi	gp, zero, 29		# emit_word site 29 = ew_ct_loop_back
	j	emit_word
ew_ct_loop_back:
	# Patch the jal we just emitted to target loop_start.
	addi	t5, s5, -4
	lw	t6, 8(sp)
	addi	gp, zero, 12		# patch_jtype site 12 = pjt_ct_loop_back
	j	patch_jtype
pjt_ct_loop_back:
	# All pending breaks jump here (loop exit = current s5). Walk the list.
ct_loop_patch_loop:
	lla	t0, break_count
	lw	t3, 0(t0)
	beqz	t3, ct_loop_patch_done
	addi	t3, t3, -1
	sw	t3, 0(t0)
	lla	t0, break_base
	lw	t4, 0(t0)
	slli	t1, t3, 2
	add	t4, t4, t1		# &base[--count]
	lw	t5, 0(t4)
	addi	t6, s5, 0
	addi	gp, zero, 13		# patch_jtype site 13 = pjt_ct_loop_break
	j	patch_jtype
pjt_ct_loop_break:
	j	ct_loop_patch_loop
ct_loop_patch_done:
	# Restore outer loop context.
	lw	t1, 0(sp)
	lla	t0, break_base
	sw	t1, 0(t0)
	lw	t1, 4(sp)
	lla	t0, break_count
	sw	t1, 0(t0)
	lw	t1, 140(sp)
	lla	t0, loop_start
	sw	t1, 0(t0)
	# Free frame, clear lv_kind, return via compile_unary exit.
	addi	sp, sp, 144
	lla	t0, lv_kind
	sw	zero, 0(t0)
	lla	t0, last_was_brace
	addi	t1, zero, 1
	sw	t1, 0(t0)
	j	ct_done

# ══════════════════════════════════════════════════════════════════════════════
# ct_kw_break — compile a `break` expression.
#
# Grammar:  'break' [value_expr]?
#
# If a value expression follows, it is compiled into a0; otherwise a0 is set
# to 0. Then a forward-jal placeholder is emitted and its address appended to
# the innermost loop's break list. At loop-exit patch time, the jal is
# redirected to the post-loop address.
#
# Errors:
#   30: break-list overflow (>32 breaks in one loop)
#   31: 'break' outside any loop
# ══════════════════════════════════════════════════════════════════════════════
ct_kw_break:
	# Must be inside a loop.
	lla	t0, break_base
	lw	t1, 0(t0)
	beqz	t1, ct_bad_break_outside

	# Peek: is there a value expression? Skip trailing whitespace first.
	addi	gp, zero, 33		# skip_ws site 33 = sw_ct_break_peek
	j	skip_ws
sw_ct_break_peek:
	bge	s2, s3, ct_break_no_val
	lbu	t0, 0(s2)
	addi	t1, zero, ';'
	beq	t0, t1, ct_break_no_val
	addi	t1, zero, '}'
	beq	t0, t1, ct_break_no_val
	addi	t1, zero, ')'
	beq	t0, t1, ct_break_no_val
	addi	t1, zero, ':'
	beq	t0, t1, ct_break_no_val
	# Compile value expression. min_bp=0 lets the whole thing parse, but
	# stops at ',' / ';' / ')' / '}' / ':' which aren't binary ops.
	addi	t6, zero, 0
	addi	gp, zero, 27		# compile_expr site 27 = ce_ct_break_val
	j	compile_expr_p
ce_ct_break_val:
	j	ct_break_emit_jal
ct_break_no_val:
	# Emit `addi a0, zero, 0` (word 0x00000513) as the break value.
	lui	a0, 0
	addi	a0, a0, 0x513
	addi	gp, zero, 31		# emit_word site 31 = ew_ct_break_li0
	j	emit_word
ew_ct_break_li0:
ct_break_emit_jal:
	# Overflow check against the 32-entry break list.
	lla	t0, break_count
	lw	t1, 0(t0)
	addi	t2, zero, 32
	bge	t1, t2, ct_bad_break_overflow
	# Emit placeholder jal zero, 0.
	lui	a0, 0
	addi	a0, a0, 0x6F
	addi	gp, zero, 30		# emit_word site 30 = ew_ct_break_jal
	j	emit_word
ew_ct_break_jal:
	# Record (s5 - 4) into break_base[break_count++].
	lla	t0, break_base
	lw	t2, 0(t0)
	lla	t0, break_count
	lw	t1, 0(t0)
	slli	t3, t1, 2
	add	t2, t2, t3
	addi	t4, s5, -4
	sw	t4, 0(t2)
	addi	t1, t1, 1
	sw	t1, 0(t0)
	# The break's "value" is unreachable at runtime (the jal took us to the
	# loop exit before any subsequent emission runs). lv_kind must be reset
	# so the Pratt loop doesn't misinterpret post-break code as an lvalue.
	lla	t0, lv_kind
	sw	zero, 0(t0)
	j	ct_done

# ══════════════════════════════════════════════════════════════════════════════
# ct_kw_continue — compile a `continue` expression.
#
# Emits an immediate backward `jal` to the current innermost loop's start
# (which is recorded in the `loop_start` global when the loop's body began).
# Unlike `break`, we don't need a patch list: loop_start is already known,
# so the jal is emitted and patched in one step.
#
# Error:
#   33: 'continue' outside any loop
# ══════════════════════════════════════════════════════════════════════════════
ct_kw_continue:
	lla	t0, break_base
	lw	t1, 0(t0)
	beqz	t1, ct_bad_continue_outside
	# Emit placeholder jal zero, 0.
	lui	a0, 0
	addi	a0, a0, 0x6F
	addi	gp, zero, 32		# emit_word site 32 = ew_ct_continue
	j	emit_word
ew_ct_continue:
	# Patch to target loop_start.
	addi	t5, s5, -4
	lla	t0, loop_start
	lw	t6, 0(t0)
	addi	gp, zero, 14		# patch_jtype site 14 = pjt_ct_continue
	j	patch_jtype
pjt_ct_continue:
	lla	t0, lv_kind
	sw	zero, 0(t0)
	j	ct_done

# ══════════════════════════════════════════════════════════════════════════════
# ct_struct_literal — compile `Name { v1, v2, v3 }` (positional) or
#   `Name { f1: v1, f2: v2 }` (named).
#
# Entry: s10/s11 = struct name, a0 = struct entry pointer (from lookup).
# Allocates sizeof(Name) = count*4 bytes on the current frame (bump s9),
# then zero-fills all fields, then parses and stores the specified ones.
# Returns: a0 = runtime pointer to the allocated block.
#
# Frame (24 bytes on top of compile_unary's 12):
#    0(sp): struct entry ptr
#    4(sp): block offset in frame
#    8(sp): field count
#   12(sp): positional-or-named flag (0 = positional, 1 = named)
#   16(sp): ident_start copy (for error positions)
#   20(sp): reserved
# ══════════════════════════════════════════════════════════════════════════════
ct_struct_literal:
	addi	sp, sp, -24
	sw	a0, 0(sp)
	lw	t0, 32(a0)		# field count
	sw	t0, 8(sp)

	# Reserve count*4 bytes on frame for the new block.
	slli	t1, t0, 2
	addi	t2, s9, 0
	sw	t2, 4(sp)
	add	s9, s9, t1

	# Snapshot expr_depth: the upcoming push of the runtime base address
	# goes into s[2 + entry_depth]. Each subsequent "reload base" emit
	# reads from that fixed s-reg instead of the memory stack.
	lla	t0, expr_depth
	lw	t0, 0(t0)
	sw	t0, 20(sp)

	# Consume '{'.
	addi	gp, zero, 60		# skip_ws site 60 = sw_ct_stl_lbrace
	j	skip_ws
sw_ct_stl_lbrace:
	lbu	t0, 0(s2)
	addi	t1, zero, '{'
	bne	t0, t1, ct_bad_stl_lbrace
	addi	s2, s2, 1

	# Emit: addi a0, fp, <block_offset>  (runtime a0 = block base addr)
	lw	t3, 4(sp)
	addi	t4, zero, 2047
	blt	t4, t3, ct_bad_stl_frame
	lui	a0, 0x40
	addi	a0, a0, 0x513
	andi	t3, t3, 0xFFF
	slli	t3, t3, 20
	or	a0, a0, t3
	addi	gp, zero, 79		# emit_word site 79 = ew_ct_stl_addi
	j	emit_word
ew_ct_stl_addi:

	# Push base (runtime) onto the program stack so we can load it
	# before each field store.
	addi	gp, zero, 27		# push site 27 = push_ct_stl
	j	emit_push_a0
push_ct_stl:

	# Zero all N fields: for i in 0..count, emit `lw t0, 0(sp);
	# sw zero, i*4(t0)`.
	# Compile-time loop over fields.
	sw	zero, 16(sp)		# index counter (reusing the slot)
ct_stl_zero_loop:
	lw	t0, 16(sp)
	lw	t1, 8(sp)
	beq	t0, t1, ct_stl_zero_done
	# Emit: `addi t0, s[2+entry_depth], 0` — base in compiled program's t0.
	#   opcode=0x13, rd=5(t0), f3=0, rs1=18+entry_depth, imm=0
	#   base = 0x13 | (5<<7) = 0x00000293
	lw	t2, 20(sp)		# entry_depth
	addi	t2, t2, 18
	slli	t2, t2, 15
	lui	a0, 0
	addi	a0, a0, 0x293
	or	a0, a0, t2
	addi	gp, zero, 80		# emit_word site 80 = ew_ct_stl_lw_base
	j	emit_word
ew_ct_stl_lw_base:
	# Emit: `sw zero, (i*4)(t0)`
	#   opcode=0x23, f3=2, rs1=5(t0), rs2=0(zero), imm=i*4
	#   imm S-type: imm[11:5] at bits 31..25, imm[4:0] at bits 11..7
	lw	t0, 16(sp)
	slli	t0, t0, 2		# byte offset
	andi	t1, t0, 0x1F
	slli	t1, t1, 7		# imm[4:0] bits
	srli	t2, t0, 5
	andi	t2, t2, 0x7F
	slli	t2, t2, 25		# imm[11:5] bits
	# base = opcode 0x23 | f3=2 << 12 | rs1=5 << 15
	#      = 0x23 | 0x2000 | 0x28000 = 0x2A023
	lui	a0, 0x2A
	addi	a0, a0, 0x023
	or	a0, a0, t1
	or	a0, a0, t2
	addi	gp, zero, 81		# emit_word site 81 = ew_ct_stl_sw_zero
	j	emit_word
ew_ct_stl_sw_zero:
	lw	t0, 16(sp)
	addi	t0, t0, 1
	sw	t0, 16(sp)
	j	ct_stl_zero_loop
ct_stl_zero_done:

	# Parse initializer entries. Empty `{}` is allowed (all zero).
	addi	gp, zero, 61		# skip_ws site 61 = sw_ct_stl_peek
	j	skip_ws
sw_ct_stl_peek:
	bge	s2, s3, ct_bad_stl_rbrace
	lbu	t0, 0(s2)
	addi	t1, zero, '}'
	beq	t0, t1, ct_stl_done
	# Decide positional vs named by a local peek: look past the first
	# token (ident or number/expr) for a ':'. For simplicity, we peek
	# for an ident followed by ':'. If found, named mode; else
	# positional.
	# Positional init: the first value is either an ident (NOT followed
	# by ':'), a digit, a char literal, a paren, etc.
	# Named init: an ident followed by ':'.
	#
	# Conservative rule: if s2[0] is a letter, scan past ident chars and
	# check if next non-ws is ':'. If yes → named; else → positional.
	addi	t1, zero, 'a'
	blt	t0, t1, ct_stl_pos_mode_chk_uc
	addi	t1, zero, 123
	blt	t0, t1, ct_stl_try_named
ct_stl_pos_mode_chk_uc:
	addi	t1, zero, 'A'
	blt	t0, t1, ct_stl_pos_mode
	addi	t1, zero, 91
	blt	t0, t1, ct_stl_try_named
ct_stl_pos_mode:
	sw	zero, 12(sp)		# flag = 0 (positional)
	j	ct_stl_parse_first
ct_stl_try_named:
	# Peek past the ident for a colon.
	addi	t2, s2, 0
ct_stl_pn_loop:
	bge	t2, s3, ct_stl_pos_mode
	lbu	t3, 0(t2)
	addi	t4, zero, 'a'
	blt	t3, t4, ct_stl_pn_chk_uc
	addi	t4, zero, 123
	blt	t3, t4, ct_stl_pn_next
ct_stl_pn_chk_uc:
	addi	t4, zero, 'A'
	blt	t3, t4, ct_stl_pn_chk_d
	addi	t4, zero, 91
	blt	t3, t4, ct_stl_pn_next
ct_stl_pn_chk_d:
	addi	t4, zero, '0'
	blt	t3, t4, ct_stl_pn_chk_us
	addi	t4, zero, 58
	blt	t3, t4, ct_stl_pn_next
ct_stl_pn_chk_us:
	addi	t4, zero, '_'
	beq	t3, t4, ct_stl_pn_next
	j	ct_stl_pn_done
ct_stl_pn_next:
	addi	t2, t2, 1
	j	ct_stl_pn_loop
ct_stl_pn_done:
	# skip ws
ct_stl_pn_ws:
	bge	t2, s3, ct_stl_pos_mode
	lbu	t3, 0(t2)
	addi	t4, zero, 33
	bge	t3, t4, ct_stl_pn_chk_colon
	addi	t2, t2, 1
	j	ct_stl_pn_ws
ct_stl_pn_chk_colon:
	addi	t4, zero, ':'
	bne	t3, t4, ct_stl_pos_mode
	addi	t0, zero, 1
	sw	t0, 12(sp)		# flag = 1 (named)
ct_stl_parse_first:
	# Iterate: reset the positional index at 16(sp).
	sw	zero, 16(sp)
ct_stl_parse_loop:
	addi	gp, zero, 62		# skip_ws site 62 = sw_ct_stl_elem
	j	skip_ws
sw_ct_stl_elem:
	bge	s2, s3, ct_bad_stl_rbrace
	lbu	t0, 0(s2)
	addi	t1, zero, '}'
	beq	t0, t1, ct_stl_done
	# After the first element we expect ',' to separate.
	lw	t2, 16(sp)
	beqz	t2, ct_stl_elem_body
	addi	t1, zero, ','
	bne	t0, t1, ct_bad_stl_rbrace
	addi	s2, s2, 1
	addi	gp, zero, 63		# skip_ws site 63 = sw_ct_stl_after_comma
	j	skip_ws
sw_ct_stl_after_comma:
	bge	s2, s3, ct_bad_stl_rbrace
	lbu	t0, 0(s2)
	addi	t1, zero, '}'
	beq	t0, t1, ct_stl_done
ct_stl_elem_body:
	# If in named mode, parse `name:` prefix.
	lw	t2, 12(sp)
	beqz	t2, ct_stl_elem_val_pos
	# Named: parse ident, expect ':', look up field index.
	addi	gp, zero, 12		# parse_ident site 12 = pi_ct_stl_field
	j	parse_ident
pi_ct_stl_field:
	beqz	s11, ct_bad_stl_field
	lw	a0, 0(sp)		# struct entry ptr
	addi	gp, zero, 1		# struct_field_lookup site 1 = sfl_ret_literal
	j	struct_field_lookup
sfl_ret_literal:
	addi	t0, zero, -1
	beq	a0, t0, ct_bad_stl_field
	# Field index in a0. Store temporarily in 16(sp) (it's the working
	# index slot anyway, we'll overwrite).
	sw	a0, 16(sp)
	addi	gp, zero, 64		# skip_ws site 64 = sw_ct_stl_colon
	j	skip_ws
sw_ct_stl_colon:
	lbu	t0, 0(s2)
	addi	t1, zero, ':'
	bne	t0, t1, ct_bad_stl_field
	addi	s2, s2, 1
	j	ct_stl_emit_value
ct_stl_elem_val_pos:
	# Positional: use the current index at 16(sp). Bounds check against
	# field count.
	lw	t0, 16(sp)
	lw	t1, 8(sp)
	bge	t0, t1, ct_bad_stl_too_many
ct_stl_emit_value:
	# Compile the value expression (min_bp = 0 stops at ',' / '}').
	addi	t6, zero, 0
	addi	gp, zero, 36		# compile_expr site 36 = ce_ct_stl_val
	j	compile_expr_p
ce_ct_stl_val:
	# Emit `addi t0, s[2+entry_depth], 0` — reload base into t0.
	lw	t2, 20(sp)
	addi	t2, t2, 18
	slli	t2, t2, 15
	lui	a0, 0
	addi	a0, a0, 0x293
	or	a0, a0, t2
	addi	gp, zero, 82		# emit_word site 82 = ew_ct_stl_lw_base2
	j	emit_word
ew_ct_stl_lw_base2:
	# Emit `sw a0, (idx*4)(t0)` to store the field value.
	lw	t0, 16(sp)
	slli	t0, t0, 2
	andi	t1, t0, 0x1F
	slli	t1, t1, 7
	srli	t2, t0, 5
	andi	t2, t2, 0x7F
	slli	t2, t2, 25
	# sw a0, 0(t0): opcode 0x23 | f3=2 | rs1=5 | rs2=10
	#   = 0x23 | 0x2000 | 0x28000 | 0xA00000 = 0x00A2A023
	lui	a0, 0xA2A
	addi	a0, a0, 0x023
	or	a0, a0, t1
	or	a0, a0, t2
	addi	gp, zero, 83		# emit_word site 83 = ew_ct_stl_sw_val
	j	emit_word
ew_ct_stl_sw_val:
	# Advance the index (positional) or reset it (named, the next ident
	# will overwrite). For positional, next element uses next slot. For
	# named, next element sets its own slot.
	lw	t2, 12(sp)
	bnez	t2, ct_stl_next_named
	lw	t0, 16(sp)
	addi	t0, t0, 1
	sw	t0, 16(sp)
	j	ct_stl_parse_loop
ct_stl_next_named:
	# Leave 16(sp) as-is — the next iteration will overwrite it when
	# parsing the next field name. But we need the loop-entry check
	# (which uses 16(sp) as "is-first flag") to see non-zero. So store
	# 1 there.
	addi	t0, zero, 1
	sw	t0, 16(sp)
	j	ct_stl_parse_loop

ct_stl_done:
	addi	s2, s2, 1		# consume '}'
	# Emit `addi a0, s[2+entry_depth], 0` — get base into a0 as the
	# literal's result. No sp adjust; we instead decrement expr_depth
	# to release the saved s-reg slot.
	lw	t2, 20(sp)
	addi	t2, t2, 18
	slli	t2, t2, 15
	lui	a0, 0
	addi	a0, a0, 0x513		# 0x13 | (10<<7) = base for `addi a0,...,0`
	or	a0, a0, t2
	addi	gp, zero, 85		# emit_word site 85 = ew_ct_stl_pop_a0
	j	emit_word
ew_ct_stl_pop_a0:
	# Release the s-reg slot the base was saved in.
	lla	t0, expr_depth
	lw	t1, 0(t0)
	addi	t1, t1, -1
	sw	t1, 0(t0)
	addi	sp, sp, 24
	lla	t0, lv_kind
	sw	zero, 0(t0)
	j	ct_done

# ══════════════════════════════════════════════════════════════════════════════
# ct_struct_access — compile `Name@x.field` or `Name@x[LIT].field`.
#
# Entry: s10/s11 = struct name, a0 = struct entry pointer.
# Emits: load pointer var x → a0, optional index offset, then
#   `lw a0, field_offset(a0)` to read the field. Sets lv_kind = 3 so
# the cep_pre_assign path handles writes via peephole store.
# ══════════════════════════════════════════════════════════════════════════════
ct_struct_access:
	addi	sp, sp, -12
	sw	a0, 0(sp)		# struct entry ptr
	addi	s2, s2, 1		# consume '@'
	addi	gp, zero, 65		# skip_ws site 65 = sw_ct_sa_ptr
	j	skip_ws
sw_ct_sa_ptr:
	# Parse pointer ident.
	addi	gp, zero, 13		# parse_ident site 13 = pi_ct_sa_ptr
	j	parse_ident
pi_ct_sa_ptr:
	beqz	s11, ct_bad_sa_ptr
	addi	gp, zero, 7		# lookup site 7 = la_ct_sa
	j	lookup
la_ct_sa:
	# Save mutability flag before sub-expressions overwrite last_ident_entry.
	lla	t0, last_ident_entry
	lw	t0, 0(t0)
	lbu	t0, 37(t0)
	sw	t0, 8(sp)
	# a0 = slot offset of ptr var. Emit `lw a0, off(fp)`.
	addi	gp, zero, 16		# elws site 16 = elws_ct_sa
	j	emit_lw_sp
elws_ct_sa:
	# Peek for '[LIT]' or '.field'.
	addi	gp, zero, 66		# skip_ws site 66 = sw_ct_sa_peek
	j	skip_ws
sw_ct_sa_peek:
	lbu	t0, 0(s2)
	addi	t1, zero, '['
	beq	t0, t1, ct_sa_idx
	addi	t1, zero, '.'
	beq	t0, t1, ct_sa_dot
	j	ct_bad_sa_dot
ct_sa_idx:
	# Runtime index: push base, compile index expression, scale by
	# sizeof, pop base, add. For power-of-2 sizeofs we emit a single
	# slli; for other sizes we fall back to the general emit_mul.
	addi	s2, s2, 1		# consume '['
	# Push base (runtime a0 has it from `lw a0, var(fp)`).
	addi	gp, zero, 28		# push site 28 = push_ct_sa_base
	j	emit_push_a0
push_ct_sa_base:
	# Compile index expression.
	addi	t6, zero, 0
	addi	gp, zero, 37		# compile_expr site 37 = ce_ct_sa_idx
	j	compile_expr_p
ce_ct_sa_idx:
	# Expect ']'.
	addi	gp, zero, 68		# skip_ws site 68 = sw_ct_sa_rbrack
	j	skip_ws
sw_ct_sa_rbrack:
	lbu	t0, 0(s2)
	addi	t1, zero, ']'
	bne	t0, t1, ct_bad_sa_rbrack
	addi	s2, s2, 1
	# Compute sizeof = field count * 4. Save for emitting later.
	lw	t0, 0(sp)		# struct entry ptr
	lw	t1, 32(t0)
	slli	t1, t1, 2
	sw	t1, 4(sp)		# saved sizeof
	# Is sizeof a power of 2? (sizeof & (sizeof - 1) == 0)
	addi	t2, t1, -1
	and	t3, t1, t2
	bnez	t3, ct_sa_scale_mul
	# Power of 2: compute log2 and emit slli.
	addi	t4, t1, 0
	addi	t2, zero, 0
ct_sa_log2_loop:
	addi	t5, zero, 1
	beq	t4, t5, ct_sa_log2_done
	srli	t4, t4, 1
	addi	t2, t2, 1
	j	ct_sa_log2_loop
ct_sa_log2_done:
	beqz	t2, ct_sa_scale_done
	# Emit `slli a0, a0, t2`. Word 0x00051513 | (shamt << 20).
	andi	t3, t2, 0x1F
	slli	t3, t3, 20
	lui	a0, 0x51
	addi	a0, a0, 0x513
	or	a0, a0, t3
	addi	gp, zero, 88		# emit_word site 88 = ew_ct_sa_slli
	j	emit_word
ew_ct_sa_slli:
	j	ct_sa_scale_done
ct_sa_scale_mul:
	# Non-power-of-2: push index, load sizeof as a literal, pop index
	# into t0, call emit_mul (t0=lhs, a0=rhs → a0=lhs*rhs).
	addi	gp, zero, 29		# push site 29 = push_ct_sa_idx_val
	j	emit_push_a0
push_ct_sa_idx_val:
	lw	t1, 4(sp)		# sizeof
	andi	t2, t1, 0xFFF
	slli	t2, t2, 20
	lui	a0, 0
	addi	a0, a0, 0x513
	or	a0, a0, t2
	addi	gp, zero, 89		# emit_word site 89 = ew_ct_sa_li_sizeof
	j	emit_word
ew_ct_sa_li_sizeof:
	addi	gp, zero, 29		# pop site 29 = pop_ct_sa_idx_val
	j	emit_pop_t0
pop_ct_sa_idx_val:
	addi	gp, zero, 3		# emul site 3 = emul_ct_sa
	j	emit_mul
emul_ct_sa:
ct_sa_scale_done:
	# Pop base → t0, add a0 = base + i*sizeof.
	addi	gp, zero, 30		# pop site 30 = pop_ct_sa_base
	j	emit_pop_t0
pop_ct_sa_base:
	addi	gp, zero, 4		# ea site 4 = ea_ct_sa
	j	emit_add
ea_ct_sa:
	# Expect '.' next.
	addi	gp, zero, 69		# skip_ws site 69 = sw_ct_sa_dot
	j	skip_ws
sw_ct_sa_dot:
	lbu	t0, 0(s2)
	addi	t1, zero, '.'
	bne	t0, t1, ct_bad_sa_dot
	addi	s2, s2, 1
	# Index offset is now 0 at compile time — the runtime address in
	# a0 already includes the i*sizeof contribution.
	sw	zero, 4(sp)
	j	ct_sa_parse_field
ct_sa_dot:
	# No '[i]' — index offset is 0, a0 already holds base.
	sw	zero, 4(sp)
	addi	s2, s2, 1		# consume '.'
ct_sa_parse_field:
	# Parse field name ident.
	addi	gp, zero, 70		# skip_ws site 70 = sw_ct_sa_field
	j	skip_ws
sw_ct_sa_field:
	addi	gp, zero, 14		# parse_ident site 14 = pi_ct_sa_field
	j	parse_ident
pi_ct_sa_field:
	beqz	s11, ct_bad_sa_field
	lw	a0, 0(sp)		# struct entry ptr
	addi	gp, zero, 0		# struct_field_lookup site 0 = sfl_ret_access
	j	struct_field_lookup
sfl_ret_access:
	addi	t0, zero, -1
	beq	a0, t0, ct_bad_sa_field
	# Total offset = (index offset saved at 4(sp)) + (field index * 4)
	slli	a0, a0, 2
	lw	t0, 4(sp)
	add	a0, a0, t0
	addi	t1, zero, 2047
	blt	t1, a0, ct_bad_sa_offset
	# If offset != 0, emit `addi a0, a0, offset` so runtime a0 = base +
	# offset before the load. We need this because cep_pre_assign un-
	# emits the last instruction on write, and the store must go to the
	# correct address. For offset == 0, skip the addi entirely.
	beqz	a0, ct_sa_no_addi
	# Word = 0x00050513 | (offset << 20), where 0x00050513 = addi a0, a0, 0
	andi	t2, a0, 0xFFF
	slli	t2, t2, 20
	lui	a0, 0x50
	addi	a0, a0, 0x513
	or	a0, a0, t2
	addi	gp, zero, 87		# emit_word site 87 = ew_ct_sa_addi
	j	emit_word
ew_ct_sa_addi:
ct_sa_no_addi:
	# Peek for another '.': if found, this is an intermediate pointer
	# dereference in a chain like `Outer@x.inner.field`. Emit an lw
	# (non-lvalue, can't be un-emitted) and loop back to parse the
	# next field name using the SAME struct type.
	addi	t3, s2, 0
ct_sa_chain_ws:
	bge	t3, s3, ct_sa_final_lw
	lbu	t0, 0(t3)
	addi	t1, zero, 33
	bge	t0, t1, ct_sa_chain_peek
	addi	t3, t3, 1
	j	ct_sa_chain_ws
ct_sa_chain_peek:
	addi	t1, zero, '.'
	bne	t0, t1, ct_sa_final_lw
	# Another '.' follows — intermediate dereference.
	addi	s2, t3, 1		# consume '.'
	# Emit lw a0, 0(a0) — runtime loads the intermediate pointer.
	lui	a0, 0x52
	addi	a0, a0, 0x503
	addi	gp, zero, 90		# emit_word site 90 = ew_ct_sa_chain_lw
	j	emit_word
ew_ct_sa_chain_lw:
	# Clear index offset and loop back to parse the next field.
	sw	zero, 4(sp)
	j	ct_sa_parse_field

ct_sa_final_lw:
	# This is the LAST field in the chain. Emit `lw a0, 0(a0)` and
	# set lv_kind = 3 so cep_pre_assign can peephole it for writes.
	lui	a0, 0x52
	addi	a0, a0, 0x503
	addi	gp, zero, 84		# emit_word site 84 = ew_ct_sa_lw
	j	emit_word
ew_ct_sa_lw:
	# Check saved mutability flag: 0 = immutable → lv_kind = 0 (read-only).
	lw	t1, 8(sp)
	addi	sp, sp, 12
	lla	t0, lv_kind
	beqz	t1, ct_sa_immut
	addi	t1, zero, 3
	sw	t1, 0(t0)
	j	ct_done
ct_sa_immut:
	sw	zero, 0(t0)
	j	ct_done

ct_bad_struct_use:
	addi	a0, zero, 49		# err 49: struct used outside literal/access
	j	report_err
ct_bad_stl_lbrace:
	addi	a0, zero, 9		# err 9: expected '{'
	j	report_err
ct_bad_stl_rbrace:
	addi	a0, zero, 48		# err 48: expected ',' or '}'
	j	report_err
ct_bad_stl_field:
	addi	a0, zero, 50		# err 50: unknown field name
	j	report_err
ct_bad_stl_too_many:
	addi	a0, zero, 51		# err 51: too many initializers
	j	report_err
ct_bad_stl_frame:
	addi	a0, zero, 40		# err 40: frame too large
	j	report_err
ct_bad_sa_ptr:
	addi	a0, zero, 6		# err 6: expected identifier
	j	report_err
ct_bad_sa_dot:
	addi	a0, zero, 52		# err 52: expected '.'
	j	report_err
ct_bad_sa_lit:
	addi	a0, zero, 46		# err 46: array size must be a literal
	j	report_err
ct_bad_sa_rbrack:
	addi	a0, zero, 44		# err 44: expected ']'
	j	report_err
ct_bad_sa_field:
	addi	a0, zero, 50		# err 50: unknown field name
	j	report_err
ct_bad_sa_offset:
	addi	a0, zero, 40		# err 40: frame too large (offset overflow)
	j	report_err

# ══════════════════════════════════════════════════════════════════════════════
# ct_kw_sizeof — compile a `sizeof(StructName)` expression.
#
# Returns a compile-time integer literal: the struct's instance size in
# bytes (= field count × 4). Only struct types are supported in v1;
# primitives already have implicit stride via the @/#/* prefixes.
# ══════════════════════════════════════════════════════════════════════════════
ct_kw_sizeof:
	# Expect '('.
	addi	gp, zero, 71		# skip_ws site 71 = sw_ct_so_lparen
	j	skip_ws
sw_ct_so_lparen:
	bge	s2, s3, ct_bad_so_lparen
	lbu	t0, 0(s2)
	addi	t1, zero, '('
	bne	t0, t1, ct_bad_so_lparen
	addi	s2, s2, 1
	# Parse struct name ident.
	addi	gp, zero, 72		# skip_ws site 72 = sw_ct_so_name
	j	skip_ws
sw_ct_so_name:
	bge	s2, s3, ct_bad_so_name
	lbu	t0, 0(s2)
	addi	t1, zero, '_'
	beq	t0, t1, ct_so_name_ok
	addi	t1, zero, 'a'
	blt	t0, t1, ct_so_name_chk_uc
	addi	t1, zero, 123
	blt	t0, t1, ct_so_name_ok
ct_so_name_chk_uc:
	addi	t1, zero, 'A'
	blt	t0, t1, ct_bad_so_name
	addi	t1, zero, 91
	bge	t0, t1, ct_bad_so_name
ct_so_name_ok:
	addi	gp, zero, 15		# parse_ident site 15 = pi_ct_so
	j	parse_ident
pi_ct_so:
	# Look up struct type.
	addi	gp, zero, 3		# struct_lookup site 3 = stlk_ret_so
	j	struct_lookup
stlk_ret_so:
	beqz	a0, ct_bad_so_unknown
	# a0 = struct entry ptr. size = count * 4.
	lw	t0, 32(a0)		# field count
	slli	t0, t0, 2		# * 4
	# Expect ')'.
	addi	gp, zero, 73		# skip_ws site 73 = sw_ct_so_rparen
	# Stash size across skip_ws — use famc stack.
	addi	sp, sp, -4
	sw	t0, 0(sp)
	j	skip_ws
sw_ct_so_rparen:
	bge	s2, s3, ct_bad_so_rparen
	lbu	t0, 0(s2)
	addi	t1, zero, ')'
	bne	t0, t1, ct_bad_so_rparen
	addi	s2, s2, 1
	# Emit `li a0, size` via emit_li.
	lw	a0, 0(sp)
	addi	sp, sp, 4
	addi	gp, zero, 0		# eli site 0 = eli_ret
	j	emit_li
	# emit_li falls through to eli_ret → ct_deref → ct_done. Since we
	# have no prefix (deref_kind = 0 at compile_unary entry, still 0),
	# ct_deref sees kind 0 and jumps to ct_done.
	# lv_kind stays 0 (sizeof result is not an lvalue).

ct_bad_so_lparen:
	addi	a0, zero, 12		# err 12: expected '('
	j	report_err
ct_bad_so_name:
	addi	a0, zero, 6		# err 6: expected identifier
	j	report_err
ct_bad_so_unknown:
	lla	t0, ident_start
	lw	s2, 0(t0)
	addi	a0, zero, 53		# err 53: sizeof of non-struct
	j	report_err
ct_bad_so_rparen:
	addi	a0, zero, 2		# err 2: expected ')'
	j	report_err

# ══════════════════════════════════════════════════════════════════════════════
# ct_kw_for — compile a `for IDENT in LOWER..UPPER { BODY }` expression.
#
# Desugars to (roughly):
#
#     x = LOWER - 1;
#     hi = UPPER;
#     last = 0;
#     loop {
#         x += 1;
#         (x < hi) or (x <= hi) ? 0 : break last;    # cond-fail returns last
#         last = { BODY };                           # save each iter's value
#     }
#
# The pre-decrement of LOWER ("x = LOWER - 1") lets `continue` correctly
# re-enter at the increment: it jumps to loop_start (the start of the
# `x += 1` sequence), bumps x, and re-checks the bound — same as normal
# fall-through. The loop's result is whatever `last` held at the final
# successful iteration (or 0 if the range was empty), unless a user
# `break v` fires, in which case v wins.
#
# The condition-fail exit is emitted as an inline `break last` (the jal is
# added to the loop's break list), so it shares the break-patch machinery.
# User `break v` just jumps to the same exit with v preloaded in a0.
#
# Scoping: the loop variable shadows any outer binding of the same name.
# We save s8 on entry and force-allocate a fresh symtab entry via
# `j la_new`. On exit, s8 is restored, forgetting the inner binding.
#
# Frame (192 bytes on top of compile_unary's 12-byte frame):
#     0..128: break list (32 × 4 bytes)
#   128..132: saved outer break_base
#   132..136: saved outer break_count
#   136..140: saved outer loop_start
#   140..144: saved outer s8
#   144..148: x_slot offset (compiled-program frame)
#   148..152: hi_slot offset
#   152..156: last_slot offset
#   156..160: inclusive flag (0 = '..', 1 = '..=')
# ══════════════════════════════════════════════════════════════════════════════
ct_kw_for:
	# Reject prefix ++/-- / deref combinations against `for`.
	lw	t0, 8(sp)
	bnez	t0, ct_bad_literal_pp
	lw	t0, 4(sp)
	bnez	t0, ct_bad_literal_pp

	addi	sp, sp, -192
	# Save outer loop/scope context.
	lla	t0, break_base
	lw	t1, 0(t0)
	sw	t1, 128(sp)
	lla	t0, break_count
	lw	t1, 0(t0)
	sw	t1, 132(sp)
	lla	t0, loop_start
	lw	t1, 0(t0)
	sw	t1, 136(sp)
	sw	s8, 140(sp)

	# Skip ws, parse the loop-variable identifier.
	addi	gp, zero, 35		# skip_ws site 35 = sw_ct_for_name
	j	skip_ws
sw_ct_for_name:
	# Stash s2 so any subsequent parse error points at the token start
	# (rather than somewhere past it after parse_ident consumed chars).
	sw	s2, 160(sp)
	bge	s2, s3, ct_bad_for_name
	# First char must be a letter or underscore. parse_ident accepts
	# digit chars too (it's a looser scanner), so we pre-check here.
	lbu	t0, 0(s2)
	addi	t1, zero, '_'
	beq	t0, t1, ct_for_name_start_ok
	addi	t1, zero, 'a'
	blt	t0, t1, ct_for_name_chk_uc
	addi	t1, zero, 123
	blt	t0, t1, ct_for_name_start_ok
ct_for_name_chk_uc:
	addi	t1, zero, 'A'
	blt	t0, t1, ct_bad_for_name
	addi	t1, zero, 91
	bge	t0, t1, ct_bad_for_name
ct_for_name_start_ok:
	addi	gp, zero, 4		# parse_ident site 4 = pi_ct_for_name
	j	parse_ident
pi_ct_for_name:
	beqz	s11, ct_bad_for_name
	# Reject keywords as the loop variable name (loop, break, continue,
	# for, in). Only 2/3-char matches and 4/5/8-char matches needed.
	addi	t0, zero, 2
	beq	s11, t0, ct_for_chk_in
	addi	t0, zero, 3
	beq	s11, t0, ct_for_chk_for
	addi	t0, zero, 4
	beq	s11, t0, ct_for_chk_loop
	addi	t0, zero, 5
	beq	s11, t0, ct_for_chk_break
	addi	t0, zero, 8
	beq	s11, t0, ct_for_chk_cont
	j	ct_for_name_ok
ct_for_chk_in:
	lbu	t1, 0(s10)
	addi	t2, zero, 'i'
	bne	t1, t2, ct_for_name_ok
	lbu	t1, 1(s10)
	addi	t2, zero, 'n'
	bne	t1, t2, ct_for_name_ok
	j	ct_bad_for_name
ct_for_chk_for:
	lbu	t1, 0(s10)
	addi	t2, zero, 'f'
	bne	t1, t2, ct_for_name_ok
	lbu	t1, 1(s10)
	addi	t2, zero, 'o'
	bne	t1, t2, ct_for_name_ok
	lbu	t1, 2(s10)
	addi	t2, zero, 'r'
	bne	t1, t2, ct_for_name_ok
	j	ct_bad_for_name
ct_for_chk_loop:
	lbu	t1, 0(s10)
	addi	t2, zero, 'l'
	bne	t1, t2, ct_for_name_ok
	lbu	t1, 1(s10)
	addi	t2, zero, 'o'
	bne	t1, t2, ct_for_name_ok
	lbu	t1, 2(s10)
	bne	t1, t2, ct_for_name_ok
	lbu	t1, 3(s10)
	addi	t2, zero, 'p'
	bne	t1, t2, ct_for_name_ok
	j	ct_bad_for_name
ct_for_chk_break:
	lbu	t1, 0(s10)
	addi	t2, zero, 'b'
	bne	t1, t2, ct_for_name_ok
	lbu	t1, 1(s10)
	addi	t2, zero, 'r'
	bne	t1, t2, ct_for_name_ok
	lbu	t1, 2(s10)
	addi	t2, zero, 'e'
	bne	t1, t2, ct_for_name_ok
	lbu	t1, 3(s10)
	addi	t2, zero, 'a'
	bne	t1, t2, ct_for_name_ok
	lbu	t1, 4(s10)
	addi	t2, zero, 'k'
	bne	t1, t2, ct_for_name_ok
	j	ct_bad_for_name
ct_for_chk_cont:
	lbu	t1, 0(s10)
	addi	t2, zero, 'c'
	bne	t1, t2, ct_for_name_ok
	lbu	t1, 1(s10)
	addi	t2, zero, 'o'
	bne	t1, t2, ct_for_name_ok
	lbu	t1, 2(s10)
	addi	t2, zero, 'n'
	bne	t1, t2, ct_for_name_ok
	lbu	t1, 3(s10)
	addi	t2, zero, 't'
	bne	t1, t2, ct_for_name_ok
	lbu	t1, 4(s10)
	addi	t2, zero, 'i'
	bne	t1, t2, ct_for_name_ok
	lbu	t1, 5(s10)
	addi	t2, zero, 'n'
	bne	t1, t2, ct_for_name_ok
	lbu	t1, 6(s10)
	addi	t2, zero, 'u'
	bne	t1, t2, ct_for_name_ok
	lbu	t1, 7(s10)
	addi	t2, zero, 'e'
	bne	t1, t2, ct_for_name_ok
	j	ct_bad_for_name
ct_for_name_ok:
	# Force-allocate a fresh symtab entry (shadowing any outer binding).
	addi	gp, zero, 4		# lookup_or_alloc site 4 = la_ct_for
	j	la_new
la_ct_for:
	# For-loop variable is always mutable (the loop increments it).
	lla	t0, last_ident_entry
	lw	t1, 0(t0)
	addi	t2, zero, 1
	sb	t2, 37(t1)
	sw	a0, 144(sp)		# x_slot = newly-allocated offset

	# Allocate two hidden slots (hi, last) by bumping s9 directly.
	addi	t0, s9, 0
	sw	t0, 148(sp)
	addi	s9, s9, 4
	addi	t0, s9, 0
	sw	t0, 152(sp)
	addi	s9, s9, 4

	# Skip ws, expect the 'in' keyword.
	addi	gp, zero, 36		# skip_ws site 36 = sw_ct_for_in
	j	skip_ws
sw_ct_for_in:
	sw	s2, 160(sp)		# stash token start for error reporting
	bge	s2, s3, ct_bad_for_in
	# The 'in' keyword must start with a letter — pre-check before
	# calling parse_ident, which would otherwise accept digits.
	lbu	t0, 0(s2)
	addi	t1, zero, 'a'
	blt	t0, t1, ct_bad_for_in
	addi	t1, zero, 123
	bge	t0, t1, ct_bad_for_in
	addi	gp, zero, 5		# parse_ident site 5 = pi_ct_for_in
	j	parse_ident
pi_ct_for_in:
	addi	t0, zero, 2
	bne	s11, t0, ct_bad_for_in
	lbu	t1, 0(s10)
	addi	t2, zero, 'i'
	bne	t1, t2, ct_bad_for_in
	lbu	t1, 1(s10)
	addi	t2, zero, 'n'
	bne	t1, t2, ct_bad_for_in

	# Compile LOWER expression. min_bp = 0 stops at '.' (not a binop).
	addi	t6, zero, 0
	addi	gp, zero, 29		# compile_expr site 29 = ce_ct_for_low
	j	compile_expr_p
ce_ct_for_low:
	# Runtime: a0 = LOWER. Emit `addi a0, a0, -1` so the upcoming loop's
	# increment brings x to LOWER on the first iteration.
	addi	gp, zero, 4		# eaam1 site 4 = eaam1_ct_for_low
	j	emit_addi_a0_m1
eaam1_ct_for_low:
	# Emit `sw a0, x_slot(fp)` — store initial x = LOWER - 1.
	lw	a0, 144(sp)
	addi	gp, zero, 19		# esws site 19 = esws_ct_for_x_init
	j	emit_sw_sp
esws_ct_for_x_init:

	# Expect '..' and optional '='.
	addi	gp, zero, 37		# skip_ws site 37 = sw_ct_for_dotdot
	j	skip_ws
sw_ct_for_dotdot:
	bge	s2, s3, ct_bad_for_range
	lbu	t0, 0(s2)
	addi	t1, zero, '.'
	bne	t0, t1, ct_bad_for_range
	addi	t2, s2, 1
	bge	t2, s3, ct_bad_for_range
	lbu	t0, 0(t2)
	bne	t0, t1, ct_bad_for_range
	addi	s2, s2, 2
	# Check for optional '=' → inclusive range.
	sw	zero, 156(sp)
	bge	s2, s3, ct_for_upper
	lbu	t0, 0(s2)
	addi	t1, zero, '='
	bne	t0, t1, ct_for_upper
	addi	s2, s2, 1
	addi	t0, zero, 1
	sw	t0, 156(sp)
ct_for_upper:
	# Compile UPPER expression.
	addi	t6, zero, 0
	addi	gp, zero, 30		# compile_expr site 30 = ce_ct_for_high
	j	compile_expr_p
ce_ct_for_high:
	# Emit `sw a0, hi_slot(fp)`.
	lw	a0, 148(sp)
	addi	gp, zero, 20		# esws site 20 = esws_ct_for_hi
	j	emit_sw_sp
esws_ct_for_hi:
	# Emit `addi a0, zero, 0` (word 0x00000513) to initialize last = 0.
	lui	a0, 0
	addi	a0, a0, 0x513
	addi	gp, zero, 33		# emit_word site 33 = ew_ct_for_last_init
	j	emit_word
ew_ct_for_last_init:
	# Emit `sw a0, last_slot(fp)`.
	lw	a0, 152(sp)
	addi	gp, zero, 21		# esws site 21 = esws_ct_for_last_init
	j	emit_sw_sp
esws_ct_for_last_init:

	# Install new (empty) break list; loop_start = start of the increment.
	lla	t0, break_base
	addi	t1, sp, 0
	sw	t1, 0(t0)
	lla	t0, break_count
	sw	zero, 0(t0)
	lla	t0, loop_start
	sw	s5, 0(t0)

	# Emit: lw a0, x_slot(fp)   (load x for increment).
	lw	a0, 144(sp)
	addi	gp, zero, 13		# elws site 13 = elws_ct_for_inc_load
	j	emit_lw_sp
elws_ct_for_inc_load:
	addi	gp, zero, 4		# eaa1 site 4 = eaa1_ct_for_inc
	j	emit_addi_a0_1
eaa1_ct_for_inc:
	lw	a0, 144(sp)
	addi	gp, zero, 22		# esws site 22 = esws_ct_for_x_inc
	j	emit_sw_sp
esws_ct_for_x_inc:
	# Save incremented x on the runtime stack, load hi, pop x → t0.
	addi	gp, zero, 23		# push site 23 = push_ct_for_cond
	j	emit_push_a0
push_ct_for_cond:
	lw	a0, 148(sp)
	addi	gp, zero, 14		# elws site 14 = elws_ct_for_hi_load
	j	emit_lw_sp
elws_ct_for_hi_load:
	addi	gp, zero, 23		# pop site 23 = pop_ct_for_cond
	j	emit_pop_t0
pop_ct_for_cond:
	# emit_pop_t0 didn't materialize the popped value into t0 — for the
	# comparison sequence below we still need it there, so emit
	# `addi t0, sN, 0` directly to s5.
	addi	t2, s5, 4
	lla	t3, bin_end
	lw	t3, 0(t3)
	bgeu	t2, t3, bin_full
	lla	t0, popped_src_reg
	lw	t0, 0(t0)
	slli	t0, t0, 15
	lui	a0, 0
	addi	a0, a0, 0x293
	or	a0, a0, t0
	sw	a0, 0(s5)
	addi	s5, s5, 4
	# t0 = x, a0 = hi. Emit comparison:
	#   exclusive:  slt a0, t0, a0             (a0 = x < hi)
	#   inclusive:  slt a0, a0, t0 ; xori a0,a0,1  (a0 = !(hi < x) = x <= hi)
	lw	t5, 156(sp)
	bnez	t5, ct_for_cmp_inclusive
	# Exclusive: slt a0, t0, a0  →  word 0x00A2A533
	lui	a0, 0xA2A
	addi	a0, a0, 0x533
	addi	gp, zero, 34		# emit_word site 34 = ew_ct_for_slt_lt
	j	emit_word
ew_ct_for_slt_lt:
	j	ct_for_cmp_done
ct_for_cmp_inclusive:
	# slt a0, a0, t0  →  word 0x00552533
	lui	a0, 0x552
	addi	a0, a0, 0x533
	addi	gp, zero, 35		# emit_word site 35 = ew_ct_for_slt_le1
	j	emit_word
ew_ct_for_slt_le1:
	# xori a0, a0, 1  →  word 0x00154513
	lui	a0, 0x154
	addi	a0, a0, 0x513
	addi	gp, zero, 36		# emit_word site 36 = ew_ct_for_slt_le2
	j	emit_word
ew_ct_for_slt_le2:
ct_for_cmp_done:
	# Emit `bne a0, zero, +12` — skip the 2-instruction "break last"
	# sequence (lw + jal) when the condition is true.
	#   imm = 12 (skip bne + lw + jal = 3 insns, so branch target = bne+12)
	#   encoding: imm[12|10:5] bits 31..25, imm[4:1|11] bits 11..7
	#   12 = 0b1100, imm[4:1] = 0110 = 6, imm[11]=0, imm[10:5]=0, imm[12]=0
	#   bits 11..8 = 0110 = 0x600, bit 7 = 0
	#   word = 0x63 | (1<<12) | (10<<15) | (0<<20) | 0x600
	#        = 0x00051663
	lui	a0, 0x51
	addi	a0, a0, 0x663
	addi	gp, zero, 37		# emit_word site 37 = ew_ct_for_bne
	j	emit_word
ew_ct_for_bne:
	# Emit the "break last" sequence: load last_slot then forward-jal.
	lw	a0, 152(sp)
	addi	gp, zero, 15		# elws site 15 = elws_ct_for_last_load
	j	emit_lw_sp
elws_ct_for_last_load:
	# Emit placeholder jal zero, 0 — add to break list.
	lui	a0, 0
	addi	a0, a0, 0x6F
	addi	gp, zero, 38		# emit_word site 38 = ew_ct_for_exit_jal
	j	emit_word
ew_ct_for_exit_jal:
	lla	t0, break_base
	lw	t2, 0(t0)
	lla	t0, break_count
	lw	t1, 0(t0)
	slli	t3, t1, 2
	add	t2, t2, t3
	addi	t4, s5, -4
	sw	t4, 0(t2)
	addi	t1, t1, 1
	sw	t1, 0(t0)

	# Parse the body — must be a `{ … }` block.
	addi	gp, zero, 38		# skip_ws site 38 = sw_ct_for_lbrace
	j	skip_ws
sw_ct_for_lbrace:
	bge	s2, s3, ct_bad_loop_lbrace
	lbu	t0, 0(s2)
	addi	t1, zero, '{'
	bne	t0, t1, ct_bad_loop_lbrace
	# Recurse compile_expr_p — the nud sees '{' and dispatches into
	# ct_lbrace, which parses the block and returns with a0 = last expr.
	addi	t6, zero, 0
	addi	gp, zero, 31		# compile_expr site 31 = ce_ct_for_body
	j	compile_expr_p
ce_ct_for_body:
	# After body, a0 = last body expression's value. Store to last_slot.
	lw	a0, 152(sp)
	addi	gp, zero, 23		# esws site 23 = esws_ct_for_body_save
	j	emit_sw_sp
esws_ct_for_body_save:
	# Emit backward jal to loop_start (increment step).
	lui	a0, 0
	addi	a0, a0, 0x6F
	addi	gp, zero, 39		# emit_word site 39 = ew_ct_for_back_jal
	j	emit_word
ew_ct_for_back_jal:
	addi	t5, s5, -4
	lla	t0, loop_start
	lw	t6, 0(t0)
	addi	gp, zero, 15		# patch_jtype site 15 = pjt_ct_for_back
	j	patch_jtype
pjt_ct_for_back:
	# Natural exit = current s5. Walk break list, patch each to here.
ct_for_break_patch_loop:
	lla	t0, break_count
	lw	t3, 0(t0)
	beqz	t3, ct_for_break_patch_done
	addi	t3, t3, -1
	sw	t3, 0(t0)
	lla	t0, break_base
	lw	t4, 0(t0)
	slli	t1, t3, 2
	add	t4, t4, t1
	lw	t5, 0(t4)
	addi	t6, s5, 0
	addi	gp, zero, 16		# patch_jtype site 16 = pjt_ct_for_break
	j	patch_jtype
pjt_ct_for_break:
	j	ct_for_break_patch_loop
ct_for_break_patch_done:
	# Restore outer loop/scope context.
	lw	t1, 128(sp)
	lla	t0, break_base
	sw	t1, 0(t0)
	lw	t1, 132(sp)
	lla	t0, break_count
	sw	t1, 0(t0)
	lw	t1, 136(sp)
	lla	t0, loop_start
	sw	t1, 0(t0)
	lw	s8, 140(sp)		# restore symtab write ptr (forget shadow)

	addi	sp, sp, 192
	lla	t0, lv_kind
	sw	zero, 0(t0)
	lla	t0, last_was_brace
	addi	t1, zero, 1
	sw	t1, 0(t0)
	j	ct_done

ct_bad_loop_lbrace:
	addi	a0, zero, 9		# err 9: expected '{'
	j	report_err
ct_bad_break_overflow:
	addi	a0, zero, 30		# err 30: too many breaks
	j	report_err
ct_bad_break_outside:
	addi	a0, zero, 31		# err 31: break outside loop
	j	report_err
ct_bad_continue_outside:
	addi	a0, zero, 33		# err 33: continue outside loop
	j	report_err
ct_bad_for_name:
	# Rewind s2 to the saved token start so the error points there
	# (instead of wherever parse_ident stopped).
	lw	s2, 160(sp)
	addi	a0, zero, 6		# err 6: expected identifier
	j	report_err
ct_bad_for_in:
	lw	s2, 160(sp)		# point at the token start, not where we got stuck
	addi	a0, zero, 10		# err 10: expected 'in'
	j	report_err
ct_bad_for_range:
	addi	a0, zero, 11		# err 11: expected '..' or '..='
	j	report_err
ct_bad_char_esc:
	addi	a0, zero, 34		# err 34: unknown escape sequence
	j	report_err

# ══════════════════════════════════════════════════════════════════════════════
# Function definitions and calls.
#
# Calling convention (no jalr available):
#   - Args passed in a0..a7 (up to 8; caller errors if more)
#   - Return value in a0
#   - ra (x1) holds the compile-time-assigned "return site ID" at entry; the
#     callee saves it in its frame and restores it before dispatching back
#     through master_dispatch at the end of the program
#   - Caller's fp is saved in the callee's frame; callee's own fp is set to
#     the base of its locals so push/pop during body compilation can coexist
#     with fp-relative access to locals
#
# Callee frame layout (stack grows down):
#     [saved fp]    fp + frame_size + 4
#     [saved ra]    fp + frame_size + 0
#     [local N-1]   fp + frame_size - 4
#     ...
#     [local 0]     fp + 0    ←  sp = fp after prologue
#
# Stage 3 wire-up (master_dispatch) runs after Phase 4 (main epilogue) so
# every function's epilogue-`jal zero, 0` placeholder can be patched to
# point at the master_dispatch entry.
# ══════════════════════════════════════════════════════════════════════════════

# ── fn symtab helpers ────────────────────────────────────────────────────────
# fn_lookup — scan fn_base..fn_top for a name matching s10/s11. Returns the
# entry pointer in a0, or 0 if not found. No-growth, no-alloc.
fn_lookup:
	lla	t0, fn_base
	lw	t0, 0(t0)
	lla	t1, fn_top
	lw	t1, 0(t1)
fnlk_scan:
	beq	t0, t1, fnlk_missing
	addi	t2, zero, 0
fnlk_cmp:
	addi	t3, zero, 32
	beq	t2, t3, fnlk_match
	add	t4, t0, t2
	lbu	t5, 0(t4)
	blt	t2, s11, fnlk_in_tok
	bnez	t5, fnlk_next
	addi	t2, t2, 1
	j	fnlk_cmp
fnlk_in_tok:
	add	t6, s10, t2
	lbu	a1, 0(t6)
	bne	t5, a1, fnlk_next
	addi	t2, t2, 1
	j	fnlk_cmp
fnlk_match:
	addi	a0, t0, 0
	j	fn_lookup_disp
fnlk_next:
	addi	t0, t0, 40
	j	fnlk_scan
fnlk_missing:
	addi	a0, zero, 0
	j	fn_lookup_disp

fn_lookup_disp:
	bnez	gp, fnlk_d1
	j	fnlk_ret_def
fnlk_d1:
	addi	gp, gp, -1
	bnez	gp, fnlk_d2
	j	fnlk_ret_call
fnlk_d2:
	j	fnlk_ret_asm

# fn_alloc — append a new entry at fn_top, growing the fn symtab if needed.
# Inputs: s10/s11 = name; a0 = entry_addr; a1 = num_params (0..8).
# Returns: entry pointer in a0 via fn_alloc_disp.
fn_alloc:
	addi	sp, sp, -12
	sw	a0, 0(sp)		# [0] entry_addr
	sw	a1, 4(sp)		# [4] num_params
	sw	gp, 8(sp)
	# Check capacity.
	lla	t0, fn_top
	lw	t1, 0(t0)
	lla	t0, fn_end
	lw	t2, 0(t0)
	bne	t1, t2, fna_ok
	# Grow: new_cap = 2 * old_cap, new_base = tp.
	lla	t0, fn_base
	lw	t3, 0(t0)
	sub	t4, t2, t3		# old_cap
	slli	t5, t4, 1		# new_cap
	# heap_end check: tp + new_cap must fit below heap_end.
	add	t6, tp, t5
	lla	a2, heap_end
	lw	a2, 0(a2)
	bgeu	t6, a2, heap_full
	addi	t6, tp, 0		# new_base
	addi	a2, t3, 0		# src
	addi	a3, t6, 0		# dst
fna_copy:
	beq	a2, t1, fna_copy_done
	lw	a4, 0(a2)
	sw	a4, 0(a3)
	addi	a2, a2, 4
	addi	a3, a3, 4
	j	fna_copy
fna_copy_done:
	lla	t0, fn_base
	sw	t6, 0(t0)
	add	a2, t6, t4
	lla	t0, fn_top
	sw	a2, 0(t0)
	add	a3, t6, t5
	lla	t0, fn_end
	sw	a3, 0(t0)
	add	tp, tp, t5
	lla	t0, fn_top
	lw	t1, 0(t0)
fna_ok:
	# Zero the 40-byte entry at t1.
	addi	t2, zero, 0
fna_zero:
	addi	t3, zero, 40
	beq	t2, t3, fna_zero_done
	add	t4, t1, t2
	sb	zero, 0(t4)
	addi	t2, t2, 1
	j	fna_zero
fna_zero_done:
	# Copy name (s11 bytes from s10) into [t1..t1+s11).
	addi	t2, zero, 0
fna_cp:
	beq	t2, s11, fna_cp_done
	add	t3, s10, t2
	lbu	t4, 0(t3)
	add	t5, t1, t2
	sb	t4, 0(t5)
	addi	t2, t2, 1
	j	fna_cp
fna_cp_done:
	# Fields at 32..39.
	lw	a0, 0(sp)
	sw	a0, 32(t1)		# entry_addr
	lw	a0, 4(sp)
	sb	a0, 36(t1)		# num_params
	# Bump fn_top.
	addi	t1, t1, 40
	lla	t0, fn_top
	sw	t1, 0(t0)
	# Return the new entry pointer (old fn_top, before bump).
	addi	a0, t1, -40
	lw	gp, 8(sp)
	addi	sp, sp, 12
	j	fn_alloc_disp

fn_alloc_disp:
	bnez	gp, fna_d1
	j	fna_ret_def
fna_d1:
	j	fna_ret_asm

# ══════════════════════════════════════════════════════════════════════════════
# Struct symtab helpers: struct_lookup, struct_alloc, struct_field_lookup
# ══════════════════════════════════════════════════════════════════════════════
# struct_lookup — scan struct_base..struct_top for a struct matching s10/s11.
# Returns a0 = entry pointer (non-zero) on match, a0 = 0 if not found.
# Dispatches via gp.
struct_lookup:
	lla	t0, struct_base
	lw	t0, 0(t0)
	lla	t1, struct_top
	lw	t1, 0(t1)
stlk_scan:
	beq	t0, t1, stlk_missing
	addi	t2, zero, 0
stlk_cmp:
	addi	t3, zero, 32
	beq	t2, t3, stlk_match
	add	t4, t0, t2
	lbu	t5, 0(t4)
	blt	t2, s11, stlk_in_tok
	bnez	t5, stlk_next
	addi	t2, t2, 1
	j	stlk_cmp
stlk_in_tok:
	add	t6, s10, t2
	lbu	a1, 0(t6)
	bne	t5, a1, stlk_next
	addi	t2, t2, 1
	j	stlk_cmp
stlk_match:
	addi	a0, t0, 0		# entry pointer
	j	struct_lookup_disp
stlk_next:
	addi	t0, t0, 320
	j	stlk_scan
stlk_missing:
	addi	a0, zero, 0
	j	struct_lookup_disp

struct_lookup_disp:
	bnez	gp, stlkd_1
	j	stlk_ret_def
stlkd_1:
	addi	gp, gp, -1
	bnez	gp, stlkd_2
	j	stlk_ret_ct_id
stlkd_2:
	addi	gp, gp, -1
	bnez	gp, stlkd_3
	j	stlk_ret_cs
stlkd_3:
	addi	gp, gp, -1
	bnez	gp, stlkd_4
	j	stlk_ret_so
stlkd_4:
	addi	gp, gp, -1
	bnez	gp, stlkd_5
	j	stlk_ret_ct_primary
stlkd_5:
	j	stlk_blk_struct

# struct_alloc — append a new struct entry at struct_top. Grows the table
# if needed. Inputs: s10/s11 = struct name (field names copied separately
# via struct_add_field later). Sets all 320 bytes to zero except the name.
# Returns: a0 = entry pointer.
struct_alloc:
	addi	sp, sp, -4
	sw	gp, 0(sp)
	lla	t0, struct_top
	lw	t1, 0(t0)
	lla	t0, struct_end
	lw	t2, 0(t0)
	bne	t1, t2, sta_ok
	# Grow: copy existing entries to fresh heap region at tp.
	lla	t0, struct_base
	lw	t3, 0(t0)
	sub	t4, t2, t3		# old cap (bytes)
	slli	t5, t4, 1		# new cap
	# heap_end check: tp + new_cap must fit below heap_end.
	add	t6, tp, t5
	lla	a2, heap_end
	lw	a2, 0(a2)
	bgeu	t6, a2, heap_full
	addi	t6, tp, 0		# new base
	addi	a2, t3, 0		# src
	addi	a3, t6, 0		# dst
sta_copy:
	beq	a2, t1, sta_copy_done
	lw	a4, 0(a2)
	sw	a4, 0(a3)
	addi	a2, a2, 4
	addi	a3, a3, 4
	j	sta_copy
sta_copy_done:
	lla	t0, struct_base
	sw	t6, 0(t0)
	add	a2, t6, t4
	lla	t0, struct_top
	sw	a2, 0(t0)
	add	a3, t6, t5
	lla	t0, struct_end
	sw	a3, 0(t0)
	add	tp, tp, t5
	lla	t0, struct_top
	lw	t1, 0(t0)
sta_ok:
	# Zero 320 bytes at t1.
	addi	t2, zero, 0
sta_zero:
	addi	t3, zero, 320
	beq	t2, t3, sta_zero_done
	add	t4, t1, t2
	sb	zero, 0(t4)
	addi	t2, t2, 1
	j	sta_zero
sta_zero_done:
	# Copy struct name (s11 bytes from s10) into bytes 0..s11.
	addi	t2, zero, 0
sta_cp:
	beq	t2, s11, sta_cp_done
	add	t3, s10, t2
	lbu	t4, 0(t3)
	add	t5, t1, t2
	sb	t4, 0(t5)
	addi	t2, t2, 1
	j	sta_cp
sta_cp_done:
	# Bump struct_top by 320.
	addi	a0, t1, 0		# return entry pointer
	addi	t1, t1, 320
	lla	t0, struct_top
	sw	t1, 0(t0)
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	struct_alloc_disp

struct_alloc_disp:
	j	sta_ret_def

# struct_add_field — append a field name to an existing struct entry. The
# entry pointer is in a0; the field name is in s10/s11. Field count (at
# byte 32) must already be the INDEX (0-based) at which to write; we bump
# it after writing.
struct_add_field:
	addi	sp, sp, -4
	sw	gp, 0(sp)
	lw	t0, 32(a0)		# current field count
	addi	t1, zero, 16
	bge	t0, t1, saf_too_many
	# Offset of the new field name = 40 + 16*count
	slli	t2, t0, 4		# count * 16
	addi	t2, t2, 40
	add	t3, a0, t2
	# Zero 16 bytes
	addi	t4, zero, 0
saf_zero:
	addi	t5, zero, 16
	beq	t4, t5, saf_zero_done
	add	t6, t3, t4
	sb	zero, 0(t6)
	addi	t4, t4, 1
	j	saf_zero
saf_zero_done:
	# Copy name (min of s11 and 16 bytes)
	addi	t4, zero, 0
saf_cp:
	beq	t4, s11, saf_cp_done
	addi	t5, zero, 16
	beq	t4, t5, saf_cp_done
	add	t6, s10, t4
	lbu	a1, 0(t6)
	add	a2, t3, t4
	sb	a1, 0(a2)
	addi	t4, t4, 1
	j	saf_cp
saf_cp_done:
	# Bump field count
	lw	t0, 32(a0)
	addi	t0, t0, 1
	sw	t0, 32(a0)
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	struct_add_field_disp
saf_too_many:
	addi	a0, zero, 47		# err 47: too many struct fields
	j	report_err

struct_add_field_disp:
	j	saf_ret_def

# struct_field_lookup — find a field's index within a struct. Inputs:
# a0 = entry pointer, s10/s11 = field name. Returns: a0 = field index
# (0-based), or -1 if not found. Dispatches via gp.
struct_field_lookup:
	lw	t0, 32(a0)		# field count
	addi	t1, zero, 0		# index
sfl_loop:
	beq	t1, t0, sfl_missing
	# Compare s10/s11 with field t1's name at offset 40 + 16*t1
	slli	t2, t1, 4
	addi	t2, t2, 40
	add	t3, a0, t2		# field name address
	addi	t4, zero, 0
sfl_cmp:
	addi	t5, zero, 16
	beq	t4, t5, sfl_match
	add	t6, t3, t4
	lbu	a1, 0(t6)
	blt	t4, s11, sfl_in_tok
	bnez	a1, sfl_next
	addi	t4, t4, 1
	j	sfl_cmp
sfl_in_tok:
	add	a2, s10, t4
	lbu	a3, 0(a2)
	bne	a1, a3, sfl_next
	addi	t4, t4, 1
	j	sfl_cmp
sfl_match:
	addi	a0, t1, 0
	j	struct_field_lookup_disp
sfl_next:
	addi	t1, t1, 1
	j	sfl_loop
sfl_missing:
	addi	a0, zero, -1
	j	struct_field_lookup_disp

struct_field_lookup_disp:
	bnez	gp, sfld_1
	j	sfl_ret_access
sfld_1:
	j	sfl_ret_literal

# Stub return sites — replaced by real call sites as each feature is added.
stlk_ret_ct_primary:
	j	halt_err
# Dead emit_word/stack_check sites left over from the old memory-stack push/pop.
# emit_push_a0 and emit_pop_t0 no longer use emit_word — they write directly to
# s5 — so these labels are unreachable but still referenced by the dispatch
# tables. Wired to halt_err defensively.
ew_push_addi:
	j	halt_err
ew_push_sw:
	j	halt_err
ew_pop_lw:
	j	halt_err
ew_pop_addi:
	j	halt_err
esc_ret_push:
	j	halt_err
ew_ct_call_spadj:
	j	halt_err
ew_ct_stl_spadj:
	j	halt_err

# ══════════════════════════════════════════════════════════════════════════════
# Macro symtab + helpers.
# Entry layout (320 bytes):
#    0..31: name
#   32..35: body_start (source ptr)
#   36..39: body_end   (source ptr, one past last body char)
#   40    : num_args
#   41..43: pad
#   44..299: arg names (8 × 32 bytes)
#  300..319: pad
# ══════════════════════════════════════════════════════════════════════════════

# macro_lookup — scan macro_base..macro_top for a name matching s10/s11.
# Returns the entry pointer in a0, or 0 if not found. Dispatches via gp.
macro_lookup:
	lla	t0, macro_base
	lw	t0, 0(t0)
	lla	t1, macro_top
	lw	t1, 0(t1)
mlk_scan:
	beq	t0, t1, mlk_missing
	addi	t2, zero, 0
mlk_cmp:
	addi	t3, zero, 32
	beq	t2, t3, mlk_match
	add	t4, t0, t2
	lbu	t5, 0(t4)
	blt	t2, s11, mlk_in_tok
	bnez	t5, mlk_next
	addi	t2, t2, 1
	j	mlk_cmp
mlk_in_tok:
	add	t6, s10, t2
	lbu	a1, 0(t6)
	bne	t5, a1, mlk_next
	addi	t2, t2, 1
	j	mlk_cmp
mlk_match:
	addi	a0, t0, 0
	j	macro_lookup_disp
mlk_next:
	addi	t0, t0, 320
	j	mlk_scan
mlk_missing:
	addi	a0, zero, 0
	j	macro_lookup_disp

macro_lookup_disp:
	bnez	gp, mlk_d1
	j	mlk_ret_def
mlk_d1:
	j	mlk_ret_call

# macro_alloc — append a new (zeroed) entry at macro_top, growing if needed.
# Inputs: s10/s11 = name. Returns: a0 = entry pointer (the just-zeroed entry).
# Assumes the caller has verified the name isn't already taken.
macro_alloc:
	addi	sp, sp, -4
	sw	gp, 0(sp)
	lla	t0, macro_top
	lw	t1, 0(t0)
	lla	t0, macro_end
	lw	t2, 0(t0)
	bne	t1, t2, ma_ok
	# Grow: copy existing entries to fresh heap region at tp.
	lla	t0, macro_base
	lw	t3, 0(t0)
	sub	t4, t2, t3		# old cap (bytes)
	slli	t5, t4, 1		# new cap
	# heap_end check
	add	t6, tp, t5
	lla	a2, heap_end
	lw	a2, 0(a2)
	bgeu	t6, a2, heap_full
	addi	t6, tp, 0		# new base
	addi	a2, t3, 0		# src
	addi	a3, t6, 0		# dst
ma_copy:
	beq	a2, t1, ma_copy_done
	lw	a4, 0(a2)
	sw	a4, 0(a3)
	addi	a2, a2, 4
	addi	a3, a3, 4
	j	ma_copy
ma_copy_done:
	lla	t0, macro_base
	sw	t6, 0(t0)
	add	a2, t6, t4
	lla	t0, macro_top
	sw	a2, 0(t0)
	add	a3, t6, t5
	lla	t0, macro_end
	sw	a3, 0(t0)
	add	tp, tp, t5
	lla	t0, macro_top
	lw	t1, 0(t0)
ma_ok:
	# Zero 320 bytes at t1.
	addi	t2, zero, 0
ma_zero:
	addi	t3, zero, 320
	beq	t2, t3, ma_zero_done
	add	t4, t1, t2
	sb	zero, 0(t4)
	addi	t2, t2, 1
	j	ma_zero
ma_zero_done:
	# Copy name (s11 bytes from s10).
	addi	t2, zero, 0
ma_cp:
	beq	t2, s11, ma_cp_done
	add	t3, s10, t2
	lbu	t4, 0(t3)
	add	t5, t1, t2
	sb	t4, 0(t5)
	addi	t2, t2, 1
	j	ma_cp
ma_cp_done:
	addi	a0, t1, 0		# return entry pointer (still at macro_top)
	# Caller bumps macro_top after filling in body_start/body_end/args.
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	macro_alloc_disp

macro_alloc_disp:
	j	ma_ret_def

# ── cs_kw_fn — compile a `fn name(params) { body }` definition ───────────────
# Syntax:  fn IDENT '(' (IDENT (',' IDENT)*)? ')' '{' body '}'
# Restrictions (v1):  function must be top-level (no nesting).
#
# Frame (64 bytes) on top of compile_stmt's 4-byte entry frame:
#     0(sp):  saved outer s8  (for scope restore at fn exit)
#     4(sp):  saved outer s9
#     8(sp):  fn entry_addr
#    12(sp):  frame_alloc addi addr (patched after body)
#    16(sp):  frame_free addi addr  (patched after body)
#    20(sp):  skip-over jal addr   (patched after epilogue)
#    24(sp):  num_params
#    28(sp):  saved outer ret_list_top (reset during body compile)
#    32(sp):  (spare)
# ══════════════════════════════════════════════════════════════════════════════
# ══════════════════════════════════════════════════════════════════════════════
# cs_kw_struct — compile a `struct Name { f1, f2, f3 }` declaration.
#
# Parses the struct name (must be a fresh identifier, not shared with vars
# or functions), then a brace-delimited list of field identifiers. Builds
# a new entry in the struct symtab via struct_alloc + struct_add_field.
# Emits no runtime code — struct definitions are purely compile-time.
# ══════════════════════════════════════════════════════════════════════════════
cs_kw_struct:
	# Parse struct name.
	addi	gp, zero, 56		# skip_ws site 56 = sw_cs_struct_name
	j	skip_ws
sw_cs_struct_name:
	bge	s2, s3, cs_bad_struct_name
	lbu	t0, 0(s2)
	addi	t1, zero, '_'
	beq	t0, t1, cs_struct_name_ok
	addi	t1, zero, 'a'
	blt	t0, t1, cs_struct_name_chk_uc
	addi	t1, zero, 123
	blt	t0, t1, cs_struct_name_ok
cs_struct_name_chk_uc:
	addi	t1, zero, 'A'
	blt	t0, t1, cs_bad_struct_name
	addi	t1, zero, 91
	bge	t0, t1, cs_bad_struct_name
cs_struct_name_ok:
	addi	gp, zero, 10		# parse_ident site 10 = pi_cs_struct
	j	parse_ident
pi_cs_struct:
	# Check not already a struct.
	addi	gp, zero, 0		# struct_lookup site 0 = stlk_ret_def
	j	struct_lookup
stlk_ret_def:
	bnez	a0, cs_bad_struct_redefined
	# Allocate the struct entry.
	addi	gp, zero, 0		# struct_alloc site 0 = sta_ret_def
	j	struct_alloc
sta_ret_def:
	# Save entry pointer in a reg so we can keep adding fields. Use
	# s0 temporarily... no, s0 is symtab end. Use t5? But t5 gets
	# clobbered by skip_ws. Use a frame slot.
	addi	sp, sp, -8
	sw	a0, 0(sp)		# struct entry ptr
	sw	gp, 4(sp)

	# Expect '{'.
	addi	gp, zero, 57		# skip_ws site 57 = sw_cs_struct_lbrace
	j	skip_ws
sw_cs_struct_lbrace:
	bge	s2, s3, cs_bad_struct_lbrace
	lbu	t0, 0(s2)
	addi	t1, zero, '{'
	bne	t0, t1, cs_bad_struct_lbrace
	addi	s2, s2, 1

	# Parse zero-or-more comma-separated field names, terminated by '}'.
cs_struct_field_loop:
	addi	gp, zero, 58		# skip_ws site 58 = sw_cs_struct_field
	j	skip_ws
sw_cs_struct_field:
	bge	s2, s3, cs_bad_struct_rbrace
	lbu	t0, 0(s2)
	addi	t1, zero, '}'
	beq	t0, t1, cs_struct_fields_done
	# If not the first field, expect ','
	lw	t0, 0(sp)		# entry ptr
	lw	t2, 32(t0)		# current field count
	beqz	t2, cs_struct_field_name
	lbu	t0, 0(s2)
	addi	t1, zero, ','
	bne	t0, t1, cs_bad_struct_rbrace
	addi	s2, s2, 1
	addi	gp, zero, 59		# skip_ws site 59 = sw_cs_struct_field_after_comma
	j	skip_ws
sw_cs_struct_field_after_comma:
cs_struct_field_name:
	bge	s2, s3, cs_bad_struct_field
	lbu	t0, 0(s2)
	# Letter-start check.
	addi	t1, zero, '_'
	beq	t0, t1, cs_struct_field_start_ok
	addi	t1, zero, 'a'
	blt	t0, t1, cs_struct_field_chk_uc
	addi	t1, zero, 123
	blt	t0, t1, cs_struct_field_start_ok
cs_struct_field_chk_uc:
	addi	t1, zero, 'A'
	blt	t0, t1, cs_bad_struct_field
	addi	t1, zero, 91
	bge	t0, t1, cs_bad_struct_field
cs_struct_field_start_ok:
	addi	gp, zero, 11		# parse_ident site 11 = pi_cs_struct_field
	j	parse_ident
pi_cs_struct_field:
	beqz	s11, cs_bad_struct_field
	# Append field to entry.
	lw	a0, 0(sp)		# entry ptr
	addi	gp, zero, 0		# struct_add_field site 0 = saf_ret_def
	j	struct_add_field
saf_ret_def:
	j	cs_struct_field_loop

cs_struct_fields_done:
	addi	s2, s2, 1		# consume '}'
	addi	sp, sp, 8
	j	cs_done

cs_bad_struct_name:
	addi	a0, zero, 6		# err 6: expected identifier
	j	report_err
cs_bad_struct_redefined:
	addi	a0, zero, 45		# err 45: already defined
	j	report_err
cs_bad_struct_lbrace:
	addi	a0, zero, 9		# err 9: expected '{'
	j	report_err
cs_bad_struct_rbrace:
	addi	a0, zero, 48		# err 48: expected ',' or '}'
	j	report_err
cs_bad_struct_field:
	addi	a0, zero, 6		# err 6: expected identifier
	j	report_err

# ══════════════════════════════════════════════════════════════════════════════
# cs_kw_macro — compile `macro NAME(arg1, arg2) { body }` definition.
#
# Parses the name + arg list, then captures the body's source-text range
# (start ptr, end ptr) into a new macro symtab entry. The body is NOT parsed
# at definition time — we just brace-balance to find its end. Expansion is
# done at each call site by cs_macro_call.
#
# Frame (8 bytes) on top of compile_stmt's 4-byte entry frame:
#    0(sp): num_args parsed so far
#    4(sp): macro symtab entry pointer
# ══════════════════════════════════════════════════════════════════════════════
cs_kw_macro:
	addi	sp, sp, -8
	sw	zero, 0(sp)
	sw	zero, 4(sp)

	# Parse the macro name.
	addi	gp, zero, 109		# skip_ws site 109 = sw_cs_macro_name
	j	skip_ws
sw_cs_macro_name:
	bge	s2, s3, cs_bad_macro_name
	lbu	t0, 0(s2)
	addi	t1, zero, '_'
	beq	t0, t1, cs_macro_name_letter_ok
	addi	t1, zero, 'a'
	blt	t0, t1, cs_macro_name_chk_uc
	addi	t1, zero, 123
	blt	t0, t1, cs_macro_name_letter_ok
cs_macro_name_chk_uc:
	addi	t1, zero, 'A'
	blt	t0, t1, cs_bad_macro_name
	addi	t1, zero, 91
	bge	t0, t1, cs_bad_macro_name
cs_macro_name_letter_ok:
	addi	gp, zero, 27		# parse_ident site 27 = pi_cs_macro
	j	parse_ident
pi_cs_macro:
	beqz	s11, cs_bad_macro_name
	# Reject if a macro of this name already exists.
	addi	gp, zero, 0		# mlk site 0 = mlk_ret_def
	j	macro_lookup
mlk_ret_def:
	bnez	a0, cs_bad_macro_redefined
	# Allocate a fresh entry (zeroed, name copied from s10/s11).
	addi	gp, zero, 0		# ma site 0 = ma_ret_def
	j	macro_alloc
ma_ret_def:
	sw	a0, 4(sp)

	# Both `macro NAME(args) { body }` and `macro NAME args { body }`
	# (GAS-style, no parens) are accepted. We optionally consume the '('
	# here and then enter the unified arg loop, which terminates on
	# either ')' (paren mode) or '{' (no-paren mode).
	addi	gp, zero, 110		# skip_ws site 110 = sw_cs_macro_lparen
	j	skip_ws
sw_cs_macro_lparen:
	bge	s2, s3, cs_bad_macro_lparen
	lbu	t0, 0(s2)
	addi	t1, zero, '('
	bne	t0, t1, cs_macro_arg_loop
	addi	s2, s2, 1		# consume '('

cs_macro_arg_loop:
	addi	gp, zero, 111		# skip_ws site 111 = sw_cs_macro_arg
	j	skip_ws
sw_cs_macro_arg:
	bge	s2, s3, cs_bad_macro_rparen
	lbu	t0, 0(s2)
	addi	t1, zero, ')'
	beq	t0, t1, cs_macro_args_done
	addi	t1, zero, '{'
	beq	t0, t1, cs_macro_args_done_noparen
	# Not first arg → expect ','
	lw	t2, 0(sp)
	beqz	t2, cs_macro_arg_name_check
	addi	t1, zero, ','
	bne	t0, t1, cs_bad_macro_rparen
	addi	s2, s2, 1
	addi	gp, zero, 112		# skip_ws site 112 = sw_cs_macro_arg_after_comma
	j	skip_ws
sw_cs_macro_arg_after_comma:
	bge	s2, s3, cs_bad_macro_arg_name
	lbu	t0, 0(s2)
cs_macro_arg_name_check:
	addi	t1, zero, '_'
	beq	t0, t1, cs_macro_arg_name_ok
	addi	t1, zero, 'a'
	blt	t0, t1, cs_macro_arg_chk_uc
	addi	t1, zero, 123
	blt	t0, t1, cs_macro_arg_name_ok
cs_macro_arg_chk_uc:
	addi	t1, zero, 'A'
	blt	t0, t1, cs_bad_macro_arg_name
	addi	t1, zero, 91
	bge	t0, t1, cs_bad_macro_arg_name
cs_macro_arg_name_ok:
	# Enforce 8-arg max.
	lw	t2, 0(sp)
	addi	t3, zero, 8
	bge	t2, t3, cs_bad_macro_too_many_args
	addi	gp, zero, 28		# parse_ident site 28 = pi_cs_macro_arg
	j	parse_ident
pi_cs_macro_arg:
	beqz	s11, cs_bad_macro_arg_name
	# Copy arg name into entry at offset 44 + count*32.
	lw	t2, 0(sp)		# count
	lw	t3, 4(sp)		# entry ptr
	slli	t4, t2, 5
	addi	t4, t4, 44
	add	t4, t3, t4		# dest in entry
	addi	t5, zero, 0
ma_arg_cp:
	beq	t5, s11, ma_arg_cp_done
	add	t6, s10, t5
	lbu	a0, 0(t6)
	add	a1, t4, t5
	sb	a0, 0(a1)
	addi	t5, t5, 1
	j	ma_arg_cp
ma_arg_cp_done:
	addi	t2, t2, 1
	sw	t2, 0(sp)
	j	cs_macro_arg_loop

cs_macro_args_done:
	addi	s2, s2, 1		# consume ')'
cs_macro_args_done_noparen:
	# Save num_args at entry offset 40.
	lw	t2, 0(sp)
	lw	t3, 4(sp)
	sb	t2, 40(t3)

	# Parse '{'
	addi	gp, zero, 113		# skip_ws site 113 = sw_cs_macro_lbrace
	j	skip_ws
sw_cs_macro_lbrace:
	bge	s2, s3, cs_bad_macro_body
	lbu	t0, 0(s2)
	addi	t1, zero, '{'
	bne	t0, t1, cs_bad_macro_body
	addi	s2, s2, 1		# consume '{'

	# Save body_start = current s2.
	lw	t3, 4(sp)
	sw	s2, 32(t3)

	# Brace-balance to find the matching '}'. We skip string and char
	# literals so a '{' or '}' inside one isn't mistaken for a real brace.
	addi	t4, zero, 1
cs_macro_body_scan:
	bge	s2, s3, cs_bad_macro_body
	lbu	t0, 0(s2)
	addi	t1, zero, 39		# '\''
	beq	t0, t1, cs_macro_body_qrun
	addi	t1, zero, 34		# '"'
	beq	t0, t1, cs_macro_body_qrun
	addi	t1, zero, '{'
	beq	t0, t1, cs_macro_body_open
	addi	t1, zero, '}'
	beq	t0, t1, cs_macro_body_close
	addi	s2, s2, 1
	j	cs_macro_body_scan
cs_macro_body_open:
	addi	t4, t4, 1
	addi	s2, s2, 1
	j	cs_macro_body_scan
cs_macro_body_close:
	addi	t4, t4, -1
	beqz	t4, cs_macro_body_done
	addi	s2, s2, 1
	j	cs_macro_body_scan
cs_macro_body_qrun:
	addi	t1, t0, 0		# save quote char
	addi	s2, s2, 1
cs_macro_body_qloop:
	bge	s2, s3, cs_bad_macro_body
	lbu	t0, 0(s2)
	addi	t2, zero, 92		# '\\'
	beq	t0, t2, cs_macro_body_qesc
	beq	t0, t1, cs_macro_body_qclose
	addi	s2, s2, 1
	j	cs_macro_body_qloop
cs_macro_body_qesc:
	addi	s2, s2, 1
	bge	s2, s3, cs_bad_macro_body
	addi	s2, s2, 1
	j	cs_macro_body_qloop
cs_macro_body_qclose:
	addi	s2, s2, 1
	j	cs_macro_body_scan
cs_macro_body_done:
	# body_end = current s2 (one past last body char, pointing at '}').
	lw	t3, 4(sp)
	sw	s2, 36(t3)
	addi	s2, s2, 1		# consume '}'

	# Bump macro_top now that the entry is fully populated.
	lla	t0, macro_top
	lw	t1, 0(t0)
	addi	t1, t1, 320
	sw	t1, 0(t0)

	addi	sp, sp, 8
	# Set last_was_brace so a trailing ';' is optional.
	lla	t0, last_was_brace
	addi	t1, zero, 1
	sw	t1, 0(t0)
	j	cs_done

cs_bad_macro_name:
	addi	a0, zero, 77		# err 77: bad macro name
	j	report_err
cs_bad_macro_redefined:
	addi	a0, zero, 78		# err 78: macro already defined
	j	report_err
cs_bad_macro_lparen:
	addi	a0, zero, 12		# err 12: expected '('
	j	report_err
cs_bad_macro_rparen:
	addi	a0, zero, 2		# err 2: expected ')'
	j	report_err
cs_bad_macro_arg_name:
	addi	a0, zero, 6		# err 6: expected identifier
	j	report_err
cs_bad_macro_too_many_args:
	addi	a0, zero, 79		# err 79: too many macro args
	j	report_err
cs_bad_macro_body:
	addi	a0, zero, 9		# err 9: expected '{'
	j	report_err

# ══════════════════════════════════════════════════════════════════════════════
# cs_macro_call — invoke a macro: NAME(arg1, arg2, ...);
#
# Entry: a0 = macro entry pointer (just returned from macro_lookup), s2
# pointing just after the macro name's last char.
#
# Strategy:
#   1. Parse '(' and capture each arg as a raw (start, length) pair from the
#      source. Args are split on top-level commas; we don't track paren depth.
#   2. After ')' and ';', expand the body into macro_scratch with `\arg`
#      substitution (replace `\NAME` with the captured raw text).
#   3. Append a literal '}' to the scratch so asm_loop terminates cleanly
#      when it reaches the end of the expanded body.
#   4. Save s2/s3, point them at the scratch buffer, set macro_active=1, and
#      jump to asm_loop. asm_end checks macro_active and restores s2/s3.
#
# Frame (80 bytes) on top of compile_stmt's 4-byte entry frame:
#    0(sp): macro entry ptr
#    4(sp): num_args parsed so far
#    8(sp): saved s2 (the source position to resume after expansion)
#   12(sp): saved s3
#   16(sp)..79(sp): 8 × (arg_start, arg_len) pairs (8 bytes each)
# ══════════════════════════════════════════════════════════════════════════════
cs_macro_call:
	addi	sp, sp, -80
	sw	a0, 0(sp)
	sw	zero, 4(sp)

	# Skip ws and expect '('.
	addi	gp, zero, 114		# skip_ws site 114 = sw_cs_mc_lparen
	j	skip_ws
sw_cs_mc_lparen:
	bge	s2, s3, cs_bad_mc_lparen
	lbu	t0, 0(s2)
	addi	t1, zero, '('
	bne	t0, t1, cs_bad_mc_lparen
	addi	s2, s2, 1

cs_mc_arg_loop:
	# Skip ws, peek for ')' or first arg.
	addi	gp, zero, 115		# skip_ws site 115 = sw_cs_mc_arg
	j	skip_ws
sw_cs_mc_arg:
	bge	s2, s3, cs_bad_mc_rparen
	lbu	t0, 0(s2)
	addi	t1, zero, ')'
	beq	t0, t1, cs_mc_args_done
	# If not the first arg, expect a ','.
	lw	t2, 4(sp)
	beqz	t2, cs_mc_arg_capture
	addi	t1, zero, ','
	bne	t0, t1, cs_bad_mc_rparen
	addi	s2, s2, 1
	addi	gp, zero, 116		# skip_ws site 116 = sw_cs_mc_arg_after_comma
	j	skip_ws
sw_cs_mc_arg_after_comma:
cs_mc_arg_capture:
	# Capture the arg text: from current s2 up to next ',' or ')'.
	# Reject empty args.
	bge	s2, s3, cs_bad_mc_rparen
	# Enforce 8-arg max.
	lw	t2, 4(sp)
	addi	t3, zero, 8
	bge	t2, t3, cs_bad_mc_too_many_args
	addi	t4, s2, 0		# arg start
	addi	t6, zero, 0		# paren depth
cs_mc_scan_arg:
	bge	t4, s3, cs_bad_mc_rparen
	lbu	t0, 0(t4)
	addi	t1, zero, 39		# '\''
	beq	t0, t1, cs_mc_scan_arg_qrun
	addi	t1, zero, 34		# '"'
	beq	t0, t1, cs_mc_scan_arg_qrun
	addi	t1, zero, '('
	beq	t0, t1, cs_mc_scan_arg_open
	addi	t1, zero, ')'
	beq	t0, t1, cs_mc_scan_arg_chk_rp
	addi	t1, zero, ','
	beq	t0, t1, cs_mc_scan_arg_chk_comma
	addi	t4, t4, 1
	j	cs_mc_scan_arg
cs_mc_scan_arg_open:
	addi	t6, t6, 1
	addi	t4, t4, 1
	j	cs_mc_scan_arg
cs_mc_scan_arg_chk_rp:
	beqz	t6, cs_mc_scan_arg_done
	addi	t6, t6, -1
	addi	t4, t4, 1
	j	cs_mc_scan_arg
cs_mc_scan_arg_chk_comma:
	beqz	t6, cs_mc_scan_arg_done
	addi	t4, t4, 1
	j	cs_mc_scan_arg
cs_mc_scan_arg_qrun:
	addi	t1, t0, 0		# save quote char
	addi	t4, t4, 1
cs_mc_scan_arg_qloop:
	bge	t4, s3, cs_bad_mc_rparen
	lbu	t0, 0(t4)
	addi	t2, zero, 92
	beq	t0, t2, cs_mc_scan_arg_qesc
	beq	t0, t1, cs_mc_scan_arg_qclose
	addi	t4, t4, 1
	j	cs_mc_scan_arg_qloop
cs_mc_scan_arg_qesc:
	addi	t4, t4, 1
	bge	t4, s3, cs_bad_mc_rparen
	addi	t4, t4, 1
	j	cs_mc_scan_arg_qloop
cs_mc_scan_arg_qclose:
	addi	t4, t4, 1
	j	cs_mc_scan_arg
cs_mc_scan_arg_done:
	# t4 points at ',' or ')'. Trim trailing ws back from t4.
	addi	t5, t4, 0
cs_mc_trim:
	beq	t5, s2, cs_mc_trim_done
	addi	t6, t5, -1
	lbu	a0, 0(t6)
	addi	a1, zero, 33
	bge	a0, a1, cs_mc_trim_done
	addi	t5, t5, -1
	j	cs_mc_trim
cs_mc_trim_done:
	# Save (start=s2, length = t5 - s2) at frame slot 16 + count*8.
	lw	t2, 4(sp)
	slli	t6, t2, 3
	addi	t6, t6, 16
	add	a0, sp, t6
	sw	s2, 0(a0)
	sub	a1, t5, s2
	sw	a1, 4(a0)
	addi	t2, t2, 1
	sw	t2, 4(sp)
	# Advance s2 past the arg (up to the ',' or ')').
	addi	s2, t4, 0
	j	cs_mc_arg_loop

cs_mc_args_done:
	addi	s2, s2, 1		# consume ')'
	# Expect num_args == macro's declared arg count.
	lw	t2, 4(sp)
	lw	t3, 0(sp)
	lbu	t4, 40(t3)		# declared
	bne	t2, t4, cs_bad_mc_arg_count
	# Skip ws and expect ';'.
	addi	gp, zero, 117		# skip_ws site 117 = sw_cs_mc_semi
	j	skip_ws
sw_cs_mc_semi:
	bge	s2, s3, cs_bad_mc_semi
	lbu	t0, 0(s2)
	addi	t1, zero, ';'
	bne	t0, t1, cs_bad_mc_semi
	addi	s2, s2, 1

	# ── Begin expansion ────────────────────────────────────────────
	# Push (s2, s3, macro_scratch_top) onto the expansion stack.
	lla	t0, macro_stack_top
	lw	t1, 0(t0)
	lla	t2, macro_stack_end
	lw	t3, 0(t2)
	bgeu	t1, t3, cs_bad_mc_nested
	sw	s2, 0(t1)
	sw	s3, 4(t1)
	lla	t2, macro_scratch_top
	lw	t3, 0(t2)
	sw	t3, 8(t1)
	addi	t1, t1, 12
	sw	t1, 0(t0)

	# Walk the body, writing into the scratch buffer with substitution.
	lw	t3, 0(sp)		# macro entry
	lw	a4, 32(t3)		# body_start (source ptr)
	lw	a5, 36(t3)		# body_end
	lla	t0, macro_scratch_top
	lw	a6, 0(t0)		# scratch write ptr (= inner_start)
	lla	t0, macro_scratch_end
	lw	a7, 0(t0)		# scratch end
	# t3 stays = entry ptr (we'll re-read num_args & arg names from it).

cs_mc_expand_loop:
	beq	a4, a5, cs_mc_expand_done
	# Bounds check the scratch buffer.
	addi	t0, a6, 1
	bgeu	t0, a7, cs_bad_mc_scratch
	lbu	t0, 0(a4)
	addi	t1, zero, 92		# '\\'
	beq	t0, t1, cs_mc_subst
	# Plain copy.
	sb	t0, 0(a6)
	addi	a6, a6, 1
	addi	a4, a4, 1
	j	cs_mc_expand_loop

cs_mc_subst:
	# Skip the backslash and read the ident name that follows. A bare
	# '\' (no ident, or end of body) is passed through verbatim — the
	# downstream parser will see it and decide whether it's valid (e.g.
	# inside a char literal it's an escape).
	addi	a4, a4, 1
	bge	a4, a5, cs_mc_subst_bare
	addi	t4, a4, 0		# ident start in body
cs_mc_subst_scan:
	bge	a4, a5, cs_mc_subst_scan_done
	lbu	t0, 0(a4)
	# ident chars: a-z A-Z 0-9 _
	addi	t1, zero, '_'
	beq	t0, t1, cs_mc_subst_keep
	addi	t1, zero, '0'
	blt	t0, t1, cs_mc_subst_scan_done
	addi	t1, zero, 58
	blt	t0, t1, cs_mc_subst_keep
	addi	t1, zero, 'A'
	blt	t0, t1, cs_mc_subst_scan_done
	addi	t1, zero, 91
	blt	t0, t1, cs_mc_subst_keep
	addi	t1, zero, 'a'
	blt	t0, t1, cs_mc_subst_scan_done
	addi	t1, zero, 123
	blt	t0, t1, cs_mc_subst_keep
	j	cs_mc_subst_scan_done
cs_mc_subst_keep:
	addi	a4, a4, 1
	j	cs_mc_subst_scan
cs_mc_subst_scan_done:
	# t4..a4 is the substitution name. Look it up in arg names.
	sub	t5, a4, t4		# name length
	beqz	t5, cs_mc_subst_bare
	# Iterate arg slots and compare.
	addi	t6, zero, 0		# i
cs_mc_subst_lookup:
	lbu	t0, 40(t3)		# num_args
	beq	t6, t0, cs_mc_subst_passthrough
	# arg name pointer = entry + 44 + i*32
	slli	t1, t6, 5
	addi	t1, t1, 44
	add	t1, t3, t1
	# Compare t1[0..32] against body[t4..a4]. The arg name is null-padded
	# to 32 bytes; the body name is t5 chars long (no null terminator).
	addi	t2, zero, 0
cs_mc_subst_cmp:
	addi	a0, zero, 32
	beq	t2, a0, cs_mc_subst_arg_overflow
	add	a0, t1, t2
	lbu	a1, 0(a0)
	# In-name region (t2 < t5): compare to body byte. Past-name region
	# (t2 >= t5): require null in arg name slot.
	blt	t2, t5, cs_mc_subst_in_name
	bnez	a1, cs_mc_subst_next
	j	cs_mc_subst_found
cs_mc_subst_in_name:
	add	a0, t4, t2
	lbu	a2, 0(a0)
	bne	a1, a2, cs_mc_subst_next
	addi	t2, t2, 1
	j	cs_mc_subst_cmp
cs_mc_subst_arg_overflow:
	# We compared all 32 bytes of arg name. Match only if t5 == 32.
	addi	a0, zero, 32
	beq	t5, a0, cs_mc_subst_found
cs_mc_subst_next:
	addi	t6, t6, 1
	j	cs_mc_subst_lookup
cs_mc_subst_passthrough:
	# `\name` doesn't match any of this macro's args — copy verbatim
	# (the backslash plus the ident bytes) so a nested rept or another
	# expansion downstream can handle it.
	addi	t0, a6, 1
	bgeu	t0, a7, cs_bad_mc_scratch
	addi	t0, zero, 92
	sb	t0, 0(a6)
	addi	a6, a6, 1
	addi	t0, t4, 0
cs_mc_subst_pass_loop:
	beq	t0, a4, cs_mc_expand_loop
	addi	t1, a6, 1
	bgeu	t1, a7, cs_bad_mc_scratch
	lbu	t1, 0(t0)
	sb	t1, 0(a6)
	addi	a6, a6, 1
	addi	t0, t0, 1
	j	cs_mc_subst_pass_loop

cs_mc_subst_bare:
	# Bare '\': no ident follows. Emit a literal backslash so that
	# escapes like `'\\'` survive macro expansion verbatim.
	addi	t0, a6, 1
	bgeu	t0, a7, cs_bad_mc_scratch
	addi	t0, zero, 92
	sb	t0, 0(a6)
	addi	a6, a6, 1
	j	cs_mc_expand_loop
cs_mc_subst_found:
	# Copy the captured arg text (start, len) at frame slot 16 + i*8 to a6.
	slli	t0, t6, 3
	addi	t0, t0, 16
	add	t0, sp, t0
	lw	a0, 0(t0)		# arg src ptr
	lw	a1, 4(t0)		# arg len
	addi	t1, zero, 0
cs_mc_subst_copy:
	beq	t1, a1, cs_mc_subst_copy_done
	addi	t2, a6, 1
	bgeu	t2, a7, cs_bad_mc_scratch
	add	t2, a0, t1
	lbu	a2, 0(t2)
	sb	a2, 0(a6)
	addi	a6, a6, 1
	addi	t1, t1, 1
	j	cs_mc_subst_copy
cs_mc_subst_copy_done:
	j	cs_mc_expand_loop

cs_mc_expand_done:
	# Update bump pointer and point s2/s3 at the just-written region.
	# inner_start is in the top stack entry's slot 8.
	lla	t0, macro_scratch_top
	sw	a6, 0(t0)
	lla	t0, macro_stack_top
	lw	t1, 0(t0)
	addi	t1, t1, -12
	lw	s2, 8(t1)		# inner_start (saved scratch_top at push)
	addi	s3, a6, 0
	addi	sp, sp, 80
	j	cs_done

cs_bad_mc_lparen:
	addi	a0, zero, 12		# err 12: expected '('
	j	report_err
cs_bad_mc_rparen:
	addi	a0, zero, 2		# err 2: expected ')'
	j	report_err
cs_bad_mc_too_many_args:
	addi	a0, zero, 79		# err 79: too many macro args
	j	report_err
cs_bad_mc_arg_count:
	addi	a0, zero, 80		# err 80: macro arg count mismatch
	j	report_err
cs_bad_mc_semi:
	addi	a0, zero, 1		# err 1: expected ';'
	j	report_err
cs_bad_mc_nested:
	addi	a0, zero, 81		# err 81: nested macro expansion
	j	report_err
cs_bad_mc_subst:
	addi	a0, zero, 82		# err 82: bad macro substitution
	j	report_err
cs_bad_mc_scratch:
	addi	a0, zero, 83		# err 83: macro scratch buffer overflow
	j	report_err

# ══════════════════════════════════════════════════════════════════════════════
# cs_kw_rept — compile-time loop unroll: `rept IDENT in N..M { body }`
#                                       or `rept IDENT in N..=M { body }`
#
# Captures the body source range, then walks it once per iteration into
# macro_scratch with `\IDENT` substituted by the current iteration counter
# rendered as decimal text. After expansion, points s2/s3 at the scratch
# and reuses the macro_active / EOI hook to splice the unrolled output
# back into the statement stream.
#
# Frame (60 bytes) on top of compile_stmt's 4-byte entry frame:
#    0(sp): counter name length
#    4(sp): low bound  (signed)
#    8(sp): high bound (signed)
#   12(sp): inclusive flag
#   16(sp): body_start (source ptr)
#   20(sp): body_end   (source ptr, points at '}')
#   24(sp): unused
#   28(sp)..59(sp): counter name buffer (32 bytes)
# ══════════════════════════════════════════════════════════════════════════════
cs_kw_rept:
	addi	sp, sp, -60

	# Parse the counter ident.
	addi	gp, zero, 118		# skip_ws site 118 = sw_cs_rept_name
	j	skip_ws
sw_cs_rept_name:
	bge	s2, s3, cs_bad_rept_name
	lbu	t0, 0(s2)
	addi	t1, zero, '_'
	beq	t0, t1, cs_rept_name_letter_ok
	addi	t1, zero, 'a'
	blt	t0, t1, cs_rept_name_chk_uc
	addi	t1, zero, 123
	blt	t0, t1, cs_rept_name_letter_ok
cs_rept_name_chk_uc:
	addi	t1, zero, 'A'
	blt	t0, t1, cs_bad_rept_name
	addi	t1, zero, 91
	bge	t0, t1, cs_bad_rept_name
cs_rept_name_letter_ok:
	addi	gp, zero, 29		# parse_ident site 29 = pi_cs_rept
	j	parse_ident
pi_cs_rept:
	beqz	s11, cs_bad_rept_name
	# Save the counter name into the frame. We need it after parse_num
	# overwrites s10/s11 and after the body scan.
	sw	s11, 0(sp)
	addi	t0, zero, 0
cs_rept_cp:
	beq	t0, s11, cs_rept_cp_done
	add	t1, s10, t0
	lbu	t2, 0(t1)
	addi	t3, sp, 28
	add	t3, t3, t0
	sb	t2, 0(t3)
	addi	t0, t0, 1
	j	cs_rept_cp
cs_rept_cp_done:

	# Expect `in`.
	addi	gp, zero, 119		# skip_ws site 119 = sw_cs_rept_in
	j	skip_ws
sw_cs_rept_in:
	addi	t0, s2, 2
	bge	t0, s3, cs_bad_rept_in
	lbu	t1, 0(s2)
	addi	t2, zero, 'i'
	bne	t1, t2, cs_bad_rept_in
	lbu	t1, 1(s2)
	addi	t2, zero, 'n'
	bne	t1, t2, cs_bad_rept_in
	# The char following `in` must be ws or boundary so we don't grab
	# the start of an ident like `index`.
	lbu	t1, 2(s2)
	addi	t2, zero, 33
	bge	t1, t2, cs_bad_rept_in
	addi	s2, s2, 2

	# Parse low bound.
	addi	gp, zero, 120		# skip_ws site 120 = sw_cs_rept_low
	j	skip_ws
sw_cs_rept_low:
	addi	gp, zero, 7		# parse_num site 7 = pn_cs_rept_low
	j	parse_num
pn_cs_rept_low:
	sw	a0, 4(sp)

	# Expect `..` or `..=`.
	addi	gp, zero, 121		# skip_ws site 121 = sw_cs_rept_dot
	j	skip_ws
sw_cs_rept_dot:
	addi	t0, s2, 2
	bge	t0, s3, cs_bad_rept_range
	lbu	t1, 0(s2)
	addi	t2, zero, '.'
	bne	t1, t2, cs_bad_rept_range
	lbu	t1, 1(s2)
	addi	t2, zero, '.'
	bne	t1, t2, cs_bad_rept_range
	addi	s2, s2, 2
	# Optional '='
	sw	zero, 12(sp)
	bge	s2, s3, cs_bad_rept_range
	lbu	t1, 0(s2)
	addi	t2, zero, '='
	bne	t1, t2, sw_cs_rept_high
	addi	t1, zero, 1
	sw	t1, 12(sp)
	addi	s2, s2, 1

	# Parse high bound.
sw_cs_rept_high:
	addi	gp, zero, 122		# skip_ws site 122 = sw_cs_rept_high
	j	skip_ws
sw_cs_rept_high_after_skip:
	addi	gp, zero, 8		# parse_num site 8 = pn_cs_rept_high
	j	parse_num
pn_cs_rept_high:
	sw	a0, 8(sp)

	# Expect `{`.
	addi	gp, zero, 123		# skip_ws site 123 = sw_cs_rept_lbrace
	j	skip_ws
sw_cs_rept_lbrace:
	bge	s2, s3, cs_bad_rept_body
	lbu	t0, 0(s2)
	addi	t1, zero, '{'
	bne	t0, t1, cs_bad_rept_body
	addi	s2, s2, 1
	sw	s2, 16(sp)		# body_start

	# Brace-balance to find the matching '}', skipping string and char
	# literals so internal braces don't fool the count.
	addi	t4, zero, 1
cs_rept_body_scan:
	bge	s2, s3, cs_bad_rept_body
	lbu	t0, 0(s2)
	addi	t1, zero, 39		# '\''
	beq	t0, t1, cs_rept_body_qrun
	addi	t1, zero, 34		# '"'
	beq	t0, t1, cs_rept_body_qrun
	addi	t1, zero, '{'
	beq	t0, t1, cs_rept_body_open
	addi	t1, zero, '}'
	beq	t0, t1, cs_rept_body_close
	addi	s2, s2, 1
	j	cs_rept_body_scan
cs_rept_body_open:
	addi	t4, t4, 1
	addi	s2, s2, 1
	j	cs_rept_body_scan
cs_rept_body_close:
	addi	t4, t4, -1
	beqz	t4, cs_rept_body_done
	addi	s2, s2, 1
	j	cs_rept_body_scan
cs_rept_body_qrun:
	addi	t1, t0, 0
	addi	s2, s2, 1
cs_rept_body_qloop:
	bge	s2, s3, cs_bad_rept_body
	lbu	t0, 0(s2)
	addi	t2, zero, 92
	beq	t0, t2, cs_rept_body_qesc
	beq	t0, t1, cs_rept_body_qclose
	addi	s2, s2, 1
	j	cs_rept_body_qloop
cs_rept_body_qesc:
	addi	s2, s2, 1
	bge	s2, s3, cs_bad_rept_body
	addi	s2, s2, 1
	j	cs_rept_body_qloop
cs_rept_body_qclose:
	addi	s2, s2, 1
	j	cs_rept_body_scan
cs_rept_body_done:
	sw	s2, 20(sp)		# body_end (points at '}')
	addi	s2, s2, 1		# consume '}'

	# Compute iteration count = high - low (+1 if inclusive).
	lw	a4, 4(sp)		# low
	lw	a5, 8(sp)		# high
	sub	a6, a5, a4
	lw	t0, 12(sp)
	beqz	t0, cs_rept_count_done
	addi	a6, a6, 1
cs_rept_count_done:
	# Bound: 0 <= count <= 4096. Negative or oversize → error.
	bltz	a6, cs_bad_rept_count
	lui	t0, 0x1
	bgeu	a6, t0, cs_bad_rept_count

	# Push (s2, s3, macro_scratch_top) onto the expansion stack.
	lla	t0, macro_stack_top
	lw	t1, 0(t0)
	lla	t2, macro_stack_end
	lw	t3, 0(t2)
	bgeu	t1, t3, cs_bad_rept_nested
	sw	s2, 0(t1)
	sw	s3, 4(t1)
	lla	t2, macro_scratch_top
	lw	t3, 0(t2)
	sw	t3, 8(t1)
	addi	t1, t1, 12
	sw	t1, 0(t0)

	# ── Expand into scratch ─────────────────────────────────────────
	# a4 = current iteration value (starts at low)
	# a5 = limit (exclusive: stop when iter >= a5)
	lw	a4, 4(sp)		# low (current iter)
	lw	t0, 12(sp)
	bnez	t0, cs_rept_init_inc
	lw	a5, 8(sp)		# exclusive
	j	cs_rept_init_done
cs_rept_init_inc:
	lw	a5, 8(sp)
	addi	a5, a5, 1		# inclusive: stop when iter >= a5+1
cs_rept_init_done:
	lla	t0, macro_scratch_top
	lw	a6, 0(t0)		# scratch write ptr (= inner_start)
	lla	t0, macro_scratch_end
	lw	a7, 0(t0)		# scratch end

cs_rept_outer:
	bge	a4, a5, cs_rept_outer_done
	# Inner loop: walk body chars, substitute \counter with decimal(a4).
	lw	t3, 16(sp)		# body_start
	lw	t4, 20(sp)		# body_end
cs_rept_inner:
	beq	t3, t4, cs_rept_inner_done
	addi	t0, a6, 1
	bgeu	t0, a7, cs_bad_rept_scratch
	lbu	t0, 0(t3)
	addi	t1, zero, 92		# '\\'
	beq	t0, t1, cs_rept_subst
	# Plain copy.
	sb	t0, 0(a6)
	addi	a6, a6, 1
	addi	t3, t3, 1
	j	cs_rept_inner

cs_rept_subst:
	# Skip backslash, read ident name, compare to counter name.
	addi	t3, t3, 1
	bge	t3, t4, cs_rept_subst_bare
	addi	t5, t3, 0		# ident start
cs_rept_subst_scan:
	beq	t3, t4, cs_rept_subst_scan_done
	lbu	t0, 0(t3)
	addi	t1, zero, '_'
	beq	t0, t1, cs_rept_subst_keep
	addi	t1, zero, '0'
	blt	t0, t1, cs_rept_subst_scan_done
	addi	t1, zero, 58
	blt	t0, t1, cs_rept_subst_keep
	addi	t1, zero, 'A'
	blt	t0, t1, cs_rept_subst_scan_done
	addi	t1, zero, 91
	blt	t0, t1, cs_rept_subst_keep
	addi	t1, zero, 'a'
	blt	t0, t1, cs_rept_subst_scan_done
	addi	t1, zero, 123
	blt	t0, t1, cs_rept_subst_keep
	j	cs_rept_subst_scan_done
cs_rept_subst_keep:
	addi	t3, t3, 1
	j	cs_rept_subst_scan
cs_rept_subst_scan_done:
	sub	t6, t3, t5		# substituted name length
	beqz	t6, cs_rept_subst_bare
	# Compare against counter name (length at sp+0, bytes at sp+28).
	lw	t0, 0(sp)
	bne	t6, t0, cs_rept_subst_passthrough
	addi	t0, zero, 0
cs_rept_subst_cmp:
	beq	t0, t6, cs_rept_subst_emit
	add	t1, t5, t0
	lbu	t2, 0(t1)
	addi	t1, sp, 28
	add	t1, t1, t0
	lbu	a0, 0(t1)
	bne	t2, a0, cs_rept_subst_passthrough
	addi	t0, t0, 1
	j	cs_rept_subst_cmp
cs_rept_subst_passthrough:
	# `\name` isn't this rept's counter — copy verbatim so a downstream
	# expansion (outer macro arg, nested rept counter) can handle it.
	addi	t0, a6, 1
	bgeu	t0, a7, cs_bad_rept_scratch
	addi	t0, zero, 92
	sb	t0, 0(a6)
	addi	a6, a6, 1
	addi	t0, t5, 0
cs_rept_subst_pass_loop:
	beq	t0, t3, cs_rept_inner
	addi	t1, a6, 1
	bgeu	t1, a7, cs_bad_rept_scratch
	lbu	t1, 0(t0)
	sb	t1, 0(a6)
	addi	a6, a6, 1
	addi	t0, t0, 1
	j	cs_rept_subst_pass_loop

cs_rept_subst_bare:
	# Bare backslash: emit it verbatim and continue.
	addi	t0, a6, 1
	bgeu	t0, a7, cs_bad_rept_scratch
	addi	t0, zero, 92
	sb	t0, 0(a6)
	addi	a6, a6, 1
	j	cs_rept_inner
cs_rept_subst_emit:
	# Emit decimal digits of a4 into scratch. Use a small in-frame buffer
	# to build digits in reverse, then copy out. Negative values get a
	# leading '-' written directly to scratch, then we negate and convert
	# the magnitude.
	addi	sp, sp, -16
	addi	t0, sp, 16		# write head (going down)
	addi	a0, a4, 0		# value to convert
	bgez	a0, cs_rept_dec_zero_check
	# Negative: write '-' into scratch first, then take absolute value.
	addi	t1, a6, 1
	bgeu	t1, a7, cs_bad_rept_scratch_pop
	addi	t1, zero, 45		# '-'
	sb	t1, 0(a6)
	addi	a6, a6, 1
	sub	a0, zero, a0
cs_rept_dec_zero_check:
	# Special-case zero.
	bnez	a0, cs_rept_dec_loop
	addi	t0, t0, -1
	addi	t1, zero, 48
	sb	t1, 0(t0)
	j	cs_rept_dec_emit
cs_rept_dec_loop:
	beqz	a0, cs_rept_dec_emit
	# a0 / 10 via repeated subtract.
	addi	t1, zero, 0		# quotient
cs_rept_dec_div:
	addi	t2, zero, 10
	blt	a0, t2, cs_rept_dec_div_done
	sub	a0, a0, t2
	addi	t1, t1, 1
	j	cs_rept_dec_div
cs_rept_dec_div_done:
	# a0 = remainder, t1 = quotient
	addi	t0, t0, -1
	addi	t2, a0, 48
	sb	t2, 0(t0)
	addi	a0, t1, 0
	j	cs_rept_dec_loop
cs_rept_dec_emit:
	# Copy from t0 .. (sp+16) to a6.
	addi	t1, sp, 16
cs_rept_dec_cp:
	beq	t0, t1, cs_rept_dec_cp_done
	addi	t2, a6, 1
	bgeu	t2, a7, cs_bad_rept_scratch_pop
	lbu	t2, 0(t0)
	sb	t2, 0(a6)
	addi	a6, a6, 1
	addi	t0, t0, 1
	j	cs_rept_dec_cp
cs_rept_dec_cp_done:
	addi	sp, sp, 16
	j	cs_rept_inner
cs_bad_rept_scratch_pop:
	addi	sp, sp, 16
	j	cs_bad_rept_scratch

cs_rept_inner_done:
	addi	a4, a4, 1
	j	cs_rept_outer
cs_rept_outer_done:
	# Update bump pointer and point s2/s3 at the just-written region.
	lla	t0, macro_scratch_top
	sw	a6, 0(t0)
	lla	t0, macro_stack_top
	lw	t1, 0(t0)
	addi	t1, t1, -12
	lw	s2, 8(t1)		# inner_start
	addi	s3, a6, 0
	addi	sp, sp, 60
	j	cs_done

cs_bad_rept_name:
	addi	a0, zero, 6		# err 6: expected identifier
	j	report_err
cs_bad_rept_in:
	addi	a0, zero, 10		# err 10: expected 'in'
	j	report_err
cs_bad_rept_range:
	addi	a0, zero, 11		# err 11: expected '..' or '..='
	j	report_err
cs_bad_rept_body:
	addi	a0, zero, 9		# err 9: expected '{'
	j	report_err
cs_bad_rept_count:
	addi	a0, zero, 84		# err 84: rept count out of range
	j	report_err
cs_bad_rept_nested:
	addi	a0, zero, 81		# err 81: nested macro/rept expansion
	j	report_err
cs_bad_rept_subst:
	addi	a0, zero, 85		# err 85: bad rept substitution
	j	report_err
cs_bad_rept_scratch:
	addi	a0, zero, 83		# err 83: scratch buffer overflow
	j	report_err

cs_kw_fn:
	# Nesting check: current_fn must be 0.
	lla	t0, current_fn
	lw	t1, 0(t0)
	bnez	t1, cs_bad_fn_nested

	addi	sp, sp, -80
	sw	s8, 0(sp)
	sw	s9, 4(sp)
	# Slots 32/36/40 are new for the value-stack save area:
	#   32(sp): saved outer expr_max_depth
	#   36(sp): save_area_addr  (start of the 9 nop save slots in prologue)
	#   40(sp): restore_area_addr (start of the 9 nop restore slots in epilogue)
	# Save outer expr_max_depth and reset the fn-local one to 0.
	lla	t0, expr_max_depth
	lw	t1, 0(t0)
	sw	t1, 32(sp)
	sw	zero, 0(t0)

	# Parse the function name.
	addi	gp, zero, 39		# skip_ws site 39 = sw_cs_var_decide — wait we need a new site
	# Actually, let me reuse a unique site for this.
	addi	gp, zero, 40		# skip_ws site 40 = sw_cs_fn_name
	j	skip_ws
sw_cs_fn_name:
	bge	s2, s3, cs_bad_fn_name
	lbu	t0, 0(s2)
	addi	t1, zero, '_'
	beq	t0, t1, cs_fn_name_start_ok
	addi	t1, zero, 'a'
	blt	t0, t1, cs_fn_name_chk_uc
	addi	t1, zero, 123
	blt	t0, t1, cs_fn_name_start_ok
cs_fn_name_chk_uc:
	addi	t1, zero, 'A'
	blt	t0, t1, cs_bad_fn_name
	addi	t1, zero, 91
	bge	t0, t1, cs_bad_fn_name
cs_fn_name_start_ok:
	addi	gp, zero, 6		# parse_ident site 6 = pi_cs_fn
	j	parse_ident
pi_cs_fn:
	# Reject keywords as the function name.
	addi	t0, zero, 2
	beq	s11, t0, cs_fn_name_chk_2
	addi	t0, zero, 3
	beq	s11, t0, cs_fn_name_chk_3
	addi	t0, zero, 4
	beq	s11, t0, cs_fn_name_chk_4
	addi	t0, zero, 5
	beq	s11, t0, cs_fn_name_chk_5
	addi	t0, zero, 6
	beq	s11, t0, cs_fn_name_chk_6
	addi	t0, zero, 8
	beq	s11, t0, cs_fn_name_chk_8
	j	cs_fn_name_ok
cs_fn_name_chk_2:
	# 'in' / 'fn' / 'or'?
	lbu	t1, 0(s10)
	addi	t2, zero, 'f'
	bne	t1, t2, cs_fn_name_chk_2_in
	lbu	t1, 1(s10)
	addi	t2, zero, 'n'
	beq	t1, t2, cs_bad_fn_name
cs_fn_name_chk_2_in:
	lbu	t1, 0(s10)
	addi	t2, zero, 'i'
	bne	t1, t2, cs_fn_name_ok
	lbu	t1, 1(s10)
	addi	t2, zero, 'n'
	beq	t1, t2, cs_bad_fn_name
	j	cs_fn_name_ok
cs_fn_name_chk_3:
	lbu	t1, 0(s10)
	addi	t2, zero, 'f'
	bne	t1, t2, cs_fn_name_ok
	lbu	t1, 1(s10)
	addi	t2, zero, 'o'
	bne	t1, t2, cs_fn_name_ok
	lbu	t1, 2(s10)
	addi	t2, zero, 'r'
	beq	t1, t2, cs_bad_fn_name
	j	cs_fn_name_ok
cs_fn_name_chk_4:
	lbu	t1, 0(s10)
	addi	t2, zero, 'l'
	bne	t1, t2, cs_fn_name_ok
	lbu	t1, 1(s10)
	addi	t2, zero, 'o'
	bne	t1, t2, cs_fn_name_ok
	lbu	t1, 2(s10)
	bne	t1, t2, cs_fn_name_ok
	lbu	t1, 3(s10)
	addi	t2, zero, 'p'
	beq	t1, t2, cs_bad_fn_name
	j	cs_fn_name_ok
cs_fn_name_chk_5:
	lbu	t1, 0(s10)
	addi	t2, zero, 'b'
	bne	t1, t2, cs_fn_name_ok
	lbu	t1, 1(s10)
	addi	t2, zero, 'r'
	bne	t1, t2, cs_fn_name_ok
	lbu	t1, 2(s10)
	addi	t2, zero, 'e'
	bne	t1, t2, cs_fn_name_ok
	lbu	t1, 3(s10)
	addi	t2, zero, 'a'
	bne	t1, t2, cs_fn_name_ok
	lbu	t1, 4(s10)
	addi	t2, zero, 'k'
	beq	t1, t2, cs_bad_fn_name
	j	cs_fn_name_ok
cs_fn_name_chk_6:
	lbu	t1, 0(s10)
	addi	t2, zero, 'r'
	bne	t1, t2, cs_fn_name_ok
	lbu	t1, 1(s10)
	addi	t2, zero, 'e'
	bne	t1, t2, cs_fn_name_ok
	lbu	t1, 2(s10)
	addi	t2, zero, 't'
	bne	t1, t2, cs_fn_name_ok
	lbu	t1, 3(s10)
	addi	t2, zero, 'u'
	bne	t1, t2, cs_fn_name_ok
	lbu	t1, 4(s10)
	addi	t2, zero, 'r'
	bne	t1, t2, cs_fn_name_ok
	lbu	t1, 5(s10)
	addi	t2, zero, 'n'
	beq	t1, t2, cs_bad_fn_name
	j	cs_fn_name_ok
cs_fn_name_chk_8:
	lbu	t1, 0(s10)
	addi	t2, zero, 'c'
	bne	t1, t2, cs_fn_name_ok
	lbu	t1, 1(s10)
	addi	t2, zero, 'o'
	bne	t1, t2, cs_fn_name_ok
	lbu	t1, 2(s10)
	addi	t2, zero, 'n'
	bne	t1, t2, cs_fn_name_ok
	lbu	t1, 3(s10)
	addi	t2, zero, 't'
	bne	t1, t2, cs_fn_name_ok
	lbu	t1, 4(s10)
	addi	t2, zero, 'i'
	bne	t1, t2, cs_fn_name_ok
	lbu	t1, 5(s10)
	addi	t2, zero, 'n'
	bne	t1, t2, cs_fn_name_ok
	lbu	t1, 6(s10)
	addi	t2, zero, 'u'
	bne	t1, t2, cs_fn_name_ok
	lbu	t1, 7(s10)
	addi	t2, zero, 'e'
	beq	t1, t2, cs_bad_fn_name
	j	cs_fn_name_ok
cs_fn_name_ok:
	# Check not already defined.
	addi	gp, zero, 0		# fn_lookup site 0 = fnlk_ret_def
	j	fn_lookup
fnlk_ret_def:
	bnez	a0, cs_bad_fn_redefined

	# Allocate the fn symtab entry NOW, before parsing params. parse_ident
	# will overwrite s10/s11 for each parameter, so we can't wait until
	# after the parameter list to call fn_alloc — we'd be allocating with
	# the wrong name. We temporarily pass entry_addr=0, num_params=0; both
	# fields are patched in place once we know them (before emitting the
	# body's prologue).
	addi	a0, zero, 0
	addi	a1, zero, 0
	addi	gp, zero, 0		# fn_alloc site 0 = fna_ret_def
	j	fn_alloc
fna_ret_def:
	sw	a0, 32(sp)		# save entry pointer

	# Parse '(' and parameter list (0..8 idents). Parameters are added to
	# the variable symtab as local slots inside a fresh scope (s8 save).
	addi	gp, zero, 41		# skip_ws site 41 = sw_cs_fn_lparen
	j	skip_ws
sw_cs_fn_lparen:
	bge	s2, s3, cs_bad_fn_lparen
	lbu	t0, 0(s2)
	addi	t1, zero, '('
	bne	t0, t1, cs_bad_fn_lparen
	addi	s2, s2, 1

	# Enter the function's fresh variable scope: save s8, start fresh
	# s9 = 0. After exit we restore from frame slots 0/4.
	addi	s9, zero, 0

	# Parse parameter idents into the variable symtab. Track count in
	# 24(sp).
	sw	zero, 24(sp)
cs_fn_param_loop:
	addi	gp, zero, 42		# skip_ws site 42 = sw_cs_fn_param
	j	skip_ws
sw_cs_fn_param:
	bge	s2, s3, cs_bad_fn_rparen
	lbu	t0, 0(s2)
	addi	t1, zero, ')'
	beq	t0, t1, cs_fn_params_done
	# If it's not the first parameter, expect a ','.
	lw	t2, 24(sp)
	beqz	t2, cs_fn_param_name
	addi	t1, zero, ','
	bne	t0, t1, cs_bad_fn_rparen
	addi	s2, s2, 1
	addi	gp, zero, 43		# skip_ws site 43 = sw_cs_fn_param_after_comma
	j	skip_ws
sw_cs_fn_param_after_comma:
	bge	s2, s3, cs_bad_fn_param_name
	lbu	t0, 0(s2)
cs_fn_param_name:
	# Check letter-start.
	addi	t1, zero, '_'
	beq	t0, t1, cs_fn_param_ok
	addi	t1, zero, 'a'
	blt	t0, t1, cs_fn_param_chk_uc
	addi	t1, zero, 123
	blt	t0, t1, cs_fn_param_ok
cs_fn_param_chk_uc:
	addi	t1, zero, 'A'
	blt	t0, t1, cs_bad_fn_param_name
	addi	t1, zero, 91
	bge	t0, t1, cs_bad_fn_param_name
cs_fn_param_ok:
	# Enforce 8-arg max.
	lw	t2, 24(sp)
	addi	t3, zero, 8
	bge	t2, t3, cs_bad_fn_too_many_args
	# parse_ident and force-alloc the param.
	addi	gp, zero, 7		# parse_ident site 7 = pi_cs_fn_param
	j	parse_ident
pi_cs_fn_param:
	beqz	s11, cs_bad_fn_param_name
	addi	gp, zero, 5		# lookup_or_alloc site 5 = la_cs_fn_param
	j	la_new
la_cs_fn_param:
	# Function parameters are mutable (caller can modify locally).
	lla	t0, last_ident_entry
	lw	t1, 0(t0)
	addi	t2, zero, 1
	sb	t2, 37(t1)
	# a0 = slot offset (= (count * 4), since s9 started at 0). Increment
	# param count.
	lw	t2, 24(sp)
	addi	t2, t2, 1
	sw	t2, 24(sp)
	j	cs_fn_param_loop

cs_fn_params_done:
	# Consume ')'.
	addi	s2, s2, 1

	# Peek '{' — body follows. We don't consume it; compile_expr_p's nud
	# will see it and dispatch to ct_lbrace.
	addi	gp, zero, 44		# skip_ws site 44 = sw_cs_fn_lbrace
	j	skip_ws
sw_cs_fn_lbrace:
	bge	s2, s3, cs_bad_fn_body
	lbu	t0, 0(s2)
	addi	t1, zero, '{'
	bne	t0, t1, cs_bad_fn_body

	# Emit `jal zero, 0` (placeholder) so normal top-level execution skips
	# over the function body. We'll patch it to the post-epilogue addr.
	lui	a0, 0
	addi	a0, a0, 0x6F
	addi	gp, zero, 43		# emit_word site 43 = ew_cs_fn_skip
	j	emit_word
ew_cs_fn_skip:
	addi	t0, s5, -4
	sw	t0, 20(sp)		# skip_jal addr

	# Record the function's entry address (= current s5) and update the
	# fn symtab entry we pre-allocated earlier with the real entry_addr
	# and num_params.
	sw	s5, 8(sp)
	lw	t0, 32(sp)		# entry ptr
	sw	s5, 32(t0)		# entry_addr
	lw	t1, 24(sp)		# num_params
	sb	t1, 36(t0)		# num_params

	# Mark "we're inside a function body" — used by return keyword check.
	lw	t0, 8(sp)
	lla	t1, current_fn
	sw	t0, 0(t1)
	# Reset the per-function return-placeholder list.
	lla	t0, ret_list_base
	lw	t1, 0(t0)
	lla	t0, ret_list_top
	sw	t1, 0(t0)

	# ── Emit prologue ───────────────────────────────────────────────
	# addi sp, sp, -4 (reserve slot for saved fp)
	lui	a0, 0xFFC10
	addi	a0, a0, 0x113
	addi	gp, zero, 44		# emit_word site 44 = ew_cs_fn_prol1
	j	emit_word
ew_cs_fn_prol1:
	# sw fp, 0(sp)   word 0x00812023
	lui	a0, 0x812
	addi	a0, a0, 0x023
	addi	gp, zero, 45		# emit_word site 45 = ew_cs_fn_prol2
	j	emit_word
ew_cs_fn_prol2:
	# Shadow stack push: addi tp, tp, -4  (word 0xFFC20213)
	lui	a0, 0xFFC20
	addi	a0, a0, 0x213
	addi	gp, zero, 46		# emit_word site 46 = ew_cs_fn_prol3
	j	emit_word
ew_cs_fn_prol3:
	# Shadow stack save: sw ra, 0(tp)  (word 0x00122023)
	lui	a0, 0x122
	addi	a0, a0, 0x023
	addi	gp, zero, 47		# emit_word site 47 = ew_cs_fn_prol4
	j	emit_word
ew_cs_fn_prol4:
	# Frame alloc: 3-instruction sequence to support frames up to 2^20 bytes.
	#   lui  t0, 0       (patched after body to hi20(frame_size))
	#   addi t0, t0, 0   (patched after body to lo12(frame_size))
	#   sub  sp, sp, t0
	# Emit lui t0, 0 = 0x000002B7
	lui	a0, 0
	addi	a0, a0, 0x2B7
	addi	gp, zero, 48		# emit_word site 48 = ew_cs_fn_prol5
	j	emit_word
ew_cs_fn_prol5:
	addi	t0, s5, -4
	sw	t0, 12(sp)		# frame_alloc lui addr
	# Emit addi t0, t0, 0 = 0x00028293
	lui	a0, 0x28
	addi	a0, a0, 0x293
	addi	gp, zero, 103		# emit_word site 103 = ew_cs_fn_prol5b
	j	emit_word
ew_cs_fn_prol5b:
	addi	t0, s5, -4
	sw	t0, 16(sp)		# frame_alloc addi addr
	# Emit sub sp, sp, t0 = 0x40510133
	lui	a0, 0x40510
	addi	a0, a0, 0x133
	addi	gp, zero, 104		# emit_word site 104 = ew_cs_fn_prol5c
	j	emit_word
ew_cs_fn_prol5c:
	addi	gp, zero, 1		# esc site 1 = esc_ret_fn
	j	emit_stack_check
esc_ret_fn:
	# addi fp, sp, 0   word 0x00010413
	lui	a0, 0x10
	addi	a0, a0, 0x413
	addi	gp, zero, 49		# emit_word site 49 = ew_cs_fn_prol6
	j	emit_word
ew_cs_fn_prol6:

	# ── Reserve a single jal placeholder for the save block ──────
	# After body compile we know max_depth. If > 0, this jal is patched
	# to jump to a save_block emitted at the tail of the fn binary
	# (which then jumps back to right after this slot). If max_depth
	# == 0, it's patched to a nop and no trailer is emitted.
	sw	s5, 36(sp)		# save_jal_addr
	lui	a0, 0
	addi	a0, a0, 0x6F		# jal zero, 0 (placeholder)
	addi	gp, zero, 106		# emit_word site 106 = ew_cs_fn_save_nop
	j	emit_word
ew_cs_fn_save_nop:

	# Emit `sw a_i, (i*4)(fp)` for each param. Words:
	#   sw a0, 0(fp)   0x00a42023
	#   sw a1, 4(fp)   0x00b42223
	#   sw a2, 8(fp)   0x00c42423
	#   sw a3, 12(fp)  0x00d42623
	#   sw a4, 16(fp)  0x00e42823
	#   sw a5, 20(fp)  0x00f42a23
	#   sw a6, 24(fp)  0x01042c23
	#   sw a7, 28(fp)  0x01142e23
	lw	t5, 24(sp)		# num_params
	beqz	t5, cs_fn_params_saved
	# param 0
	lui	a0, 0xA42
	addi	a0, a0, 0x023
	addi	gp, zero, 50		# emit_word site 50 = ew_cs_fn_sv0
	j	emit_word
ew_cs_fn_sv0:
	lw	t5, 24(sp)
	addi	t6, zero, 1
	beq	t5, t6, cs_fn_params_saved
	# param 1
	lui	a0, 0xB42
	addi	a0, a0, 0x223
	addi	gp, zero, 51		# emit_word site 51 = ew_cs_fn_sv1
	j	emit_word
ew_cs_fn_sv1:
	lw	t5, 24(sp)
	addi	t6, zero, 2
	beq	t5, t6, cs_fn_params_saved
	lui	a0, 0xC42
	addi	a0, a0, 0x423
	addi	gp, zero, 52		# emit_word site 52 = ew_cs_fn_sv2
	j	emit_word
ew_cs_fn_sv2:
	lw	t5, 24(sp)
	addi	t6, zero, 3
	beq	t5, t6, cs_fn_params_saved
	lui	a0, 0xD42
	addi	a0, a0, 0x623
	addi	gp, zero, 53		# emit_word site 53 = ew_cs_fn_sv3
	j	emit_word
ew_cs_fn_sv3:
	lw	t5, 24(sp)
	addi	t6, zero, 4
	beq	t5, t6, cs_fn_params_saved
	lui	a0, 0xE42
	addi	a0, a0, 0x823
	addi	gp, zero, 54		# emit_word site 54 = ew_cs_fn_sv4
	j	emit_word
ew_cs_fn_sv4:
	lw	t5, 24(sp)
	addi	t6, zero, 5
	beq	t5, t6, cs_fn_params_saved
	lui	a0, 0xF42
	addi	a0, a0, 0xA23
	addi	gp, zero, 55		# emit_word site 55 = ew_cs_fn_sv5
	j	emit_word
ew_cs_fn_sv5:
	lw	t5, 24(sp)
	addi	t6, zero, 6
	beq	t5, t6, cs_fn_params_saved
	lui	a0, 0x1042
	addi	a0, a0, 0xC23
	addi	gp, zero, 56		# emit_word site 56 = ew_cs_fn_sv6
	j	emit_word
ew_cs_fn_sv6:
	lw	t5, 24(sp)
	addi	t6, zero, 7
	beq	t5, t6, cs_fn_params_saved
	lui	a0, 0x1142
	addi	a0, a0, 0xE23
	addi	gp, zero, 57		# emit_word site 57 = ew_cs_fn_sv7
	j	emit_word
ew_cs_fn_sv7:
cs_fn_params_saved:

	# Compile the body — compile_expr_p sees '{' and parses a block.
	addi	t6, zero, 0
	addi	gp, zero, 32		# compile_expr site 32 = ce_cs_fn_body
	j	compile_expr_p
ce_cs_fn_body:

	# ── Frame-size adjustment for the value-stack save area ───────
	# Snapshot locals_total so the trailer (after the epilogue) can
	# build save/restore offsets against it, and grow s9 by max_depth*4
	# so the frame_alloc and frame_free patchers reserve room for the
	# save area at the top of the locals frame.
	sw	s9, 44(sp)		# locals_total
	lla	t0, expr_max_depth
	lw	t6, 0(t0)		# t6 = max_depth (used several times below)
	beqz	t6, cs_fn_skip_grow
	slli	a0, t6, 2
	add	s9, s9, a0
cs_fn_skip_grow:

	# ── Patch frame_alloc lui/addi to load frame_size into t0 ──────
	# frame_size = s9. Prologue emitted lui t0, 0; addi t0, t0, 0; sub sp, sp, t0.
	# We patch the lui's imm20 to hi20(s9) and the addi's imm12 to lo12(s9).
	# Max frame size = 2^20 (enforced in la_new).
	lui	t0, 0x100
	bgeu	s9, t0, cs_bad_fn_frame_too_big
	# Compute hi20 = (s9 + 0x800) >> 12 (rounded), lo12 = s9 - (hi20 << 12)
	addi	t0, zero, 1
	slli	t0, t0, 11		# 0x800
	add	t1, s9, t0
	srai	t1, t1, 12		# hi20
	# Patch lui t0, hi20: OR (hi20 << 12) into the placeholder word
	lw	t5, 12(sp)		# lui addr
	lw	t0, 0(t5)
	slli	t2, t1, 12		# hi20 << 12
	or	t0, t0, t2
	sw	t0, 0(t5)
	# Compute lo12 = s9 - (hi20 << 12)
	sub	t2, s9, t2
	# Patch addi t0, t0, lo12: OR (lo12[11:0] << 20) into the placeholder
	lw	t5, 16(sp)		# addi addr
	lw	t0, 0(t5)
	andi	t2, t2, 0xFFF
	slli	t2, t2, 20
	or	t0, t0, t2
	sw	t0, 0(t5)

	# ── Epilogue ────────────────────────────────────────────────────
	# Epilogue start addr = s5 (used to patch all returns' jals).
	sw	s5, 16(sp)		# save epilogue start (reusing the slot)
	# Patch every return placeholder in ret_list_base..ret_list_top.
	# Save loop state around patch_jtype since it clobbers t-regs.
	lla	t0, ret_list_base
	lw	t1, 0(t0)
	lla	t0, ret_list_top
	lw	t2, 0(t0)
cs_fn_patch_rets:
	beq	t1, t2, cs_fn_patch_rets_done
	lw	t5, 0(t1)		# placeholder addr
	addi	t6, s5, 0		# target
	addi	sp, sp, -8
	sw	t1, 0(sp)
	sw	t2, 4(sp)
	addi	gp, zero, 17		# patch_jtype site 17 = pjt_cs_fn_ret
	j	patch_jtype
pjt_cs_fn_ret:
	lw	t1, 0(sp)
	lw	t2, 4(sp)
	addi	sp, sp, 8
	addi	t1, t1, 4
	j	cs_fn_patch_rets
cs_fn_patch_rets_done:

	# ── Reserve a single jal placeholder for the restore block ────
	# Mirrors the prologue's save jal: patched to jump to a restore_block
	# in the trailer (or to nop if max_depth == 0).
	sw	s5, 40(sp)		# restore_jal_addr
	lui	a0, 0
	addi	a0, a0, 0x6F		# jal zero, 0 (placeholder)
	addi	gp, zero, 107		# emit_word site 107 = ew_cs_fn_restore_nop
	j	emit_word
ew_cs_fn_restore_nop:

	# (Save/restore patching now happens after the entire fn body +
	# epilogue + master_dispatch jal is emitted — see the trailer
	# block below at cs_fn_emit_save_restore.)

	# Emit frame free: compute `sp = fp + frame_size` via 3-instruction
	# sequence so large frames (up to 2^20) work. Uses t0 as scratch.
	#   lui  t0, hi20(frame_size)
	#   addi t0, t0, lo12(frame_size)
	#   add  sp, fp, t0
	# Compute hi20/lo12 of s9 (positive).
	addi	t0, zero, 1
	slli	t0, t0, 11		# 0x800
	add	t1, s9, t0
	srai	t1, t1, 12		# hi20
	slli	t2, t1, 12		# hi20 << 12 (for lui imm placement)
	# Save hi20<<12 and lo12 in sp slots (survival across emit_word calls).
	addi	sp, sp, -8
	sw	t2, 0(sp)		# hi20 << 12
	sub	t3, s9, t2		# lo12
	sw	t3, 4(sp)		# lo12
	# Emit lui t0, hi20 (base 0x002B7)
	lui	a0, 0
	addi	a0, a0, 0x2B7
	or	a0, a0, t2
	addi	gp, zero, 58		# emit_word site 58 = ew_cs_fn_ep1
	j	emit_word
ew_cs_fn_ep1:
	# Emit addi t0, t0, lo12 (base 0x00028293)
	lw	t3, 4(sp)
	andi	t3, t3, 0xFFF
	slli	t3, t3, 20
	lui	a0, 0x28
	addi	a0, a0, 0x293
	or	a0, a0, t3
	addi	gp, zero, 59		# emit_word site 59 = ew_cs_fn_ep2
	j	emit_word
ew_cs_fn_ep2:
	addi	sp, sp, 8		# free the hi20/lo12 scratch slots
	# Emit add sp, fp, t0 (word 0x00540133)
	#   opcode 0x33, rd=2(sp), rs1=8(fp), rs2=5(t0), f7=0
	#   word = 0x33 | (2<<7) | (8<<15) | (5<<20) = 0x33 | 0x100 | 0x40000 | 0x500000 = 0x00540133
	lui	a0, 0x540
	addi	a0, a0, 0x133
	addi	gp, zero, 105		# emit_word site 105 = ew_cs_fn_ep2b
	j	emit_word
ew_cs_fn_ep2b:
	# Emit: lw fp, 0(sp)   word 0x00012403 — restore fp from DATA stack.
	lui	a0, 0x12
	addi	a0, a0, 0x403
	addi	gp, zero, 60		# emit_word site 60 = ew_cs_fn_ep3
	j	emit_word
ew_cs_fn_ep3:
	# Emit: addi sp, sp, 4   word 0x00410113 — pop fp slot.
	lui	a0, 0x410
	addi	a0, a0, 0x113
	addi	gp, zero, 61		# emit_word site 61 = ew_cs_fn_ep4
	j	emit_word
ew_cs_fn_ep4:
	# Shadow stack pop: lw ra, 0(tp)  word 0x00022083
	lui	a0, 0x22
	addi	a0, a0, 0x083
	addi	gp, zero, 62		# emit_word site 62 = ew_cs_fn_ep5
	j	emit_word
ew_cs_fn_ep5:
	# Shadow stack pop: addi tp, tp, 4  word 0x00420213
	lui	a0, 0x420
	addi	a0, a0, 0x213
	addi	gp, zero, 63		# emit_word site 63 = ew_cs_fn_ep6
	j	emit_word
ew_cs_fn_ep6:
	# Emit: jal zero, 0 (placeholder) — patched by master_dispatch emit.
	lui	a0, 0
	addi	a0, a0, 0x6F
	addi	gp, zero, 64		# emit_word site 64 = ew_cs_fn_ep7
	j	emit_word
ew_cs_fn_ep7:
	# Append jal addr to md_patch list.
	addi	a0, s5, -4
	lla	a1, md_patch_base
	lla	a2, md_patch_top
	lla	a3, md_patch_end
	addi	gp, zero, 2		# list_append_word site 2 = law_ret_md_patch
	j	list_append_word
law_ret_md_patch:

	# ── Value-stack save/restore trailer ──────────────────────────
	# We deferred reservation of the save area to a single jal placeholder
	# in the prologue (and one in the epilogue). Now we know max_depth:
	#   max_depth == 0 → patch both jals to nop (8 bytes overhead)
	#   max_depth >  0 → emit save_block + restore_block here, patch the
	#                    jals to jump to them
	#
	# Each block ends with a `jal zero, ret_addr` that sends control back
	# to the instruction right after the original placeholder.
	lla	t0, expr_max_depth
	lw	t6, 0(t0)
	beqz	t6, cs_fn_skip_save_blocks

	# ── Emit save_block ──
	sw	s5, 48(sp)		# save_block_addr
	sw	zero, 52(sp)		# i
cs_fn_save_emit_loop:
	lw	a0, 52(sp)
	beq	a0, t6, cs_fn_save_emit_done
	# offset = locals_total + i*4
	lw	t0, 44(sp)		# locals_total
	slli	t1, a0, 2
	add	t2, t0, t1
	# encode `sw s[2+i], offset(fp)`
	addi	t1, a0, 18
	slli	t1, t1, 20		# rs2
	lui	a0, 0x42
	addi	a0, a0, 0x023
	or	a0, a0, t1
	andi	t1, t2, 0x1F
	slli	t1, t1, 7
	or	a0, a0, t1
	srli	t1, t2, 5
	andi	t1, t1, 0x7F
	slli	t1, t1, 25
	or	a0, a0, t1
	addi	gp, zero, 108		# emit_word site 108 = ew_cs_fn_save_emit
	j	emit_word
ew_cs_fn_save_emit:
	lw	a0, 52(sp)
	addi	a0, a0, 1
	sw	a0, 52(sp)
	# Reload max_depth (clobbered by emit_word via t6).
	lla	t0, expr_max_depth
	lw	t6, 0(t0)
	j	cs_fn_save_emit_loop
cs_fn_save_emit_done:
	# Emit `jal zero, save_jal_addr + 4` to return.
	lw	t0, 36(sp)		# save_jal_addr
	addi	t6, t0, 4		# target
	addi	t5, s5, 0		# this jal addr
	# Encode jal zero, (target - this_addr)
	sub	t6, t6, t5
	# Use patch_jtype on a placeholder: emit placeholder, patch.
	lui	a0, 0
	addi	a0, a0, 0x6F
	addi	gp, zero, 109		# emit_word site 109 = ew_cs_fn_save_back
	j	emit_word
ew_cs_fn_save_back:
	# Patch the just-emitted jal to target save_jal_addr+4.
	addi	t5, s5, -4
	lw	t0, 36(sp)
	addi	t6, t0, 4
	addi	gp, zero, 22		# patch_jtype site 22 = pjt_cs_fn_save_back
	j	patch_jtype
pjt_cs_fn_save_back:

	# ── Emit restore_block ──
	sw	s5, 56(sp)		# restore_block_addr
	sw	zero, 52(sp)		# i = 0
	# Reload max_depth.
	lla	t0, expr_max_depth
	lw	t6, 0(t0)
cs_fn_restore_emit_loop:
	lw	a0, 52(sp)
	beq	a0, t6, cs_fn_restore_emit_done
	# offset = locals_total + i*4
	lw	t0, 44(sp)
	slli	t1, a0, 2
	add	t2, t0, t1
	# encode `lw s[2+i], offset(fp)`
	#   opcode=0x03, rd=18+i, f3=2, rs1=8(fp), imm=offset
	addi	t1, a0, 18
	slli	t1, t1, 7		# rd
	lui	a0, 0x42
	addi	a0, a0, 0x003
	or	a0, a0, t1
	andi	t1, t2, 0xFFF
	slli	t1, t1, 20
	or	a0, a0, t1
	addi	gp, zero, 110		# emit_word site 110 = ew_cs_fn_restore_emit
	j	emit_word
ew_cs_fn_restore_emit:
	lw	a0, 52(sp)
	addi	a0, a0, 1
	sw	a0, 52(sp)
	lla	t0, expr_max_depth
	lw	t6, 0(t0)
	j	cs_fn_restore_emit_loop
cs_fn_restore_emit_done:
	# Emit `jal zero, restore_jal_addr + 4` to return.
	lui	a0, 0
	addi	a0, a0, 0x6F
	addi	gp, zero, 111		# emit_word site 111 = ew_cs_fn_restore_back
	j	emit_word
ew_cs_fn_restore_back:
	addi	t5, s5, -4
	lw	t0, 40(sp)
	addi	t6, t0, 4
	addi	gp, zero, 23		# patch_jtype site 23 = pjt_cs_fn_restore_back
	j	patch_jtype
pjt_cs_fn_restore_back:

	# ── Patch the prologue save_jal to jump to save_block_addr ──
	lw	t5, 36(sp)		# save_jal_addr
	lw	t6, 48(sp)		# save_block_addr
	addi	gp, zero, 24		# patch_jtype site 24 = pjt_cs_fn_save_jal
	j	patch_jtype
pjt_cs_fn_save_jal:
	# ── Patch the epilogue restore_jal to jump to restore_block_addr ──
	lw	t5, 40(sp)		# restore_jal_addr
	lw	t6, 56(sp)		# restore_block_addr
	addi	gp, zero, 25		# patch_jtype site 25 = pjt_cs_fn_restore_jal
	j	patch_jtype
pjt_cs_fn_restore_jal:
	j	cs_fn_save_done

cs_fn_skip_save_blocks:
	# max_depth == 0: patch both jal placeholders to nop.
	lw	t0, 36(sp)
	lui	t1, 0
	addi	t1, t1, 0x13		# nop
	sw	t1, 0(t0)
	lw	t0, 40(sp)
	sw	t1, 0(t0)
cs_fn_save_done:

	# Restore outer expr_max_depth.
	lw	t0, 32(sp)
	lla	t1, expr_max_depth
	sw	t0, 0(t1)

	# ── Patch the skip-over jal at start of fn to point to current s5 ──
	lw	t5, 20(sp)
	addi	t6, s5, 0
	addi	gp, zero, 18		# patch_jtype site 18 = pjt_cs_fn_skip
	j	patch_jtype
pjt_cs_fn_skip:

	# ── Restore outer scope ────────────────────────────────────────
	lw	s8, 0(sp)
	lw	s9, 4(sp)
	lla	t0, current_fn
	sw	zero, 0(t0)

	addi	sp, sp, 80
	j	cs_done

# ══════════════════════════════════════════════════════════════════════════════
# cs_kw_asm — inline assembly block.
#
# Syntax:
#   asm {
#       (reg=var)         — emit lw reg, var_off(fp)
#       (var=reg)         — emit sw reg, var_off(fp)
#       MNEMONIC args     — raw RV32I instruction
#   }
#
# MVP mnemonics: nop, mv, li, lui, addi, add, sub
# ══════════════════════════════════════════════════════════════════════════════
cs_kw_asm:
	addi	gp, zero, 74		# skip_ws site 74 = asm_sw_lbrace
	j	skip_ws
asm_sw_lbrace:
	bge	s2, s3, asm_bad_lbrace
	lbu	t0, 0(s2)
	addi	t1, zero, '{'
	bne	t0, t1, asm_fn_begin	# not '{' → named asm function
	addi	s2, s2, 1
	# Inline asm block: clear asm-fn marker.
	lla	t0, current_asm_fn
	sw	zero, 0(t0)
asm_loop:
	# Bin-end guard: every asm instruction handler emits via direct
	# `sw a0, 0(s5)` (bypassing emit_word). Reserve enough headroom for
	# the largest single instruction emit — currently 8 bytes (li-expand,
	# lla, etc.) — and bail loudly if the next instr wouldn't fit.
	addi	t0, s5, 8
	lla	t1, bin_end
	lw	t1, 0(t1)
	bgeu	t0, t1, bin_full
	addi	gp, zero, 75		# skip_ws site 75 = asm_sw_item
	j	skip_ws
asm_sw_item:
	bge	s2, s3, asm_bad_unterm
	lbu	t0, 0(s2)
	addi	t1, zero, '}'
	beq	t0, t1, asm_end
	addi	t1, zero, '('
	beq	t0, t1, asm_binding
	addi	t1, zero, '.'
	beq	t0, t1, asm_directive
	# Check for numeric label definition: digit followed by ':'
	addi	t1, zero, '0'
	blt	t0, t1, asm_not_digit
	addi	t1, zero, 58		# '9' + 1
	blt	t0, t1, asm_num_label_def
asm_not_digit:
	addi	gp, zero, 17		# parse_ident site 17 = asm_pi_mnem
	j	parse_ident
asm_pi_mnem:
	beqz	s11, asm_bad_mnem
	# Check if this is a label definition: `name:`
	bge	s2, s3, asm_mnem_dispatch
	lbu	t0, 0(s2)
	addi	t1, zero, ':'
	bne	t0, t1, asm_mnem_dispatch
	addi	s2, s2, 1		# consume ':'
	j	asm_define_label
asm_mnem_dispatch:
	addi	t0, zero, 5
	beq	s11, t0, asm_chk_len5
	addi	t0, zero, 4
	beq	s11, t0, asm_chk_len4
	addi	t0, zero, 3
	beq	s11, t0, asm_chk_len3
	addi	t0, zero, 2
	beq	s11, t0, asm_chk_len2
	addi	t0, zero, 1
	beq	s11, t0, asm_chk_len1
	j	asm_bad_mnem
asm_chk_len1:
	lbu	t1, 0(s10)
	addi	t2, zero, 'j'
	beq	t1, t2, asm_instr_j
	j	asm_bad_mnem

# ── Length 5: auipc, sltiu ────────────────────────────────────────────────────
asm_chk_len5:
	lbu	t1, 0(s10)
	addi	t2, zero, 'a'
	beq	t1, t2, asm_chk_auipc
	addi	t2, zero, 's'
	beq	t1, t2, asm_chk_sltiu
	j	asm_bad_mnem
asm_chk_auipc:
	lbu	t1, 1(s10)
	addi	t2, zero, 'u'
	bne	t1, t2, asm_bad_mnem
	lbu	t1, 2(s10)
	addi	t2, zero, 'i'
	bne	t1, t2, asm_bad_mnem
	lbu	t1, 3(s10)
	addi	t2, zero, 'p'
	bne	t1, t2, asm_bad_mnem
	lbu	t1, 4(s10)
	addi	t2, zero, 'c'
	bne	t1, t2, asm_bad_mnem
	j	asm_instr_auipc
asm_chk_sltiu:
	lbu	t1, 1(s10)
	addi	t2, zero, 'l'
	bne	t1, t2, asm_bad_mnem
	lbu	t1, 2(s10)
	addi	t2, zero, 't'
	bne	t1, t2, asm_bad_mnem
	lbu	t1, 3(s10)
	addi	t2, zero, 'i'
	bne	t1, t2, asm_bad_mnem
	lbu	t1, 4(s10)
	addi	t2, zero, 'u'
	bne	t1, t2, asm_bad_mnem
	j	asm_instr_sltiu

# ── Length 4: addi, xori, andi, slti, slli, srli, srai, sltu, bltu, bgeu,
#             beqz, bnez, bltz, bgez, bgtu, bleu (pseudos),
#             seqz, snez, sltz, sgtz (pseudos) ─────────────────────────────
asm_chk_len4:
	lbu	t1, 0(s10)
	addi	t2, zero, 'a'
	beq	t1, t2, asm_chk_l4_a
	addi	t2, zero, 'x'
	beq	t1, t2, asm_chk_xori
	addi	t2, zero, 's'
	beq	t1, t2, asm_chk_l4_s
	addi	t2, zero, 'b'
	beq	t1, t2, asm_chk_l4_b
	j	asm_bad_mnem
asm_chk_l4_b:
	# bltu, bgeu, beqz, bnez, bltz, bgez, bgtu, bleu
	lbu	t1, 1(s10)
	addi	t2, zero, 'l'
	beq	t1, t2, asm_chk_l4_bl
	addi	t2, zero, 'g'
	beq	t1, t2, asm_chk_l4_bg
	addi	t2, zero, 'e'
	beq	t1, t2, asm_chk_l4_be
	addi	t2, zero, 'n'
	beq	t1, t2, asm_chk_l4_bn
	j	asm_bad_mnem
asm_chk_l4_bl:
	# bltu, bltz, bleu
	lbu	t1, 2(s10)
	addi	t2, zero, 't'
	beq	t1, t2, asm_chk_l4_blt
	addi	t2, zero, 'e'
	beq	t1, t2, asm_chk_l4_ble
	j	asm_bad_mnem
asm_chk_l4_blt:
	lbu	t1, 3(s10)
	addi	t2, zero, 'u'
	beq	t1, t2, asm_instr_bltu
	addi	t2, zero, 'z'
	beq	t1, t2, asm_instr_bltz
	j	asm_bad_mnem
asm_chk_l4_ble:
	lbu	t1, 3(s10)
	addi	t2, zero, 'u'
	bne	t1, t2, asm_bad_mnem
	j	asm_instr_bleu
asm_chk_l4_bg:
	# bgeu, bgez, bgtu
	lbu	t1, 2(s10)
	addi	t2, zero, 'e'
	beq	t1, t2, asm_chk_l4_bge
	addi	t2, zero, 't'
	beq	t1, t2, asm_chk_l4_bgt
	j	asm_bad_mnem
asm_chk_l4_bge:
	lbu	t1, 3(s10)
	addi	t2, zero, 'u'
	beq	t1, t2, asm_instr_bgeu
	addi	t2, zero, 'z'
	beq	t1, t2, asm_instr_bgez
	j	asm_bad_mnem
asm_chk_l4_bgt:
	lbu	t1, 3(s10)
	addi	t2, zero, 'u'
	bne	t1, t2, asm_bad_mnem
	j	asm_instr_bgtu
asm_chk_l4_be:
	lbu	t1, 2(s10)
	addi	t2, zero, 'q'
	bne	t1, t2, asm_bad_mnem
	lbu	t1, 3(s10)
	addi	t2, zero, 'z'
	bne	t1, t2, asm_bad_mnem
	j	asm_instr_beqz
asm_chk_l4_bn:
	lbu	t1, 2(s10)
	addi	t2, zero, 'e'
	bne	t1, t2, asm_bad_mnem
	lbu	t1, 3(s10)
	addi	t2, zero, 'z'
	bne	t1, t2, asm_bad_mnem
	j	asm_instr_bnez
asm_chk_l4_a:
	# addi or andi
	lbu	t1, 1(s10)
	addi	t2, zero, 'd'
	beq	t1, t2, asm_chk_addi
	addi	t2, zero, 'n'
	beq	t1, t2, asm_chk_andi
	j	asm_bad_mnem
asm_chk_addi:
	lbu	t1, 2(s10)
	addi	t2, zero, 'd'
	bne	t1, t2, asm_bad_mnem
	lbu	t1, 3(s10)
	addi	t2, zero, 'i'
	bne	t1, t2, asm_bad_mnem
	j	asm_instr_addi
asm_chk_andi:
	lbu	t1, 2(s10)
	addi	t2, zero, 'd'
	bne	t1, t2, asm_bad_mnem
	lbu	t1, 3(s10)
	addi	t2, zero, 'i'
	bne	t1, t2, asm_bad_mnem
	j	asm_instr_andi
asm_chk_xori:
	lbu	t1, 1(s10)
	addi	t2, zero, 'o'
	bne	t1, t2, asm_bad_mnem
	lbu	t1, 2(s10)
	addi	t2, zero, 'r'
	bne	t1, t2, asm_bad_mnem
	lbu	t1, 3(s10)
	addi	t2, zero, 'i'
	bne	t1, t2, asm_bad_mnem
	j	asm_instr_xori
asm_chk_l4_s:
	# slti, slli, srli, srai, sltu, sltz, seqz, snez, sgtz
	lbu	t1, 1(s10)
	addi	t2, zero, 'l'
	beq	t1, t2, asm_chk_l4_sl
	addi	t2, zero, 'r'
	beq	t1, t2, asm_chk_l4_sr
	addi	t2, zero, 'e'
	beq	t1, t2, asm_chk_l4_se
	addi	t2, zero, 'n'
	beq	t1, t2, asm_chk_l4_sn
	addi	t2, zero, 'g'
	beq	t1, t2, asm_chk_l4_sg
	j	asm_bad_mnem
asm_chk_l4_se:
	lbu	t1, 2(s10)
	addi	t2, zero, 'q'
	bne	t1, t2, asm_bad_mnem
	lbu	t1, 3(s10)
	addi	t2, zero, 'z'
	bne	t1, t2, asm_bad_mnem
	j	asm_instr_seqz
asm_chk_l4_sn:
	lbu	t1, 2(s10)
	addi	t2, zero, 'e'
	bne	t1, t2, asm_bad_mnem
	lbu	t1, 3(s10)
	addi	t2, zero, 'z'
	bne	t1, t2, asm_bad_mnem
	j	asm_instr_snez
asm_chk_l4_sg:
	lbu	t1, 2(s10)
	addi	t2, zero, 't'
	bne	t1, t2, asm_bad_mnem
	lbu	t1, 3(s10)
	addi	t2, zero, 'z'
	bne	t1, t2, asm_bad_mnem
	j	asm_instr_sgtz
asm_chk_l4_sl:
	# slti, slli, sltu, sltz
	lbu	t1, 2(s10)
	addi	t2, zero, 't'
	beq	t1, t2, asm_chk_l4_slt
	addi	t2, zero, 'l'
	beq	t1, t2, asm_chk_slli
	j	asm_bad_mnem
asm_chk_l4_slt:
	lbu	t1, 3(s10)
	addi	t2, zero, 'i'
	beq	t1, t2, asm_instr_slti
	addi	t2, zero, 'u'
	beq	t1, t2, asm_instr_sltu
	addi	t2, zero, 'z'
	beq	t1, t2, asm_instr_sltz
	j	asm_bad_mnem
asm_chk_slli:
	lbu	t1, 3(s10)
	addi	t2, zero, 'i'
	bne	t1, t2, asm_bad_mnem
	j	asm_instr_slli
asm_chk_l4_sr:
	# srli, srai
	lbu	t1, 2(s10)
	addi	t2, zero, 'l'
	beq	t1, t2, asm_chk_srli
	addi	t2, zero, 'a'
	beq	t1, t2, asm_chk_srai
	j	asm_bad_mnem
asm_chk_srli:
	lbu	t1, 3(s10)
	addi	t2, zero, 'i'
	bne	t1, t2, asm_bad_mnem
	j	asm_instr_srli
asm_chk_srai:
	lbu	t1, 3(s10)
	addi	t2, zero, 'i'
	bne	t1, t2, asm_bad_mnem
	j	asm_instr_srai

# ── Length 3: nop, add, sub, lui, xor, and, sll, srl, sra, slt, ori,
#             beq, bne, blt, bge, jal, lhu, lbu, wfi,
#             not, neg, bgt, ble (pseudos) ─────────────────────────────────
asm_chk_len3:
	lbu	t1, 0(s10)
	addi	t2, zero, 'n'
	beq	t1, t2, asm_chk_l3_n
	addi	t2, zero, 'a'
	beq	t1, t2, asm_chk_l3_a
	addi	t2, zero, 's'
	beq	t1, t2, asm_chk_l3_s
	addi	t2, zero, 'l'
	beq	t1, t2, asm_chk_lui
	addi	t2, zero, 'x'
	beq	t1, t2, asm_chk_xor
	addi	t2, zero, 'o'
	beq	t1, t2, asm_chk_ori
	addi	t2, zero, 'b'
	beq	t1, t2, asm_chk_l3_b
	addi	t2, zero, 'j'
	beq	t1, t2, asm_chk_jal
	addi	t2, zero, 'w'
	beq	t1, t2, asm_chk_wfi
	j	asm_bad_mnem
asm_chk_l3_n:
	# nop, not, neg
	lbu	t1, 1(s10)
	addi	t2, zero, 'o'
	beq	t1, t2, asm_chk_l3_no
	addi	t2, zero, 'e'
	beq	t1, t2, asm_chk_l3_ne
	j	asm_bad_mnem
asm_chk_l3_no:
	lbu	t1, 2(s10)
	addi	t2, zero, 'p'
	beq	t1, t2, asm_instr_nop
	addi	t2, zero, 't'
	beq	t1, t2, asm_instr_not
	j	asm_bad_mnem
asm_chk_l3_ne:
	lbu	t1, 2(s10)
	addi	t2, zero, 'g'
	bne	t1, t2, asm_bad_mnem
	j	asm_instr_neg
asm_chk_wfi:
	lbu	t1, 1(s10)
	addi	t2, zero, 'f'
	bne	t1, t2, asm_bad_mnem
	lbu	t1, 2(s10)
	addi	t2, zero, 'i'
	bne	t1, t2, asm_bad_mnem
	j	asm_instr_wfi
asm_chk_l3_b:
	# beq, bne, blt, bge, bgt, ble
	lbu	t1, 1(s10)
	addi	t2, zero, 'e'
	beq	t1, t2, asm_chk_l3_be
	addi	t2, zero, 'n'
	beq	t1, t2, asm_chk_bne
	addi	t2, zero, 'l'
	beq	t1, t2, asm_chk_l3_bl
	addi	t2, zero, 'g'
	beq	t1, t2, asm_chk_l3_bg
	j	asm_bad_mnem
asm_chk_l3_be:
	# beq
	lbu	t1, 2(s10)
	addi	t2, zero, 'q'
	bne	t1, t2, asm_bad_mnem
	j	asm_instr_beq
asm_chk_bne:
	lbu	t1, 2(s10)
	addi	t2, zero, 'e'
	bne	t1, t2, asm_bad_mnem
	j	asm_instr_bne
asm_chk_l3_bl:
	# blt, ble
	lbu	t1, 2(s10)
	addi	t2, zero, 't'
	beq	t1, t2, asm_instr_blt
	addi	t2, zero, 'e'
	beq	t1, t2, asm_instr_ble
	j	asm_bad_mnem
asm_chk_l3_bg:
	# bge, bgt
	lbu	t1, 2(s10)
	addi	t2, zero, 'e'
	beq	t1, t2, asm_instr_bge
	addi	t2, zero, 't'
	beq	t1, t2, asm_instr_bgt
	j	asm_bad_mnem
asm_chk_jal:
	lbu	t1, 1(s10)
	addi	t2, zero, 'a'
	bne	t1, t2, asm_bad_mnem
	lbu	t1, 2(s10)
	addi	t2, zero, 'l'
	bne	t1, t2, asm_bad_mnem
	j	asm_instr_jal
asm_chk_nop:
	lbu	t1, 1(s10)
	addi	t2, zero, 'o'
	bne	t1, t2, asm_bad_mnem
	lbu	t1, 2(s10)
	addi	t2, zero, 'p'
	bne	t1, t2, asm_bad_mnem
	j	asm_instr_nop
asm_chk_l3_a:
	# add, and
	lbu	t1, 1(s10)
	addi	t2, zero, 'd'
	beq	t1, t2, asm_chk_add_3
	addi	t2, zero, 'n'
	beq	t1, t2, asm_chk_and
	j	asm_bad_mnem
asm_chk_add_3:
	lbu	t1, 2(s10)
	addi	t2, zero, 'd'
	bne	t1, t2, asm_bad_mnem
	j	asm_instr_add
asm_chk_and:
	lbu	t1, 2(s10)
	addi	t2, zero, 'd'
	bne	t1, t2, asm_bad_mnem
	j	asm_instr_and
asm_chk_l3_s:
	# sub, sll, srl, sra, slt
	lbu	t1, 1(s10)
	addi	t2, zero, 'u'
	beq	t1, t2, asm_chk_sub
	addi	t2, zero, 'l'
	beq	t1, t2, asm_chk_l3_sl
	addi	t2, zero, 'r'
	beq	t1, t2, asm_chk_l3_sr
	j	asm_bad_mnem
asm_chk_sub:
	lbu	t1, 2(s10)
	addi	t2, zero, 'b'
	bne	t1, t2, asm_bad_mnem
	j	asm_instr_sub
asm_chk_l3_sl:
	# sll, slt
	lbu	t1, 2(s10)
	addi	t2, zero, 'l'
	beq	t1, t2, asm_instr_sll
	addi	t2, zero, 't'
	beq	t1, t2, asm_instr_slt
	j	asm_bad_mnem
asm_chk_l3_sr:
	# srl, sra
	lbu	t1, 2(s10)
	addi	t2, zero, 'l'
	beq	t1, t2, asm_instr_srl
	addi	t2, zero, 'a'
	beq	t1, t2, asm_instr_sra
	j	asm_bad_mnem
asm_chk_lui:
	# lui, lhu, lbu, lla
	lbu	t1, 1(s10)
	addi	t2, zero, 'u'
	beq	t1, t2, asm_chk_lui_cont
	addi	t2, zero, 'h'
	beq	t1, t2, asm_chk_lhu
	addi	t2, zero, 'b'
	beq	t1, t2, asm_chk_lbu
	addi	t2, zero, 'l'
	beq	t1, t2, asm_chk_lla
	j	asm_bad_mnem
asm_chk_lui_cont:
	lbu	t1, 2(s10)
	addi	t2, zero, 'i'
	bne	t1, t2, asm_bad_mnem
	j	asm_instr_lui
asm_chk_lla:
	lbu	t1, 2(s10)
	addi	t2, zero, 'a'
	bne	t1, t2, asm_bad_mnem
	j	asm_instr_lla
asm_chk_lhu:
	lbu	t1, 2(s10)
	addi	t2, zero, 'u'
	bne	t1, t2, asm_bad_mnem
	j	asm_instr_lhu
asm_chk_lbu:
	lbu	t1, 2(s10)
	addi	t2, zero, 'u'
	bne	t1, t2, asm_bad_mnem
	j	asm_instr_lbu
asm_chk_xor:
	lbu	t1, 1(s10)
	addi	t2, zero, 'o'
	bne	t1, t2, asm_bad_mnem
	lbu	t1, 2(s10)
	addi	t2, zero, 'r'
	bne	t1, t2, asm_bad_mnem
	j	asm_instr_xor
asm_chk_ori:
	lbu	t1, 1(s10)
	addi	t2, zero, 'r'
	bne	t1, t2, asm_bad_mnem
	lbu	t1, 2(s10)
	addi	t2, zero, 'i'
	bne	t1, t2, asm_bad_mnem
	j	asm_instr_ori

# ── Length 2: mv, li, or, lw, lh, lb, sw, sh, sb ─────────────────────────────
asm_chk_len2:
	lbu	t1, 0(s10)
	addi	t2, zero, 'm'
	beq	t1, t2, asm_chk_mv
	addi	t2, zero, 'l'
	beq	t1, t2, asm_chk_l2_l
	addi	t2, zero, 'o'
	beq	t1, t2, asm_chk_or
	addi	t2, zero, 's'
	beq	t1, t2, asm_chk_l2_s
	j	asm_bad_mnem
asm_chk_mv:
	lbu	t1, 1(s10)
	addi	t2, zero, 'v'
	bne	t1, t2, asm_bad_mnem
	j	asm_instr_mv
asm_chk_l2_l:
	# li, lw, lh, lb
	lbu	t1, 1(s10)
	addi	t2, zero, 'i'
	beq	t1, t2, asm_instr_li
	addi	t2, zero, 'w'
	beq	t1, t2, asm_instr_lw
	addi	t2, zero, 'h'
	beq	t1, t2, asm_instr_lh
	addi	t2, zero, 'b'
	beq	t1, t2, asm_instr_lb
	j	asm_bad_mnem
asm_chk_or:
	lbu	t1, 1(s10)
	addi	t2, zero, 'r'
	bne	t1, t2, asm_bad_mnem
	j	asm_instr_or
asm_chk_l2_s:
	# sw, sh, sb
	lbu	t1, 1(s10)
	addi	t2, zero, 'w'
	beq	t1, t2, asm_instr_sw
	addi	t2, zero, 'h'
	beq	t1, t2, asm_instr_sh
	addi	t2, zero, 'b'
	beq	t1, t2, asm_instr_sb
	j	asm_bad_mnem

asm_end:
	addi	s2, s2, 1		# consume '}'
	# Pad binary-offset (s5 - s4) up to a 4-byte boundary. s5's absolute
	# address may not be aligned because the input buffer start (s4) is
	# unaligned, so we compute the relative offset and check that.
	sub	t0, s5, s4
	andi	t1, t0, 3
	beqz	t1, asm_end_padded
asm_end_pad:
	sb	zero, 0(s5)
	addi	s5, s5, 1
	sub	t0, s5, s4
	andi	t1, t0, 3
	bnez	t1, asm_end_pad
asm_end_padded:
	lla	t0, last_was_brace
	addi	t1, zero, 1
	sw	t1, 0(t0)
	lla	t0, current_asm_fn
	lw	t1, 0(t0)
	bnez	t1, asm_fn_end
	j	cs_done

# ══════════════════════════════════════════════════════════════════════════════
# asm_fn_begin — compile `asm NAME { ... }` named assembly function.
#
# Frame (16 bytes):
#   0(sp): fn symtab entry pointer
#   4(sp): skip-over jal addr (patched after epilogue)
#   8(sp): saved prev current_fn
#  12(sp): unused
#
# Convention: args in a0-a7, return in a0. Compiler emits minimal prologue
# (shadow stack push ra) and epilogue (pop ra + jal master_dispatch). The
# body follows standard RISC-V ABI — callee must preserve s0-s11, must not
# touch tp/gp. Shared namespace with `fn`: collision errors.
# ══════════════════════════════════════════════════════════════════════════════
asm_fn_begin:
	# Reject nested function definition.
	lla	t0, current_fn
	lw	t1, 0(t0)
	bnez	t1, cs_bad_fn_nested
	addi	sp, sp, -16
	# Parse name: letter-start check (reuse same pattern as fn).
	bge	s2, s3, cs_bad_fn_name
	lbu	t0, 0(s2)
	addi	t1, zero, '_'
	beq	t0, t1, asm_fn_name_letter_ok
	addi	t1, zero, 'a'
	blt	t0, t1, asm_fn_name_chk_uc
	addi	t1, zero, 123
	blt	t0, t1, asm_fn_name_letter_ok
asm_fn_name_chk_uc:
	addi	t1, zero, 'A'
	blt	t0, t1, cs_bad_fn_name
	addi	t1, zero, 91
	bge	t0, t1, cs_bad_fn_name
asm_fn_name_letter_ok:
	addi	gp, zero, 24		# parse_ident site 24 = asm_fn_pi_name
	j	parse_ident
asm_fn_pi_name:
	beqz	s11, cs_bad_fn_name
	# Check not already defined in fn symtab.
	addi	gp, zero, 2		# fn_lookup site 2 = fnlk_ret_asm
	j	fn_lookup
fnlk_ret_asm:
	bnez	a0, cs_bad_fn_redefined
	# Allocate fn symtab entry with num_params = 0xFF (accept any count).
	addi	a0, zero, 0
	addi	a1, zero, 0xFF
	addi	gp, zero, 1		# fn_alloc site 1 = fna_ret_asm
	j	fn_alloc
fna_ret_asm:
	sw	a0, 0(sp)		# entry ptr
	# Skip ws, expect '{'
	addi	gp, zero, 101		# skip_ws site 101 = asm_fn_sw_lbrace
	j	skip_ws
asm_fn_sw_lbrace:
	bge	s2, s3, asm_bad_lbrace
	lbu	t0, 0(s2)
	addi	t1, zero, '{'
	bne	t0, t1, asm_bad_lbrace
	addi	s2, s2, 1
	# Emit skip-over jal placeholder (patched at end of fn body).
	lui	a0, 0
	addi	a0, a0, 0x6F
	addi	gp, zero, 97		# emit_word site 97 = ew_asm_fn_skip
	j	emit_word
ew_asm_fn_skip:
	addi	t0, s5, -4
	sw	t0, 4(sp)		# skip_jal addr
	# Record entry_addr in fn symtab (= current s5).
	lw	t1, 0(sp)
	sw	s5, 32(t1)
	# Save prev current_fn, set current_fn = entry_addr.
	lla	t0, current_fn
	lw	t1, 0(t0)
	sw	t1, 8(sp)
	sw	s5, 0(t0)
	# Set current_asm_fn marker (any non-zero value).
	lla	t0, current_asm_fn
	sw	s5, 0(t0)
	# Reset per-function ret_list top (in case any prior fn left state).
	lla	t0, ret_list_base
	lw	t1, 0(t0)
	lla	t0, ret_list_top
	sw	t1, 0(t0)
	# Emit minimal prologue: shadow stack push ra.
	# addi tp, tp, -4   word 0xFFC20213
	lui	a0, 0xFFC20
	addi	a0, a0, 0x213
	addi	gp, zero, 98		# emit_word site 98 = ew_asm_fn_prol1
	j	emit_word
ew_asm_fn_prol1:
	# sw ra, 0(tp)   word 0x00122023
	lui	a0, 0x122
	addi	a0, a0, 0x023
	addi	gp, zero, 99		# emit_word site 99 = ew_asm_fn_prol2
	j	emit_word
ew_asm_fn_prol2:
	j	asm_loop

# ══════════════════════════════════════════════════════════════════════════════
# asm_fn_end — finalize a named asm function: emit epilogue, patch skip-over,
# restore outer scope. Entered from asm_end when current_asm_fn is non-zero.
# Stack frame (16 bytes) is still live at this point.
# ══════════════════════════════════════════════════════════════════════════════
asm_fn_end:
	# lw ra, 0(tp)   word 0x00022083
	lui	a0, 0x22
	addi	a0, a0, 0x083
	addi	gp, zero, 100		# emit_word site 100 = ew_asm_fn_ep1
	j	emit_word
ew_asm_fn_ep1:
	# addi tp, tp, 4   word 0x00420213
	lui	a0, 0x420
	addi	a0, a0, 0x213
	addi	gp, zero, 101		# emit_word site 101 = ew_asm_fn_ep2
	j	emit_word
ew_asm_fn_ep2:
	# jal zero, 0 placeholder — patched by master_dispatch emit.
	lui	a0, 0
	addi	a0, a0, 0x6F
	addi	gp, zero, 102		# emit_word site 102 = ew_asm_fn_ep3
	j	emit_word
ew_asm_fn_ep3:
	# Append jal addr to md_patch list.
	addi	a0, s5, -4
	lla	a1, md_patch_base
	lla	a2, md_patch_top
	lla	a3, md_patch_end
	addi	gp, zero, 3		# list_append_word site 3 = law_ret_md_asm
	j	list_append_word
law_ret_md_asm:
	# Patch skip-over jal to point past epilogue.
	lw	t5, 4(sp)
	addi	t6, s5, 0
	addi	gp, zero, 21		# patch_jtype site 21 = pjt_asm_fn_skip
	j	patch_jtype
pjt_asm_fn_skip:
	# Restore outer scope.
	lw	t1, 8(sp)
	lla	t0, current_fn
	sw	t1, 0(t0)
	lla	t0, current_asm_fn
	sw	zero, 0(t0)
	addi	sp, sp, 16
	j	cs_done

# ══════════════════════════════════════════════════════════════════════════════
# asm_define_label — register a symbolic label at the current emit position.
# Entry: s10/s11 = label name, s2 past ':'.
# Errors if label already defined. No fixup resolution here — deferred to
# Phase 4.6.
# ══════════════════════════════════════════════════════════════════════════════
asm_define_label:
	# Scan existing labels for duplicate
	lla	t0, asm_lbl_base
	lw	t3, 0(t0)		# scan ptr
	lla	t0, asm_lbl_top
	lw	t4, 0(t0)		# top
adl_scan:
	beq	t3, t4, adl_new
	# Compare 32-byte name at t3 with s11-byte name at s10
	addi	t5, zero, 0
adl_cmp:
	addi	t6, zero, 32
	beq	t5, t6, adl_dup
	add	t1, t3, t5
	lbu	t2, 0(t1)
	bge	t5, s11, adl_chk_tail
	add	t1, s10, t5
	lbu	t0, 0(t1)
	bne	t0, t2, adl_next
	addi	t5, t5, 1
	j	adl_cmp
adl_chk_tail:
	bnez	t2, adl_next		# tail byte should be null
	addi	t5, t5, 1
	j	adl_cmp
adl_next:
	addi	t3, t3, 40
	j	adl_scan
adl_dup:
	lla	t0, ident_start
	lw	s2, 0(t0)
	addi	a0, zero, 63		# err 63: duplicate asm label
	j	report_err
adl_new:
	# Check capacity
	lla	t0, asm_lbl_end
	lw	t1, 0(t0)
	bge	t4, t1, adl_no_room
	# Copy name to entry, pad to 32 bytes
	addi	t5, zero, 0
adl_cp:
	addi	t6, zero, 32
	beq	t5, t6, adl_cp_done
	add	t0, t4, t5
	bge	t5, s11, adl_cp_zero
	add	t1, s10, t5
	lbu	t2, 0(t1)
	sb	t2, 0(t0)
	j	adl_cp_next
adl_cp_zero:
	sb	zero, 0(t0)
adl_cp_next:
	addi	t5, t5, 1
	j	adl_cp
adl_cp_done:
	# Store address (current s5) at offset 32
	sw	s5, 32(t4)
	# Advance top
	addi	t4, t4, 40
	lla	t0, asm_lbl_top
	sw	t4, 0(t0)
	j	asm_loop
adl_no_room:
	addi	a0, zero, 64		# err 64: too many asm labels
	j	report_err

# ══════════════════════════════════════════════════════════════════════════════
# asm_num_label_def — register a numeric label at the current emit position.
# Entry: s2 points at the first digit. Expected syntax: DIGIT ':'
# Numeric labels are reusable — multiple entries with the same number are
# allowed. References use `Nf` (forward) or `Nb` (backward).
# ══════════════════════════════════════════════════════════════════════════════
asm_num_label_def:
	lbu	t0, 0(s2)
	addi	t1, zero, '0'
	sub	t0, t0, t1		# t0 = number 0..9
	addi	s2, s2, 1
	# Expect ':'
	bge	s2, s3, asm_bad_label
	lbu	t1, 0(s2)
	addi	t2, zero, ':'
	bne	t1, t2, asm_bad_label
	addi	s2, s2, 1
	# Append to numeric label list
	lla	t2, asm_nlbl_top
	lw	t3, 0(t2)
	lla	t2, asm_nlbl_end
	lw	t4, 0(t2)
	bge	t3, t4, asm_bad_nlbl_full
	sw	t0, 0(t3)		# number
	sw	s5, 4(t3)		# address
	addi	t3, t3, 8
	lla	t2, asm_nlbl_top
	sw	t3, 0(t2)
	j	asm_loop
asm_bad_nlbl_full:
	addi	a0, zero, 67		# err 67: too many numeric labels
	j	report_err

# ══════════════════════════════════════════════════════════════════════════════
# asm_directive — parse a data directive (.byte, .word, .zero, .ascii).
# Entry: s2 points at the '.'.
#
# Frame (4 bytes): 0(sp) = directive kind
#   0 = .byte   — list of int values, 1 byte each
#   1 = .word   — list of int values, 4 bytes each (little-endian)
#   2 = .zero   — single count, emits count zero bytes
#
# .ascii uses a dedicated path that doesn't loop.
#
# Data directives emit raw bytes. No alignment is inserted between
# instructions and data within the block — user is responsible for layout.
# The closing '}' of the asm block pads to a 4-byte boundary so subsequent
# code stays aligned.
# ══════════════════════════════════════════════════════════════════════════════
asm_directive:
	addi	s2, s2, 1		# consume '.'
	addi	gp, zero, 25		# parse_ident site 25 = asm_pi_dir
	j	parse_ident
asm_pi_dir:
	beqz	s11, asm_bad_dir
	addi	t0, zero, 4
	beq	s11, t0, asm_dir_len4
	addi	t0, zero, 5
	beq	s11, t0, asm_dir_len5
	j	asm_bad_dir
asm_dir_len4:
	lbu	t1, 0(s10)
	addi	t2, zero, 'b'
	beq	t1, t2, asm_dir_chk_byte
	addi	t2, zero, 'w'
	beq	t1, t2, asm_dir_chk_word
	addi	t2, zero, 'z'
	beq	t1, t2, asm_dir_chk_zero
	j	asm_bad_dir
asm_dir_chk_byte:
	lbu	t1, 1(s10)
	addi	t2, zero, 'y'
	bne	t1, t2, asm_bad_dir
	lbu	t1, 2(s10)
	addi	t2, zero, 't'
	bne	t1, t2, asm_bad_dir
	lbu	t1, 3(s10)
	addi	t2, zero, 'e'
	bne	t1, t2, asm_bad_dir
	addi	sp, sp, -4
	sw	zero, 0(sp)		# kind = 0
	j	asm_dir_numlist
asm_dir_chk_word:
	lbu	t1, 1(s10)
	addi	t2, zero, 'o'
	bne	t1, t2, asm_bad_dir
	lbu	t1, 2(s10)
	addi	t2, zero, 'r'
	bne	t1, t2, asm_bad_dir
	lbu	t1, 3(s10)
	addi	t2, zero, 'd'
	bne	t1, t2, asm_bad_dir
	addi	sp, sp, -4
	addi	t0, zero, 1
	sw	t0, 0(sp)		# kind = 1
	j	asm_dir_numlist
asm_dir_chk_zero:
	lbu	t1, 1(s10)
	addi	t2, zero, 'e'
	bne	t1, t2, asm_bad_dir
	lbu	t1, 2(s10)
	addi	t2, zero, 'r'
	bne	t1, t2, asm_bad_dir
	lbu	t1, 3(s10)
	addi	t2, zero, 'o'
	bne	t1, t2, asm_bad_dir
	addi	sp, sp, -4
	addi	t0, zero, 2
	sw	t0, 0(sp)		# kind = 2
	j	asm_dir_numlist
asm_dir_len5:
	# .ascii
	lbu	t1, 0(s10)
	addi	t2, zero, 'a'
	bne	t1, t2, asm_bad_dir
	lbu	t1, 1(s10)
	addi	t2, zero, 's'
	bne	t1, t2, asm_bad_dir
	lbu	t1, 2(s10)
	addi	t2, zero, 'c'
	bne	t1, t2, asm_bad_dir
	lbu	t1, 3(s10)
	addi	t2, zero, 'i'
	bne	t1, t2, asm_bad_dir
	lbu	t1, 4(s10)
	addi	t2, zero, 'i'
	bne	t1, t2, asm_bad_dir
	j	asm_dir_ascii

# ── Numeric directive loop (.byte, .word, .zero) ────────────────────────────
# Frame: 0(sp) = kind
asm_dir_numlist:
	addi	gp, zero, 102		# skip_ws site 102 = asm_dir_sw_arg
	j	skip_ws
asm_dir_sw_arg:
	addi	gp, zero, 6		# parse_num site 6 = pn_asm_dir
	j	parse_num
pn_asm_dir:
	lw	t0, 0(sp)		# kind
	beqz	t0, pn_dir_byte
	addi	t1, zero, 1
	beq	t0, t1, pn_dir_word
	addi	t1, zero, 2
	beq	t0, t1, pn_dir_zero
	j	asm_bad_dir
pn_dir_byte:
	sb	a0, 0(s5)
	addi	s5, s5, 1
	j	asm_dir_chk_comma
pn_dir_word:
	sb	a0, 0(s5)
	srli	t0, a0, 8
	sb	t0, 1(s5)
	srli	t0, a0, 16
	sb	t0, 2(s5)
	srli	t0, a0, 24
	sb	t0, 3(s5)
	addi	s5, s5, 4
	j	asm_dir_chk_comma
pn_dir_zero:
	# a0 = count. Emit count zero bytes.
	addi	t0, a0, 0
pn_dir_zero_loop:
	beqz	t0, pn_dir_zero_done
	sb	zero, 0(s5)
	addi	s5, s5, 1
	addi	t0, t0, -1
	j	pn_dir_zero_loop
pn_dir_zero_done:
	addi	sp, sp, 4
	j	asm_loop

asm_dir_chk_comma:
	addi	gp, zero, 103		# skip_ws site 103 = asm_dir_sw_comma
	j	skip_ws
asm_dir_sw_comma:
	bge	s2, s3, asm_dir_done
	lbu	t0, 0(s2)
	addi	t1, zero, ','
	bne	t0, t1, asm_dir_done
	addi	s2, s2, 1
	j	asm_dir_numlist
asm_dir_done:
	addi	sp, sp, 4
	j	asm_loop

# ── .ascii "string" — emits raw bytes of a string literal ───────────────────
asm_dir_ascii:
	addi	gp, zero, 104		# skip_ws site 104 = asm_dir_sw_ascii
	j	skip_ws
asm_dir_sw_ascii:
	bge	s2, s3, asm_bad_dir
	lbu	t0, 0(s2)
	addi	t1, zero, 34		# '"'
	bne	t0, t1, asm_bad_dir
	addi	s2, s2, 1
asm_ascii_copy:
	bge	s2, s3, asm_bad_dir
	lbu	t0, 0(s2)
	addi	t1, zero, 34
	beq	t0, t1, asm_ascii_end
	addi	t1, zero, 92		# '\\'
	beq	t0, t1, asm_ascii_esc
	sb	t0, 0(s5)
	addi	s5, s5, 1
	addi	s2, s2, 1
	j	asm_ascii_copy
asm_ascii_esc:
	addi	s2, s2, 1
	bge	s2, s3, asm_bad_dir
	lbu	t0, 0(s2)
	addi	s2, s2, 1
	addi	t1, zero, 'n'
	beq	t0, t1, asm_ascii_nl
	addi	t1, zero, 't'
	beq	t0, t1, asm_ascii_tab
	addi	t1, zero, 'r'
	beq	t0, t1, asm_ascii_cr
	addi	t1, zero, '0'
	beq	t0, t1, asm_ascii_nul
	addi	t1, zero, 92
	beq	t0, t1, asm_ascii_write
	addi	t1, zero, 34
	beq	t0, t1, asm_ascii_write
	j	asm_bad_dir
asm_ascii_nl:
	addi	t0, zero, 10
	j	asm_ascii_write
asm_ascii_tab:
	addi	t0, zero, 9
	j	asm_ascii_write
asm_ascii_cr:
	addi	t0, zero, 13
	j	asm_ascii_write
asm_ascii_nul:
	addi	t0, zero, 0
asm_ascii_write:
	sb	t0, 0(s5)
	addi	s5, s5, 1
	j	asm_ascii_copy
asm_ascii_end:
	addi	s2, s2, 1		# consume closing '"'
	j	asm_loop

asm_bad_dir:
	addi	a0, zero, 68		# err 68: bad asm directive
	j	report_err

# ── nop ─ addi x0, x0, 0 = 0x00000013 ────────────────────────────────────────
asm_instr_nop:
	lui	a0, 0
	addi	a0, a0, 0x13
	sw	a0, 0(s5)
	addi	s5, s5, 4
	j	asm_loop

# ── wfi ─ wait for interrupt (SYSTEM instr, funct12=0x105) = 0x10500073 ──────
asm_instr_wfi:
	lui	a0, 0x10500
	addi	a0, a0, 0x73
	sw	a0, 0(s5)
	addi	s5, s5, 4
	j	asm_loop

# ── mv rd, rs1 ─ addi rd, rs1, 0 ─────────────────────────────────────────────
asm_instr_mv:
	addi	sp, sp, -8
	addi	gp, zero, 0		# apr site 0 = apr_mv_rd
	j	asm_parse_reg
apr_mv_rd:
	sw	a0, 0(sp)
	addi	gp, zero, 76		# skip_ws site 76 = asm_sw_mv_c
	j	skip_ws
asm_sw_mv_c:
	lbu	t0, 0(s2)
	addi	t1, zero, ','
	bne	t0, t1, asm_bad_comma
	addi	s2, s2, 1
	addi	gp, zero, 1		# apr site 1 = apr_mv_rs1
	j	asm_parse_reg
apr_mv_rs1:
	sw	a0, 4(sp)
	lw	t5, 0(sp)		# rd
	lw	t6, 4(sp)		# rs1
	addi	sp, sp, 8
	lui	a0, 0
	addi	a0, a0, 0x13
	slli	t0, t5, 7
	or	a0, a0, t0
	slli	t0, t6, 15
	or	a0, a0, t0
	sw	a0, 0(s5)
	addi	s5, s5, 4
	j	asm_loop

# ── li rd, imm ─ addi rd, zero, imm ──────────────────────────────────────────
asm_instr_li:
	addi	sp, sp, -8
	addi	gp, zero, 2		# apr site 2 = apr_li_rd
	j	asm_parse_reg
apr_li_rd:
	sw	a0, 0(sp)
	addi	gp, zero, 77		# skip_ws site 77 = asm_sw_li_c
	j	skip_ws
asm_sw_li_c:
	lbu	t0, 0(s2)
	addi	t1, zero, ','
	bne	t0, t1, asm_bad_comma
	addi	s2, s2, 1
	addi	gp, zero, 78		# skip_ws site 78 = asm_sw_li_imm
	j	skip_ws
asm_sw_li_imm:
	addi	gp, zero, 2		# parse_num site 2 = pn_asm
	j	parse_num
pn_asm_li:
	sw	a0, 4(sp)
	lw	t5, 0(sp)		# rd
	lw	t6, 4(sp)		# imm (may be negative)
	addi	sp, sp, 8
	# Decide between the small form (single addi) and the full lui+addi
	# pair. Small form works for any value that sign-extends from bit 11
	# back to itself, i.e. -2048 ≤ imm ≤ 2047.
	slli	t0, t6, 20
	srai	t0, t0, 20
	bne	t0, t6, pn_asm_li_full
	# Small form: addi rd, zero, imm
	lui	a0, 0
	addi	a0, a0, 0x13
	slli	t0, t5, 7
	or	a0, a0, t0
	andi	t0, t6, 0xFFF
	slli	t0, t0, 20
	or	a0, a0, t0
	sw	a0, 0(s5)
	addi	s5, s5, 4
	j	asm_loop
pn_asm_li_full:
	# Full form: emit `lui rd, upper20; addi rd, rd, lower12` so the pair
	# loads a full 32-bit signed constant.
	#   lower12 = sign_extend_12(imm)
	#   upper20 = (imm - lower12) >> 12
	# Bounds check both inline writes against bin_end (8 bytes total).
	addi	t0, s5, 8
	lla	t1, bin_end
	lw	t1, 0(t1)
	bgeu	t0, t1, bin_full
	# t1 = lower12 (sign-extended)
	slli	t1, t6, 20
	srai	t1, t1, 20
	# t2 = upper20
	sub	t2, t6, t1
	srai	t2, t2, 12
	# Emit lui rd, upper20 = 0x37 | (rd<<7) | (upper20<<12)
	lui	a0, 0
	addi	a0, a0, 0x37
	slli	t0, t5, 7
	or	a0, a0, t0
	slli	t0, t2, 12
	or	a0, a0, t0
	sw	a0, 0(s5)
	addi	s5, s5, 4
	# Emit addi rd, rd, lower12 = 0x13 | (rd<<7) | (rd<<15) | (lo12<<20)
	lui	a0, 0
	addi	a0, a0, 0x13
	slli	t0, t5, 7
	or	a0, a0, t0
	slli	t0, t5, 15
	or	a0, a0, t0
	andi	t0, t1, 0xFFF
	slli	t0, t0, 20
	or	a0, a0, t0
	sw	a0, 0(s5)
	addi	s5, s5, 4
	j	asm_loop

# ══════════════════════════════════════════════════════════════════════════════
# Shared instruction handlers.
#
# U-type: lui, auipc
#   Frame (12 bytes): 0=rd 4=imm 8=base
#   Entry: sp already allocated and base stored at 8(sp).
#   Word = base | (rd<<7) | (imm<<12)
#
# I-type: addi, xori, ori, andi, slti, sltiu
#   Frame (16 bytes): 0=rd 4=rs1 8=imm 12=base
#   Word = base | (rd<<7) | (rs1<<15) | ((imm&0xFFF)<<20)
#
# Shift-I: slli, srli, srai  — imm masked to 5 bits
#   Frame (16 bytes): 0=rd 4=rs1 8=imm 12=base
#   Word = base | (rd<<7) | (rs1<<15) | ((imm&0x1F)<<20)
#   (base already encodes f7 in the high bits for srai)
#
# R-type: add, sub, xor, or, and, sll, srl, sra, slt, sltu
#   Frame (16 bytes): 0=rd 4=rs1 8=rs2 12=base
#   Word = base | (rd<<7) | (rs1<<15) | (rs2<<20)
# ══════════════════════════════════════════════════════════════════════════════

# ── U-type handlers (lui, auipc) ─────────────────────────────────────────────
asm_instr_lui:
	addi	sp, sp, -12
	lui	a0, 0
	addi	a0, a0, 0x37
	sw	a0, 8(sp)
	j	asm_utype_start
asm_instr_auipc:
	addi	sp, sp, -12
	lui	a0, 0
	addi	a0, a0, 0x17
	sw	a0, 8(sp)
	j	asm_utype_start
asm_utype_start:
	addi	gp, zero, 3		# apr site 3 = apr_utype_rd
	j	asm_parse_reg
apr_utype_rd:
	sw	a0, 0(sp)
	addi	gp, zero, 79		# skip_ws site 79 = asm_sw_utype_c
	j	skip_ws
asm_sw_utype_c:
	lbu	t0, 0(s2)
	addi	t1, zero, ','
	bne	t0, t1, asm_bad_comma
	addi	s2, s2, 1
	addi	gp, zero, 80		# skip_ws site 80 = asm_sw_utype_imm
	j	skip_ws
asm_sw_utype_imm:
	addi	gp, zero, 3		# parse_num site 3 = pn_asm_utype
	j	parse_num
pn_asm_utype:
	sw	a0, 4(sp)
	lw	t5, 0(sp)		# rd
	lw	t6, 4(sp)		# imm
	lw	t3, 8(sp)		# base
	addi	sp, sp, 12
	# U-type imm must fit in 20 bits unsigned. Without this check a value
	# ≥ 2^20 silently loses its high bits when slli'd left by 12.
	lui	t0, 0x100		# 2^20
	bgeu	t6, t0, asm_bad_utype_imm
	slli	t0, t5, 7
	or	t3, t3, t0
	slli	t0, t6, 12
	or	t3, t3, t0
	addi	a0, t3, 0
	sw	a0, 0(s5)
	addi	s5, s5, 4
	j	asm_loop

# ── I-type handlers (addi, xori, ori, andi, slti, sltiu) ─────────────────────
asm_instr_addi:
	addi	sp, sp, -16
	lui	a0, 0
	addi	a0, a0, 0x13
	sw	a0, 12(sp)
	j	asm_itype_start
asm_instr_xori:
	addi	sp, sp, -16
	lui	a0, 4
	addi	a0, a0, 0x13
	sw	a0, 12(sp)
	j	asm_itype_start
asm_instr_ori:
	addi	sp, sp, -16
	lui	a0, 6
	addi	a0, a0, 0x13
	sw	a0, 12(sp)
	j	asm_itype_start
asm_instr_andi:
	addi	sp, sp, -16
	lui	a0, 7
	addi	a0, a0, 0x13
	sw	a0, 12(sp)
	j	asm_itype_start
asm_instr_slti:
	addi	sp, sp, -16
	lui	a0, 2
	addi	a0, a0, 0x13
	sw	a0, 12(sp)
	j	asm_itype_start
asm_instr_sltiu:
	addi	sp, sp, -16
	lui	a0, 3
	addi	a0, a0, 0x13
	sw	a0, 12(sp)
	j	asm_itype_start
# ── Shift-immediate handlers (slli, srli, srai) ──────────────────────────────
asm_instr_slli:
	addi	sp, sp, -16
	lui	a0, 1
	addi	a0, a0, 0x13
	sw	a0, 12(sp)
	j	asm_shift_start
asm_instr_srli:
	addi	sp, sp, -16
	lui	a0, 5
	addi	a0, a0, 0x13
	sw	a0, 12(sp)
	j	asm_shift_start
asm_instr_srai:
	addi	sp, sp, -16
	lui	a0, 0x40005
	addi	a0, a0, 0x13
	sw	a0, 12(sp)
	j	asm_shift_start

asm_itype_start:
asm_shift_start:
	addi	gp, zero, 4		# apr site 4 = apr_itype_rd
	j	asm_parse_reg
apr_itype_rd:
	sw	a0, 0(sp)
	addi	gp, zero, 81		# skip_ws site 81 = asm_sw_itype_c1
	j	skip_ws
asm_sw_itype_c1:
	lbu	t0, 0(s2)
	addi	t1, zero, ','
	bne	t0, t1, asm_bad_comma
	addi	s2, s2, 1
	addi	gp, zero, 5		# apr site 5 = apr_itype_rs1
	j	asm_parse_reg
apr_itype_rs1:
	sw	a0, 4(sp)
	addi	gp, zero, 82		# skip_ws site 82 = asm_sw_itype_c2
	j	skip_ws
asm_sw_itype_c2:
	lbu	t0, 0(s2)
	addi	t1, zero, ','
	bne	t0, t1, asm_bad_comma
	addi	s2, s2, 1
	addi	gp, zero, 83		# skip_ws site 83 = asm_sw_itype_imm
	j	skip_ws
asm_sw_itype_imm:
	addi	gp, zero, 4		# parse_num site 4 = pn_asm_itype
	j	parse_num
pn_asm_itype:
	sw	a0, 8(sp)
	lw	t5, 0(sp)		# rd
	lw	t6, 4(sp)		# rs1
	lw	t4, 8(sp)		# imm
	lw	t3, 12(sp)		# base
	addi	sp, sp, 16
	# Determine mask: if base has bit 12 clear (f3=0,2,3,4,6,7) → 0xFFF;
	# if base has f3=1 or 5 (shift) → 0x1F.
	# Simpler: check the funct3 bits of base.
	srli	t0, t3, 12
	andi	t0, t0, 7		# t0 = f3
	addi	t1, zero, 1
	beq	t0, t1, pn_asm_itype_shift
	addi	t1, zero, 5
	beq	t0, t1, pn_asm_itype_shift
	# Regular I-type: imm must fit in 12-bit signed [-2048, 2047]. Verify
	# by sign-extending from bit 11 and comparing back to the original.
	slli	t1, t4, 20
	srai	t1, t1, 20
	bne	t1, t4, asm_bad_itype_imm
	andi	t0, t4, 0xFFF
	j	pn_asm_itype_emit
pn_asm_itype_shift:
	# Shift amount must fit in 5 bits unsigned [0, 31]. Negative literals
	# come through as huge unsigned values and are rejected by bgeu.
	addi	t1, zero, 32
	bgeu	t4, t1, asm_bad_itype_imm
	andi	t0, t4, 0x1F
pn_asm_itype_emit:
	slli	t0, t0, 20
	or	t3, t3, t0
	slli	t0, t5, 7
	or	t3, t3, t0
	slli	t0, t6, 15
	or	t3, t3, t0
	addi	a0, t3, 0
	sw	a0, 0(s5)
	addi	s5, s5, 4
	j	asm_loop

# ── R-type handlers (add, sub, xor, or, and, sll, srl, sra, slt, sltu) ───────
asm_instr_add:
	addi	sp, sp, -16
	lui	a0, 0
	addi	a0, a0, 0x33
	sw	a0, 12(sp)
	j	asm_rtype_start
asm_instr_sub:
	addi	sp, sp, -16
	lui	a0, 0x40000
	addi	a0, a0, 0x33
	sw	a0, 12(sp)
	j	asm_rtype_start
asm_instr_xor:
	addi	sp, sp, -16
	lui	a0, 4
	addi	a0, a0, 0x33
	sw	a0, 12(sp)
	j	asm_rtype_start
asm_instr_or:
	addi	sp, sp, -16
	lui	a0, 6
	addi	a0, a0, 0x33
	sw	a0, 12(sp)
	j	asm_rtype_start
asm_instr_and:
	addi	sp, sp, -16
	lui	a0, 7
	addi	a0, a0, 0x33
	sw	a0, 12(sp)
	j	asm_rtype_start
asm_instr_sll:
	addi	sp, sp, -16
	lui	a0, 1
	addi	a0, a0, 0x33
	sw	a0, 12(sp)
	j	asm_rtype_start
asm_instr_srl:
	addi	sp, sp, -16
	lui	a0, 5
	addi	a0, a0, 0x33
	sw	a0, 12(sp)
	j	asm_rtype_start
asm_instr_sra:
	addi	sp, sp, -16
	lui	a0, 0x40005
	addi	a0, a0, 0x33
	sw	a0, 12(sp)
	j	asm_rtype_start
asm_instr_slt:
	addi	sp, sp, -16
	lui	a0, 2
	addi	a0, a0, 0x33
	sw	a0, 12(sp)
	j	asm_rtype_start
asm_instr_sltu:
	addi	sp, sp, -16
	lui	a0, 3
	addi	a0, a0, 0x33
	sw	a0, 12(sp)
	j	asm_rtype_start

asm_rtype_start:
	addi	gp, zero, 6		# apr site 6 = apr_rtype_rd
	j	asm_parse_reg
apr_rtype_rd:
	sw	a0, 0(sp)
	addi	gp, zero, 84		# skip_ws site 84 = asm_sw_rtype_c1
	j	skip_ws
asm_sw_rtype_c1:
	lbu	t0, 0(s2)
	addi	t1, zero, ','
	bne	t0, t1, asm_bad_comma
	addi	s2, s2, 1
	addi	gp, zero, 7		# apr site 7 = apr_rtype_rs1
	j	asm_parse_reg
apr_rtype_rs1:
	sw	a0, 4(sp)
	addi	gp, zero, 85		# skip_ws site 85 = asm_sw_rtype_c2
	j	skip_ws
asm_sw_rtype_c2:
	lbu	t0, 0(s2)
	addi	t1, zero, ','
	bne	t0, t1, asm_bad_comma
	addi	s2, s2, 1
	addi	gp, zero, 8		# apr site 8 = apr_rtype_rs2
	j	asm_parse_reg
apr_rtype_rs2:
	sw	a0, 8(sp)
	lw	t5, 0(sp)		# rd
	lw	t6, 4(sp)		# rs1
	lw	t4, 8(sp)		# rs2
	lw	t3, 12(sp)		# base
	addi	sp, sp, 16
	slli	t0, t5, 7
	or	t3, t3, t0
	slli	t0, t6, 15
	or	t3, t3, t0
	slli	t0, t4, 20
	or	t3, t3, t0
	addi	a0, t3, 0
	sw	a0, 0(s5)
	addi	s5, s5, 4
	j	asm_loop

# ══════════════════════════════════════════════════════════════════════════════
# Memory op handlers (lw, lh, lhu, lb, lbu, sw, sh, sb).
# Syntax: MNEM reg, imm(reg)
#
# Frame (16 bytes):
#   0(sp): first reg  (rd for loads, rs2 for stores)
#   4(sp): imm
#   8(sp): second reg (rs1)
#  12(sp): base word  (opcode distinguishes load 0x03 vs store 0x23)
#
# Load encoding (I-type): base | (rd<<7) | (rs1<<15) | (imm<<20)
# Store encoding (S-type): base | (imm[4:0]<<7) | (rs1<<15) | (rs2<<20) | (imm[11:5]<<25)
# ══════════════════════════════════════════════════════════════════════════════
asm_instr_lw:
	addi	sp, sp, -16
	lui	a0, 2
	addi	a0, a0, 0x03
	sw	a0, 12(sp)
	j	asm_memop_start
asm_instr_lh:
	addi	sp, sp, -16
	lui	a0, 1
	addi	a0, a0, 0x03
	sw	a0, 12(sp)
	j	asm_memop_start
asm_instr_lhu:
	addi	sp, sp, -16
	lui	a0, 5
	addi	a0, a0, 0x03
	sw	a0, 12(sp)
	j	asm_memop_start
asm_instr_lb:
	addi	sp, sp, -16
	lui	a0, 0
	addi	a0, a0, 0x03
	sw	a0, 12(sp)
	j	asm_memop_start
asm_instr_lbu:
	addi	sp, sp, -16
	lui	a0, 4
	addi	a0, a0, 0x03
	sw	a0, 12(sp)
	j	asm_memop_start
asm_instr_sw:
	addi	sp, sp, -16
	lui	a0, 2
	addi	a0, a0, 0x23
	sw	a0, 12(sp)
	j	asm_memop_start
asm_instr_sh:
	addi	sp, sp, -16
	lui	a0, 1
	addi	a0, a0, 0x23
	sw	a0, 12(sp)
	j	asm_memop_start
asm_instr_sb:
	addi	sp, sp, -16
	lui	a0, 0
	addi	a0, a0, 0x23
	sw	a0, 12(sp)
	j	asm_memop_start

asm_memop_start:
	addi	gp, zero, 11		# apr site 11 = apr_memop_first
	j	asm_parse_reg
apr_memop_first:
	sw	a0, 0(sp)
	addi	gp, zero, 91		# skip_ws site 91 = asm_sw_memop_c
	j	skip_ws
asm_sw_memop_c:
	lbu	t0, 0(s2)
	addi	t1, zero, ','
	bne	t0, t1, asm_bad_comma
	addi	s2, s2, 1
	addi	gp, zero, 92		# skip_ws site 92 = asm_sw_memop_imm
	j	skip_ws
asm_sw_memop_imm:
	addi	gp, zero, 5		# parse_num site 5 = pn_asm_memop
	j	parse_num
pn_asm_memop:
	sw	a0, 4(sp)
	addi	gp, zero, 93		# skip_ws site 93 = asm_sw_memop_lp
	j	skip_ws
asm_sw_memop_lp:
	lbu	t0, 0(s2)
	addi	t1, zero, '('
	bne	t0, t1, asm_bad_memop
	addi	s2, s2, 1
	addi	gp, zero, 12		# apr site 12 = apr_memop_second
	j	asm_parse_reg
apr_memop_second:
	sw	a0, 8(sp)
	addi	gp, zero, 94		# skip_ws site 94 = asm_sw_memop_rp
	j	skip_ws
asm_sw_memop_rp:
	lbu	t0, 0(s2)
	addi	t1, zero, ')'
	bne	t0, t1, asm_bad_memop
	addi	s2, s2, 1
	lw	t5, 0(sp)		# first reg (rd or rs2)
	lw	t6, 4(sp)		# imm
	lw	t4, 8(sp)		# second reg (rs1)
	lw	t3, 12(sp)		# base
	addi	sp, sp, 16
	# Dispatch on opcode: 0x23 = store, else load
	andi	t0, t3, 0x7F
	addi	t1, zero, 0x23
	beq	t0, t1, asm_memop_store
asm_memop_load:
	# base | (rd<<7) | (rs1<<15) | (imm<<20)
	slli	t0, t5, 7
	or	t3, t3, t0
	slli	t0, t4, 15
	or	t3, t3, t0
	andi	t0, t6, 0xFFF
	slli	t0, t0, 20
	or	t3, t3, t0
	j	asm_memop_emit
asm_memop_store:
	# base | (imm[4:0]<<7) | (rs1<<15) | (rs2<<20) | (imm[11:5]<<25)
	andi	t0, t6, 0x1F
	slli	t0, t0, 7
	or	t3, t3, t0
	slli	t0, t4, 15
	or	t3, t3, t0
	slli	t0, t5, 20
	or	t3, t3, t0
	srli	t0, t6, 5
	andi	t0, t0, 0x7F
	slli	t0, t0, 25
	or	t3, t3, t0
asm_memop_emit:
	addi	a0, t3, 0
	sw	a0, 0(s5)
	addi	s5, s5, 4
	j	asm_loop

asm_bad_memop:
	addi	a0, zero, 62
	j	report_err

# ══════════════════════════════════════════════════════════════════════════════
# Branch and jump handlers.
#
# Branches (B-type): beq, bne, blt, bge, bltu, bgeu
#   Syntax: MNEM rs1, rs2, label
#   Encoding: base | (imm[11:7]) | (rs1<<15) | (rs2<<20) | (imm[31:25])
#   where imm bits are split per B-type format.
#
# Jumps (J-type): jal, j (pseudo)
#   Syntax: jal rd, label   or   j label (= jal zero, label)
#   Encoding: base | (rd<<7) | (imm bits per J-type format)
#
# Frame (16 bytes) for branches:
#   0(sp): rs1  4(sp): rs2  8(sp): unused  12(sp): base word
# Frame (12 bytes) for jumps:
#   0(sp): rd  4(sp): unused  8(sp): base word
#
# Both emit a placeholder (offset=0) and register a fixup for resolution
# at Phase 4.6.
# ══════════════════════════════════════════════════════════════════════════════

# ── B-type instruction handlers ──────────────────────────────────────────────
asm_instr_beq:
	addi	sp, sp, -16
	lui	a0, 0
	addi	a0, a0, 0x63
	sw	a0, 12(sp)
	j	asm_btype_start
asm_instr_bne:
	addi	sp, sp, -16
	lui	a0, 1
	addi	a0, a0, 0x63
	sw	a0, 12(sp)
	j	asm_btype_start
asm_instr_blt:
	addi	sp, sp, -16
	lui	a0, 4
	addi	a0, a0, 0x63
	sw	a0, 12(sp)
	j	asm_btype_start
asm_instr_bge:
	addi	sp, sp, -16
	lui	a0, 5
	addi	a0, a0, 0x63
	sw	a0, 12(sp)
	j	asm_btype_start
asm_instr_bltu:
	addi	sp, sp, -16
	lui	a0, 6
	addi	a0, a0, 0x63
	sw	a0, 12(sp)
	j	asm_btype_start
asm_instr_bgeu:
	addi	sp, sp, -16
	lui	a0, 7
	addi	a0, a0, 0x63
	sw	a0, 12(sp)
	j	asm_btype_start

asm_btype_start:
	addi	gp, zero, 13		# apr site 13 = apr_btype_rs1
	j	asm_parse_reg
apr_btype_rs1:
	sw	a0, 0(sp)
	addi	gp, zero, 95		# skip_ws site 95 = asm_sw_btype_c1
	j	skip_ws
asm_sw_btype_c1:
	lbu	t0, 0(s2)
	addi	t1, zero, ','
	bne	t0, t1, asm_bad_comma
	addi	s2, s2, 1
	addi	gp, zero, 14		# apr site 14 = apr_btype_rs2
	j	asm_parse_reg
apr_btype_rs2:
	sw	a0, 4(sp)
	addi	gp, zero, 96		# skip_ws site 96 = asm_sw_btype_c2
	j	skip_ws
asm_sw_btype_c2:
	lbu	t0, 0(s2)
	addi	t1, zero, ','
	bne	t0, t1, asm_bad_comma
	addi	s2, s2, 1
	addi	gp, zero, 97		# skip_ws site 97 = asm_sw_btype_lbl
	j	skip_ws
asm_sw_btype_lbl:
	# Check for numeric ref (digit) or symbolic ref (identifier)
	bge	s2, s3, asm_bad_label
	lbu	t0, 0(s2)
	addi	t1, zero, '0'
	blt	t0, t1, asm_btype_sym
	addi	t1, zero, 58
	blt	t0, t1, asm_btype_num
asm_btype_sym:
	addi	gp, zero, 21		# parse_ident site 21 = asm_pi_btype_lbl
	j	parse_ident
asm_pi_btype_lbl:
	beqz	s11, asm_bad_label
	# Emit placeholder: base | (rs1<<15) | (rs2<<20)
	lw	t5, 0(sp)		# rs1
	lw	t6, 4(sp)		# rs2
	lw	t3, 12(sp)		# base
	addi	sp, sp, 16
	slli	t0, t5, 15
	or	t3, t3, t0
	slli	t0, t6, 20
	or	t3, t3, t0
	# Record fixup: (label name, fixup_addr=s5, kind=0)
	addi	a0, zero, 0		# kind = 0 (B-type sym)
	j	asm_add_fixup_and_emit
asm_btype_num:
	# Parse digit + 'f'/'b'
	lbu	t0, 0(s2)
	addi	t1, zero, '0'
	sub	t4, t0, t1		# t4 = number
	addi	s2, s2, 1
	bge	s2, s3, asm_bad_label
	lbu	t1, 0(s2)
	addi	t2, zero, 'f'
	beq	t1, t2, asm_btype_num_fwd
	addi	t2, zero, 'b'
	beq	t1, t2, asm_btype_num_bwd
	j	asm_bad_label
asm_btype_num_fwd:
	addi	s2, s2, 1
	addi	a0, zero, 2		# kind = 2 (B-type num fwd)
	j	asm_btype_num_emit
asm_btype_num_bwd:
	addi	s2, s2, 1
	addi	a0, zero, 4		# kind = 4 (B-type num bwd)
asm_btype_num_emit:
	# a0 = kind, t4 = number. Build placeholder.
	lw	t5, 0(sp)		# rs1
	lw	t6, 4(sp)		# rs2
	lw	t3, 12(sp)		# base
	addi	sp, sp, 16
	slli	t0, t5, 15
	or	t3, t3, t0
	slli	t0, t6, 20
	or	t3, t3, t0
	j	asm_add_num_fixup_and_emit

# ── jal / j handlers ─────────────────────────────────────────────────────────
asm_instr_jal:
	addi	sp, sp, -12
	lui	a0, 0
	addi	a0, a0, 0x6F
	sw	a0, 8(sp)
	# jal rd, label — parse rd first
	addi	gp, zero, 15		# apr site 15 = apr_jal_rd
	j	asm_parse_reg
apr_jal_rd:
	sw	a0, 0(sp)
	addi	gp, zero, 98		# skip_ws site 98 = asm_sw_jal_c
	j	skip_ws
asm_sw_jal_c:
	lbu	t0, 0(s2)
	addi	t1, zero, ','
	bne	t0, t1, asm_bad_comma
	addi	s2, s2, 1
	addi	gp, zero, 99		# skip_ws site 99 = asm_sw_jal_lbl
	j	skip_ws
asm_sw_jal_lbl:
	bge	s2, s3, asm_bad_label
	lbu	t0, 0(s2)
	addi	t1, zero, '0'
	blt	t0, t1, asm_jal_sym
	addi	t1, zero, 58
	blt	t0, t1, asm_jal_num
asm_jal_sym:
	addi	gp, zero, 22		# parse_ident site 22 = asm_pi_jal_lbl
	j	parse_ident
asm_pi_jal_lbl:
	beqz	s11, asm_bad_label
	lw	t5, 0(sp)		# rd
	lw	t3, 8(sp)		# base
	addi	sp, sp, 12
	slli	t0, t5, 7
	or	t3, t3, t0
	addi	a0, zero, 1		# kind = 1 (J-type sym)
	j	asm_add_fixup_and_emit
asm_jal_num:
	lbu	t0, 0(s2)
	addi	t1, zero, '0'
	sub	t4, t0, t1
	addi	s2, s2, 1
	bge	s2, s3, asm_bad_label
	lbu	t1, 0(s2)
	addi	t2, zero, 'f'
	beq	t1, t2, asm_jal_num_fwd
	addi	t2, zero, 'b'
	beq	t1, t2, asm_jal_num_bwd
	j	asm_bad_label
asm_jal_num_fwd:
	addi	s2, s2, 1
	addi	a0, zero, 3		# kind = 3 (J-type num fwd)
	j	asm_jal_num_emit
asm_jal_num_bwd:
	addi	s2, s2, 1
	addi	a0, zero, 5		# kind = 5 (J-type num bwd)
asm_jal_num_emit:
	lw	t5, 0(sp)		# rd
	lw	t3, 8(sp)		# base
	addi	sp, sp, 12
	slli	t0, t5, 7
	or	t3, t3, t0
	j	asm_add_num_fixup_and_emit

# ── j label ─ pseudo for "jal zero, label" ───────────────────────────────────
asm_instr_j:
	addi	gp, zero, 100		# skip_ws site 100 = asm_sw_j_lbl
	j	skip_ws
asm_sw_j_lbl:
	bge	s2, s3, asm_bad_label
	lbu	t0, 0(s2)
	addi	t1, zero, '0'
	blt	t0, t1, asm_j_sym
	addi	t1, zero, 58
	blt	t0, t1, asm_j_num
asm_j_sym:
	addi	gp, zero, 23		# parse_ident site 23 = asm_pi_j_lbl
	j	parse_ident
asm_pi_j_lbl:
	beqz	s11, asm_bad_label
	# Build base = jal zero, 0 = 0x0000006F
	lui	t3, 0
	addi	t3, t3, 0x6F
	addi	a0, zero, 1		# kind = 1 (J-type sym)
	j	asm_add_fixup_and_emit
asm_j_num:
	lbu	t0, 0(s2)
	addi	t1, zero, '0'
	sub	t4, t0, t1
	addi	s2, s2, 1
	bge	s2, s3, asm_bad_label
	lbu	t1, 0(s2)
	addi	t2, zero, 'f'
	beq	t1, t2, asm_j_num_fwd
	addi	t2, zero, 'b'
	beq	t1, t2, asm_j_num_bwd
	j	asm_bad_label
asm_j_num_fwd:
	addi	s2, s2, 1
	addi	a0, zero, 3		# kind = 3 (J-type num fwd)
	j	asm_j_num_emit
asm_j_num_bwd:
	addi	s2, s2, 1
	addi	a0, zero, 5		# kind = 5 (J-type num bwd)
asm_j_num_emit:
	lui	t3, 0
	addi	t3, t3, 0x6F		# jal zero, 0 base
	j	asm_add_num_fixup_and_emit

# ══════════════════════════════════════════════════════════════════════════════
# asm_add_fixup_and_emit — emit the placeholder word in t3, record a fixup
# entry with (label_name from s10/s11, fixup_addr=s5 before emit, kind in a0).
# Then jump to asm_loop.
# ══════════════════════════════════════════════════════════════════════════════
asm_add_fixup_and_emit:
	# a0 = kind
	addi	t4, a0, 0		# save kind
	# Check capacity
	lla	t0, asm_fix_top
	lw	t1, 0(t0)
	lla	t0, asm_fix_end
	lw	t2, 0(t0)
	bge	t1, t2, asm_fix_full
	# Copy name from s10/s11 to fixup entry (first 32 bytes, pad with null)
	addi	t5, zero, 0
afe_cp:
	addi	t6, zero, 32
	beq	t5, t6, afe_cp_done
	add	t0, t1, t5
	bge	t5, s11, afe_cp_zero
	add	t2, s10, t5
	lbu	a0, 0(t2)
	sb	a0, 0(t0)
	j	afe_cp_next
afe_cp_zero:
	sb	zero, 0(t0)
afe_cp_next:
	addi	t5, t5, 1
	j	afe_cp
afe_cp_done:
	# Store fixup_addr (current s5) at offset 32
	sw	s5, 32(t1)
	# Store kind at offset 36
	sw	t4, 36(t1)
	# Advance fixup top
	addi	t1, t1, 40
	lla	t0, asm_fix_top
	sw	t1, 0(t0)
	# Emit placeholder word (t3)
	sw	t3, 0(s5)
	addi	s5, s5, 4
	j	asm_loop
asm_fix_full:
	addi	a0, zero, 65
	j	report_err
asm_bad_label:
	addi	a0, zero, 6		# expected identifier
	j	report_err

# ══════════════════════════════════════════════════════════════════════════════
# asm_add_num_fixup_and_emit — same as asm_add_fixup_and_emit but for numeric
# label refs. Stores the number (in t4) in bytes 0-3 of the fixup entry.
# a0 = kind (2, 3, 4, or 5), t4 = number, t3 = placeholder word.
# ══════════════════════════════════════════════════════════════════════════════
asm_add_num_fixup_and_emit:
	addi	t5, a0, 0		# save kind
	lla	t0, asm_fix_top
	lw	t1, 0(t0)
	lla	t0, asm_fix_end
	lw	t2, 0(t0)
	bge	t1, t2, asm_fix_full
	# Write number at offset 0 (first 4 bytes); zero bytes 4..31
	sw	t4, 0(t1)
	sw	zero, 4(t1)
	sw	zero, 8(t1)
	sw	zero, 12(t1)
	sw	zero, 16(t1)
	sw	zero, 20(t1)
	sw	zero, 24(t1)
	sw	zero, 28(t1)
	# fixup_addr at 32, kind at 36
	sw	s5, 32(t1)
	sw	t5, 36(t1)
	addi	t1, t1, 40
	lla	t0, asm_fix_top
	sw	t1, 0(t0)
	# Emit placeholder
	sw	t3, 0(s5)
	addi	s5, s5, 4
	j	asm_loop

# ══════════════════════════════════════════════════════════════════════════════
# Pseudo-instruction handlers: neg, not, seqz, snez, sltz, sgtz,
#                              beqz, bnez, bltz, bgez, bgt, ble, bgtu, bleu.
#
# Each entry sets up a 16-byte frame with a base instruction word at sp[12]
# and (for the 2-reg pseudos) a pseudo id at sp[8], then jumps to one of
# three shared parsers. The parser populates sp[0]/sp[4] with the operands
# and dispatches to either an existing R/B-type encoder or a per-pseudo
# encoder block at the bottom of this section.
# ══════════════════════════════════════════════════════════════════════════════

# ── 2-reg R/I-type pseudos (rd, rs) ─────────────────────────────────────────
asm_instr_neg:
	addi	sp, sp, -16
	sw	zero, 8(sp)
	j	asm_pseudo_2r_start
asm_instr_not:
	addi	sp, sp, -16
	addi	t0, zero, 1
	sw	t0, 8(sp)
	j	asm_pseudo_2r_start
asm_instr_seqz:
	addi	sp, sp, -16
	addi	t0, zero, 2
	sw	t0, 8(sp)
	j	asm_pseudo_2r_start
asm_instr_snez:
	addi	sp, sp, -16
	addi	t0, zero, 3
	sw	t0, 8(sp)
	j	asm_pseudo_2r_start
asm_instr_sltz:
	addi	sp, sp, -16
	addi	t0, zero, 4
	sw	t0, 8(sp)
	j	asm_pseudo_2r_start
asm_instr_sgtz:
	addi	sp, sp, -16
	addi	t0, zero, 5
	sw	t0, 8(sp)
	j	asm_pseudo_2r_start

asm_pseudo_2r_start:
	addi	gp, zero, 16		# apr site 16 = apr_2r_rd
	j	asm_parse_reg
apr_2r_rd:
	sw	a0, 0(sp)
	addi	gp, zero, 105		# skip_ws site 105 = asm_sw_2r_c
	j	skip_ws
asm_sw_2r_c:
	lbu	t0, 0(s2)
	addi	t1, zero, ','
	bne	t0, t1, asm_bad_comma
	addi	s2, s2, 1
	addi	gp, zero, 17		# apr site 17 = apr_2r_rs
	j	asm_parse_reg
apr_2r_rs:
	sw	a0, 4(sp)
	lw	t5, 0(sp)		# rd
	lw	t6, 4(sp)		# rs
	lw	t4, 8(sp)		# pseudo id
	addi	sp, sp, 16
	beqz	t4, p2r_neg
	addi	t0, zero, 1
	beq	t4, t0, p2r_not
	addi	t0, zero, 2
	beq	t4, t0, p2r_seqz
	addi	t0, zero, 3
	beq	t4, t0, p2r_snez
	addi	t0, zero, 4
	beq	t4, t0, p2r_sltz
	j	p2r_sgtz		# id 5

p2r_neg:
	# sub rd, zero, rs:  f7=0x20, rs1=0, rs2=rs, f3=0, op=0x33
	lui	a0, 0x40000
	addi	a0, a0, 0x33
	slli	t0, t5, 7
	or	a0, a0, t0
	slli	t0, t6, 20		# rs2
	or	a0, a0, t0
	sw	a0, 0(s5)
	addi	s5, s5, 4
	j	asm_loop
p2r_not:
	# xori rd, rs, -1:  f3=4, op=0x13, imm=-1 (0xFFF)
	lui	a0, 4
	addi	a0, a0, 0x13
	slli	t0, t5, 7
	or	a0, a0, t0
	slli	t0, t6, 15		# rs1
	or	a0, a0, t0
	lui	t0, 0xFFF00		# imm = 0xFFF in bits 31:20
	or	a0, a0, t0
	sw	a0, 0(s5)
	addi	s5, s5, 4
	j	asm_loop
p2r_seqz:
	# sltiu rd, rs, 1:  f3=3, op=0x13, imm=1
	lui	a0, 3
	addi	a0, a0, 0x13
	slli	t0, t5, 7
	or	a0, a0, t0
	slli	t0, t6, 15		# rs1
	or	a0, a0, t0
	addi	t0, zero, 1
	slli	t0, t0, 20		# imm=1
	or	a0, a0, t0
	sw	a0, 0(s5)
	addi	s5, s5, 4
	j	asm_loop
p2r_snez:
	# sltu rd, zero, rs:  f3=3, op=0x33, rs1=0, rs2=rs
	lui	a0, 3
	addi	a0, a0, 0x33
	slli	t0, t5, 7
	or	a0, a0, t0
	slli	t0, t6, 20		# rs2
	or	a0, a0, t0
	sw	a0, 0(s5)
	addi	s5, s5, 4
	j	asm_loop
p2r_sltz:
	# slt rd, rs, zero:  f3=2, op=0x33, rs1=rs, rs2=0
	lui	a0, 2
	addi	a0, a0, 0x33
	slli	t0, t5, 7
	or	a0, a0, t0
	slli	t0, t6, 15		# rs1
	or	a0, a0, t0
	sw	a0, 0(s5)
	addi	s5, s5, 4
	j	asm_loop
p2r_sgtz:
	# slt rd, zero, rs:  f3=2, op=0x33, rs1=0, rs2=rs
	lui	a0, 2
	addi	a0, a0, 0x33
	slli	t0, t5, 7
	or	a0, a0, t0
	slli	t0, t6, 20		# rs2
	or	a0, a0, t0
	sw	a0, 0(s5)
	addi	s5, s5, 4
	j	asm_loop

# ── B-type vs zero (rs, label) ──────────────────────────────────────────────
asm_instr_beqz:
	addi	sp, sp, -16
	lui	a0, 0
	addi	a0, a0, 0x63		# beq base
	sw	a0, 12(sp)
	j	asm_btype_z_start
asm_instr_bnez:
	addi	sp, sp, -16
	lui	a0, 1
	addi	a0, a0, 0x63		# bne base
	sw	a0, 12(sp)
	j	asm_btype_z_start
asm_instr_bltz:
	addi	sp, sp, -16
	lui	a0, 4
	addi	a0, a0, 0x63		# blt base
	sw	a0, 12(sp)
	j	asm_btype_z_start
asm_instr_bgez:
	addi	sp, sp, -16
	lui	a0, 5
	addi	a0, a0, 0x63		# bge base
	sw	a0, 12(sp)
	j	asm_btype_z_start

asm_btype_z_start:
	sw	zero, 4(sp)		# rs2 = zero
	addi	gp, zero, 18		# apr site 18 = apr_btz_rs
	j	asm_parse_reg
apr_btz_rs:
	sw	a0, 0(sp)
	addi	gp, zero, 96		# skip_ws site 96 = asm_sw_btype_c2
	j	skip_ws

# ── B-type with operand swap (rs, rt, label → original opcode rt, rs, label)
asm_instr_bgt:
	addi	sp, sp, -16
	lui	a0, 4
	addi	a0, a0, 0x63		# blt base
	sw	a0, 12(sp)
	j	asm_btype_swap_start
asm_instr_ble:
	addi	sp, sp, -16
	lui	a0, 5
	addi	a0, a0, 0x63		# bge base
	sw	a0, 12(sp)
	j	asm_btype_swap_start
asm_instr_bgtu:
	addi	sp, sp, -16
	lui	a0, 6
	addi	a0, a0, 0x63		# bltu base
	sw	a0, 12(sp)
	j	asm_btype_swap_start
asm_instr_bleu:
	addi	sp, sp, -16
	lui	a0, 7
	addi	a0, a0, 0x63		# bgeu base
	sw	a0, 12(sp)
	j	asm_btype_swap_start

# ── lla rd, label — load label address (auipc + addi pair) ─────────────────
# Emits two placeholder words (auipc rd, 0; addi rd, rd, 0) and registers a
# kind-6 fixup so Phase 4.6 can patch both with the pc-relative offset.
asm_instr_lla:
	addi	sp, sp, -4
	addi	gp, zero, 21		# apr site 21 = apr_lla_rd
	j	asm_parse_reg
apr_lla_rd:
	sw	a0, 0(sp)
	addi	gp, zero, 107		# skip_ws site 107 = asm_sw_lla_c
	j	skip_ws
asm_sw_lla_c:
	lbu	t0, 0(s2)
	addi	t1, zero, ','
	bne	t0, t1, asm_bad_comma
	addi	s2, s2, 1
	addi	gp, zero, 108		# skip_ws site 108 = asm_sw_lla_lbl
	j	skip_ws
asm_sw_lla_lbl:
	bge	s2, s3, asm_bad_label
	addi	gp, zero, 26		# parse_ident site 26 = asm_pi_lla_lbl
	j	parse_ident
asm_pi_lla_lbl:
	beqz	s11, asm_bad_label
	# Build and emit the auipc placeholder: 0x00000017 | (rd<<7).
	lw	t5, 0(sp)		# rd
	addi	sp, sp, 4
	lui	a0, 0
	addi	a0, a0, 0x17
	slli	t0, t5, 7
	or	a0, a0, t0
	# We need a second slot for the addi placeholder so we can't go through
	# asm_add_fixup_and_emit (which only emits one word). Inline it.
	# First: register the fixup with kind=6 and fixup_addr=s5.
	lla	t0, asm_fix_top
	lw	t1, 0(t0)
	lla	t0, asm_fix_end
	lw	t2, 0(t0)
	bge	t1, t2, asm_fix_full
	# Copy label name (s10/s11) into the fixup entry's first 32 bytes.
	addi	t5, zero, 0
asm_lla_cp:
	addi	t6, zero, 32
	beq	t5, t6, asm_lla_cp_done
	add	t3, t1, t5
	blt	t5, s11, asm_lla_cp_in
	sb	zero, 0(t3)
	j	asm_lla_cp_next
asm_lla_cp_in:
	add	t4, s10, t5
	lbu	t6, 0(t4)
	sb	t6, 0(t3)
asm_lla_cp_next:
	addi	t5, t5, 1
	j	asm_lla_cp
asm_lla_cp_done:
	sw	s5, 32(t1)		# fixup_addr = current s5 (auipc PC)
	addi	t5, zero, 6
	sw	t5, 36(t1)		# kind = 6 (LLA)
	addi	t1, t1, 40
	lla	t0, asm_fix_top
	sw	t1, 0(t0)
	# Emit the auipc placeholder.
	sw	a0, 0(s5)
	addi	s5, s5, 4
	# Emit the addi placeholder: 0x00000013 | (rd<<7) | (rd<<15).
	# Reload rd (we popped sp earlier so need to recompute from a0).
	# Simpler: extract rd from a0 (auipc word) bits 11:7.
	srli	t5, a0, 7
	andi	t5, t5, 0x1F		# t5 = rd
	lui	a0, 0
	addi	a0, a0, 0x13
	slli	t0, t5, 7
	or	a0, a0, t0
	slli	t0, t5, 15
	or	a0, a0, t0
	sw	a0, 0(s5)
	addi	s5, s5, 4
	j	asm_loop

asm_btype_swap_start:
	addi	gp, zero, 19		# apr site 19 = apr_bts_first
	j	asm_parse_reg
apr_bts_first:
	sw	a0, 4(sp)		# first arg → rs2 slot (swap)
	addi	gp, zero, 106		# skip_ws site 106 = asm_sw_bts_c1
	j	skip_ws
asm_sw_bts_c1:
	lbu	t0, 0(s2)
	addi	t1, zero, ','
	bne	t0, t1, asm_bad_comma
	addi	s2, s2, 1
	addi	gp, zero, 20		# apr site 20 = apr_bts_second
	j	asm_parse_reg
apr_bts_second:
	sw	a0, 0(sp)		# second arg → rs1 slot (swap)
	addi	gp, zero, 96		# skip_ws site 96 = asm_sw_btype_c2
	j	skip_ws

# ══════════════════════════════════════════════════════════════════════════════
# asm_binding — parse (reg=var) or (var=reg).
# Frame (16 bytes): tok1_s10 tok1_s11 tok1_reg tok2_reg
# ══════════════════════════════════════════════════════════════════════════════
asm_binding:
	# Frame (12 bytes):
	#   0(sp): tok1_reg  (or -1 if tok1 is a variable)
	#   4(sp): saved var offset (for output case; parsed before tok2 overwrites buffer)
	addi	s2, s2, 1		# consume '('
	addi	sp, sp, -12
	addi	gp, zero, 86		# skip_ws site 86 = asm_bind_sw1
	j	skip_ws
asm_bind_sw1:
	addi	gp, zero, 19		# parse_ident site 19 = asm_bind_pi1
	j	parse_ident
asm_bind_pi1:
	beqz	s11, asm_bad_binding
	# Try reg lookup on token1 (still in buffer).
	addi	gp, zero, 9		# apr site 9 = apr_bind1
	j	asm_parse_reg_tok
apr_bind1:
	sw	a0, 0(sp)		# tok1_reg (-1 if var)
	addi	t0, zero, -1
	beq	a0, t0, asm_bind_tok1_is_var
	j	asm_bind_after_tok1
asm_bind_tok1_is_var:
	# tok1 is a variable name — look it up NOW before tok2 overwrites buffer.
	addi	gp, zero, 8		# lookup site 8 = la_asm_out_tok1
	j	lookup
la_asm_out_tok1:
	sw	a0, 4(sp)		# saved var offset
asm_bind_after_tok1:
	addi	gp, zero, 87		# skip_ws site 87 = asm_bind_sw_eq
	j	skip_ws
asm_bind_sw_eq:
	bge	s2, s3, asm_bad_binding
	lbu	t0, 0(s2)
	addi	t1, zero, '='
	bne	t0, t1, asm_bad_binding
	addi	s2, s2, 1
	addi	gp, zero, 88		# skip_ws site 88 = asm_bind_sw2
	j	skip_ws
asm_bind_sw2:
	addi	gp, zero, 20		# parse_ident site 20 = asm_bind_pi2
	j	parse_ident
asm_bind_pi2:
	beqz	s11, asm_bad_binding
	addi	gp, zero, 10		# apr site 10 = apr_bind2
	j	asm_parse_reg_tok
apr_bind2:
	# a0 = tok2_reg (-1 if var). Save for direction decision.
	# Keep s10/s11 pointing at tok2 in case we need lookup (input case).
	addi	t5, a0, 0		# save tok2_reg in t5
	addi	gp, zero, 89		# skip_ws site 89 = asm_bind_sw_rp
	j	skip_ws
asm_bind_sw_rp:
	bge	s2, s3, asm_bad_binding
	lbu	t0, 0(s2)
	addi	t1, zero, ')'
	bne	t0, t1, asm_bad_binding
	addi	s2, s2, 1
	# Decide direction. tok1_reg at 0(sp), tok2_reg in t5.
	lw	t0, 0(sp)		# tok1_reg
	addi	t1, zero, -1
	beq	t0, t1, asm_bind_out	# tok1 is var → (var=reg) output
	beq	t5, t1, asm_bind_in	# tok2 is var → (reg=var) input
	j	asm_bad_binding

asm_bind_in:
	# tok2 is var, s10/s11 still hold tok2. Look up, emit lw.
	# Save tok1_reg (t5 has tok2_reg which is -1; we want tok1_reg from stack).
	lw	t6, 0(sp)		# tok1_reg (the register to load into)
	addi	sp, sp, -4
	sw	t6, 0(sp)		# push tok1_reg
	addi	gp, zero, 9		# lookup site 9 = la_asm_in
	j	lookup
la_asm_in:
	lw	t5, 0(sp)		# tok1_reg
	addi	sp, sp, 16		# free pushed reg + 12-byte frame
	# lw rd, off(fp) = 0x00042003 base
	lui	t0, 0x42
	addi	t0, t0, 0x003
	slli	t1, t5, 7
	or	t0, t0, t1
	andi	t1, a0, 0xFFF
	slli	t1, t1, 20
	or	t0, t0, t1
	sw	t0, 0(s5)
	addi	s5, s5, 4
	j	asm_loop

asm_bind_out:
	# tok1 is var, already looked up. Offset is at 4(sp). tok2_reg is in t5.
	lw	a0, 4(sp)		# saved var offset
	addi	sp, sp, 12
	# sw rs2, off(fp) = 0x00042023 base
	lui	t0, 0x42
	addi	t0, t0, 0x023
	slli	t1, t5, 20		# rs2 = tok2_reg
	or	t0, t0, t1
	andi	t1, a0, 0x1F
	slli	t1, t1, 7
	or	t0, t0, t1
	srli	t1, a0, 5
	andi	t1, t1, 0x7F
	slli	t1, t1, 25
	or	t0, t0, t1
	sw	t0, 0(s5)
	addi	s5, s5, 4
	j	asm_loop

# ══════════════════════════════════════════════════════════════════════════════
# asm_parse_reg — parse next whitespace-separated token as a register name.
# Multi-caller, dispatches back via gp. Returns reg num in a0.
# asm_parse_reg_tok is an alternate entry that skips skip_ws + parse_ident.
# ══════════════════════════════════════════════════════════════════════════════
asm_parse_reg:
	addi	sp, sp, -4
	sw	gp, 0(sp)
	addi	gp, zero, 90		# skip_ws site 90 = asm_apr_sw
	j	skip_ws
asm_apr_sw:
	addi	gp, zero, 18		# parse_ident site 18 = asm_apr_pi
	j	parse_ident
asm_apr_pi:
	beqz	s11, asm_apr_bad
	j	asm_apr_lookup
asm_parse_reg_tok:
	addi	sp, sp, -4
	sw	gp, 0(sp)
asm_apr_lookup:
	addi	t0, zero, 4
	blt	t0, s11, asm_apr_notreg
	addi	t0, zero, 0
	lbu	t1, 0(s10)
	or	t0, t0, t1
	addi	t2, zero, 1
	beq	s11, t2, asm_apr_do
	lbu	t1, 1(s10)
	slli	t1, t1, 8
	or	t0, t0, t1
	addi	t2, zero, 2
	beq	s11, t2, asm_apr_do
	lbu	t1, 2(s10)
	slli	t1, t1, 16
	or	t0, t0, t1
	addi	t2, zero, 3
	beq	s11, t2, asm_apr_do
	lbu	t1, 3(s10)
	slli	t1, t1, 24
	or	t0, t0, t1
asm_apr_do:
	# Special case "fp" → x8
	lui	t1, 0x7
	addi	t1, t1, 0x66
	beq	t0, t1, asm_apr_fp
	lla	t1, asm_abi_names
	addi	t2, zero, 0
asm_apr_scan_abi:
	addi	t3, zero, 32
	beq	t2, t3, asm_apr_try_x
	slli	t3, t2, 2
	add	t4, t1, t3
	lw	t4, 0(t4)
	beq	t0, t4, asm_apr_found
	addi	t2, t2, 1
	j	asm_apr_scan_abi
asm_apr_try_x:
	lla	t1, asm_x_names
	addi	t2, zero, 0
asm_apr_scan_x:
	addi	t3, zero, 32
	beq	t2, t3, asm_apr_notreg
	slli	t3, t2, 2
	add	t4, t1, t3
	lw	t4, 0(t4)
	beq	t0, t4, asm_apr_found
	addi	t2, t2, 1
	j	asm_apr_scan_x
asm_apr_fp:
	addi	t2, zero, 8
asm_apr_found:
	addi	a0, t2, 0
	j	asm_apr_ret
asm_apr_notreg:
	addi	a0, zero, -1
asm_apr_ret:
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	asm_apr_disp
asm_apr_bad:
	addi	a0, zero, 59
	j	report_err

asm_apr_disp:
	bnez	gp, asm_apr_d1
	j	apr_mv_rd
asm_apr_d1:
	addi	gp, gp, -1
	bnez	gp, asm_apr_d2
	j	apr_mv_rs1
asm_apr_d2:
	addi	gp, gp, -1
	bnez	gp, asm_apr_d3
	j	apr_li_rd
asm_apr_d3:
	addi	gp, gp, -1
	bnez	gp, asm_apr_d4
	j	apr_utype_rd
asm_apr_d4:
	addi	gp, gp, -1
	bnez	gp, asm_apr_d5
	j	apr_itype_rd
asm_apr_d5:
	addi	gp, gp, -1
	bnez	gp, asm_apr_d6
	j	apr_itype_rs1
asm_apr_d6:
	addi	gp, gp, -1
	bnez	gp, asm_apr_d7
	j	apr_rtype_rd
asm_apr_d7:
	addi	gp, gp, -1
	bnez	gp, asm_apr_d8
	j	apr_rtype_rs1
asm_apr_d8:
	addi	gp, gp, -1
	bnez	gp, asm_apr_d9
	j	apr_rtype_rs2
asm_apr_d9:
	addi	gp, gp, -1
	bnez	gp, asm_apr_d10
	j	apr_bind1
asm_apr_d10:
	addi	gp, gp, -1
	bnez	gp, asm_apr_d11
	j	apr_bind2
asm_apr_d11:
	addi	gp, gp, -1
	bnez	gp, asm_apr_d12
	j	apr_memop_first
asm_apr_d12:
	addi	gp, gp, -1
	bnez	gp, asm_apr_d13
	j	apr_memop_second
asm_apr_d13:
	addi	gp, gp, -1
	bnez	gp, asm_apr_d14
	j	apr_btype_rs1
asm_apr_d14:
	addi	gp, gp, -1
	bnez	gp, asm_apr_d15
	j	apr_btype_rs2
asm_apr_d15:
	addi	gp, gp, -1
	bnez	gp, asm_apr_d16
	j	apr_jal_rd
asm_apr_d16:
	addi	gp, gp, -1
	bnez	gp, asm_apr_d17
	j	apr_2r_rd
asm_apr_d17:
	addi	gp, gp, -1
	bnez	gp, asm_apr_d18
	j	apr_2r_rs
asm_apr_d18:
	addi	gp, gp, -1
	bnez	gp, asm_apr_d19
	j	apr_btz_rs
asm_apr_d19:
	addi	gp, gp, -1
	bnez	gp, asm_apr_d20
	j	apr_bts_first
asm_apr_d20:
	addi	gp, gp, -1
	bnez	gp, asm_apr_d21
	j	apr_bts_second
asm_apr_d21:
	j	apr_lla_rd

asm_bad_lbrace:
	addi	a0, zero, 9
	j	report_err
asm_bad_unterm:
	addi	a0, zero, 58
	j	report_err
asm_bad_mnem:
	addi	a0, zero, 59
	j	report_err
asm_bad_comma:
	addi	a0, zero, 60
	j	report_err
asm_bad_binding:
	addi	a0, zero, 61
	j	report_err
asm_bad_utype_imm:
	addi	a0, zero, 75		# err 75: asm U-type imm out of range
	j	report_err
asm_bad_itype_imm:
	addi	a0, zero, 76		# err 76: asm I-type imm out of range
	j	report_err

# ── ct_fn_call — compile a function call expression ─────────────────────────
# Entered from pi_ct_var after parse_ident finds an ident followed by '('.
# We're in compile_unary's 12-byte frame; we allocate an extra 24 bytes for
# our own state.
ct_fn_call:
	# Reject prefix ++/-- / deref against a call for now.
	lw	t0, 8(sp)
	bnez	t0, ct_bad_literal_pp
	lw	t0, 4(sp)
	bnez	t0, ct_bad_literal_pp

	addi	sp, sp, -24
	# 0(sp): fn entry_addr
	# 4(sp): num_params
	# 8(sp): arg count parsed so far
	# 12(sp): entry_depth (value-stack depth on entry to ct_fn_call)
	# Snapshot entry_depth so the arg loader knows which s-regs hold the
	# args (s[2+entry_depth] .. s[2+entry_depth+num_args-1]).
	lla	t0, expr_depth
	lw	t1, 0(t0)
	sw	t1, 12(sp)

	# Look up the function.
	addi	gp, zero, 1		# fn_lookup site 1 = fnlk_ret_call
	j	fn_lookup
fnlk_ret_call:
	beqz	a0, ct_bad_undef_fn
	lw	t0, 32(a0)		# entry_addr
	sw	t0, 0(sp)
	lbu	t0, 36(a0)		# num_params
	sw	t0, 4(sp)
	sw	zero, 8(sp)

	# Require entry_depth + num_params ≤ 9 so every arg lives in an
	# s-register (the load loop doesn't handle memory-spilled args).
	# For flex-arg asm fns (num_params == 0xFF) the worst case is 8,
	# so use 8 for the check.
	addi	t1, zero, 0xFF
	bne	t0, t1, ct_call_depth_chk
	addi	t0, zero, 8
ct_call_depth_chk:
	lw	t2, 12(sp)		# entry_depth
	add	t2, t2, t0
	addi	t1, zero, 9
	bgt	t2, t1, ct_bad_expr_too_deep

	# Skip ws, consume '(' (we peeked it already in pi_ct_var).
	addi	gp, zero, 45		# skip_ws site 45 = sw_ct_call_lparen
	j	skip_ws
sw_ct_call_lparen:
	addi	s2, s2, 1		# we know it's '('

	# Parse args: expressions separated by ',', terminated by ')'.
ct_call_arg_loop:
	addi	gp, zero, 46		# skip_ws site 46 = sw_ct_call_arg
	j	skip_ws
sw_ct_call_arg:
	bge	s2, s3, ct_bad_call_rparen
	lbu	t0, 0(s2)
	addi	t1, zero, ')'
	beq	t0, t1, ct_call_args_done
	# If not the first arg, expect ','.
	lw	t2, 8(sp)
	beqz	t2, ct_call_compile_arg
	addi	t1, zero, ','
	bne	t0, t1, ct_bad_call_rparen
	addi	s2, s2, 1
ct_call_compile_arg:
	# Compile the next argument — min_bp = 0, stops at ',' or ')'.
	addi	t6, zero, 0
	addi	gp, zero, 33		# compile_expr site 33 = ce_ct_call_arg
	j	compile_expr_p
ce_ct_call_arg:
	# Push the result.
	addi	gp, zero, 25		# push site 25 = push_ct_call_arg
	j	emit_push_a0
push_ct_call_arg:
	lw	t2, 8(sp)
	addi	t2, t2, 1
	sw	t2, 8(sp)
	j	ct_call_arg_loop

ct_call_args_done:
	addi	s2, s2, 1		# consume ')'
	# Check arg count == num_params. For asm functions (num_params == 0xFF)
	# we accept any count up to 8 and overwrite num_params with actual count.
	lw	t0, 4(sp)
	addi	t2, zero, 0xFF
	bne	t0, t2, ct_call_chk_normal
	# Flex arg count: must be 0..8.
	lw	t0, 8(sp)
	addi	t1, zero, 9
	bge	t0, t1, cs_bad_fn_too_many_args
	sw	t0, 4(sp)		# replace num_params with actual count
	j	ct_call_args_ok
ct_call_chk_normal:
	lw	t1, 8(sp)
	bne	t0, t1, ct_bad_call_argc
ct_call_args_ok:

	# Load args into a0..a(N-1) from the value-stack s-regs. Each arg N
	# was pushed at depth (entry_depth + N), so it lives in
	# s[2 + entry_depth + N]. We emit `addi a[idx], s[..], 0` (mv) for
	# each arg idx in 0..num_params-1, then drop expr_depth back to
	# entry_depth to release the slots. emit_word clobbers t6, so we
	# reload entry_depth from frame each iteration.
	lw	t5, 4(sp)		# num_params
	beqz	t5, ct_call_args_loaded
	addi	t3, zero, 0		# idx
ct_call_load_loop:
	lw	t5, 4(sp)
	beq	t3, t5, ct_call_load_done
	lw	t6, 12(sp)		# reload entry_depth
	# rs1 = 18 + entry_depth + idx  (= s[2 + entry_depth + idx])
	add	t0, t6, t3
	addi	t0, t0, 18
	slli	t0, t0, 15
	# rd  = 10 + idx                (= a[idx])
	addi	t1, t3, 10
	slli	t1, t1, 7
	# word = 0x13 | rs1 | rd
	lui	a0, 0
	addi	a0, a0, 0x13
	or	a0, a0, t0
	or	a0, a0, t1
	addi	gp, zero, 65		# emit_word site 65 = ew_ct_call_load
	j	emit_word
ew_ct_call_load:
	addi	t3, t3, 1
	j	ct_call_load_loop
ct_call_load_done:
	# Release the arg slots: depth = entry_depth.
	lw	t6, 12(sp)
	lla	t0, expr_depth
	sw	t6, 0(t0)
ct_call_args_loaded:

	# Allocate a new ret_id (= current ret_top count).
	lla	t0, ret_base
	lw	t0, 0(t0)
	lla	t1, ret_top
	lw	t1, 0(t1)
	sub	t2, t1, t0		# bytes used
	srli	t2, t2, 2		# count = ret_id

	# Emit `lui ra, hi` and `addi ra, ra, lo` so ra = ret_id at runtime.
	# lui ra:   0x000000B7 | (hi << 12)
	# addi ra:  0x00008093 | (lo << 20)
	# hi = (id + 0x800) >> 12  (signed arithmetic)
	# lo = sign-extended low 12 of id
	addi	t3, t2, 0		# id
	addi	t4, zero, 1
	slli	t4, t4, 11		# 0x800
	add	t5, t3, t4
	srai	t5, t5, 12		# hi
	# lui ra, hi
	slli	t6, t5, 12
	lui	a0, 0
	addi	a0, a0, 0xB7
	or	a0, a0, t6
	addi	gp, zero, 67		# emit_word site 67 = ew_ct_call_lui
	j	emit_word
ew_ct_call_lui:
	# lo12 = id - (hi<<12), fit back into 12-bit
	lla	t0, ret_base
	lw	t0, 0(t0)
	lla	t1, ret_top
	lw	t1, 0(t1)
	sub	t2, t1, t0
	srli	t2, t2, 2		# id
	addi	t4, zero, 1
	slli	t4, t4, 11
	add	t5, t2, t4
	srai	t5, t5, 12		# hi
	slli	t6, t5, 12
	sub	t3, t2, t6		# lo12 (signed)
	andi	t3, t3, 0xFFF
	slli	t3, t3, 20
	lui	a0, 0x8
	addi	a0, a0, 0x093
	or	a0, a0, t3
	addi	gp, zero, 68		# emit_word site 68 = ew_ct_call_addi
	j	emit_word
ew_ct_call_addi:
	# Emit `jal zero, 0` (placeholder), then patch to fn entry_addr.
	lui	a0, 0
	addi	a0, a0, 0x6F
	addi	gp, zero, 69		# emit_word site 69 = ew_ct_call_jal
	j	emit_word
ew_ct_call_jal:
	addi	t5, s5, -4
	lw	t6, 0(sp)		# fn entry_addr
	addi	gp, zero, 19		# patch_jtype site 19 = pjt_ct_call_jal
	j	patch_jtype
pjt_ct_call_jal:

	# Record ret_site = current s5 in ret_base list.
	addi	a0, s5, 0
	lla	a1, ret_base
	lla	a2, ret_top
	lla	a3, ret_end
	addi	gp, zero, 0		# list_append_word site 0 = law_ret_ret_site
	j	list_append_word
law_ret_ret_site:

	# a0 at runtime now holds the return value. lv_kind = 0 (not lvalue).
	addi	sp, sp, 24
	lla	t0, lv_kind
	sw	zero, 0(t0)
	j	ct_done

# ── ct_kw_return — compile `return [expr]` ──────────────────────────────────
# Reached via pi_ct's keyword check. Requires we're inside a function.
ct_kw_return:
	lla	t0, current_fn
	lw	t1, 0(t0)
	beqz	t1, ct_bad_return_outside

	# Peek for an optional value expression (stops at ';', '}', etc.).
	addi	gp, zero, 47		# skip_ws site 47 = sw_ct_return_peek
	j	skip_ws
sw_ct_return_peek:
	bge	s2, s3, ct_return_no_val
	lbu	t0, 0(s2)
	addi	t1, zero, ';'
	beq	t0, t1, ct_return_no_val
	addi	t1, zero, '}'
	beq	t0, t1, ct_return_no_val
	addi	t1, zero, ')'
	beq	t0, t1, ct_return_no_val
	addi	t1, zero, ':'
	beq	t0, t1, ct_return_no_val
	# Compile value expr.
	addi	t6, zero, 0
	addi	gp, zero, 34		# compile_expr site 34 = ce_ct_return_val
	j	compile_expr_p
ce_ct_return_val:
	j	ct_return_emit_jal
ct_return_no_val:
	# Default 0.
	lui	a0, 0
	addi	a0, a0, 0x513
	addi	gp, zero, 70		# emit_word site 70 = ew_ct_return_li0
	j	emit_word
ew_ct_return_li0:
ct_return_emit_jal:
	# Emit placeholder jal, add its addr to ret_list.
	lui	a0, 0
	addi	a0, a0, 0x6F
	addi	gp, zero, 71		# emit_word site 71 = ew_ct_return_jal
	j	emit_word
ew_ct_return_jal:
	addi	a0, s5, -4
	lla	a1, ret_list_base
	lla	a2, ret_list_top
	lla	a3, ret_list_end
	addi	gp, zero, 1		# list_append_word site 1 = law_ret_return_list
	j	list_append_word
law_ret_return_list:
	lla	t0, lv_kind
	sw	zero, 0(t0)
	j	ct_done

cs_bad_fn_nested:
	addi	a0, zero, 37		# err 37: nested function
	j	report_err
cs_bad_fn_name:
	addi	a0, zero, 6		# err 6: expected identifier
	j	report_err
cs_bad_fn_lparen:
	addi	a0, zero, 12		# err 12: '('
	j	report_err
cs_bad_fn_rparen:
	addi	a0, zero, 2		# err 2: ')'
	j	report_err
cs_bad_fn_param_name:
	addi	a0, zero, 6		# err 6: expected identifier
	j	report_err
cs_bad_fn_too_many_args:
	addi	a0, zero, 38		# err 38: too many params (>8)
	j	report_err
cs_bad_fn_body:
	addi	a0, zero, 9		# err 9: '{'
	j	report_err
cs_bad_fn_redefined:
	addi	a0, zero, 39		# err 39: function already defined
	j	report_err
cs_bad_fn_frame_too_big:
	addi	a0, zero, 40		# err 40: function frame too large
	j	report_err
ct_bad_undef_fn:
	# Point at the function name (ident_start was saved by parse_ident).
	lla	t0, ident_start
	lw	s2, 0(t0)
	addi	a0, zero, 41		# err 41: undefined function
	j	report_err
ct_bad_call_argc:
	addi	a0, zero, 42		# err 42: wrong number of arguments
	j	report_err
ct_bad_call_rparen:
	addi	a0, zero, 2		# err 2: ')'
	j	report_err
ct_bad_expr_too_deep:
	addi	a0, zero, 87		# err 87: expression too deep
	j	report_err
ct_bad_return_outside:
	addi	a0, zero, 43		# err 43: return outside function
	j	report_err

ct_id:
	addi	gp, zero, 0
	j	parse_ident
pi_ct:
	# Keyword check before treating as variable. parse_ident left the
	# token chars at s10, length at s11.
	addi	t0, zero, 4
	bne	s11, t0, pi_ct_not_loop
	lbu	t1, 0(s10)
	addi	t2, zero, 'l'
	bne	t1, t2, pi_ct_not_loop
	lbu	t1, 1(s10)
	addi	t2, zero, 'o'
	bne	t1, t2, pi_ct_not_loop
	lbu	t1, 2(s10)
	bne	t1, t2, pi_ct_not_loop
	lbu	t1, 3(s10)
	addi	t2, zero, 'p'
	bne	t1, t2, pi_ct_not_loop
	j	ct_kw_loop
pi_ct_not_loop:
	addi	t0, zero, 5
	bne	s11, t0, pi_ct_not_break
	lbu	t1, 0(s10)
	addi	t2, zero, 'b'
	bne	t1, t2, pi_ct_not_break
	lbu	t1, 1(s10)
	addi	t2, zero, 'r'
	bne	t1, t2, pi_ct_not_break
	lbu	t1, 2(s10)
	addi	t2, zero, 'e'
	bne	t1, t2, pi_ct_not_break
	lbu	t1, 3(s10)
	addi	t2, zero, 'a'
	bne	t1, t2, pi_ct_not_break
	lbu	t1, 4(s10)
	addi	t2, zero, 'k'
	bne	t1, t2, pi_ct_not_break
	j	ct_kw_break
pi_ct_not_break:
	addi	t0, zero, 8
	bne	s11, t0, pi_ct_not_continue
	lbu	t1, 0(s10)
	addi	t2, zero, 'c'
	bne	t1, t2, pi_ct_not_continue
	lbu	t1, 1(s10)
	addi	t2, zero, 'o'
	bne	t1, t2, pi_ct_not_continue
	lbu	t1, 2(s10)
	addi	t2, zero, 'n'
	bne	t1, t2, pi_ct_not_continue
	lbu	t1, 3(s10)
	addi	t2, zero, 't'
	bne	t1, t2, pi_ct_not_continue
	lbu	t1, 4(s10)
	addi	t2, zero, 'i'
	bne	t1, t2, pi_ct_not_continue
	lbu	t1, 5(s10)
	addi	t2, zero, 'n'
	bne	t1, t2, pi_ct_not_continue
	lbu	t1, 6(s10)
	addi	t2, zero, 'u'
	bne	t1, t2, pi_ct_not_continue
	lbu	t1, 7(s10)
	addi	t2, zero, 'e'
	bne	t1, t2, pi_ct_not_continue
	j	ct_kw_continue
pi_ct_not_continue:
	addi	t0, zero, 3
	bne	s11, t0, pi_ct_not_for
	lbu	t1, 0(s10)
	addi	t2, zero, 'f'
	bne	t1, t2, pi_ct_not_for
	lbu	t1, 1(s10)
	addi	t2, zero, 'o'
	bne	t1, t2, pi_ct_not_for
	lbu	t1, 2(s10)
	addi	t2, zero, 'r'
	bne	t1, t2, pi_ct_not_for
	j	ct_kw_for
pi_ct_not_for:
	# 'return' (6 chars) — early return from the current function.
	addi	t0, zero, 6
	bne	s11, t0, pi_ct_not_return
	lbu	t1, 0(s10)
	addi	t2, zero, 'r'
	bne	t1, t2, pi_ct_not_return
	lbu	t1, 1(s10)
	addi	t2, zero, 'e'
	bne	t1, t2, pi_ct_not_return
	lbu	t1, 2(s10)
	addi	t2, zero, 't'
	bne	t1, t2, pi_ct_not_return
	lbu	t1, 3(s10)
	addi	t2, zero, 'u'
	bne	t1, t2, pi_ct_not_return
	lbu	t1, 4(s10)
	addi	t2, zero, 'r'
	bne	t1, t2, pi_ct_not_return
	lbu	t1, 5(s10)
	addi	t2, zero, 'n'
	bne	t1, t2, pi_ct_not_return
	j	ct_kw_return
pi_ct_not_return:
	# 'sizeof' (6 chars) — compile-time size query. Currently only
	# struct types are supported.
	addi	t0, zero, 6
	bne	s11, t0, pi_ct_var
	lbu	t1, 0(s10)
	addi	t2, zero, 's'
	bne	t1, t2, pi_ct_var
	lbu	t1, 1(s10)
	addi	t2, zero, 'i'
	bne	t1, t2, pi_ct_var
	lbu	t1, 2(s10)
	addi	t2, zero, 'z'
	bne	t1, t2, pi_ct_var
	lbu	t1, 3(s10)
	addi	t2, zero, 'e'
	bne	t1, t2, pi_ct_var
	lbu	t1, 4(s10)
	addi	t2, zero, 'o'
	bne	t1, t2, pi_ct_var
	lbu	t1, 5(s10)
	addi	t2, zero, 'f'
	bne	t1, t2, pi_ct_var
	j	ct_kw_sizeof
pi_ct_var:
	# First — check if this ident names a known struct type. If so,
	# peek for '{' (struct literal) or '@' (struct access). Otherwise
	# fall through to the regular variable/function logic below.
	addi	gp, zero, 1		# struct_lookup site 1 = stlk_ret_ct_id
	j	struct_lookup
stlk_ret_ct_id:
	beqz	a0, pi_ct_not_struct
	# a0 = struct entry pointer. Peek next non-ws char.
	addi	t3, s2, 0
	j	pk_sct_ws
pi_ct_not_struct:
	# Peek: if next non-ws char is '@', user tried a struct access with
	# an unknown type — give a specific error instead of "undefined var".
	addi	t3, s2, 0
pct_ns_ws:
	bge	t3, s3, pi_ct_not_struct_var
	lbu	t0, 0(t3)
	addi	t1, zero, 33
	bge	t0, t1, pct_ns_check
	addi	t3, t3, 1
	j	pct_ns_ws
pct_ns_check:
	addi	t1, zero, '@'
	bne	t0, t1, pi_ct_not_struct_var
	lla	t0, ident_start
	lw	s2, 0(t0)
	addi	a0, zero, 54		# err 54: unknown struct type
	j	report_err
pi_ct_not_struct_var:
	# Fall through to the regular variable lookup logic below.
	j	pk_ws_loop

	# ── Struct-found path continues here (from stlk_ret_ct_id above).
pk_sct_ws:
	bge	t3, s3, ct_bad_struct_use
	lbu	t0, 0(t3)
	addi	t1, zero, 33
	bge	t0, t1, pk_sct_non_ws
	addi	t3, t3, 1
	j	pk_sct_ws
pk_sct_non_ws:
	addi	t1, zero, '{'
	beq	t0, t1, ct_struct_literal
	addi	t1, zero, '@'
	beq	t0, t1, ct_struct_access
	j	ct_bad_struct_use
	# Decide between "lookup-or-alloc" (if this ident is about to be the
	# LHS of a bare '=' assignment — definition or reuse) and "lookup
	# only, error if missing" (otherwise). We peek the first non-ws char
	# after the ident; a single '=' that isn't followed by another '='
	# means we're in write context.
	addi	t3, s2, 0
pk_ws_loop:
	bge	t3, s3, pk_read_ctx
	lbu	t0, 0(t3)
	addi	t1, zero, 33
	bge	t0, t1, pk_non_ws
	addi	t3, t3, 1
	j	pk_ws_loop
pk_non_ws:
	addi	t1, zero, '('
	beq	t0, t1, pk_fn_call	# ident followed by '(' → function call
	# Check ':=' (mutable assign)
	addi	t1, zero, ':'
	beq	t0, t1, pk_chk_mut
	# Check '=' (immutable assign) — but not '=='
	addi	t1, zero, '='
	bne	t0, t1, pk_read_ctx
	addi	t3, t3, 1
	bge	t3, s3, pk_write_ctx
	lbu	t0, 0(t3)
	addi	t1, zero, '='
	beq	t0, t1, pk_read_ctx	# '==' is equality, read context
pk_write_ctx:
	addi	gp, zero, 0
	j	lookup_or_alloc
pk_chk_mut:
	addi	t3, t3, 1
	bge	t3, s3, pk_read_ctx
	lbu	t0, 0(t3)
	addi	t1, zero, '='
	bne	t0, t1, pk_read_ctx	# bare ':' → not assignment
	j	pk_write_ctx		# ':=' → write context
pk_read_ctx:
	addi	gp, zero, 0
	j	lookup
pk_fn_call:
	j	ct_fn_call
la_ct:
	# a0 = byte offset of the variable (or, for const-folded vars, the
	# constant value itself — see ce_cs_rhs). Check is_const flag.
	lla	t0, last_ident_entry
	lw	t0, 0(t0)
	lbu	t1, 38(t0)
	beqz	t1, la_ct_normal
	# Const-folded: emit `li a0, value` directly. Sub-expressions
	# downstream may try to treat this as an lvalue; that's fine —
	# cep_pre_assign rejects existing immutable rebinds.
	addi	sp, sp, -4
	sw	a0, 0(sp)
	# a0 already holds the const value (lookup returned 32(entry)).
	addi	gp, zero, 1		# eli site 1 = eli_ret_id_const
	j	emit_li
la_ct_normal:
	# Stash offset for potential reuse by prefix/postfix '++'/'--'.
	addi	sp, sp, -4
	sw	a0, 0(sp)
	addi	gp, zero, 0		# elws site 0 = elws_ret
	j	emit_lw_sp
elws_ret:
	# Was there a prefix '++' or '--'?
	lw	t0, 12(sp)
	bnez	t0, ct_id_prefix_emit
	# Check postfix '++'/'--' BEFORE the deref prefix so `@x++` means
	# `@(x++)` — dereference the OLD pointer value (C-style `*p++`).
	addi	gp, zero, 14		# skip_ws site 14 = sw_ct_post
	j	skip_ws
sw_ct_post:
	bge	s2, s3, ct_post_no_pf
	lbu	t0, 0(s2)
	addi	t1, zero, '+'
	beq	t0, t1, ct_pf_chkpp
	addi	t1, zero, '-'
	beq	t0, t1, ct_pf_chkmm
ct_post_no_pf:
	# No postfix. If there's a prefix '*'/'@', apply it now.
	lw	t0, 8(sp)
	bnez	t0, ct_id_pop_then_deref
	j	ct_id_nopf
ct_pf_chkpp:
	addi	t2, s2, 1
	bge	t2, s3, ct_post_no_pf
	lbu	t0, 0(t2)
	addi	t1, zero, '+'
	bne	t0, t1, ct_post_no_pf
	addi	s2, s2, 2
	j	ct_do_post_inc
ct_pf_chkmm:
	addi	t2, s2, 1
	bge	t2, s3, ct_post_no_pf
	lbu	t0, 0(t2)
	addi	t1, zero, '-'
	bne	t0, t1, ct_post_no_pf
	addi	s2, s2, 2
	j	ct_do_post_dec

ct_id_nopf:
	# No postfix; pure IDENT lvalue. Record slot offset and mark lv_kind = 1.
	lw	t0, 0(sp)
	addi	sp, sp, 4
	lla	t1, lv_slot
	sw	t0, 0(t1)
	lla	t1, lv_kind
	addi	t0, zero, 1
	sw	t0, 0(t1)
	j	ct_done

ct_id_pop_then_deref:
	# Prefix '*'/'@' active; discard saved offset and emit the deref.
	addi	sp, sp, 4
	j	ct_deref

ct_id_prefix_emit:
	# t0 holds incdec_kind (1 = ++, 2 = --). If a deref prefix is also
	# set, the combination isn't supported in this pass.
	lw	t1, 8(sp)
	bnez	t1, ct_bad_prefix_combo
	# Check mutability — prefix ++/-- requires mutable variable.
	lla	t3, last_ident_entry
	lw	t3, 0(t3)
	lbu	t4, 37(t3)
	beqz	t4, ct_bad_immut_pp
	addi	t2, zero, 1
	beq	t0, t2, ct_pre_inc_emit
	j	ct_pre_dec_emit

ct_pre_inc_emit:
	addi	gp, zero, 0		# eaa1 site 0 = eaa1_pre_inc
	j	emit_addi_a0_1
eaa1_pre_inc:
	lw	a0, 0(sp)
	addi	sp, sp, 4
	addi	gp, zero, 1		# esws site 1 = esws_pre_inc
	j	emit_sw_sp
esws_pre_inc:
	j	ct_done

ct_pre_dec_emit:
	addi	gp, zero, 0		# eaam1 site 0 = eaam1_pre_dec
	j	emit_addi_a0_m1
eaam1_pre_dec:
	lw	a0, 0(sp)
	addi	sp, sp, 4
	addi	gp, zero, 2		# esws site 2 = esws_pre_dec
	j	emit_sw_sp
esws_pre_dec:
	j	ct_done

ct_do_post_inc:
	lla	t3, last_ident_entry
	lw	t3, 0(t3)
	lbu	t4, 37(t3)
	beqz	t4, ct_bad_immut_pp
	# Stride from deref_kind (C-style pointer arithmetic):
	#   0 (none) → 1, 2 (byte @) → 1, 3 (half #) → 2, 1 (word *) → 4
	lw	t5, 8(sp)		# deref_kind
	addi	t6, zero, 1		# default stride = 1
	addi	t3, zero, 3
	beq	t5, t3, ct_pi_stride_h
	addi	t3, zero, 1
	beq	t5, t3, ct_pi_stride_w
	j	ct_pi_stride_done
ct_pi_stride_h:
	addi	t6, zero, 2
	j	ct_pi_stride_done
ct_pi_stride_w:
	addi	t6, zero, 4
ct_pi_stride_done:
	# Emit addi a0, a0, t6 = 0x00050513 | (t6 << 20)
	andi	t3, t6, 0xFFF
	slli	t3, t3, 20
	lui	a0, 0x50
	addi	a0, a0, 0x513
	or	a0, a0, t3
	sw	a0, 0(s5)
	addi	s5, s5, 4
	# Emit sw a0, off(fp)
	lw	a0, 0(sp)
	addi	sp, sp, 4
	# Stash stride in frame — but we already freed the offset slot.
	# Use a scratch: push stride back via sp.
	addi	sp, sp, -4
	sw	t6, 0(sp)
	addi	gp, zero, 3		# esws site 3 = esws_post_inc
	j	emit_sw_sp
eaa1_post_inc:
eaam1_post_inc_undo:
eaam1_post_dec:
eaa1_post_dec_undo:
	j	halt_err
esws_post_inc:
	# Emit addi a0, a0, -stride to undo for postfix return value.
	lw	t6, 0(sp)
	addi	sp, sp, 4
	sub	t6, zero, t6		# t6 = -stride
	andi	t3, t6, 0xFFF
	slli	t3, t3, 20
	lui	a0, 0x50
	addi	a0, a0, 0x513
	or	a0, a0, t3
	sw	a0, 0(s5)
	addi	s5, s5, 4
	j	ct_deref

ct_do_post_dec:
	lla	t3, last_ident_entry
	lw	t3, 0(t3)
	lbu	t4, 37(t3)
	beqz	t4, ct_bad_immut_pp
	# Stride from deref_kind.
	lw	t5, 8(sp)
	addi	t6, zero, 1
	addi	t3, zero, 3
	beq	t5, t3, ct_pd_stride_h
	addi	t3, zero, 1
	beq	t5, t3, ct_pd_stride_w
	j	ct_pd_stride_done
ct_pd_stride_h:
	addi	t6, zero, 2
	j	ct_pd_stride_done
ct_pd_stride_w:
	addi	t6, zero, 4
ct_pd_stride_done:
	# Emit addi a0, a0, -stride
	sub	t6, zero, t6
	andi	t3, t6, 0xFFF
	slli	t3, t3, 20
	lui	a0, 0x50
	addi	a0, a0, 0x513
	or	a0, a0, t3
	sw	a0, 0(s5)
	addi	s5, s5, 4
	# Emit sw a0, off(fp)
	lw	a0, 0(sp)
	addi	sp, sp, 4
	# Push stride (negated) for undo
	addi	sp, sp, -4
	sw	t6, 0(sp)
	addi	gp, zero, 4		# esws site 4 = esws_post_dec
	j	emit_sw_sp
esws_post_dec:
	# Emit addi a0, a0, +stride to undo.
	lw	t6, 0(sp)
	addi	sp, sp, 4
	sub	t6, zero, t6		# negate back to +stride
	andi	t3, t6, 0xFFF
	slli	t3, t3, 20
	lui	a0, 0x50
	addi	a0, a0, 0x513
	or	a0, a0, t3
	sw	a0, 0(s5)
	addi	s5, s5, 4
	j	ct_deref

ct_lparen:
	# '(' expr ')' as a primary. Consume '(', compile expr, then expect ')'.
	# A preceding '*'/'@' deref_kind (if any) is applied on the way out via
	# ct_deref. '++'/'--' never reach ct_primary with a valid incdec_kind set
	# against a paren, because those prefix handlers fall into ct_num/ct_id
	# only paths; any such pairing errors at ct_primary itself.
	addi	s2, s2, 1
	addi	t6, zero, 0		# min_bp = 0: any expr allowed inside parens
	addi	gp, zero, 12		# compile_expr site 12 = ce_ct_paren
	j	compile_expr_p
ce_ct_paren:
	addi	gp, zero, 21		# skip_ws site 21 = sw_ct_rparen
	j	skip_ws
sw_ct_rparen:
	bge	s2, s3, ct_bad_rparen
	lbu	t0, 0(s2)
	addi	t1, zero, ')'
	bne	t0, t1, ct_bad_rparen
	addi	s2, s2, 1
	j	ct_deref

ct_lbrace:
	# '{' (expr (';' expr)* ';'?)? '}'
	# Rust-style block: value is that of the last expression. Each non-final
	# expression's value is simply overwritten in a0 by the next one (no stack
	# cleanup needed since values live only in a0). A trailing ';' before '}'
	# is allowed (the block still takes its value from the last expression —
	# we don't distinguish "statement position" vs "tail expr" here).
	addi	s2, s2, 1
ct_blk_loop:
	# Leading peek: allow `{ }` (empty block) and trailing `;` before `}`.
	addi	gp, zero, 34		# skip_ws site 34 = sw_ct_blk_lead
	j	skip_ws
sw_ct_blk_lead:
	bge	s2, s3, ct_bad_brace_sep
	lbu	t0, 0(s2)
	addi	t1, zero, '}'
	beq	t0, t1, ct_blk_end
	# Try array declaration — `@IDENT[LIT];`, `#IDENT[LIT];`, or
	# `*IDENT[LIT];`. These are block-level statements (no value), and
	# after they run we fall back to the block loop via gp=1 exit.
	addi	t1, zero, '@'
	beq	t0, t1, blk_chk_decl_at
	addi	t1, zero, '#'
	beq	t0, t1, blk_chk_decl_hash
	addi	t1, zero, '*'
	beq	t0, t1, blk_chk_decl_star
	# Check for struct-typed array decl: StructName@ident[LIT]; where
	# first char is a letter. Uses an inline peek scan (no shared
	# cad_probe) to avoid stack-leak issues with the outer rewind.
	addi	t1, zero, 'a'
	blt	t0, t1, blk_chk_struct_uc
	addi	t1, zero, 123
	blt	t0, t1, blk_try_struct_decl
blk_chk_struct_uc:
	addi	t1, zero, 'A'
	blt	t0, t1, blk_compile_expr
	addi	t1, zero, 91
	blt	t0, t1, blk_try_struct_decl
	j	blk_compile_expr

blk_try_struct_decl:
	# Save s2 for rewind. Parse the ident, check struct symtab, then
	# do a simplified inline peek for @IDENT[LITERAL]; without the
	# shared scan (which has the cad_probe issue).
	addi	sp, sp, -4
	sw	s2, 0(sp)
	addi	gp, zero, 16		# parse_ident site 16 = pi_blk_struct
	j	parse_ident
pi_blk_struct:
	addi	gp, zero, 5		# struct_lookup site 5 = stlk_blk_struct
	j	struct_lookup
stlk_blk_struct:
	beqz	a0, blk_struct_rewind
	bge	s2, s3, blk_struct_rewind
	lbu	t0, 0(s2)
	addi	t1, zero, '@'
	bne	t0, t1, blk_struct_rewind
	# Struct found, '@' present. Inline peek for IDENT[LITERAL];
	# starting from s2 (which is at '@').
	addi	t0, s2, 1
bsd_ws1:
	bge	t0, s3, blk_struct_rewind
	lbu	t1, 0(t0)
	addi	t2, zero, 33
	bge	t1, t2, bsd_id_start
	addi	t0, t0, 1
	j	bsd_ws1
bsd_id_start:
	addi	t2, zero, '_'
	beq	t1, t2, bsd_id_loop
	addi	t2, zero, 'a'
	blt	t1, t2, bsd_id_uc
	addi	t2, zero, 123
	blt	t1, t2, bsd_id_loop
bsd_id_uc:
	addi	t2, zero, 'A'
	blt	t1, t2, blk_struct_rewind
	addi	t2, zero, 91
	bge	t1, t2, blk_struct_rewind
bsd_id_loop:
	addi	t0, t0, 1
	bge	t0, s3, blk_struct_rewind
	lbu	t1, 0(t0)
	addi	t2, zero, 'a'
	blt	t1, t2, bsd_id_uc2
	addi	t2, zero, 123
	blt	t1, t2, bsd_id_loop
bsd_id_uc2:
	addi	t2, zero, 'A'
	blt	t1, t2, bsd_id_dig
	addi	t2, zero, 91
	blt	t1, t2, bsd_id_loop
bsd_id_dig:
	addi	t2, zero, '0'
	blt	t1, t2, bsd_id_us
	addi	t2, zero, 58
	blt	t1, t2, bsd_id_loop
bsd_id_us:
	addi	t2, zero, '_'
	beq	t1, t2, bsd_id_loop
bsd_ws2:
	bge	t0, s3, blk_struct_rewind
	lbu	t1, 0(t0)
	addi	t2, zero, 33
	bge	t1, t2, bsd_lbrack
	addi	t0, t0, 1
	j	bsd_ws2
bsd_lbrack:
	addi	t2, zero, '['
	bne	t1, t2, blk_struct_rewind
	addi	t0, t0, 1
bsd_ws3:
	bge	t0, s3, blk_struct_rewind
	lbu	t1, 0(t0)
	addi	t2, zero, 33
	bge	t1, t2, bsd_digit
	addi	t0, t0, 1
	j	bsd_ws3
bsd_digit:
	addi	t2, zero, '0'
	blt	t1, t2, blk_struct_rewind
	addi	t2, zero, 58
	bge	t1, t2, blk_struct_rewind
bsd_d_loop:
	addi	t0, t0, 1
	bge	t0, s3, blk_struct_rewind
	lbu	t1, 0(t0)
	addi	t2, zero, '0'
	blt	t1, t2, bsd_chk_hex
	addi	t2, zero, 58
	blt	t1, t2, bsd_d_loop
bsd_chk_hex:
	addi	t2, zero, 'a'
	blt	t1, t2, bsd_chk_HEX
	addi	t2, zero, 123
	blt	t1, t2, bsd_d_loop
bsd_chk_HEX:
	addi	t2, zero, 'A'
	blt	t1, t2, bsd_after_lit
	addi	t2, zero, 91
	blt	t1, t2, bsd_d_loop
bsd_after_lit:
bsd_ws4:
	bge	t0, s3, blk_struct_rewind
	lbu	t1, 0(t0)
	addi	t2, zero, 33
	bge	t1, t2, bsd_rbrack
	addi	t0, t0, 1
	j	bsd_ws4
bsd_rbrack:
	addi	t2, zero, ']'
	bne	t1, t2, blk_struct_rewind
	addi	t0, t0, 1
bsd_ws5:
	bge	t0, s3, blk_struct_rewind
	lbu	t1, 0(t0)
	addi	t2, zero, 33
	bge	t1, t2, bsd_semi
	addi	t0, t0, 1
	j	bsd_ws5
bsd_semi:
	addi	t2, zero, ';'
	bne	t1, t2, blk_struct_rewind
	# Pattern matches. Commit. Drop saved s2 (no longer needed).
	lw	t6, 32(a0)		# a0 still has struct entry from lookup
	slli	t6, t6, 2		# stride = count * 4
	addi	sp, sp, 4		# pop saved s2
	# Reuse the shared cs_array_decl_go. s2 is at '@' (from the struct
	# name parse). go expects s2 at the prefix char. Good.
	addi	gp, zero, 1		# cs_array_decl_go return site 1 = ct_blk_loop
	j	cs_array_decl_go

blk_struct_rewind:
	lw	s2, 0(sp)
	addi	sp, sp, 4
	j	blk_compile_expr

blk_chk_decl_at:
	addi	t6, zero, 1
	addi	gp, zero, 1		# scan return site 1 = scan_ret_blk
	j	cs_array_decl_scan
blk_chk_decl_hash:
	addi	t6, zero, 2
	addi	gp, zero, 1
	j	cs_array_decl_scan
blk_chk_decl_star:
	addi	t6, zero, 4
	addi	gp, zero, 1
	j	cs_array_decl_scan
scan_ret_blk:
	beqz	a0, blk_compile_expr
	addi	gp, zero, 1		# decl_go return site 1 = ct_blk_loop
	j	cs_array_decl_go
blk_compile_expr:
	addi	t6, zero, 0		# min_bp = 0: full expression allowed
	addi	gp, zero, 25		# compile_expr site 25 = ce_ct_blk_rec
	j	compile_expr_p
ce_ct_blk_rec:
	addi	gp, zero, 31		# skip_ws site 31 = sw_ct_blk_sep
	j	skip_ws
sw_ct_blk_sep:
	bge	s2, s3, ct_bad_brace_sep
	lbu	t0, 0(s2)
	addi	t1, zero, '}'
	beq	t0, t1, ct_blk_end
	addi	t1, zero, ';'
	bne	t0, t1, ct_bad_brace_sep
	addi	s2, s2, 1
	j	ct_blk_loop
ct_blk_end:
	addi	s2, s2, 1
	lla	t0, lv_kind
	sw	zero, 0(t0)
	lla	t0, last_was_brace
	addi	t1, zero, 1
	sw	t1, 0(t0)
	j	ct_deref

ct_deref:
	lw	t0, 4(sp)
	beqz	t0, ct_done
	# Check for array indexing: peek for '['. If found, compute
	# (base + i*stride) inline and then fall through to the deref emit.
	addi	t2, s2, 0
ct_idx_ws:
	bge	t2, s3, ct_deref_emit
	lbu	t3, 0(t2)
	addi	t4, zero, 33
	bge	t3, t4, ct_idx_peek
	addi	t2, t2, 1
	j	ct_idx_ws
ct_idx_peek:
	addi	t4, zero, '['
	bne	t3, t4, ct_deref_emit
	# Consume whitespace + '['
	addi	s2, t2, 1
	# Push base (a0) so we can compile the index expression.
	addi	gp, zero, 26		# push site 26 = push_ct_idx
	j	emit_push_a0
push_ct_idx:
	addi	t6, zero, 0
	addi	gp, zero, 35		# compile_expr site 35 = ce_ct_idx
	j	compile_expr_p
ce_ct_idx:
	# Expect ']'.
	addi	gp, zero, 49		# skip_ws site 49 = sw_ct_idx_rbrace
	j	skip_ws
sw_ct_idx_rbrace:
	bge	s2, s3, ct_bad_idx_rbrace
	lbu	t0, 0(s2)
	addi	t1, zero, ']'
	bne	t0, t1, ct_bad_idx_rbrace
	addi	s2, s2, 1
	# Scale index by stride. deref_kind 2 (byte) → no shift; 3 (half) →
	# shift 1; 1 (word) → shift 2. Emit `slli a0, a0, N` directly.
	lw	t0, 4(sp)
	addi	t1, zero, 2
	beq	t0, t1, ct_idx_scaled	# byte stride, no shift
	addi	t1, zero, 3
	beq	t0, t1, ct_idx_shift1
	# Word stride: shift 2. Word 0x00251513 (slli a0, a0, 2).
	lui	a0, 0x251
	addi	a0, a0, 0x513
	addi	gp, zero, 72		# emit_word site 72 = ew_ct_idx_shl2
	j	emit_word
ew_ct_idx_shl2:
	j	ct_idx_scaled
ct_idx_shift1:
	# Halfword stride: shift 1. Word 0x00151513 (slli a0, a0, 1).
	lui	a0, 0x151
	addi	a0, a0, 0x513
	addi	gp, zero, 73		# emit_word site 73 = ew_ct_idx_shl1
	j	emit_word
ew_ct_idx_shl1:
ct_idx_scaled:
	# Pop base → t0, emit `add a0, t0, a0`.
	addi	gp, zero, 26		# pop site 26 = pop_ct_idx
	j	emit_pop_t0
pop_ct_idx:
	addi	gp, zero, 3		# ea site 3 = ea_ct_idx
	j	emit_add
ea_ct_idx:
	# Now a0 runtime = base + idx*stride. Fall through to emit the deref.
ct_deref_emit:
	lw	t0, 4(sp)
	addi	t1, zero, 1
	beq	t0, t1, ct_deref_w
	addi	t1, zero, 3
	beq	t0, t1, ct_deref_h
	# Byte deref.
	j	emit_lbu_deref
elbud_ret:
	# Byte deref is an lvalue: `@expr = val` is valid. Mark lv_kind = 2.
	lla	t0, lv_kind
	addi	t1, zero, 2
	sw	t1, 0(t0)
	j	ct_done
ct_deref_w:
	j	emit_lw_deref
elwd_ret:
	# Word deref is an lvalue: `*expr = val` is valid. Mark lv_kind = 3.
	lla	t0, lv_kind
	addi	t1, zero, 3
	sw	t1, 0(t0)
	j	ct_done
ct_deref_h:
	# Emit `lhu a0, 0(a0)` directly (word 0x00055503). Halfword is an
	# lvalue: lv_kind = 4.
	lui	a0, 0x55
	addi	a0, a0, 0x503
	addi	gp, zero, 74		# emit_word site 74 = ew_ct_deref_h
	j	emit_word
ew_ct_deref_h:
	lla	t0, lv_kind
	addi	t1, zero, 4
	sw	t1, 0(t0)
	j	ct_done

ct_bad_idx_rbrace:
	addi	a0, zero, 44		# err 44: ']'
	j	report_err

ct_bad:
	addi	a0, zero, 5		# err 5: expected expression
	j	report_err
ct_bad_rparen:
	addi	a0, zero, 2		# err 2: expected ')'
	j	report_err
ct_bad_brace_sep:
	addi	a0, zero, 3		# err 3: expected '}' or ';'
	j	report_err
ct_bad_literal_pp:
	addi	a0, zero, 21		# err 21: '++'/'--' requires an lvalue
	j	report_err
ct_bad_prefix_combo:
	addi	a0, zero, 22		# err 22: cannot combine deref and ++/--
	j	report_err
ct_bad_immut_pp:
	lla	t0, ident_start
	lw	s2, 0(t0)
	addi	a0, zero, 55		# err 55: cannot reassign immutable
	j	report_err

ct_done:
	lw	gp, 0(sp)
	addi	sp, sp, 12
	j	compile_unary_disp

compile_unary_disp:
	bnez	gp, cud_1
	j	cu_cmul_first
cud_1:
	addi	gp, gp, -1
	bnez	gp, cud_2
	j	cu_cmul_next
cud_2:
	addi	gp, gp, -1
	bnez	gp, cud_3
	j	cu_uneg
cud_3:
	addi	gp, gp, -1
	bnez	gp, cud_4
	j	cu_bnot
cud_4:
	addi	gp, gp, -1
	bnez	gp, cud_5
	j	cu_cep_nud
cud_5:
	j	cu_lnot

# ══════════════════════════════════════════════════════════════════════════════
# Dead-parser compatibility stubs — labels referenced by dispatch-table entries
# whose sites are never set by the Pratt parser or any live caller. They exist
# solely so the fam3 assembler can resolve references in those (unreachable)
# dispatch entries. All halt via halt_err if ever reached.
# ══════════════════════════════════════════════════════════════════════════════
ce_tern_else:
ce_tern_mid:
cu_cmul_first:
cu_cmul_next:
ean_cand_ret:
ea_ret:
ecw_cdiv_mv:
ecw_cdivu_mv:
ecw_cland_addi:
ecw_cland_bne:
ecw_cland_jal_end:
ecw_cland_jal_sf:
ecw_cland_sltu:
ecw_clor_addi:
ecw_clor_beq:
ecw_clor_jal_end:
ecw_clor_jal_st:
ecw_clor_sltu:
ecw_cmod_mv:
ecw_cmodu_mv:
ecw_ctern_addi:
ecw_ctern_bne:
ecw_ctern_jal_else:
ecw_ctern_jal_end:
ecw_eq_done:
ecw_eq_xor:
ecw_ge_done:
ecw_ge_slt:
ecw_geu_done:
ecw_geu_sltu:
ecw_gt_done:
ecw_gtu_done:
ecw_le_done:
ecw_le_slt:
ecw_leu_done:
ecw_leu_sltu:
ecw_lt_done:
ecw_ltu_done:
ecw_ne_done:
ecw_ne_xor:
edmb_cdiv_ret:
edmb_cmod_ret:
emul_cmul_ret:
eor_cor_ret:
esll_csh_ret:
esra_csh_ret:
es_ret:
esrl_csh_ret:
eudmb_cdivu_ret:
eudmb_cmodu_ret:
ex_ret:
pjt_cland_end:
pjt_cland_sf:
pjt_clor_end:
pjt_clor_st:
pjt_ctern_else:
pjt_ctern_end:
pop_ca:
pop_cand:
pop_ccmp:
pop_ce:
pop_ceq:
pop_cmul:
pop_cor:
pop_csh:
push_ca:
push_cand:
push_ccmp:
push_ce:
push_ceq:
push_cmul:
push_cor:
push_csh:
sw_cand_and:
sw_ca_plus:
sw_ccmp_op:
sw_ceq_op:
sw_ce_xor:
sw_cland_op:
sw_clor_op:
sw_cmul_op:
sw_cor_or:
sw_csh_op:
sw_ctern_colon:
sw_ctern_op:
	j	halt_err

compile_expr_disp:
	bnez	gp, ced_1
	j	ce_cs_rhs
ced_1:
	addi	gp, gp, -1
	bnez	gp, ced_2
	j	ce_cs_addr1
ced_2:
	addi	gp, gp, -1
	bnez	gp, ced_3
	j	ce_cs_val1
ced_3:
	addi	gp, gp, -1
	bnez	gp, ced_4
	j	ce_cs_addr2
ced_4:
	addi	gp, gp, -1
	bnez	gp, ced_5
	j	ce_cs_val2
ced_5:
	addi	gp, gp, -1
	bnez	gp, ced_6
	j	ce_cs_plus
ced_6:
	addi	gp, gp, -1
	bnez	gp, ced_7
	j	ce_cs_minus
ced_7:
	addi	gp, gp, -1
	bnez	gp, ced_8
	j	ce_cs_xor
ced_8:
	addi	gp, gp, -1
	bnez	gp, ced_9
	j	ce_cs_lshift
ced_9:
	addi	gp, gp, -1
	bnez	gp, ced_10
	j	ce_cs_rshift
ced_10:
	addi	gp, gp, -1
	bnez	gp, ced_11
	j	ce_cs_and
ced_11:
	addi	gp, gp, -1
	bnez	gp, ced_12
	j	ce_cs_or
ced_12:
	addi	gp, gp, -1
	bnez	gp, ced_13
	j	ce_ct_paren
ced_13:
	addi	gp, gp, -1
	bnez	gp, ced_14
	j	ce_cs_mul
ced_14:
	addi	gp, gp, -1
	bnez	gp, ced_15
	j	ce_cs_div
ced_15:
	addi	gp, gp, -1
	bnez	gp, ced_16
	j	ce_cs_mod
ced_16:
	addi	gp, gp, -1
	bnez	gp, ced_17
	j	ce_tern_mid
ced_17:
	addi	gp, gp, -1
	bnez	gp, ced_18
	j	ce_tern_else
ced_18:
	addi	gp, gp, -1
	bnez	gp, ced_19
	j	ce_cep_rec
ced_19:
	addi	gp, gp, -1
	bnez	gp, ced_20
	j	ce_cep_tern_mid
ced_20:
	addi	gp, gp, -1
	bnez	gp, ced_21
	j	ce_cep_tern_else
ced_21:
	addi	gp, gp, -1
	bnez	gp, ced_22
	j	ce_cep_land_rhs
ced_22:
	addi	gp, gp, -1
	bnez	gp, ced_23
	j	ce_cep_lor_rhs
ced_23:
	addi	gp, gp, -1
	bnez	gp, ced_24
	j	ce_cep_asg_rhs
ced_24:
	addi	gp, gp, -1
	bnez	gp, ced_25
	j	ce_cs_exprstmt
ced_25:
	addi	gp, gp, -1
	bnez	gp, ced_26
	j	ce_ct_blk_rec
ced_26:
	addi	gp, gp, -1
	bnez	gp, ced_27
	j	ce_ct_loop_body
ced_27:
	addi	gp, gp, -1
	bnez	gp, ced_28
	j	ce_ct_break_val
ced_28:
	addi	gp, gp, -1
	bnez	gp, ced_29
	j	ce_cep_compound_rhs
ced_29:
	addi	gp, gp, -1
	bnez	gp, ced_30
	j	ce_ct_for_low
ced_30:
	addi	gp, gp, -1
	bnez	gp, ced_31
	j	ce_ct_for_high
ced_31:
	addi	gp, gp, -1
	bnez	gp, ced_32
	j	ce_ct_for_body
ced_32:
	addi	gp, gp, -1
	bnez	gp, ced_33
	j	ce_cs_fn_body
ced_33:
	addi	gp, gp, -1
	bnez	gp, ced_34
	j	ce_ct_call_arg
ced_34:
	addi	gp, gp, -1
	bnez	gp, ced_35
	j	ce_ct_return_val
ced_35:
	addi	gp, gp, -1
	bnez	gp, ced_36
	j	ce_ct_idx
ced_36:
	addi	gp, gp, -1
	bnez	gp, ced_37
	j	ce_ct_stl_val
ced_37:
	j	ce_ct_sa_idx

# ══════════════════════════════════════════════════════════════════════════════
# compile_expr_p — Pratt (top-down operator-precedence) expression parser.
#
# Replaces the layered parser (compile_or/xor/and/shift/add/mul/rel/eq/land).
# compile_unary is kept as the "null denotation" (nud): it parses primaries
# with prefix/postfix operators. compile_expr_p loops on binary operators,
# consuming those whose left binding power is at least the caller's min_bp.
#
# Caller contract:
#   t6 = min_bp        (minimum binding power this call accepts)
#   gp = return site   (dispatched via compile_expr_disp at exit)
#   On return: a0 = runtime value of the expression.
#
# Frame (24 bytes):
#   0(sp):  saved caller gp
#   4(sp):  saved caller min_bp (for comparing against l_bp of candidate ops)
#   8(sp):  op_kind (currently-processing operator, kept across recurse)
#   12(sp): r_bp    (right binding power for the recursive call)
#   16(sp): scratch1 (first jal placeholder addr for &&/||; jal_else for ?)
#   20(sp): scratch2 (second jal placeholder addr; jal_end for all branches)
#
# Operator kinds (matches the big dispatch in the post-rhs emit stage):
#   1  OP_MUL  '*'       l=20 r=21
#   2  OP_DIV  '/'       l=20 r=21
#   3  OP_MOD  '%'       l=20 r=21
#   4  OP_DIVU '/u'      l=20 r=21
#   5  OP_MODU '%u'      l=20 r=21
#   6  OP_ADD  '+'       l=18 r=19
#   7  OP_SUB  '-'       l=18 r=19
#   8  OP_SHL  '<<'      l=16 r=17
#   9  OP_SAR  '>>'      l=16 r=17
#  10  OP_SRL  '>>u'     l=16 r=17
#  11  OP_AND  '&'       l=14 r=15
#  12  OP_XOR  '^'       l=12 r=13
#  13  OP_OR   '|'       l=10 r=11
#  (relational/equality/short-circuit/ternary/assignment added in later turns)
#
# This is a WORK-IN-PROGRESS — it handles the simple binary ops listed above
# and isn't wired up yet. Short-circuit, ternary, and assignment come next.
# ══════════════════════════════════════════════════════════════════════════════
compile_expr_p:
	# Stack-depth guard: if famc's own sp has descended below heap_end,
	# deeply-nested source is about to collide with the heap region. Bail
	# out with err 72 (same code as heap_full — same collision, opposite
	# direction).
	lla	t0, heap_end
	lw	t0, 0(t0)
	bgeu	t0, sp, heap_full
	addi	sp, sp, -24
	sw	gp, 0(sp)
	sw	t6, 4(sp)		# save caller's min_bp

	# Parse the nud: a primary with any prefix/postfix operators.
	addi	gp, zero, 4
	j	compile_unary
cu_cep_nud:

	# a0 = lhs value (runtime). Enter the operator loop.
	# (The nud already set lv_kind if this primary is a simple lvalue,
	# so we fall through directly to cep_loop without clobbering it.)

cep_loop:
	# Peek next token (after ws). Identify the binary operator, compare
	# its l_bp to min_bp, and if it beats min_bp, consume and recurse.
	addi	gp, zero, 29		# skip_ws site 29 = sw_cep_op
	j	skip_ws
sw_cep_op:
	bge	s2, s3, cep_done
	lbu	t0, 0(s2)

	# Decision tree on the first char. Each arm sets:
	#   t2 = op_kind, t3 = l_bp, t4 = r_bp, t1 = char count
	# then jumps to cep_bp_check.
	addi	t1, zero, '*'
	beq	t0, t1, cep_op_star
	addi	t1, zero, '/'
	beq	t0, t1, cep_op_slash
	addi	t1, zero, '%'
	beq	t0, t1, cep_op_percent
	addi	t1, zero, '+'
	beq	t0, t1, cep_op_plus
	addi	t1, zero, '-'
	beq	t0, t1, cep_op_minus
	addi	t1, zero, '<'
	beq	t0, t1, cep_op_lt
	addi	t1, zero, '>'
	beq	t0, t1, cep_op_gt
	addi	t1, zero, '&'
	beq	t0, t1, cep_op_amp
	addi	t1, zero, '^'
	beq	t0, t1, cep_op_caret
	addi	t1, zero, '|'
	beq	t0, t1, cep_op_pipe
	addi	t1, zero, '='
	beq	t0, t1, cep_op_eq
	addi	t1, zero, '!'
	beq	t0, t1, cep_op_bang
	addi	t1, zero, '?'
	beq	t0, t1, cep_op_question
	addi	t1, zero, ':'
	beq	t0, t1, cep_op_colon
	j	cep_done

# — '*' or '*=' ———————————————————————————————————————————————————————————————
cep_op_star:
	addi	t5, s2, 1
	bge	t5, s3, cep_op_star_plain
	lbu	t0, 0(t5)
	addi	t1, zero, '='
	beq	t0, t1, cep_op_star_compound
cep_op_star_plain:
	addi	t2, zero, 1		# op = MUL
	addi	t3, zero, 20		# l_bp
	addi	t4, zero, 21		# r_bp
	addi	t1, zero, 1		# chars
	j	cep_bp_check
cep_op_star_compound:
	addi	t2, zero, 129		# op = MUL | 0x80
	addi	t3, zero, 0
	addi	t4, zero, -1
	addi	t1, zero, 2
	j	cep_bp_check

# — '/' '/u' '/=' ————————————————————————————————————————————————————————————
cep_op_slash:
	addi	t5, s2, 1
	bge	t5, s3, cep_op_slash_signed
	lbu	t0, 0(t5)
	addi	t1, zero, 'u'
	beq	t0, t1, cep_op_slash_unsigned
	addi	t1, zero, '='
	beq	t0, t1, cep_op_slash_compound
cep_op_slash_signed:
	addi	t2, zero, 2		# op = DIV
	addi	t3, zero, 20
	addi	t4, zero, 21
	addi	t1, zero, 1
	j	cep_bp_check
cep_op_slash_unsigned:
	addi	t2, zero, 4		# op = DIVU
	addi	t3, zero, 20
	addi	t4, zero, 21
	addi	t1, zero, 2
	j	cep_bp_check
cep_op_slash_compound:
	addi	t2, zero, 130		# op = DIV | 0x80
	addi	t3, zero, 0
	addi	t4, zero, -1
	addi	t1, zero, 2
	j	cep_bp_check

# — '%' '%u' '%=' ————————————————————————————————————————————————————————————
cep_op_percent:
	addi	t5, s2, 1
	bge	t5, s3, cep_op_percent_signed
	lbu	t0, 0(t5)
	addi	t1, zero, 'u'
	beq	t0, t1, cep_op_percent_unsigned
	addi	t1, zero, '='
	beq	t0, t1, cep_op_percent_compound
cep_op_percent_signed:
	addi	t2, zero, 3		# op = MOD
	addi	t3, zero, 20
	addi	t4, zero, 21
	addi	t1, zero, 1
	j	cep_bp_check
cep_op_percent_unsigned:
	addi	t2, zero, 5		# op = MODU
	addi	t3, zero, 20
	addi	t4, zero, 21
	addi	t1, zero, 2
	j	cep_bp_check
cep_op_percent_compound:
	addi	t2, zero, 131		# op = MOD | 0x80
	addi	t3, zero, 0
	addi	t4, zero, -1
	addi	t1, zero, 2
	j	cep_bp_check

# — '+' or '+=' ———————————————————————————————————————————————————————————————
cep_op_plus:
	addi	t5, s2, 1
	bge	t5, s3, cep_op_plus_plain
	lbu	t0, 0(t5)
	addi	t1, zero, '='
	beq	t0, t1, cep_op_plus_compound
	addi	t1, zero, '+'
	beq	t0, t1, cep_op_postinc
cep_op_plus_plain:
	addi	t2, zero, 6		# op = ADD
	addi	t3, zero, 18
	addi	t4, zero, 19
	addi	t1, zero, 1
	j	cep_bp_check
cep_op_postinc:
	addi	t2, zero, 29		# op = POSTINC
	addi	t3, zero, 30		# l_bp = 30 (highest)
	addi	t4, zero, 0		# r_bp unused
	addi	t1, zero, 2		# consume 2 chars
	j	cep_bp_check
cep_op_plus_compound:
	addi	t2, zero, 134		# op = ADD | 0x80 (compound)
	addi	t3, zero, 0
	addi	t4, zero, -1
	addi	t1, zero, 2
	j	cep_bp_check

# — '-' or '-=' ———————————————————————————————————————————————————————————————
cep_op_minus:
	addi	t5, s2, 1
	bge	t5, s3, cep_op_minus_plain
	lbu	t0, 0(t5)
	addi	t1, zero, '='
	beq	t0, t1, cep_op_minus_compound
	addi	t1, zero, '-'
	beq	t0, t1, cep_op_postdec
cep_op_minus_plain:
	addi	t2, zero, 7		# op = SUB
	addi	t3, zero, 18
	addi	t4, zero, 19
	addi	t1, zero, 1
	j	cep_bp_check
cep_op_postdec:
	addi	t2, zero, 30		# op = POSTDEC
	addi	t3, zero, 30		# l_bp = 30 (highest)
	addi	t4, zero, 0		# r_bp unused
	addi	t1, zero, 2		# consume 2 chars
	j	cep_bp_check
cep_op_minus_compound:
	addi	t2, zero, 135		# op = SUB | 0x80
	addi	t3, zero, 0
	addi	t4, zero, -1
	addi	t1, zero, 2
	j	cep_bp_check

# — '<' : '<' '<=' '<u' '<=u' '<<' '<<=' ——————————————————————————————————————
cep_op_lt:
	addi	t5, s2, 1
	bge	t5, s3, cep_op_lt_alone
	lbu	t0, 0(t5)
	addi	t1, zero, '<'
	beq	t0, t1, cep_op_shl_or_shleq
	addi	t1, zero, '='
	beq	t0, t1, cep_op_le_or_leu
	addi	t1, zero, 'u'
	beq	t0, t1, cep_op_ltu
cep_op_lt_alone:
	addi	t2, zero, 14		# op = LT
	addi	t3, zero, 8
	addi	t4, zero, 9
	addi	t1, zero, 1
	j	cep_bp_check
cep_op_shl_or_shleq:
	# Second '<' seen; check for '<<=' (compound) vs bare '<<'.
	addi	t5, s2, 2
	bge	t5, s3, cep_op_shl
	lbu	t0, 0(t5)
	addi	t1, zero, '='
	beq	t0, t1, cep_op_shl_compound
cep_op_shl:
	addi	t2, zero, 8		# op = SHL
	addi	t3, zero, 16
	addi	t4, zero, 17
	addi	t1, zero, 2
	j	cep_bp_check
cep_op_shl_compound:
	addi	t2, zero, 136		# op = SHL | 0x80
	addi	t3, zero, 0
	addi	t4, zero, -1
	addi	t1, zero, 3
	j	cep_bp_check
cep_op_le_or_leu:
	addi	t5, s2, 2
	bge	t5, s3, cep_op_le
	lbu	t0, 0(t5)
	addi	t1, zero, 'u'
	beq	t0, t1, cep_op_leu
cep_op_le:
	addi	t2, zero, 15		# op = LE
	addi	t3, zero, 8
	addi	t4, zero, 9
	addi	t1, zero, 2
	j	cep_bp_check
cep_op_leu:
	addi	t2, zero, 19		# op = LEU
	addi	t3, zero, 8
	addi	t4, zero, 9
	addi	t1, zero, 3
	j	cep_bp_check
cep_op_ltu:
	addi	t2, zero, 18		# op = LTU
	addi	t3, zero, 8
	addi	t4, zero, 9
	addi	t1, zero, 2
	j	cep_bp_check

# — '>' : '>' '>=' '>u' '>=u' '>>' '>>u' —————————————————————————————————————
cep_op_gt:
	addi	t5, s2, 1
	bge	t5, s3, cep_op_gt_alone
	lbu	t0, 0(t5)
	addi	t1, zero, '>'
	beq	t0, t1, cep_op_sar_or_srl
	addi	t1, zero, '='
	beq	t0, t1, cep_op_ge_or_geu
	addi	t1, zero, 'u'
	beq	t0, t1, cep_op_gtu
cep_op_gt_alone:
	addi	t2, zero, 16		# op = GT
	addi	t3, zero, 8
	addi	t4, zero, 9
	addi	t1, zero, 1
	j	cep_bp_check
cep_op_sar_or_srl:
	addi	t5, s2, 2
	bge	t5, s3, cep_op_sar
	lbu	t0, 0(t5)
	addi	t1, zero, 'u'
	beq	t0, t1, cep_op_srl_or_srleq
	addi	t1, zero, '='
	beq	t0, t1, cep_op_sar_compound
cep_op_sar:
	addi	t2, zero, 9		# op = SAR
	addi	t3, zero, 16
	addi	t4, zero, 17
	addi	t1, zero, 2
	j	cep_bp_check
cep_op_sar_compound:
	addi	t2, zero, 137		# op = SAR | 0x80
	addi	t3, zero, 0
	addi	t4, zero, -1
	addi	t1, zero, 3
	j	cep_bp_check
cep_op_srl_or_srleq:
	# Third char is 'u'; check for '>>u=' (compound) vs bare '>>u'.
	addi	t5, s2, 3
	bge	t5, s3, cep_op_srl
	lbu	t0, 0(t5)
	addi	t1, zero, '='
	beq	t0, t1, cep_op_srl_compound
cep_op_srl:
	addi	t2, zero, 10		# op = SRL
	addi	t3, zero, 16
	addi	t4, zero, 17
	addi	t1, zero, 3
	j	cep_bp_check
cep_op_srl_compound:
	addi	t2, zero, 138		# op = SRL | 0x80
	addi	t3, zero, 0
	addi	t4, zero, -1
	addi	t1, zero, 4
	j	cep_bp_check
cep_op_ge_or_geu:
	addi	t5, s2, 2
	bge	t5, s3, cep_op_ge
	lbu	t0, 0(t5)
	addi	t1, zero, 'u'
	beq	t0, t1, cep_op_geu
cep_op_ge:
	addi	t2, zero, 17		# op = GE
	addi	t3, zero, 8
	addi	t4, zero, 9
	addi	t1, zero, 2
	j	cep_bp_check
cep_op_geu:
	addi	t2, zero, 21		# op = GEU
	addi	t3, zero, 8
	addi	t4, zero, 9
	addi	t1, zero, 3
	j	cep_bp_check
cep_op_gtu:
	addi	t2, zero, 20		# op = GTU
	addi	t3, zero, 8
	addi	t4, zero, 9
	addi	t1, zero, 2
	j	cep_bp_check

# — '&' '&&' '&=' ————————————————————————————————————————————————————————————
cep_op_amp:
	addi	t5, s2, 1
	bge	t5, s3, cep_op_amp_single
	lbu	t0, 0(t5)
	addi	t1, zero, '&'
	beq	t0, t1, cep_op_land
	addi	t1, zero, '='
	beq	t0, t1, cep_op_amp_compound
cep_op_amp_single:
	addi	t2, zero, 11		# op = AND
	addi	t3, zero, 14
	addi	t4, zero, 15
	addi	t1, zero, 1
	j	cep_bp_check
cep_op_land:
	addi	t2, zero, 24		# op = LAND
	addi	t3, zero, 4
	addi	t4, zero, 5
	addi	t1, zero, 2
	j	cep_bp_check
cep_op_amp_compound:
	addi	t2, zero, 139		# op = AND | 0x80
	addi	t3, zero, 0
	addi	t4, zero, -1
	addi	t1, zero, 2
	j	cep_bp_check

# — '^' or '^=' ———————————————————————————————————————————————————————————————
cep_op_caret:
	addi	t5, s2, 1
	bge	t5, s3, cep_op_caret_plain
	lbu	t0, 0(t5)
	addi	t1, zero, '='
	beq	t0, t1, cep_op_caret_compound
cep_op_caret_plain:
	addi	t2, zero, 12		# op = XOR
	addi	t3, zero, 12
	addi	t4, zero, 13
	addi	t1, zero, 1
	j	cep_bp_check
cep_op_caret_compound:
	addi	t2, zero, 140		# op = XOR | 0x80
	addi	t3, zero, 0
	addi	t4, zero, -1
	addi	t1, zero, 2
	j	cep_bp_check

# — '|' '||' '|=' ————————————————————————————————————————————————————————————
cep_op_pipe:
	addi	t5, s2, 1
	bge	t5, s3, cep_op_pipe_single
	lbu	t0, 0(t5)
	addi	t1, zero, '|'
	beq	t0, t1, cep_op_lor
	addi	t1, zero, '='
	beq	t0, t1, cep_op_pipe_compound
cep_op_pipe_single:
	addi	t2, zero, 13		# op = OR
	addi	t3, zero, 10
	addi	t4, zero, 11
	addi	t1, zero, 1
	j	cep_bp_check
cep_op_lor:
	addi	t2, zero, 25		# op = LOR
	addi	t3, zero, 2
	addi	t4, zero, 3
	addi	t1, zero, 2
	j	cep_bp_check
cep_op_pipe_compound:
	addi	t2, zero, 141		# op = OR | 0x80
	addi	t3, zero, 0
	addi	t4, zero, -1
	addi	t1, zero, 2
	j	cep_bp_check

# — '=' : '==' (equality) or bare '=' (assignment) ———————————————————————————
cep_op_eq:
	addi	t5, s2, 1
	bge	t5, s3, cep_op_assign
	lbu	t0, 0(t5)
	addi	t1, zero, '='
	beq	t0, t1, cep_op_eq_eq
	j	cep_op_assign
cep_op_eq_eq:
	addi	t2, zero, 22		# op = EQ
	addi	t3, zero, 6
	addi	t4, zero, 7
	addi	t1, zero, 2
	j	cep_bp_check
cep_op_assign:
	# op = ASSIGN (bare '='). Lowest precedence, right-associative.
	addi	t2, zero, 27		# op = ASSIGN
	addi	t3, zero, 0		# l_bp = 0
	addi	t4, zero, -1		# r_bp = -1 (right-assoc)
	addi	t1, zero, 1
	j	cep_bp_check

# — '!' : only '!=' recognized (no unary '!' in the language today) ——————————
cep_op_bang:
	addi	t5, s2, 1
	bge	t5, s3, cep_done
	lbu	t0, 0(t5)
	addi	t1, zero, '='
	bne	t0, t1, cep_done
	addi	t2, zero, 23		# op = NE
	addi	t3, zero, 6
	addi	t4, zero, 7
	addi	t1, zero, 2
	j	cep_bp_check

# — '?' : ternary — handled via a dedicated path in cep_bp_check ———————————————
# — ':' : only ':=' recognized (mutable assign). Bare ':' is ternary-else /
# struct-init and handled by other paths, NOT cep_loop.
cep_op_colon:
	addi	t5, s2, 1
	bge	t5, s3, cep_done
	lbu	t0, 0(t5)
	addi	t1, zero, '='
	bne	t0, t1, cep_done	# bare ':' → not our op
	addi	t2, zero, 28		# op = MUTASSIGN
	addi	t3, zero, 0		# l_bp = 0 (same as assign)
	addi	t4, zero, -1		# r_bp = -1 (right-assoc)
	addi	t1, zero, 2
	j	cep_bp_check

cep_op_question:
	addi	t2, zero, 26		# op = TERN
	addi	t3, zero, 1		# l_bp = 1 (looser than '||' at 2)
	addi	t4, zero, 0		# r_bp (unused; ternary uses custom flow)
	addi	t1, zero, 1
	j	cep_bp_check

# ── Binding power check & binop dispatch ─────────────────────────────────────
# Inputs: t1 = chars to consume, t2 = op_kind, t3 = l_bp, t4 = r_bp
cep_bp_check:
	lw	t5, 4(sp)		# caller's min_bp
	blt	t3, t5, cep_done	# l_bp < min_bp → don't consume, return
	# Consume the operator chars.
	add	s2, s2, t1
	# Save op_kind and r_bp across the recurse.
	sw	t2, 8(sp)
	sw	t4, 12(sp)

	# Short-circuit / ternary / assignment take custom paths that diverge
	# from the standard "push lhs, recurse, pop, emit binop" pattern.
	addi	t1, zero, 24
	beq	t2, t1, cep_pre_land
	addi	t1, zero, 25
	beq	t2, t1, cep_pre_lor
	addi	t1, zero, 26
	beq	t2, t1, cep_pre_tern
	addi	t1, zero, 27
	beq	t2, t1, cep_pre_assign
	addi	t1, zero, 28
	beq	t2, t1, cep_pre_assign	# :=  shares the same handler
	addi	t1, zero, 29
	beq	t2, t1, cep_pre_postinc
	addi	t1, zero, 30
	beq	t2, t1, cep_pre_postdec
	# Compound assign: bit 7 of op_kind is set. Divert before the normal
	# push-recurse-pop path so we can stash the lvalue slot first.
	andi	t1, t2, 0x80
	bnez	t1, cep_pre_compound

	# Standard binary operator: push lhs, recurse, pop, emit.
	addi	gp, zero, 20		# push site 20 = push_cep
	j	emit_push_a0
push_cep:

	# Recurse for RHS with new min_bp = r_bp.
	lw	t6, 12(sp)
	addi	gp, zero, 18		# compile_expr site 18 = ce_cep_rec
	j	compile_expr_p
ce_cep_rec:

	# Pop lhs into t0 (runtime).
	addi	gp, zero, 20		# pop site 20 = pop_cep
	j	emit_pop_t0
pop_cep:

	# Dispatch on saved op_kind to emit the binop. Strip the compound-assign
	# flag bit (bit 7) — the base op is in bits 0..6.
	lw	t5, 8(sp)
	andi	t5, t5, 0x7F
	addi	t1, zero, 1
	beq	t5, t1, cep_em_mul
	addi	t1, zero, 2
	beq	t5, t1, cep_em_div
	addi	t1, zero, 3
	beq	t5, t1, cep_em_mod
	addi	t1, zero, 4
	beq	t5, t1, cep_em_divu
	addi	t1, zero, 5
	beq	t5, t1, cep_em_modu
	addi	t1, zero, 6
	beq	t5, t1, cep_em_add
	addi	t1, zero, 7
	beq	t5, t1, cep_em_sub
	addi	t1, zero, 8
	beq	t5, t1, cep_em_shl
	addi	t1, zero, 9
	beq	t5, t1, cep_em_sar
	addi	t1, zero, 10
	beq	t5, t1, cep_em_srl
	addi	t1, zero, 11
	beq	t5, t1, cep_em_and
	addi	t1, zero, 12
	beq	t5, t1, cep_em_xor
	addi	t1, zero, 13
	beq	t5, t1, cep_em_or
	addi	t1, zero, 14
	beq	t5, t1, cep_em_lt
	addi	t1, zero, 15
	beq	t5, t1, cep_em_le
	addi	t1, zero, 16
	beq	t5, t1, cep_em_gt
	addi	t1, zero, 17
	beq	t5, t1, cep_em_ge
	addi	t1, zero, 18
	beq	t5, t1, cep_em_ltu
	addi	t1, zero, 19
	beq	t5, t1, cep_em_leu
	addi	t1, zero, 20
	beq	t5, t1, cep_em_gtu
	addi	t1, zero, 21
	beq	t5, t1, cep_em_geu
	addi	t1, zero, 22
	beq	t5, t1, cep_em_eq
	j	cep_em_ne

# — Per-op emitters. Each ends with `j cep_loop`. ————————————————————————————
cep_em_add:
	addi	gp, zero, 2		# ea site 2 = ea_cep
	j	emit_add
ea_cep:
	j	cep_post_emit

cep_em_sub:
	addi	gp, zero, 2		# es site 2 = es_cep
	j	emit_sub
es_cep:
	j	cep_post_emit

cep_em_mul:
	addi	gp, zero, 2		# emul site 2 = emul_cep_ret
	j	emit_mul
emul_cep_ret:
	j	cep_post_emit

cep_em_div:
	addi	gp, zero, 4		# edmb site 4 = edmb_cep_div_ret
	j	emit_divmod_body
edmb_cep_div_ret:
	lui	a0, 0x30
	addi	a0, a0, 0x513
	addi	gp, zero, 36		# ecw site 36 = ecw_cep_div_mv
	j	emit_cmp_word
ecw_cep_div_mv:
	j	cep_post_emit

cep_em_mod:
	addi	gp, zero, 5
	j	emit_divmod_body
edmb_cep_mod_ret:
	lui	a0, 0x38
	addi	a0, a0, 0x513
	addi	gp, zero, 37		# ecw site 37 = ecw_cep_mod_mv
	j	emit_cmp_word
ecw_cep_mod_mv:
	j	cep_post_emit

cep_em_divu:
	addi	gp, zero, 2		# eudmb site 2 = eudmb_cep_divu_ret
	j	emit_udivmod_body
eudmb_cep_divu_ret:
	lui	a0, 0x30
	addi	a0, a0, 0x513
	addi	gp, zero, 38		# ecw site 38 = ecw_cep_divu_mv
	j	emit_cmp_word
ecw_cep_divu_mv:
	j	cep_post_emit

cep_em_modu:
	addi	gp, zero, 3
	j	emit_udivmod_body
eudmb_cep_modu_ret:
	lui	a0, 0x38
	addi	a0, a0, 0x513
	addi	gp, zero, 39		# ecw site 39 = ecw_cep_modu_mv
	j	emit_cmp_word
ecw_cep_modu_mv:
	j	cep_post_emit

cep_em_shl:
	addi	gp, zero, 2		# esll site 2 = esll_cep
	j	emit_sll
esll_cep:
	j	cep_post_emit

cep_em_sar:
	addi	gp, zero, 2		# esra site 2 = esra_cep
	j	emit_sra
esra_cep:
	j	cep_post_emit

cep_em_srl:
	addi	gp, zero, 1		# esrl site 1 = esrl_cep
	j	emit_srl
esrl_cep:
	j	cep_post_emit

cep_em_and:
	addi	gp, zero, 2		# ean site 2 = ean_cep
	j	emit_and
ean_cep:
	j	cep_post_emit

cep_em_xor:
	addi	gp, zero, 2		# ex site 2 = ex_cep
	j	emit_xor
ex_cep:
	j	cep_post_emit

cep_em_or:
	addi	gp, zero, 2		# eor site 2 = eor_cep
	j	emit_or
eor_cep:
	j	cep_post_emit

# ── Comparison emitters ──────────────────────────────────────────────────────
# All comparisons leave 0 or 1 in a0. The emit sequences mirror compile_rel
# and compile_eq from the layered parser.

# '<' : slt a0, sN, a0  (sN = popped LHS source)
cep_em_lt:
	lla	t0, popped_src_reg
	lw	t0, 0(t0)
	slli	t0, t0, 15
	lui	a0, 0xA02
	addi	a0, a0, 0x533
	or	a0, a0, t0
	addi	gp, zero, 40
	j	emit_cmp_word
ecw_cep_lt_done:
	j	cep_post_emit

# '<=' : slt a0, a0, sN (rs2 = sN) ; xori a0, a0, 1
cep_em_le:
	lla	t0, popped_src_reg
	lw	t0, 0(t0)
	slli	t0, t0, 20
	lui	a0, 0x52
	addi	a0, a0, 0x533
	or	a0, a0, t0
	addi	gp, zero, 41
	j	emit_cmp_word
ecw_cep_le_slt:
	lui	a0, 0x154
	addi	a0, a0, 0x513
	addi	gp, zero, 42
	j	emit_cmp_word
ecw_cep_le_done:
	j	cep_post_emit

# '>' : slt a0, a0, sN  (rs2 = sN)
cep_em_gt:
	lla	t0, popped_src_reg
	lw	t0, 0(t0)
	slli	t0, t0, 20
	lui	a0, 0x52
	addi	a0, a0, 0x533
	or	a0, a0, t0
	addi	gp, zero, 43
	j	emit_cmp_word
ecw_cep_gt_done:
	j	cep_post_emit

# '>=' : slt a0, sN, a0 ; xori a0, a0, 1
cep_em_ge:
	lla	t0, popped_src_reg
	lw	t0, 0(t0)
	slli	t0, t0, 15
	lui	a0, 0xA02
	addi	a0, a0, 0x533
	or	a0, a0, t0
	addi	gp, zero, 44
	j	emit_cmp_word
ecw_cep_ge_slt:
	lui	a0, 0x154
	addi	a0, a0, 0x513
	addi	gp, zero, 45
	j	emit_cmp_word
ecw_cep_ge_done:
	j	cep_post_emit

# '<u' : sltu a0, sN, a0
cep_em_ltu:
	lla	t0, popped_src_reg
	lw	t0, 0(t0)
	slli	t0, t0, 15
	lui	a0, 0xA03
	addi	a0, a0, 0x533
	or	a0, a0, t0
	addi	gp, zero, 46
	j	emit_cmp_word
ecw_cep_ltu_done:
	j	cep_post_emit

# '<=u' : sltu a0, a0, sN ; xori a0, a0, 1
cep_em_leu:
	lla	t0, popped_src_reg
	lw	t0, 0(t0)
	slli	t0, t0, 20
	lui	a0, 0x53
	addi	a0, a0, 0x533
	or	a0, a0, t0
	addi	gp, zero, 47
	j	emit_cmp_word
ecw_cep_leu_sltu:
	lui	a0, 0x154
	addi	a0, a0, 0x513
	addi	gp, zero, 48
	j	emit_cmp_word
ecw_cep_leu_done:
	j	cep_post_emit

# '>u' : sltu a0, a0, sN
cep_em_gtu:
	lla	t0, popped_src_reg
	lw	t0, 0(t0)
	slli	t0, t0, 20
	lui	a0, 0x53
	addi	a0, a0, 0x533
	or	a0, a0, t0
	addi	gp, zero, 49
	j	emit_cmp_word
ecw_cep_gtu_done:
	j	cep_post_emit

# '>=u' : sltu a0, sN, a0 ; xori a0, a0, 1
cep_em_geu:
	lla	t0, popped_src_reg
	lw	t0, 0(t0)
	slli	t0, t0, 15
	lui	a0, 0xA03
	addi	a0, a0, 0x533
	or	a0, a0, t0
	addi	gp, zero, 50
	j	emit_cmp_word
ecw_cep_geu_sltu:
	lui	a0, 0x154
	addi	a0, a0, 0x513
	addi	gp, zero, 51
	j	emit_cmp_word
ecw_cep_geu_done:
	j	cep_post_emit

# '==' : xor a0, sN, a0 ; sltiu a0, a0, 1
cep_em_eq:
	lla	t0, popped_src_reg
	lw	t0, 0(t0)
	slli	t0, t0, 15
	lui	a0, 0xA04
	addi	a0, a0, 0x533
	or	a0, a0, t0
	addi	gp, zero, 52
	j	emit_cmp_word
ecw_cep_eq_xor:
	lui	a0, 0x153
	addi	a0, a0, 0x513
	addi	gp, zero, 53
	j	emit_cmp_word
ecw_cep_eq_done:
	j	cep_post_emit

# '!=' : xor a0, sN, a0 ; sltu a0, zero, a0
cep_em_ne:
	lla	t0, popped_src_reg
	lw	t0, 0(t0)
	slli	t0, t0, 15
	lui	a0, 0xA04
	addi	a0, a0, 0x533
	or	a0, a0, t0
	addi	gp, zero, 54
	j	emit_cmp_word
ecw_cep_ne_xor:
	lui	a0, 0xA03
	addi	a0, a0, 0x533
	addi	gp, zero, 55
	j	emit_cmp_word
ecw_cep_ne_done:
	j	cep_post_emit

# ── Short-circuit '&&' ───────────────────────────────────────────────────────
# Pattern mirrors compile_land: bne+jal trampoline, recurse, sltu, jal, patch.
cep_pre_land:
	# Emit bne a0, zero, +8 (word 0x00051463).
	lui	a0, 0x51
	addi	a0, a0, 0x463
	addi	gp, zero, 56
	j	emit_cmp_word
ecw_cep_land_bne:
	# Save future jal_sf addr to 16(sp).
	sw	s5, 16(sp)
	# Emit placeholder jal zero, 0.
	addi	a0, zero, 0x6F
	addi	gp, zero, 57
	j	emit_cmp_word
ecw_cep_land_jal_sf:
	# Recurse for RHS with r_bp = 5.
	lw	t6, 12(sp)
	addi	gp, zero, 21		# ce site 21 = ce_cep_land_rhs
	j	compile_expr_p
ce_cep_land_rhs:
	# Emit sltu a0, zero, a0 (word 0x00A03533).
	lui	a0, 0xA03
	addi	a0, a0, 0x533
	addi	gp, zero, 58
	j	emit_cmp_word
ecw_cep_land_sltu:
	# Save future jal_end addr to 20(sp).
	sw	s5, 20(sp)
	# Emit placeholder jal zero, 0.
	addi	a0, zero, 0x6F
	addi	gp, zero, 59
	j	emit_cmp_word
ecw_cep_land_jal_end:
	# Patch jal_sf (stashed at 16(sp)) to current s5.
	lw	t5, 16(sp)
	addi	t6, s5, 0
	addi	gp, zero, 6		# patch_jtype site 6 = pjt_cep_land_sf
	j	patch_jtype
pjt_cep_land_sf:
	# Emit addi a0, zero, 0 (false-tail value).
	lui	a0, 0
	addi	a0, a0, 0x513
	addi	gp, zero, 60
	j	emit_cmp_word
ecw_cep_land_addi:
	# Patch jal_end (stashed at 20(sp)) to current s5.
	lw	t5, 20(sp)
	addi	t6, s5, 0
	addi	gp, zero, 7		# patch_jtype site 7 = pjt_cep_land_end
	j	patch_jtype
pjt_cep_land_end:
	j	cep_post_emit

# ── Short-circuit '||' ───────────────────────────────────────────────────────
cep_pre_lor:
	# Emit beq a0, zero, +8 (word 0x00050463).
	lui	a0, 0x50
	addi	a0, a0, 0x463
	addi	gp, zero, 61
	j	emit_cmp_word
ecw_cep_lor_beq:
	sw	s5, 16(sp)
	addi	a0, zero, 0x6F
	addi	gp, zero, 62
	j	emit_cmp_word
ecw_cep_lor_jal_st:
	lw	t6, 12(sp)
	addi	gp, zero, 22		# ce site 22 = ce_cep_lor_rhs
	j	compile_expr_p
ce_cep_lor_rhs:
	lui	a0, 0xA03
	addi	a0, a0, 0x533
	addi	gp, zero, 63
	j	emit_cmp_word
ecw_cep_lor_sltu:
	sw	s5, 20(sp)
	addi	a0, zero, 0x6F
	addi	gp, zero, 64
	j	emit_cmp_word
ecw_cep_lor_jal_end:
	lw	t5, 16(sp)
	addi	t6, s5, 0
	addi	gp, zero, 8		# patch_jtype site 8 = pjt_cep_lor_st
	j	patch_jtype
pjt_cep_lor_st:
	# Emit addi a0, zero, 1 (true-tail value, word 0x00100513).
	lui	a0, 0x100
	addi	a0, a0, 0x513
	addi	gp, zero, 65
	j	emit_cmp_word
ecw_cep_lor_addi:
	lw	t5, 20(sp)
	addi	t6, s5, 0
	addi	gp, zero, 9		# patch_jtype site 9 = pjt_cep_lor_end
	j	patch_jtype
pjt_cep_lor_end:
	j	cep_post_emit

# ── Ternary '?' ──────────────────────────────────────────────────────────────
# Uses condition (lhs) in a0, branches, compiles middle, emits jal, patches,
# optionally compiles else (or emits addi 0), patches, done.
cep_pre_tern:
	# Peephole A: if the cond's last two insns are `xor a0, X, Y` then
	# `sltiu a0, a0, 1` (the `==` sequence), delete both and emit
	# `beq X, Y, +8` instead of `bne a0, zero, +8`. Saves 2 insns.
	lw	t0, -4(s5)
	lui	t1, 0x153
	addi	t1, t1, 0x513		# 0x00153513 = sltiu a0, a0, 1
	bne	t0, t1, cpt_try_slt
	lw	t0, -8(s5)
	andi	t1, t0, 0x7F
	addi	t2, zero, 0x33
	bne	t1, t2, cpt_try_slt
	srli	t1, t0, 7
	andi	t1, t1, 0x1F
	addi	t2, zero, 10
	bne	t1, t2, cpt_try_slt
	srli	t1, t0, 12
	andi	t1, t1, 0x7
	addi	t2, zero, 4		# xor funct3 = 4
	bne	t1, t2, cpt_try_slt
	srli	t1, t0, 25
	bnez	t1, cpt_try_slt
	# Match: extract xor's rs1, rs2; rewind s5 by 8.
	srli	t3, t0, 15
	andi	t3, t3, 0x1F
	srli	t4, t0, 20
	andi	t4, t4, 0x1F
	addi	s5, s5, -8
	# Build beq rs1, rs2, +8: word = 0x00000463 | (rs1<<15) | (rs2<<20)
	addi	t1, zero, 0x463
	slli	t3, t3, 15
	or	t1, t1, t3
	slli	t4, t4, 20
	or	a0, t1, t4
	j	cpt_emit
cpt_try_slt:
	# Peephole B: if the cond's last emitted insn is `slt[u] a0, X, Y`
	# (R-type, opcode 0x33, funct3 ∈ {2,3}, rd=a0, funct7=0), delete
	# it and emit `blt[u] X, Y, +8` instead of the standard
	# `bne a0, zero, +8`. Saves one instruction per `<`/`>` in a cond.
	lw	t0, -4(s5)
	andi	t1, t0, 0x7F
	addi	t2, zero, 0x33
	bne	t1, t2, cpt_no_peephole
	srli	t1, t0, 7
	andi	t1, t1, 0x1F
	addi	t2, zero, 10
	bne	t1, t2, cpt_no_peephole
	srli	t1, t0, 25
	bnez	t1, cpt_no_peephole
	srli	t1, t0, 12
	andi	t1, t1, 0x7
	addi	t2, zero, 2
	beq	t1, t2, cpt_have_slt
	addi	t2, zero, 3
	bne	t1, t2, cpt_no_peephole
cpt_have_slt:
	# Build blt/bltu word: (f3<<12) | 0x463 | (rs1<<15) | (rs2<<20)
	# slt(2)→blt(4), sltu(3)→bltu(6); +2 to map.
	srli	t3, t0, 15
	andi	t3, t3, 0x1F		# rs1
	srli	t4, t0, 20
	andi	t4, t4, 0x1F		# rs2
	addi	s5, s5, -4		# delete slt
	addi	t1, t1, 2
	slli	t1, t1, 12
	addi	t2, zero, 0x463
	or	t1, t1, t2
	slli	t3, t3, 15
	or	t1, t1, t3
	slli	t4, t4, 20
	or	a0, t1, t4
	j	cpt_emit
cpt_no_peephole:
	# Emit bne a0, zero, +8 (skip jal when cond true).
	lui	a0, 0x51
	addi	a0, a0, 0x463
cpt_emit:
	addi	gp, zero, 66
	j	emit_cmp_word
ecw_cep_tern_bne:
	sw	s5, 16(sp)		# future jal_else addr
	addi	a0, zero, 0x6F
	addi	gp, zero, 67
	j	emit_cmp_word
ecw_cep_tern_jal_else:
	# Recurse for middle with min_bp = 0 (full expression allowed).
	addi	t6, zero, 0
	addi	gp, zero, 19		# ce site 19 = ce_cep_tern_mid
	j	compile_expr_p
ce_cep_tern_mid:
	# Peephole: if the middle branch's last emitted instruction is an
	# unconditional jal (rd=0, opcode=0x6F) — e.g. it ended in `break`
	# or `return` — then the jal_end we'd emit here is unreachable.
	# Skip emission and store sentinel 0 in 20(sp) so the end-patcher
	# also skips its patch step.
	lw	t0, -4(s5)
	andi	t1, t0, 0x7F
	addi	t2, zero, 0x6F
	bne	t1, t2, ctme_emit
	srli	t1, t0, 7
	andi	t1, t1, 0x1F
	bnez	t1, ctme_emit
	sw	zero, 20(sp)
	j	ecw_cep_tern_jal_end
ctme_emit:
	sw	s5, 20(sp)		# future jal_end addr
	addi	a0, zero, 0x6F
	addi	gp, zero, 68
	j	emit_cmp_word
ecw_cep_tern_jal_end:
	# Patch jal_else (16(sp)) to current s5 (start of ELSE block).
	lw	t5, 16(sp)
	addi	t6, s5, 0
	addi	gp, zero, 10		# patch_jtype site 10 = pjt_cep_tern_else
	j	patch_jtype
pjt_cep_tern_else:
	# Peek for ':'. If present, recurse for else; else emit addi 0.
	addi	gp, zero, 30		# sw_cep_tern_colon
	j	skip_ws
sw_cep_tern_colon:
	bge	s2, s3, cep_tern_no_else
	lbu	t0, 0(s2)
	addi	t1, zero, ':'
	bne	t0, t1, cep_tern_no_else
	addi	s2, s2, 1
	addi	t6, zero, 0
	addi	gp, zero, 20		# ce site 20 = ce_cep_tern_else
	j	compile_expr_p
ce_cep_tern_else:
	j	cep_tern_patch_end
cep_tern_no_else:
	# If the ternary's value is discarded (one-armed in stmt context),
	# the conventional `addi a0, zero, 0` false-tail is dead — skip it.
	# The jal_else target is already at this point, so when cond is
	# false, control falls straight through to the post-ternary code
	# (with garbage in a0, which is fine because no one reads it).
	lla	t0, expr_value_discarded
	lw	t0, 0(t0)
	bnez	t0, ecw_cep_tern_addi
	# Emit addi a0, zero, 0 as the missing else's value.
	lui	a0, 0
	addi	a0, a0, 0x513
	addi	gp, zero, 69
	j	emit_cmp_word
ecw_cep_tern_addi:
cep_tern_patch_end:
	lw	t5, 20(sp)
	beqz	t5, ctpe_skip
	addi	t6, s5, 0
	addi	gp, zero, 11		# patch_jtype site 11 = pjt_cep_tern_end
	j	patch_jtype
pjt_cep_tern_end:
ctpe_skip:
	j	cep_post_emit

# ── Assignment '=' ───────────────────────────────────────────────────────────
# Uses the lvalue marker (lv_kind / lv_slot) set by compile_unary. The last
# emitted instruction is a load from the lvalue; we rewind s5 by 4 to un-emit
# it (peephole), then emit the appropriate store after compiling the RHS.
#
#   lv_kind = 1 (IDENT): un-emit `lw a0, off(fp)`, compile RHS, emit sw.
#   lv_kind = 2 (@expr): un-emit `lbu a0, 0(a0)` — address is still in a0 at
#                         runtime because the preceding instructions left it
#                         there. Emit push a0, compile RHS, pop t0, sb.
#   lv_kind = 3 (*expr): same with `lw`/`sw`.
#
# Right-associative: recurses with min_bp = -1 so `a = b = 5` → `a = (b = 5)`.
cep_pre_assign:
	lla	t0, lv_kind
	lw	t1, 0(t0)
	beqz	t1, cep_bad_lvalue	# not an lvalue → halt

	# If this is an IDENT target, enforce mutability.
	# Rule: first binding sets mutability from the operator
	#   ('=' → immutable, ':=' → mutable). On an existing var, either
	#   operator is allowed iff the var was first-bound as mutable.
	addi	t2, zero, 1
	bne	t1, t2, cep_asg_skip_mut_check
	lw	t3, 8(sp)		# op_kind (27 = '=', 28 = ':=')
	lla	t4, lookup_was_new
	lw	t4, 0(t4)
	bnez	t4, cep_asg_new
	# EXISTING var: allowed iff the stored mutability flag is set.
	lla	t5, last_ident_entry
	lw	t5, 0(t5)
	lbu	t6, 37(t5)
	beqz	t6, cep_bad_immut_reassign
	j	cep_asg_skip_mut_check
cep_asg_new:
	# NEW var — set mutability from op_kind.
	lla	t5, last_ident_entry
	lw	t5, 0(t5)
	addi	t2, zero, 28
	bne	t3, t2, cep_asg_skip_mut_check	# '=' → immutable (default 0)
	addi	t2, zero, 1
	sb	t2, 37(t5)		# ':=' → mark mutable
cep_asg_skip_mut_check:

	sw	t1, 16(sp)		# save kind in frame scratch1
	lla	t0, lv_slot
	lw	t1, 0(t0)
	sw	t1, 20(sp)		# save slot in frame scratch2

	# Un-emit the last load (peephole: rewind s5 by 4).
	addi	s5, s5, -4
	# Marker-restore: the un-emitted instruction was a deref load
	# (lbu/lh/lw a0, 0(a0)) emitted via emit_word, which cleared the
	# marker. Inspect the new prev word; if it's one of the safe-leaf
	# producers (lw a0, off(fp); addi a0, zero, imm; lui a0, hi)
	# re-set push_safe_marker so the upcoming push can redirect its
	# rd to sN. Each pattern has a distinct low-bit signature.
	lw	t1, -4(s5)
	# 1) lw a0, off(fp) → low20 == 0x00042503
	slli	t2, t1, 12
	srli	t2, t2, 12
	lui	t3, 0x42
	addi	t3, t3, 0x503
	beq	t2, t3, cep_asg_remark
	# 2) addi a0, zero, imm → low20 == 0x00000513
	addi	t3, zero, 0x513
	beq	t2, t3, cep_asg_remark
	# 3) lui a0, imm → low12 == 0x00000537
	slli	t2, t1, 20
	srli	t2, t2, 20
	addi	t3, zero, 0x537
	bne	t2, t3, cep_asg_no_remark
cep_asg_remark:
	lla	t1, push_safe_marker
	sw	s5, 0(t1)
cep_asg_no_remark:

	# If kind == 1 (IDENT), no push needed; just recurse and emit sw.
	# If kind == 2 or 3 (deref), push a0 to save the address across RHS.
	lw	t1, 16(sp)
	addi	t2, zero, 1
	beq	t1, t2, cep_asg_recurse
	addi	gp, zero, 21		# push site 21 = push_cep_asg
	j	emit_push_a0
push_cep_asg:

cep_asg_recurse:
	# Recurse for RHS with min_bp = -1 (right-associative).
	addi	t6, zero, -1
	addi	gp, zero, 23		# compile_expr site 23 = ce_cep_asg_rhs
	j	compile_expr_p
ce_cep_asg_rhs:
	# Dispatch on saved lv_kind to emit the store.
	lw	t1, 16(sp)
	addi	t2, zero, 1
	beq	t1, t2, cep_asg_em_ident
	# kind 2/3/4 — pop address into t0, then dispatch for sb / sw / sh.
	addi	gp, zero, 21		# pop site 21 = pop_cep_asg
	j	emit_pop_t0
pop_cep_asg:
	lw	t1, 16(sp)
	addi	t2, zero, 2
	beq	t1, t2, cep_asg_em_sb
	addi	t2, zero, 4
	beq	t1, t2, cep_asg_em_sh
	j	cep_asg_em_sw

cep_asg_em_ident:
	# Reload slot offset; emit sw a0, off(fp).
	lw	a0, 20(sp)
	addi	gp, zero, 17		# esws site 17 = esws_cep_asg
	j	emit_sw_sp
esws_cep_asg:
	j	cep_post_emit

cep_asg_em_sb:
	addi	gp, zero, 1		# esb site 1 = esb_cep_asg
	j	emit_sb_deref
esb_cep_asg:
	j	cep_post_emit

cep_asg_em_sw:
	addi	gp, zero, 1		# esw site 1 = esw_cep_asg
	j	emit_sw_deref
esw_cep_asg:
	j	cep_post_emit

cep_asg_em_sh:
	# Emit `sh a0, 0(sN)` where sN = popped_src_reg.
	lla	t0, popped_src_reg
	lw	t0, 0(t0)
	slli	t0, t0, 15
	lui	a0, 0xA01
	addi	a0, a0, 0x023
	or	a0, a0, t0
	addi	gp, zero, 75		# emit_word site 75 = ew_cep_asg_sh
	j	emit_word
ew_cep_asg_sh:
	j	cep_post_emit

cep_bad_lvalue:
	addi	a0, zero, 20		# err 20: left of '=' is not an lvalue
	j	report_err
cep_bad_immut_reassign:
	lla	t0, ident_start
	lw	s2, 0(t0)
	addi	a0, zero, 55		# err 55: cannot reassign immutable
	j	report_err

# ══════════════════════════════════════════════════════════════════════════════
# cep_pre_postfix — postfix '++' (op_kind 29) and '--' (op_kind 30).
# No RHS expression. Emits: adjust(±1), store-back, undo(∓1) for postfix value.
# Saves pre-computed delta/undo instruction words in 8(sp)/12(sp) so a single
# code path handles both ++ and --.
# ══════════════════════════════════════════════════════════════════════════════
cep_pre_postinc:
cep_pre_postdec:
	lla	t0, lv_kind
	lw	t1, 0(t0)
	beqz	t1, cep_bad_lvalue
	# If IDENT, check mutability.
	addi	t2, zero, 1
	bne	t1, t2, cep_pf_skip_mut
	lla	t3, last_ident_entry
	lw	t3, 0(t3)
	lbu	t4, 37(t3)
	beqz	t4, cep_bad_immut_reassign
cep_pf_skip_mut:
	sw	t1, 16(sp)
	lla	t0, lv_slot
	lw	t2, 0(t0)
	sw	t2, 20(sp)
	# Prepare delta/undo instruction words.
	# addi a0,a0,1 = 0x00150513  addi a0,a0,-1 = 0xFFF50513
	lw	t0, 8(sp)		# op_kind: 29=++, 30=--
	addi	t1, zero, 29
	beq	t0, t1, cep_pf_inc_words
	# -- : delta=-1, undo=+1
	lui	t2, 0xFFF50
	addi	t2, t2, 0x513
	sw	t2, 8(sp)
	lui	t2, 0x150
	addi	t2, t2, 0x513
	sw	t2, 12(sp)
	j	cep_pf_begin
cep_pf_inc_words:
	# ++ : delta=+1, undo=-1
	lui	t2, 0x150
	addi	t2, t2, 0x513
	sw	t2, 8(sp)
	lui	t2, 0xFFF50
	addi	t2, t2, 0x513
	sw	t2, 12(sp)
cep_pf_begin:
	lw	t1, 16(sp)
	addi	t2, zero, 1
	beq	t1, t2, cep_pf_ident
	# ── Deref path: un-emit load, push addr, re-emit load ──────────────
	addi	s5, s5, -4
	addi	gp, zero, 30		# push site 30 = push_cep_postfix
	j	emit_push_a0
push_cep_postfix:
	lw	t1, 16(sp)
	addi	t2, zero, 3
	beq	t1, t2, cep_pf_reload_w
	addi	t2, zero, 4
	beq	t1, t2, cep_pf_reload_h
	# kind 2 (byte): lbu a0, 0(a0) = 0x00054503
	lui	a0, 0x54
	addi	a0, a0, 0x503
	addi	gp, zero, 92		# emit_word site 92 = ew_cep_pf_lbu
	j	emit_word
ew_cep_pf_lbu:
	j	cep_pf_emit_delta
cep_pf_reload_w:
	# kind 3 (word): lw a0, 0(a0) = 0x00052503
	lui	a0, 0x52
	addi	a0, a0, 0x503
	addi	gp, zero, 93		# emit_word site 93 = ew_cep_pf_lw
	j	emit_word
ew_cep_pf_lw:
	j	cep_pf_emit_delta
cep_pf_reload_h:
	# kind 4 (half): lhu a0, 0(a0) = 0x00055503
	lui	a0, 0x55
	addi	a0, a0, 0x503
	addi	gp, zero, 94		# emit_word site 94 = ew_cep_pf_lhu
	j	emit_word
ew_cep_pf_lhu:
cep_pf_emit_delta:
	# Emit delta instruction (addi a0,a0,±1)
	lw	a0, 8(sp)
	addi	gp, zero, 91		# emit_word site 91 = ew_cep_pf_delta
	j	emit_word
ew_cep_pf_delta:
	# Pop address → t0
	addi	gp, zero, 31		# pop site 31 = pop_cep_postfix
	j	emit_pop_t0
pop_cep_postfix:
	# Store back based on kind
	lw	t5, 16(sp)
	addi	t1, zero, 3
	beq	t5, t1, cep_pf_store_w
	addi	t1, zero, 2
	beq	t5, t1, cep_pf_store_b
	# kind 4 (half): sh a0, 0(sN) where sN = popped_src_reg
	lla	t0, popped_src_reg
	lw	t0, 0(t0)
	slli	t0, t0, 15
	lui	a0, 0xA01
	addi	a0, a0, 0x023
	or	a0, a0, t0
	addi	gp, zero, 95		# emit_word site 95 = ew_cep_pf_sh
	j	emit_word
ew_cep_pf_sh:
	j	cep_pf_emit_undo
cep_pf_store_w:
	addi	gp, zero, 3		# esw site 3 = esw_cep_postfix
	j	emit_sw_deref
esw_cep_postfix:
	j	cep_pf_emit_undo
cep_pf_store_b:
	addi	gp, zero, 3		# esb site 3 = esb_cep_postfix
	j	emit_sb_deref
esb_cep_postfix:
cep_pf_emit_undo:
	# Emit undo instruction (addi a0,a0,∓1)
	lw	a0, 12(sp)
	addi	gp, zero, 96		# emit_word site 96 = ew_cep_pf_undo
	j	emit_word
ew_cep_pf_undo:
	j	cep_post_emit_reset
	# ── IDENT path ──────────────────────────────────────────────────────
cep_pf_ident:
	# Emit delta (addi a0,a0,±1)
	lw	a0, 8(sp)
	sw	a0, 0(s5)
	addi	s5, s5, 4
	# Emit sw a0, slot(fp)
	lw	a0, 20(sp)
	addi	gp, zero, 25		# esws site 25 = esws_cep_postfix
	j	emit_sw_sp
esws_cep_postfix:
	# Emit undo (addi a0,a0,∓1)
	lw	a0, 12(sp)
	sw	a0, 0(s5)
	addi	s5, s5, 4
	j	cep_post_emit_reset
eaa1_cep_postinc:
eaam1_cep_postinc:
	j	halt_err

# ══════════════════════════════════════════════════════════════════════════════
# cep_pre_compound — compound assignment (`+=`, `-=`, `*=`, `/=`, `%=`, `&=`,
#   `|=`, `^=`, `<<=`, `>>=`, `>>u=`). The underlying arithmetic op is in bits
#   0..6 of op_kind; bit 7 is the compound flag.
#
# IDENT target (lv_kind == 1):
#   1. Save kind, slot to 16/20(sp).
#   2. Push a0 (loaded lhs value).
#   3. Recurse for RHS.
#   4. Pop lhs → t0, dispatch to binop emit.
#   5. cep_post_emit sees bit 7 + kind 1, emits `sw a0, slot(fp)`.
#
# Deref target (lv_kind == 2 for '@', 3 for '*'):
#   1. Save kind to 16(sp).
#   2. Un-emit the nud's load (peephole — runtime a0 is now the address).
#   3. Push a0 (address).
#   4. Re-emit the load (lbu/lw) so runtime a0 is the value.
#   5. Push a0 (value).
#   6. Recurse for RHS.
#   7. Pop lhs-value → t0, dispatch to binop emit.
#   8. cep_post_emit sees bit 7 + kind 2/3, pops address → t0, emits sb/sw.
# ══════════════════════════════════════════════════════════════════════════════
cep_pre_compound:
	lla	t0, lv_kind
	lw	t1, 0(t0)
	beqz	t1, cep_bad_lvalue
	# If IDENT, check mutability — compound assigns on immutable vars error.
	addi	t2, zero, 1
	bne	t1, t2, cep_pc_skip_mut
	lla	t3, last_ident_entry
	lw	t3, 0(t3)
	lbu	t4, 37(t3)
	beqz	t4, cep_bad_immut_reassign
cep_pc_skip_mut:
	sw	t1, 16(sp)		# scratch1 = kind
	lla	t0, lv_slot
	lw	t2, 0(t0)
	sw	t2, 20(sp)		# scratch2 = slot (used for kind 1 only)

	addi	t2, zero, 1
	beq	t1, t2, cep_pc_push_value

	# Deref path: un-emit the load, push address, re-emit the load.
	addi	s5, s5, -4
	addi	gp, zero, 24		# push site 24 = push_cep_compound_addr
	j	emit_push_a0
push_cep_compound_addr:
	lw	t1, 16(sp)
	addi	t2, zero, 3
	beq	t1, t2, cep_pc_reload_w
	addi	t2, zero, 4
	beq	t1, t2, cep_pc_reload_h
	# kind == 2 (byte deref): re-emit `lbu a0, 0(a0)` = 0x00054503.
	lui	a0, 0x54
	addi	a0, a0, 0x503
	addi	gp, zero, 40		# emit_word site 40 = ew_cep_compound_rb
	j	emit_word
ew_cep_compound_rb:
	j	cep_pc_push_value
cep_pc_reload_w:
	# kind == 3 (word deref): re-emit `lw a0, 0(a0)` = 0x00052503.
	lui	a0, 0x52
	addi	a0, a0, 0x503
	addi	gp, zero, 41		# emit_word site 41 = ew_cep_compound_rw
	j	emit_word
ew_cep_compound_rw:
	j	cep_pc_push_value
cep_pc_reload_h:
	# kind == 4 (halfword deref): re-emit `lhu a0, 0(a0)` = 0x00055503.
	lui	a0, 0x55
	addi	a0, a0, 0x503
	addi	gp, zero, 76		# emit_word site 76 = ew_cep_compound_rh
	j	emit_word
ew_cep_compound_rh:

cep_pc_push_value:
	# Push a0 (the lhs value — either the nud's load for IDENT, or the
	# re-emitted load for deref).
	addi	gp, zero, 22		# push site 22 = push_cep_compound
	j	emit_push_a0
push_cep_compound:
	# Recurse for RHS — right-associative (min_bp = -1) so `a += b += c`
	# parses as `a += (b += c)`.
	addi	t6, zero, -1
	addi	gp, zero, 28		# compile_expr site 28 = ce_cep_compound_rhs
	j	compile_expr_p
ce_cep_compound_rhs:
	# Pop lhs-value into t0.
	addi	gp, zero, 22		# pop site 22 = pop_cep_compound
	j	emit_pop_t0
pop_cep_compound:
	# Fall into the main op-dispatch (same as pop_cep's tail).
	j	pop_cep

# ══════════════════════════════════════════════════════════════════════════════
# cep_post_emit — shared tail after any binop/ternary/short-circuit completes.
# For compound assigns, emits the store here based on the saved kind:
#   kind 1 (IDENT): `sw a0, slot(fp)` — slot at 20(sp).
#   kind 2 (byte deref): pop address → t0, `sb a0, 0(t0)`.
#   kind 3 (word deref): pop address → t0, `sw a0, 0(t0)`.
# Always resets lv_kind (result of a binop is never an lvalue) before looping.
# ══════════════════════════════════════════════════════════════════════════════
cep_post_emit:
	lw	t5, 8(sp)
	andi	t5, t5, 0x80
	beqz	t5, cep_post_emit_reset
	# Compound — dispatch on saved kind at 16(sp).
	lw	t5, 16(sp)
	addi	t1, zero, 1
	beq	t5, t1, cep_pe_store_ident
	addi	t1, zero, 2
	beq	t5, t1, cep_pe_store_byte
	addi	t1, zero, 4
	beq	t5, t1, cep_pe_store_half
	# kind == 3 (word deref): pop address, emit sw.
	addi	gp, zero, 24		# pop site 24 = pop_cep_compound_addr_w
	j	emit_pop_t0
pop_cep_compound_addr_w:
	addi	gp, zero, 2		# esw site 2 = esw_cep_compound
	j	emit_sw_deref
esw_cep_compound:
	j	cep_post_emit_reset
cep_pe_store_byte:
	addi	gp, zero, 25		# pop site 25 = pop_cep_compound_addr_b
	j	emit_pop_t0
pop_cep_compound_addr_b:
	addi	gp, zero, 2		# esb site 2 = esb_cep_compound
	j	emit_sb_deref
esb_cep_compound:
	j	cep_post_emit_reset
cep_pe_store_half:
	addi	gp, zero, 27		# pop site 27 = pop_cep_compound_addr_h
	j	emit_pop_t0
pop_cep_compound_addr_h:
	# Emit `sh a0, 0(sN)` where sN = popped_src_reg.
	lla	t0, popped_src_reg
	lw	t0, 0(t0)
	slli	t0, t0, 15
	lui	a0, 0xA01
	addi	a0, a0, 0x023
	or	a0, a0, t0
	addi	gp, zero, 77		# emit_word site 77 = ew_cep_pe_sh
	j	emit_word
ew_cep_pe_sh:
	j	cep_post_emit_reset
cep_pe_store_ident:
	lw	a0, 20(sp)		# saved slot offset
	addi	gp, zero, 18		# esws site 18 = esws_cep_compound
	j	emit_sw_sp
esws_cep_compound:
cep_post_emit_reset:
	lla	t0, lv_kind
	sw	zero, 0(t0)
	j	cep_loop

cep_done:
	lw	gp, 0(sp)
	addi	sp, sp, 24
	# Dispatch back to caller via the shared compile_expr_disp. Both
	# compile_expr and compile_expr_p reach the same external return
	# sites (ce_cs_rhs, …, ce_ct_paren), so we alias the dispatch table.
	j	compile_expr_disp

# ══════════════════════════════════════════════════════════════════════════════
# compile_stmt — compile one statement. Non-ws known to be at s2.
#
# Grammar:
#   stmt := '*' expr '=' expr ';'
#         | '@' expr '=' expr ';'
#         | '++' IDENT ';'
#         | '--' IDENT ';'
#         | IDENT '='  expr ';'
#         | IDENT '+=' expr ';'
#         | IDENT '-=' expr ';'
#         | IDENT '^=' expr ';'
#         | IDENT '++' ';'
#         | IDENT '--' ';'
#
# Single caller: cs_after (compile_loop)
# ══════════════════════════════════════════════════════════════════════════════
compile_stmt:
	# Push the entry s2 onto famc's own stack so that cs_bad can rewind and
	# retry the statement as an expression-statement. Reentrant-safe: each
	# compile_stmt invocation gets its own frame slot, no global state.
	addi	sp, sp, -4
	sw	s2, 0(sp)
	lbu	t0, 0(s2)
	# Peek for array declarations '@'/'#'/'*' IDENT '[' LIT ']' ';'. We
	# only commit to the declaration path if the whole pattern matches
	# syntactically; otherwise we fall through to the normal dispatch
	# below (which handles *expr=v, @expr=v, compound assigns, etc.).
	addi	t1, zero, 42		# '*'
	beq	t0, t1, cs_chk_decl_star
	addi	t1, zero, 64		# '@'
	beq	t0, t1, cs_chk_decl_at
	addi	t1, zero, '#'
	beq	t0, t1, cs_chk_decl_hash
	j	cs_normal_dispatch
cs_chk_decl_star:
	addi	t6, zero, 4		# stride = 4 (word)
	addi	gp, zero, 0		# scan return site 0 = scan_ret_stmt
	j	cs_array_decl_scan
cs_chk_decl_at:
	addi	t6, zero, 1		# stride = 1 (byte)
	addi	gp, zero, 0
	j	cs_array_decl_scan
cs_chk_decl_hash:
	addi	t6, zero, 2		# stride = 2 (halfword)
	addi	gp, zero, 0
	j	cs_array_decl_scan
scan_ret_stmt:
	beqz	a0, cs_normal_dispatch
	addi	gp, zero, 0		# cs_array_decl_go return site 0 = cs_done
	j	cs_array_decl_go
cs_normal_dispatch:
	# Only IDENT-start characters need the special declaration path.
	# Everything else (*, @, #, ++, --, digits, etc.) falls through to
	# cs_fb which routes through the Pratt expression parser.
	addi	t1, zero, '_'
	beq	t0, t1, cs_ident_start_ok
	addi	t1, zero, 'a'
	blt	t0, t1, cs_chk_uc_start
	addi	t1, zero, 123
	blt	t0, t1, cs_ident_start_ok
cs_chk_uc_start:
	addi	t1, zero, 'A'
	blt	t0, t1, cs_fb
	addi	t1, zero, 91
	bge	t0, t1, cs_fb
cs_ident_start_ok:
	addi	gp, zero, 1
	j	parse_ident
pi_cs:
	# Keyword check before alloc. If the token is "loop" or "break",
	# rewind to entry s2 and divert to the expression-statement fallback.
	addi	t0, zero, 4
	bne	s11, t0, pi_cs_not_loop
	lbu	t1, 0(s10)
	addi	t2, zero, 'l'
	bne	t1, t2, pi_cs_not_loop
	lbu	t1, 1(s10)
	addi	t2, zero, 'o'
	bne	t1, t2, pi_cs_not_loop
	lbu	t1, 2(s10)
	bne	t1, t2, pi_cs_not_loop
	lbu	t1, 3(s10)
	addi	t2, zero, 'p'
	bne	t1, t2, pi_cs_not_loop
	j	cs_fb
pi_cs_not_loop:
	addi	t0, zero, 5
	bne	s11, t0, pi_cs_not_break
	lbu	t1, 0(s10)
	addi	t2, zero, 'b'
	bne	t1, t2, pi_cs_not_break
	lbu	t1, 1(s10)
	addi	t2, zero, 'r'
	bne	t1, t2, pi_cs_not_break
	lbu	t1, 2(s10)
	addi	t2, zero, 'e'
	bne	t1, t2, pi_cs_not_break
	lbu	t1, 3(s10)
	addi	t2, zero, 'a'
	bne	t1, t2, pi_cs_not_break
	lbu	t1, 4(s10)
	addi	t2, zero, 'k'
	bne	t1, t2, pi_cs_not_break
	j	cs_fb
pi_cs_not_break:
	addi	t0, zero, 8
	bne	s11, t0, pi_cs_not_continue
	lbu	t1, 0(s10)
	addi	t2, zero, 'c'
	bne	t1, t2, pi_cs_not_continue
	lbu	t1, 1(s10)
	addi	t2, zero, 'o'
	bne	t1, t2, pi_cs_not_continue
	lbu	t1, 2(s10)
	addi	t2, zero, 'n'
	bne	t1, t2, pi_cs_not_continue
	lbu	t1, 3(s10)
	addi	t2, zero, 't'
	bne	t1, t2, pi_cs_not_continue
	lbu	t1, 4(s10)
	addi	t2, zero, 'i'
	bne	t1, t2, pi_cs_not_continue
	lbu	t1, 5(s10)
	addi	t2, zero, 'n'
	bne	t1, t2, pi_cs_not_continue
	lbu	t1, 6(s10)
	addi	t2, zero, 'u'
	bne	t1, t2, pi_cs_not_continue
	lbu	t1, 7(s10)
	addi	t2, zero, 'e'
	bne	t1, t2, pi_cs_not_continue
	j	cs_fb
pi_cs_not_continue:
	addi	t0, zero, 3
	bne	s11, t0, pi_cs_not_for
	lbu	t1, 0(s10)
	addi	t2, zero, 'f'
	bne	t1, t2, pi_cs_not_for
	lbu	t1, 1(s10)
	addi	t2, zero, 'o'
	bne	t1, t2, pi_cs_not_for
	lbu	t1, 2(s10)
	addi	t2, zero, 'r'
	bne	t1, t2, pi_cs_not_for
	j	cs_fb
pi_cs_not_for:
	# 'macro' (5 chars) — top-level macro definition.
	addi	t0, zero, 5
	bne	s11, t0, pi_cs_not_macro
	lbu	t1, 0(s10)
	addi	t2, zero, 'm'
	bne	t1, t2, pi_cs_not_macro
	lbu	t1, 1(s10)
	addi	t2, zero, 'a'
	bne	t1, t2, pi_cs_not_macro
	lbu	t1, 2(s10)
	addi	t2, zero, 'c'
	bne	t1, t2, pi_cs_not_macro
	lbu	t1, 3(s10)
	addi	t2, zero, 'r'
	bne	t1, t2, pi_cs_not_macro
	lbu	t1, 4(s10)
	addi	t2, zero, 'o'
	bne	t1, t2, pi_cs_not_macro
	j	cs_kw_macro
pi_cs_not_macro:
	# 'rept' (4 chars) — top-level compile-time loop unrolling.
	addi	t0, zero, 4
	bne	s11, t0, pi_cs_not_rept
	lbu	t1, 0(s10)
	addi	t2, zero, 'r'
	bne	t1, t2, pi_cs_not_rept
	lbu	t1, 1(s10)
	addi	t2, zero, 'e'
	bne	t1, t2, pi_cs_not_rept
	lbu	t1, 2(s10)
	addi	t2, zero, 'p'
	bne	t1, t2, pi_cs_not_rept
	lbu	t1, 3(s10)
	addi	t2, zero, 't'
	bne	t1, t2, pi_cs_not_rept
	j	cs_kw_rept
pi_cs_not_rept:
	# 'fn' (2 chars) — function definition — stays at statement level.
	addi	t0, zero, 2
	bne	s11, t0, pi_cs_not_fn
	lbu	t1, 0(s10)
	addi	t2, zero, 'f'
	bne	t1, t2, pi_cs_not_fn
	lbu	t1, 1(s10)
	addi	t2, zero, 'n'
	bne	t1, t2, pi_cs_not_fn
	j	cs_kw_fn
pi_cs_not_fn:
	# 'asm' (3 chars) — inline assembly block.
	addi	t0, zero, 3
	bne	s11, t0, pi_cs_not_asm
	lbu	t1, 0(s10)
	addi	t2, zero, 'a'
	bne	t1, t2, pi_cs_not_asm
	lbu	t1, 1(s10)
	addi	t2, zero, 's'
	bne	t1, t2, pi_cs_not_asm
	lbu	t1, 2(s10)
	addi	t2, zero, 'm'
	bne	t1, t2, pi_cs_not_asm
	j	cs_kw_asm
pi_cs_not_asm:
	# 'return' (6 chars) — diverts to the expression-statement fallback,
	# which re-parses via the Pratt nud and hits ct_kw_return.
	addi	t0, zero, 6
	bne	s11, t0, pi_cs_not_return
	lbu	t1, 0(s10)
	addi	t2, zero, 'r'
	bne	t1, t2, pi_cs_not_return
	lbu	t1, 1(s10)
	addi	t2, zero, 'e'
	bne	t1, t2, pi_cs_not_return
	lbu	t1, 2(s10)
	addi	t2, zero, 't'
	bne	t1, t2, pi_cs_not_return
	lbu	t1, 3(s10)
	addi	t2, zero, 'u'
	bne	t1, t2, pi_cs_not_return
	lbu	t1, 4(s10)
	addi	t2, zero, 'r'
	bne	t1, t2, pi_cs_not_return
	lbu	t1, 5(s10)
	addi	t2, zero, 'n'
	bne	t1, t2, pi_cs_not_return
	j	cs_fb
pi_cs_not_return:
	# 'struct' (6 chars) — struct type definition at statement level.
	addi	t0, zero, 6
	bne	s11, t0, pi_cs_var
	lbu	t1, 0(s10)
	addi	t2, zero, 's'
	bne	t1, t2, pi_cs_var
	lbu	t1, 1(s10)
	addi	t2, zero, 't'
	bne	t1, t2, pi_cs_var
	lbu	t1, 2(s10)
	addi	t2, zero, 'r'
	bne	t1, t2, pi_cs_var
	lbu	t1, 3(s10)
	addi	t2, zero, 'u'
	bne	t1, t2, pi_cs_var
	lbu	t1, 4(s10)
	addi	t2, zero, 'c'
	bne	t1, t2, pi_cs_var
	lbu	t1, 5(s10)
	addi	t2, zero, 't'
	bne	t1, t2, pi_cs_var
	j	cs_kw_struct
pi_cs_var:
	# Macro invocation check: if the identifier names a macro, divert to
	# cs_macro_call which parses the call args and expands the body.
	addi	gp, zero, 1		# macro_lookup site 1 = mlk_ret_call
	j	macro_lookup
mlk_ret_call:
	beqz	a0, pi_cs_not_macro_call
	j	cs_macro_call
pi_cs_not_macro_call:
	# If the token names a struct type, check for an array-of-struct
	# declaration (`Name@ident[LIT];`). On match → cs_array_decl_go
	# with stride = count*4. On mismatch → cs_fb (expression fallback,
	# which handles `Name { ... }` literals and `Name@x.field` access).
	addi	gp, zero, 2		# struct_lookup site 2 = stlk_ret_cs
	j	struct_lookup
stlk_ret_cs:
	beqz	a0, pi_cs_not_struct
	# a0 = struct entry ptr. Check next char is '@'; if not, fall
	# back to expression context.
	bge	s2, s3, cs_fb
	lbu	t0, 0(s2)
	addi	t1, zero, '@'
	bne	t0, t1, cs_fb
	# Compute stride = count * 4 and run the shared array-decl scan.
	lw	t6, 32(a0)
	slli	t6, t6, 2
	addi	gp, zero, 2		# scan return site 2 = scan_ret_struct
	j	cs_array_decl_scan
scan_ret_struct:
	beqz	a0, cs_fb
	addi	gp, zero, 0		# cs_array_decl_go return site 0 = cs_done
	j	cs_array_decl_go
pi_cs_not_struct:
	# Only handle new-variable declarations (IDENT = expr / IDENT := expr).
	# Everything else (compound assigns, postfix, function calls, reads)
	# goes through cs_fb and the Pratt expression parser.
	addi	gp, zero, 39		# skip_ws site 39 = sw_cs_var_decide
	j	skip_ws
sw_cs_var_decide:
	bge	s2, s3, cs_fb
	lbu	t0, 0(s2)
	# Check ':=' (mutable assignment).
	addi	t1, zero, ':'
	beq	t0, t1, cs_chk_mut_assign
	# Check '=' (immutable assignment) — but not '=='.
	addi	t1, zero, '='
	bne	t0, t1, cs_fb
	addi	t2, s2, 1
	bge	t2, s3, cs_var_immut_write
	lbu	t3, 0(t2)
	addi	t1, zero, '='
	beq	t3, t1, cs_fb		# '==' is a read
cs_var_immut_write:
	lla	t0, assign_is_mut
	sw	zero, 0(t0)		# flag = 0 (immutable)
	addi	gp, zero, 1
	j	lookup_or_alloc
cs_chk_mut_assign:
	addi	t2, s2, 1
	bge	t2, s3, cs_fb
	lbu	t3, 0(t2)
	addi	t1, zero, '='
	bne	t3, t1, cs_fb		# bare ':' → not an op here
	lla	t0, assign_is_mut
	addi	t1, zero, 1
	sw	t1, 0(t0)		# flag = 1 (mutable)
	addi	gp, zero, 1
	j	lookup_or_alloc
sw_cs_eq1:
	j	halt_err
la_cs:
	# If lookup_or_alloc found an existing entry, the Pratt expression
	# parser already handles =/:/compound/postfix correctly. Fall to cs_fb.
	lla	t0, lookup_was_new
	lw	t4, 0(t0)
	beqz	t4, cs_fb
	# NEW entry — set mutability from the assign_is_mut flag.
	lla	t0, assign_is_mut
	lw	t3, 0(t0)
	lla	t0, last_ident_entry
	lw	t1, 0(t0)
	sb	t3, 37(t1)
	# Spill slot offset AND entry pointer to famc's stack. The entry
	# pointer is needed at ce_cs_rhs because compiling the RHS may
	# call lookup() on inner identifiers and clobber last_ident_entry.
	addi	sp, sp, -8
	sw	a0, 0(sp)
	sw	t1, 4(sp)
	# s2 is at the operator. Consume '=' or ':=' and compile RHS.
	lbu	t0, 0(s2)
	addi	t1, zero, ':'
	beq	t0, t1, cs_cs_colon_eq
	# Single '=' — consume and compile RHS.
	j	cs_op_eq
cs_cs_colon_eq:
	addi	s2, s2, 1		# skip ':' (cs_op_eq skips '=')

cs_op_eq:
	addi	s2, s2, 1
	addi	t6, zero, 0
	addi	gp, zero, 0
	j	compile_expr_p
ce_cs_rhs:
	# Const-folding peephole: this site is only reached via la_cs
	# (a new IDENT binding). If it's immutable (`=`) AND the RHS
	# compiled down to a single emit_li (push_safe_marker == s5),
	# record the literal in the symbol entry, drop the li, skip the
	# sw, and reclaim the frame slot. Subsequent reads rematerialize
	# the value inline.
	lla	t0, assign_is_mut
	lw	t0, 0(t0)
	bnez	t0, ce_cs_rhs_normal
	lla	t0, last_li_marker
	lw	t0, 0(t0)
	bne	t0, s5, ce_cs_rhs_normal
	# All checks passed — fold.
	lla	t0, last_li_start
	lw	s5, 0(t0)		# rewind to drop the li sequence
	# Clear both markers (we just rewound; the prior insn is no
	# longer the safe-leaf li that the markers pointed to).
	lla	t0, push_safe_marker
	sw	zero, 0(t0)
	lla	t0, last_li_marker
	sw	zero, 0(t0)
	# Store value in entry (which we stashed in 4(sp) at la_cs, since
	# RHS compile may have clobbered last_ident_entry) and set the
	# is_const flag at byte 38.
	lw	t1, 4(sp)		# entry pointer
	lla	t0, last_li_value
	lw	t2, 0(t0)
	sw	t2, 32(t1)		# bytes 32..35 = const value
	addi	t2, zero, 1
	sb	t2, 38(t1)		# byte 38 = is_const flag
	# Reclaim the frame slot we allocated (most-recent allocation,
	# so we can decrement s9 by 4 safely).
	addi	s9, s9, -4
	# Pop the saved offset+entry and skip the sw.
	addi	sp, sp, 8
	j	esws_ret
ce_cs_rhs_normal:
	lw	a0, 0(sp)
	addi	sp, sp, 8
	addi	gp, zero, 0		# esws site 0 = esws_ret
	j	emit_sw_sp
esws_ret:
	addi	gp, zero, 6
	j	skip_ws
sw_cs_semi1:
	# Semicolon optional after brace-terminated RHS (block/loop/for).
	bge	s2, s3, cs_semi1_check_brace
	lbu	t0, 0(s2)
	addi	t1, zero, ';'
	bne	t0, t1, cs_semi1_check_brace
	addi	s2, s2, 1
	j	cs_done
cs_semi1_check_brace:
	lla	t0, last_was_brace
	lw	t1, 0(t0)
	bnez	t1, cs_done
	j	cs_fb

# ── '+' after IDENT: distinguish '+=' and '++' ───────────────────────────────
cs_op_plus:
	addi	t2, s2, 1
	bge	t2, s3, cs_bad
	lbu	t0, 0(t2)
	addi	t1, zero, '='
	beq	t0, t1, cs_compound_add
	addi	t1, zero, '+'
	beq	t0, t1, cs_ident_post_inc
	j	cs_bad

cs_op_minus:
	addi	t2, s2, 1
	bge	t2, s3, cs_bad
	lbu	t0, 0(t2)
	addi	t1, zero, '='
	beq	t0, t1, cs_compound_sub
	addi	t1, zero, '-'
	beq	t0, t1, cs_ident_post_dec
	j	cs_bad

cs_op_xor:
	# Must be '^=' (bare '^' isn't a statement operator).
	addi	t2, s2, 1
	bge	t2, s3, cs_bad
	lbu	t0, 0(t2)
	addi	t1, zero, '='
	bne	t0, t1, cs_bad
	j	cs_compound_xor

cs_op_lshift:
	# Must be '<<=' (three chars).
	addi	t2, s2, 1
	bge	t2, s3, cs_bad
	lbu	t0, 0(t2)
	addi	t1, zero, '<'
	bne	t0, t1, cs_bad
	addi	t2, s2, 2
	bge	t2, s3, cs_bad
	lbu	t0, 0(t2)
	addi	t1, zero, '='
	bne	t0, t1, cs_bad
	j	cs_compound_lshift

cs_op_rshift:
	addi	t2, s2, 1
	bge	t2, s3, cs_bad
	lbu	t0, 0(t2)
	addi	t1, zero, '>'
	bne	t0, t1, cs_bad
	addi	t2, s2, 2
	bge	t2, s3, cs_bad
	lbu	t0, 0(t2)
	addi	t1, zero, '='
	bne	t0, t1, cs_bad
	j	cs_compound_rshift

cs_op_and:
	# Must be '&=' (bare '&' isn't a statement operator).
	addi	t2, s2, 1
	bge	t2, s3, cs_bad
	lbu	t0, 0(t2)
	addi	t1, zero, '='
	bne	t0, t1, cs_bad
	j	cs_compound_and

cs_op_or:
	# Must be '|=' (bare '|' isn't a statement operator).
	addi	t2, s2, 1
	bge	t2, s3, cs_bad
	lbu	t0, 0(t2)
	addi	t1, zero, '='
	bne	t0, t1, cs_bad
	j	cs_compound_or

cs_op_mul:
	# Must be '*=' (bare '*' isn't a statement operator after an IDENT).
	addi	t2, s2, 1
	bge	t2, s3, cs_bad
	lbu	t0, 0(t2)
	addi	t1, zero, '='
	bne	t0, t1, cs_bad
	j	cs_compound_mul

cs_op_div:
	addi	t2, s2, 1
	bge	t2, s3, cs_bad
	lbu	t0, 0(t2)
	addi	t1, zero, '='
	bne	t0, t1, cs_bad
	j	cs_compound_div

cs_op_mod:
	addi	t2, s2, 1
	bge	t2, s3, cs_bad
	lbu	t0, 0(t2)
	addi	t1, zero, '='
	bne	t0, t1, cs_bad
	j	cs_compound_mod

# ── IDENT '+=' expr ; ────────────────────────────────────────────────────────
cs_compound_add:
	addi	s2, s2, 2
	lw	a0, 0(sp)
	addi	gp, zero, 3		# elws site 3 = elws_cs_plus
	j	emit_lw_sp
elws_cs_plus:
	addi	gp, zero, 4		# push site 4 = push_cs_plus
	j	emit_push_a0
push_cs_plus:
	addi	t6, zero, 0
	addi	gp, zero, 5		# ce site 5 = ce_cs_plus
	j	compile_expr_p
ce_cs_plus:
	addi	gp, zero, 4		# pop site 4 = pop_cs_plus
	j	emit_pop_t0
pop_cs_plus:
	addi	gp, zero, 1		# ea site 1 = ea_cs_plus
	j	emit_add
ea_cs_plus:
	lw	a0, 0(sp)
	addi	sp, sp, 4
	addi	gp, zero, 7		# esws site 7 = esws_cs_plus
	j	emit_sw_sp
esws_cs_plus:
	addi	gp, zero, 15		# skip_ws site 15 = sw_cs_semi_stmt
	j	skip_ws

# ── IDENT '-=' expr ; ────────────────────────────────────────────────────────
cs_compound_sub:
	addi	s2, s2, 2
	lw	a0, 0(sp)
	addi	gp, zero, 4		# elws site 4 = elws_cs_minus
	j	emit_lw_sp
elws_cs_minus:
	addi	gp, zero, 5		# push site 5 = push_cs_minus
	j	emit_push_a0
push_cs_minus:
	addi	t6, zero, 0
	addi	gp, zero, 6		# ce site 6 = ce_cs_minus
	j	compile_expr_p
ce_cs_minus:
	addi	gp, zero, 5		# pop site 5 = pop_cs_minus
	j	emit_pop_t0
pop_cs_minus:
	addi	gp, zero, 1		# es site 1 = es_cs_minus
	j	emit_sub
es_cs_minus:
	lw	a0, 0(sp)
	addi	sp, sp, 4
	addi	gp, zero, 8		# esws site 8 = esws_cs_minus
	j	emit_sw_sp
esws_cs_minus:
	addi	gp, zero, 15
	j	skip_ws

# ── IDENT '^=' expr ; ────────────────────────────────────────────────────────
cs_compound_xor:
	addi	s2, s2, 2
	lw	a0, 0(sp)
	addi	gp, zero, 5		# elws site 5 = elws_cs_xor
	j	emit_lw_sp
elws_cs_xor:
	addi	gp, zero, 6		# push site 6 = push_cs_xor
	j	emit_push_a0
push_cs_xor:
	addi	t6, zero, 0
	addi	gp, zero, 7		# ce site 7 = ce_cs_xor
	j	compile_expr_p
ce_cs_xor:
	addi	gp, zero, 6		# pop site 6 = pop_cs_xor
	j	emit_pop_t0
pop_cs_xor:
	addi	gp, zero, 1		# ex site 1 = ex_cs_xor
	j	emit_xor
ex_cs_xor:
	lw	a0, 0(sp)
	addi	sp, sp, 4
	addi	gp, zero, 9		# esws site 9 = esws_cs_xor
	j	emit_sw_sp
esws_cs_xor:
	addi	gp, zero, 15
	j	skip_ws

# ── IDENT '<<=' expr ; ───────────────────────────────────────────────────────
cs_compound_lshift:
	addi	s2, s2, 3
	lw	a0, 0(sp)
	addi	gp, zero, 6		# elws site 6 = elws_cs_lshift
	j	emit_lw_sp
elws_cs_lshift:
	addi	gp, zero, 8		# push site 8 = push_cs_lshift
	j	emit_push_a0
push_cs_lshift:
	addi	t6, zero, 0
	addi	gp, zero, 8		# ce site 8 = ce_cs_lshift
	j	compile_expr_p
ce_cs_lshift:
	addi	gp, zero, 8		# pop site 8 = pop_cs_lshift
	j	emit_pop_t0
pop_cs_lshift:
	addi	gp, zero, 1		# esll site 1 = esll_cs_lshift
	j	emit_sll
esll_cs_lshift:
	lw	a0, 0(sp)
	addi	sp, sp, 4
	addi	gp, zero, 10		# esws site 10 = esws_cs_lshift
	j	emit_sw_sp
esws_cs_lshift:
	addi	gp, zero, 15
	j	skip_ws

# ── IDENT '>>=' expr ; ───────────────────────────────────────────────────────
cs_compound_rshift:
	addi	s2, s2, 3
	lw	a0, 0(sp)
	addi	gp, zero, 7		# elws site 7 = elws_cs_rshift
	j	emit_lw_sp
elws_cs_rshift:
	addi	gp, zero, 9		# push site 9 = push_cs_rshift
	j	emit_push_a0
push_cs_rshift:
	addi	t6, zero, 0
	addi	gp, zero, 9		# ce site 9 = ce_cs_rshift
	j	compile_expr_p
ce_cs_rshift:
	addi	gp, zero, 9		# pop site 9 = pop_cs_rshift
	j	emit_pop_t0
pop_cs_rshift:
	addi	gp, zero, 1		# esra site 1 = esra_cs_rshift
	j	emit_sra
esra_cs_rshift:
	lw	a0, 0(sp)
	addi	sp, sp, 4
	addi	gp, zero, 11		# esws site 11 = esws_cs_rshift
	j	emit_sw_sp
esws_cs_rshift:
	addi	gp, zero, 15
	j	skip_ws

# ── IDENT '&=' expr ; ────────────────────────────────────────────────────────
cs_compound_and:
	addi	s2, s2, 2
	lw	a0, 0(sp)
	addi	gp, zero, 8		# elws site 8 = elws_cs_and
	j	emit_lw_sp
elws_cs_and:
	addi	gp, zero, 11		# push site 11 = push_cs_and
	j	emit_push_a0
push_cs_and:
	addi	t6, zero, 0
	addi	gp, zero, 10		# ce site 10 = ce_cs_and
	j	compile_expr_p
ce_cs_and:
	addi	gp, zero, 11		# pop site 11 = pop_cs_and
	j	emit_pop_t0
pop_cs_and:
	addi	gp, zero, 1		# ean site 1 = ean_cs_and
	j	emit_and
ean_cs_and:
	lw	a0, 0(sp)
	addi	sp, sp, 4
	addi	gp, zero, 12		# esws site 12 = esws_cs_and
	j	emit_sw_sp
esws_cs_and:
	addi	gp, zero, 15
	j	skip_ws

# ── IDENT '|=' expr ; ────────────────────────────────────────────────────────
cs_compound_or:
	addi	s2, s2, 2
	lw	a0, 0(sp)
	addi	gp, zero, 9		# elws site 9 = elws_cs_or
	j	emit_lw_sp
elws_cs_or:
	addi	gp, zero, 13		# push site 13 = push_cs_or
	j	emit_push_a0
push_cs_or:
	addi	t6, zero, 0
	addi	gp, zero, 11		# ce site 11 = ce_cs_or
	j	compile_expr_p
ce_cs_or:
	addi	gp, zero, 13		# pop site 13 = pop_cs_or
	j	emit_pop_t0
pop_cs_or:
	addi	gp, zero, 1		# eor site 1 = eor_cs_or
	j	emit_or
eor_cs_or:
	lw	a0, 0(sp)
	addi	sp, sp, 4
	addi	gp, zero, 13		# esws site 13 = esws_cs_or
	j	emit_sw_sp
esws_cs_or:
	addi	gp, zero, 15
	j	skip_ws

# ── IDENT '*=' expr ; ────────────────────────────────────────────────────────
cs_compound_mul:
	addi	s2, s2, 2
	lw	a0, 0(sp)
	addi	gp, zero, 10		# elws site 10 = elws_cs_mul
	j	emit_lw_sp
elws_cs_mul:
	addi	gp, zero, 17		# push site 17 = push_cs_mul
	j	emit_push_a0
push_cs_mul:
	addi	t6, zero, 0
	addi	gp, zero, 13		# ce site 13 = ce_cs_mul
	j	compile_expr_p
ce_cs_mul:
	addi	gp, zero, 17		# pop site 17 = pop_cs_mul
	j	emit_pop_t0
pop_cs_mul:
	addi	gp, zero, 1		# emul site 1 = emul_cs_mul_ret
	j	emit_mul
emul_cs_mul_ret:
	lw	a0, 0(sp)
	addi	sp, sp, 4
	addi	gp, zero, 14		# esws site 14 = esws_cs_mul
	j	emit_sw_sp
esws_cs_mul:
	addi	gp, zero, 15
	j	skip_ws

# ── IDENT '/=' expr ; ────────────────────────────────────────────────────────
cs_compound_div:
	addi	s2, s2, 2
	lw	a0, 0(sp)
	addi	gp, zero, 11		# elws site 11 = elws_cs_div
	j	emit_lw_sp
elws_cs_div:
	addi	gp, zero, 18		# push site 18 = push_cs_div
	j	emit_push_a0
push_cs_div:
	addi	t6, zero, 0
	addi	gp, zero, 14		# ce site 14 = ce_cs_div
	j	compile_expr_p
ce_cs_div:
	addi	gp, zero, 18		# pop site 18 = pop_cs_div
	j	emit_pop_t0
pop_cs_div:
	addi	gp, zero, 2		# edmb site 2 = edmb_cs_div_ret
	j	emit_divmod_body
edmb_cs_div_ret:
	lui	a0, 0x30
	addi	a0, a0, 0x513
	addi	gp, zero, 18		# ecw site 18 = ecw_cs_div_mv
	j	emit_cmp_word
ecw_cs_div_mv:
	lw	a0, 0(sp)
	addi	sp, sp, 4
	addi	gp, zero, 15		# esws site 15 = esws_cs_div
	j	emit_sw_sp
esws_cs_div:
	addi	gp, zero, 15
	j	skip_ws

# ── IDENT '%=' expr ; ────────────────────────────────────────────────────────
cs_compound_mod:
	addi	s2, s2, 2
	lw	a0, 0(sp)
	addi	gp, zero, 12		# elws site 12 = elws_cs_mod
	j	emit_lw_sp
elws_cs_mod:
	addi	gp, zero, 19		# push site 19 = push_cs_mod
	j	emit_push_a0
push_cs_mod:
	addi	t6, zero, 0
	addi	gp, zero, 15		# ce site 15 = ce_cs_mod
	j	compile_expr_p
ce_cs_mod:
	addi	gp, zero, 19		# pop site 19 = pop_cs_mod
	j	emit_pop_t0
pop_cs_mod:
	addi	gp, zero, 3		# edmb site 3 = edmb_cs_mod_ret
	j	emit_divmod_body
edmb_cs_mod_ret:
	lui	a0, 0x38
	addi	a0, a0, 0x513
	addi	gp, zero, 19		# ecw site 19 = ecw_cs_mod_mv
	j	emit_cmp_word
ecw_cs_mod_mv:
	lw	a0, 0(sp)
	addi	sp, sp, 4
	addi	gp, zero, 16		# esws site 16 = esws_cs_mod
	j	emit_sw_sp
esws_cs_mod:
	addi	gp, zero, 15
	j	skip_ws

# ── IDENT '++' ; (postfix, value discarded) ──────────────────────────────────
cs_ident_post_inc:
	addi	s2, s2, 2
	lw	a0, 0(sp)
	addi	gp, zero, 1		# elws site 1 = elws_cs_inc_stmt
	j	emit_lw_sp

# ── IDENT '--' ; (postfix, value discarded) ──────────────────────────────────
cs_ident_post_dec:
	addi	s2, s2, 2
	lw	a0, 0(sp)
	addi	gp, zero, 2		# elws site 2 = elws_cs_dec_stmt
	j	emit_lw_sp

# Shared tail for '++x;' / 'x++;' (load already emitted, offset at 0(sp)).
elws_cs_inc_stmt:
	addi	gp, zero, 3		# eaa1 site 3 = eaa1_cs_inc_stmt
	j	emit_addi_a0_1
eaa1_cs_inc_stmt:
	lw	a0, 0(sp)
	addi	sp, sp, 4
	addi	gp, zero, 5		# esws site 5 = esws_cs_inc_stmt
	j	emit_sw_sp
esws_cs_inc_stmt:
	addi	gp, zero, 15
	j	skip_ws

# Shared tail for '--x;' / 'x--;'.
elws_cs_dec_stmt:
	addi	gp, zero, 3		# eaam1 site 3 = eaam1_cs_dec_stmt
	j	emit_addi_a0_m1
eaam1_cs_dec_stmt:
	lw	a0, 0(sp)
	addi	sp, sp, 4
	addi	gp, zero, 6		# esws site 6 = esws_cs_dec_stmt
	j	emit_sw_sp
esws_cs_dec_stmt:
	addi	gp, zero, 15
	j	skip_ws

# Shared trailing-';' check for every path that jumps to skip_ws site 15.
# Reached after a compound assign has popped its intermediate stack frame,
# so sp = entry_sp - 4 (compile_stmt's frame only). Fallback goes to cs_fb.
sw_cs_semi_stmt:
	bge	s2, s3, cs_fb
	lbu	t0, 0(s2)
	addi	t1, zero, ';'
	bne	t0, t1, cs_fb
	addi	s2, s2, 1
	j	cs_done

# ── '++' IDENT ; (bare prefix statement) ─────────────────────────────────────
cs_chk_pre_pp:
	addi	t2, s2, 1
	bge	t2, s3, cs_fb
	lbu	t0, 0(t2)
	addi	t1, zero, '+'
	bne	t0, t1, cs_fb
	addi	s2, s2, 2
	addi	gp, zero, 16		# skip_ws site 16 = sw_cs_pp_id
	j	skip_ws
sw_cs_pp_id:
	addi	gp, zero, 2		# parse_ident site 2 = pi_cs_pp
	j	parse_ident
pi_cs_pp:
	# '++y;' reads y then writes — y must already exist.
	addi	gp, zero, 2		# lookup site 2 = la_cs_pp
	j	lookup
la_cs_pp:
	addi	sp, sp, -4
	sw	a0, 0(sp)
	addi	gp, zero, 1		# elws site 1 = elws_cs_inc_stmt (shared)
	j	emit_lw_sp

# ── '--' IDENT ; (bare prefix statement) ─────────────────────────────────────
cs_chk_pre_mm:
	addi	t2, s2, 1
	bge	t2, s3, cs_fb
	lbu	t0, 0(t2)
	addi	t1, zero, '-'
	bne	t0, t1, cs_fb
	addi	s2, s2, 2
	addi	gp, zero, 17		# skip_ws site 17 = sw_cs_mm_id
	j	skip_ws
sw_cs_mm_id:
	addi	gp, zero, 3		# parse_ident site 3 = pi_cs_mm
	j	parse_ident
pi_cs_mm:
	# '--y;' reads y then writes — y must already exist.
	addi	gp, zero, 3		# lookup site 3 = la_cs_mm
	j	lookup
la_cs_mm:
	addi	sp, sp, -4
	sw	a0, 0(sp)
	addi	gp, zero, 2		# elws site 2 = elws_cs_dec_stmt (shared)
	j	emit_lw_sp

cs_star:
	addi	s2, s2, 1
	addi	t6, zero, 1
	addi	gp, zero, 1
	j	compile_expr_p
ce_cs_addr1:
	# Push the address onto the compiled program's stack.
	addi	gp, zero, 1		# push site 1 = push_cs_star
	j	emit_push_a0
push_cs_star:

	addi	gp, zero, 7
	j	skip_ws
sw_cs_eq2:
	lbu	t0, 0(s2)
	addi	t1, zero, '='
	bne	t0, t1, cs_fb
	addi	s2, s2, 1

	addi	t6, zero, 0
	addi	gp, zero, 2
	j	compile_expr_p
ce_cs_val1:
	# Pop the address into t0 in the compiled program, then sw.
	addi	gp, zero, 1		# pop site 1 = pop_cs_star
	j	emit_pop_t0
pop_cs_star:
	addi	gp, zero, 0		# esw site 0 = esw_ret
	j	emit_sw_deref
esw_ret:

	addi	gp, zero, 8
	j	skip_ws
sw_cs_semi2:
	lbu	t0, 0(s2)
	addi	t1, zero, ';'
	bne	t0, t1, cs_fb
	addi	s2, s2, 1
	j	cs_done

cs_at:
	addi	s2, s2, 1
	addi	t6, zero, 1
	addi	gp, zero, 3
	j	compile_expr_p
ce_cs_addr2:
	addi	gp, zero, 2		# push site 2 = push_cs_at
	j	emit_push_a0
push_cs_at:

	addi	gp, zero, 9
	j	skip_ws
sw_cs_eq3:
	lbu	t0, 0(s2)
	addi	t1, zero, '='
	bne	t0, t1, cs_fb
	addi	s2, s2, 1

	addi	t6, zero, 0
	addi	gp, zero, 4
	j	compile_expr_p
ce_cs_val2:
	addi	gp, zero, 2		# pop site 2 = pop_cs_at
	j	emit_pop_t0
pop_cs_at:
	addi	gp, zero, 0		# esb site 0 = esb_ret
	j	emit_sb_deref
esb_ret:

	addi	gp, zero, 10
	j	skip_ws
sw_cs_semi3:
	lbu	t0, 0(s2)
	addi	t1, zero, ';'
	bne	t0, t1, cs_fb
	addi	s2, s2, 1
	j	cs_done

cs_bad:
	# IDENT-path fallback. la_cs pushed +4 on top of compile_stmt's entry
	# frame (4 bytes), so sp = entry_sp - 8 here. Pop la_cs's slot and
	# fall through to cs_fb, which expects sp = entry_sp - 4.
	addi	sp, sp, 4
	# Fall through.

cs_fb:
	# Expression-statement fallback. sp = entry_sp - 4, with the entry s2
	# saved at 0(sp). Rewind s2, call compile_expr_p, expect trailing ';'.
	lw	s2, 0(sp)
	# Mark the upcoming expression's top-level value as discarded so
	# cep_pre_tern can skip a one-armed ternary's dead false-tail.
	# The flag is only consulted at the moment cep_pre_tern emits its
	# tail; it doesn't propagate into sub-expressions of operators.
	lla	t0, expr_value_discarded
	addi	t1, zero, 1
	sw	t1, 0(t0)
	addi	t6, zero, 0
	addi	gp, zero, 24		# compile_expr site 24 = ce_cs_exprstmt
	j	compile_expr_p
ce_cs_exprstmt:
	lla	t0, expr_value_discarded
	sw	zero, 0(t0)
	# If ';' follows, consume it. If expression ended with '}' (block/loop/for),
	# the semicolon is optional.
	bge	s2, s3, cs_exprstmt_check_brace
	lbu	t0, 0(s2)
	addi	t1, zero, ';'
	bne	t0, t1, cs_exprstmt_check_brace
	addi	s2, s2, 1
	j	cs_done
cs_exprstmt_check_brace:
	lla	t0, last_was_brace
	lw	t1, 0(t0)
	bnez	t1, cs_done
	j	cs_halt

cs_halt:
	addi	a0, zero, 1		# err 1: expected ';'
	j	report_err
cs_bad_immut_reassign:
	lla	t0, ident_start
	lw	s2, 0(t0)
	addi	a0, zero, 55		# err 55: cannot reassign immutable
	j	report_err

cs_done:
	addi	sp, sp, 4		# pop compile_stmt's entry frame
	j	cs_after

# ══════════════════════════════════════════════════════════════════════════════
# cs_array_decl_scan / cs_array_decl_go — peek for an array declaration
# (`@IDENT[LIT];` / `#IDENT[LIT];` / `*IDENT[LIT];`) and commit on match.
#
# Inputs: t6 = stride (1, 2, or 4), s2 = prefix char ('@', '#', '*')
# On match: jumps to cs_array_decl_go (actual parse & emit).
# On mismatch: jumps to cs_normal_dispatch (falls into the existing * / @ /
#   letter-IDENT dispatch, which handles writes, reads, compound assigns).
# ══════════════════════════════════════════════════════════════════════════════
cs_array_decl_scan:
	addi	t0, s2, 1		# cursor past prefix
cad_s1:
	bge	t0, s3, scan_decl_fail
	lbu	t1, 0(t0)
	addi	t2, zero, 33
	bge	t1, t2, cad_id_start
	addi	t0, t0, 1
	j	cad_s1
cad_id_start:
	# Must start with letter or underscore.
	addi	t2, zero, '_'
	beq	t1, t2, cad_id_loop
	addi	t2, zero, 'a'
	blt	t1, t2, cad_id_chk_uc
	addi	t2, zero, 123
	blt	t1, t2, cad_id_loop
cad_id_chk_uc:
	addi	t2, zero, 'A'
	blt	t1, t2, scan_decl_fail
	addi	t2, zero, 91
	bge	t1, t2, scan_decl_fail
cad_id_loop:
	addi	t0, t0, 1
	bge	t0, s3, scan_decl_fail
	lbu	t1, 0(t0)
	addi	t2, zero, 'a'
	blt	t1, t2, cad_id_chk_uc2
	addi	t2, zero, 123
	blt	t1, t2, cad_id_loop
cad_id_chk_uc2:
	addi	t2, zero, 'A'
	blt	t1, t2, cad_id_chk_dig
	addi	t2, zero, 91
	blt	t1, t2, cad_id_loop
cad_id_chk_dig:
	addi	t2, zero, '0'
	blt	t1, t2, cad_id_chk_us
	addi	t2, zero, 58
	blt	t1, t2, cad_id_loop
cad_id_chk_us:
	addi	t2, zero, '_'
	beq	t1, t2, cad_id_loop
	# Done with ident.
cad_after_id:
cad_s2:
	bge	t0, s3, scan_decl_fail
	lbu	t1, 0(t0)
	addi	t2, zero, 33
	bge	t1, t2, cad_lbracket
	addi	t0, t0, 1
	j	cad_s2
cad_lbracket:
	addi	t2, zero, '['
	bne	t1, t2, scan_decl_fail
	addi	t0, t0, 1
cad_s3:
	bge	t0, s3, scan_decl_fail
	lbu	t1, 0(t0)
	addi	t2, zero, 33
	bge	t1, t2, cad_digit
	addi	t0, t0, 1
	j	cad_s3
cad_digit:
	# We've scanned `<prefix> IDENT [` and now expect a digit for the
	# size literal. If the next char isn't a digit, the user either wrote
	# an expression like `@arr[x]` (which is valid when `arr` is defined)
	# or an illegal array declaration with a non-literal size. Branch to
	# the diagnostic probe which distinguishes the two.
	addi	t2, zero, '0'
	blt	t1, t2, cad_probe_nonlit
	addi	t2, zero, 58
	bge	t1, t2, cad_probe_nonlit
cad_d_loop:
	addi	t0, t0, 1
	bge	t0, s3, scan_decl_fail
	lbu	t1, 0(t0)
	# Allow digits and hex letters for 0x literals.
	addi	t2, zero, '0'
	blt	t1, t2, cad_chk_xaf
	addi	t2, zero, 58
	blt	t1, t2, cad_d_loop
cad_chk_xaf:
	addi	t2, zero, 'a'
	blt	t1, t2, cad_chk_xAF
	addi	t2, zero, 123
	blt	t1, t2, cad_d_loop
cad_chk_xAF:
	addi	t2, zero, 'A'
	blt	t1, t2, cad_after_lit
	addi	t2, zero, 91
	blt	t1, t2, cad_d_loop
cad_after_lit:
cad_s4:
	bge	t0, s3, scan_decl_fail
	lbu	t1, 0(t0)
	addi	t2, zero, 33
	bge	t1, t2, cad_rbracket
	addi	t0, t0, 1
	j	cad_s4
cad_rbracket:
	addi	t2, zero, ']'
	bne	t1, t2, scan_decl_fail
	addi	t0, t0, 1
cad_s5:
	bge	t0, s3, scan_decl_fail
	lbu	t1, 0(t0)
	addi	t2, zero, 33
	bge	t1, t2, cad_semi
	addi	t0, t0, 1
	j	cad_s5
cad_semi:
	addi	t2, zero, ';'
	bne	t1, t2, scan_decl_fail
	# All match. Set a0 = 1; dispatch via gp to the caller's result label.
	addi	a0, zero, 1
	j	scan_decl_disp
scan_decl_fail:
	addi	a0, zero, 0
	j	scan_decl_disp
scan_decl_disp:
	bnez	gp, sdd_1
	j	scan_ret_stmt
sdd_1:
	addi	gp, gp, -1
	bnez	gp, sdd_2
	j	scan_ret_blk
sdd_2:
	addi	gp, gp, -1
	bnez	gp, sdd_3
	j	scan_ret_struct
sdd_3:
	j	halt_err

# ── cad_probe_nonlit — diagnostic probe for `<prefix> IDENT [<non-digit>` ──
# The scan got far enough to know this LOOKED like an array declaration
# (prefix + ident + '['), but the content inside '[' isn't a digit. Two
# cases:
#   1. IDENT is already a variable → this is an indexed deref expression
#      like `@arr[i]`. Fall back to the caller's expression path.
#   2. IDENT is new → the user was trying to declare an array but used a
#      non-literal size. Emit a dedicated error.
#
# Caller context: gp holds the scan-site id (0 = statement, 1 = block).
# We save gp and s2 on entry so we can rewind and dispatch appropriately.
cad_probe_nonlit:
	addi	sp, sp, -8
	sw	gp, 0(sp)
	sw	s2, 4(sp)		# s2 is at the prefix char
	addi	s2, s2, 1
	addi	gp, zero, 55		# skip_ws site 55 = sw_cad_probe
	j	skip_ws
sw_cad_probe:
	addi	gp, zero, 9		# parse_ident site 9 = pi_cad_probe
	j	parse_ident
pi_cad_probe:
	# Silent lookup in the variable symtab.
	addi	t0, s8, -40
cad_probe_scan:
	blt	t0, s7, cad_probe_not_def
	addi	t1, zero, 0
cad_probe_cmp:
	addi	t2, zero, 32
	beq	t1, t2, cad_probe_defined
	add	t3, t0, t1
	lbu	t4, 0(t3)
	blt	t1, s11, cad_probe_in_tok
	bnez	t4, cad_probe_next
	addi	t1, t1, 1
	j	cad_probe_cmp
cad_probe_in_tok:
	add	t5, s10, t1
	lbu	t6, 0(t5)
	bne	t4, t6, cad_probe_next
	addi	t1, t1, 1
	j	cad_probe_cmp
cad_probe_next:
	addi	t0, t0, -40
	j	cad_probe_scan
cad_probe_defined:
	# It's a real variable — this is an expression access. Restore s2
	# to the prefix and fall back based on the original scan context.
	lw	gp, 0(sp)
	lw	s2, 4(sp)
	addi	sp, sp, 8
	bnez	gp, cad_probe_def_blk
	j	cs_normal_dispatch
cad_probe_def_blk:
	j	blk_compile_expr
cad_probe_not_def:
	# The ident is new — declaration attempt with a non-literal size.
	# Point at the ident start for a clean error column.
	lw	gp, 0(sp)
	addi	sp, sp, 8
	lla	t0, ident_start
	lw	s2, 0(t0)
	addi	a0, zero, 46		# err 46: array size must be a literal
	j	report_err

# ── cs_array_decl_go — commit: parse the declaration, allocate, emit init ──
# Stride is still in t6. s2 is still at the prefix char (unchanged by scan).
# gp = return-site id (0 = cs_done, 1 = ct_blk_loop).
#
# Frame (24 bytes):
#    0(sp): stride (1/2/4)
#    4(sp): element count (N)
#    8(sp): total block bytes (N*stride rounded to 4)
#   12(sp): block offset within frame
#   16(sp): variable's own slot offset (returned by la_new)
#   20(sp): saved caller gp (for exit dispatch)
cs_array_decl_go:
	addi	sp, sp, -24
	sw	t6, 0(sp)
	sw	gp, 20(sp)
	addi	s2, s2, 1		# consume prefix char
	addi	gp, zero, 50		# skip_ws site 50 = sw_cs_decl_name
	j	skip_ws
sw_cs_decl_name:
	addi	gp, zero, 8		# parse_ident site 8 = pi_cs_decl
	j	parse_ident
pi_cs_decl:
	# Ensure the name is fresh in the variable symtab.
	addi	t0, s7, 0
cad_chk_exist:
	beq	t0, s8, cad_name_ok
	addi	t1, zero, 0
cad_ce_cmp:
	addi	t2, zero, 32
	beq	t1, t2, cad_bad_already_defined
	add	t3, t0, t1
	lbu	t4, 0(t3)
	blt	t1, s11, cad_ce_in_tok
	bnez	t4, cad_ce_next
	addi	t1, t1, 1
	j	cad_ce_cmp
cad_ce_in_tok:
	add	t5, s10, t1
	lbu	t6, 0(t5)
	bne	t4, t6, cad_ce_next
	addi	t1, t1, 1
	j	cad_ce_cmp
cad_ce_next:
	addi	t0, t0, 40
	j	cad_chk_exist
cad_name_ok:
	# Consume '[' (already confirmed by peek; sanity-re-check).
	addi	gp, zero, 51		# skip_ws site 51 = sw_cs_decl_lbrack
	j	skip_ws
sw_cs_decl_lbrack:
	addi	s2, s2, 1		# consume '['
	addi	gp, zero, 52		# skip_ws site 52 = sw_cs_decl_lit
	j	skip_ws
sw_cs_decl_lit:
	addi	gp, zero, 1
	j	parse_num
pn_cs_decl:
	sw	a0, 4(sp)		# N
	addi	gp, zero, 53		# skip_ws site 53 = sw_cs_decl_rbrack
	j	skip_ws
sw_cs_decl_rbrack:
	addi	s2, s2, 1		# consume ']'
	addi	gp, zero, 54		# skip_ws site 54 = sw_cs_decl_semi
	j	skip_ws
sw_cs_decl_semi:
	addi	s2, s2, 1		# consume ';'

	# total = N * stride, rounded up to 4 bytes.
	#
	# The old O(N) add-loop multiply wrapped silently on huge N and took
	# forever besides. Stride can be 1/2/4 for primitive arrays or up to
	# 64 for struct arrays (max 16 fields × 4 bytes), so we can't just use
	# a power-of-two shift. Instead: reject N ≥ 2^20 upfront (nothing
	# usable comes from a frame bigger than the 2^20 cap), then do a
	# shift-add multiply that processes each bit of stride and bails as
	# soon as the running product crosses the 2^20 cap.
	lw	t0, 4(sp)		# N
	lw	t1, 0(sp)		# stride
	lui	t4, 0x100		# 2^20
	bgeu	t0, t4, cad_bad_frame_too_big
	addi	t2, zero, 0		# product
	addi	t3, t0, 0		# N << bit_index
cad_mul_loop:
	beqz	t1, cad_mul_done
	andi	t5, t1, 1
	beqz	t5, cad_mul_next
	add	t2, t2, t3
	bgeu	t2, t4, cad_bad_frame_too_big
cad_mul_next:
	slli	t3, t3, 1
	srli	t1, t1, 1
	j	cad_mul_loop
cad_mul_done:
	addi	t2, t2, 3
	andi	t2, t2, -4
	sw	t2, 8(sp)

	# Block offset = current s9; advance s9 past block.
	addi	t3, s9, 0
	sw	t3, 12(sp)
	add	s9, s9, t2

	# Allocate the array-variable entry via la_new. s10/s11 still hold
	# the name parsed earlier.
	addi	gp, zero, 6		# lookup_or_alloc site 6 = la_cs_decl
	j	la_new
la_cs_decl:
	sw	a0, 16(sp)		# variable slot offset
	# Array declarations are always mutable.
	lla	t0, last_ident_entry
	lw	t0, 0(t0)
	addi	t1, zero, 1
	sb	t1, 37(t0)

	# Emit `a0 = fp + block_offset`. For small offsets (<2048) use a single
	# `addi a0, fp, imm`. For larger offsets, use a 3-instruction sequence
	# `lui t0, hi20; addi t0, t0, lo12; add a0, fp, t0`.
	lw	t3, 12(sp)		# block offset
	addi	t4, zero, 2048
	bge	t3, t4, cad_emit_big
	# Small: single addi a0, fp, imm (word 0x00040513 | imm<<20)
	lui	a0, 0x40
	addi	a0, a0, 0x513
	andi	t4, t3, 0xFFF
	slli	t4, t4, 20
	or	a0, a0, t4
	addi	gp, zero, 78		# emit_word site 78 = ew_cs_decl_addi
	j	emit_word
cad_emit_big:
	# Big: lui t0, hi20; addi t0, t0, lo12; add a0, fp, t0
	# Bounds check for 12 bytes (3 words) of inline emission.
	addi	t6, s5, 12
	lla	t0, bin_end
	lw	t0, 0(t0)
	bgeu	t6, t0, bin_full
	addi	t0, zero, 1
	slli	t0, t0, 11		# 0x800
	add	t1, t3, t0
	srai	t1, t1, 12		# hi20
	slli	t2, t1, 12		# hi20 << 12
	sub	t4, t3, t2		# lo12
	# Emit lui t0, hi20  (base 0x002B7)
	lui	a0, 0
	addi	a0, a0, 0x2B7
	or	a0, a0, t2
	sw	a0, 0(s5)
	addi	s5, s5, 4
	# Emit addi t0, t0, lo12  (base 0x00028293)
	andi	t2, t4, 0xFFF
	slli	t2, t2, 20
	lui	a0, 0x28
	addi	a0, a0, 0x293
	or	a0, a0, t2
	sw	a0, 0(s5)
	addi	s5, s5, 4
	# Emit add a0, fp, t0  = 0x00540533
	#   opcode 0x33, rd=10, f3=0, rs1=8, rs2=5, f7=0
	#   word = 0x33 | (10<<7) | (8<<15) | (5<<20) = 0x33 | 0x500 | 0x40000 | 0x500000 = 0x00540533
	lui	a0, 0x540
	addi	a0, a0, 0x533
	sw	a0, 0(s5)
	addi	s5, s5, 4
ew_cs_decl_addi:
	# Emit `sw a0, <var_slot>(fp)` via emit_sw_sp.
	lw	a0, 16(sp)
	addi	gp, zero, 24		# esws site 24 = esws_cs_decl
	j	emit_sw_sp
esws_cs_decl:
	lw	gp, 20(sp)
	addi	sp, sp, 24
	bnez	gp, decl_exit_blk
	j	cs_done
decl_exit_blk:
	j	ct_blk_loop

cad_bad_already_defined:
	addi	a0, zero, 45		# err 45: variable already defined
	j	report_err
cad_bad_frame_too_big:
	addi	a0, zero, 40		# err 40: frame too large
	j	report_err

# ══════════════════════════════════════════════════════════════════════════════
# emit_mul — emit the 11-instruction inline signed-multiply sequence.
#
# Runtime contract (i.e. what the emitted instructions expect at runtime):
#   t0 = LHS (just popped by caller), a0 = RHS.
#   On exit: a0 = product (low 32 bits). t1, t2, t3, t4 clobbered.
#
# Emission works by looping over `mul_code` (a table of 11 pre-assembled
# instruction words) and calling emit_word once per entry. Signed and
# unsigned multiplication produce identical low-32-bit results in two's
# complement, so a single shift-and-add loop handles both.
#
# Multi-caller. Call sites:
#   0: emul_cmul_ret    (compile_mul '*' loop)
#   1: emul_cs_mul_ret  (compile_stmt '*=')
#   2: emul_cep_ret     (compile_expr_p '*' Pratt op)
# ══════════════════════════════════════════════════════════════════════════════
emit_mul:
	addi	sp, sp, -4
	sw	gp, 0(sp)
	# The mul template hard-codes t0 as the LHS source. With the s-reg
	# value-stack codegen the LHS lives in popped_src_reg = sN, so we
	# emit a `mv t0, sN` prefix inline (bypassing emit_word for one
	# instruction).
	addi	t2, s5, 4
	lla	t3, bin_end
	lw	t3, 0(t3)
	bgeu	t2, t3, bin_full
	lla	t0, popped_src_reg
	lw	t0, 0(t0)
	slli	t0, t0, 15
	lui	a0, 0
	addi	a0, a0, 0x293		# addi t0, x0, 0 → mv t0, sN
	or	a0, a0, t0
	sw	a0, 0(s5)
	addi	s5, s5, 4
	lla	t0, mul_code
	lla	t1, mul_code_end
emul_loop:
	bge	t0, t1, emul_done
	lw	a0, 0(t0)
	addi	sp, sp, -8
	sw	t0, 0(sp)
	sw	t1, 4(sp)
	addi	gp, zero, 26		# ew site 26 = ew_mul
	j	emit_word
ew_mul:
	lw	t0, 0(sp)
	lw	t1, 4(sp)
	addi	sp, sp, 8
	addi	t0, t0, 4
	j	emul_loop
emul_done:
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	emit_mul_disp

emit_mul_disp:
	bnez	gp, emul_d1
	j	emul_cmul_ret
emul_d1:
	addi	gp, gp, -1
	bnez	gp, emul_d2
	j	emul_cs_mul_ret
emul_d2:
	addi	gp, gp, -1
	bnez	gp, emul_d3
	j	emul_cep_ret
emul_d3:
	j	emul_ct_sa

# The compiled-program mul loop template. Each entry is one RV32I instruction.
# Offsets inside the template (relative to the start of the emitted block):
#    0:  addi t1, a0, 0       # t1 = multiplier (RHS)
#    4:  addi t2, t0, 0       # t2 = multiplicand (LHS)
#    8:  addi a0, zero, 0     # a0 = accumulator
#   12:  addi t3, zero, 32    # t3 = bit counter
#   16:  andi t4, t1, 1       ← LOOP
#   20:  beq  t4, zero, +8    # skip add if low bit of multiplier is 0
#   24:  add  a0, a0, t2
#   28:  slli t2, t2, 1       (skip lands here)
#   32:  srli t1, t1, 1
#   36:  addi t3, t3, -1
#   40:  bnez t3, -24         # branch back to LOOP (offset -24)
#   44:  (fall through: a0 holds product)
mul_code:
	.word	0x00050313
	.word	0x00028393
	.word	0x00000513
	.word	0x02000E13
	.word	0x00137E93
	.word	0x000E8463
	.word	0x00750533
	.word	0x00139393
	.word	0x00135313
	.word	0xFFFE0E13
	.word	0xFE0E14E3
mul_code_end:

# ══════════════════════════════════════════════════════════════════════════════
# emit_divmod_body — emit the 24-instruction shared divmod body.
#
# Runtime contract:
#   t0 = LHS (dividend), a0 = RHS (divisor).
#   On exit: t1 = signed quotient, t2 = signed remainder.
#   Clobbers: t0, a0, t3, t4, t5, t6.
#
# The body does: save signs → absolute value → unsigned shift-and-subtract
# division loop → sign fixup for quotient (xor of signs) and remainder
# (sign of dividend). After this helper returns, the caller must emit one
# more instruction: either `mv a0, t1` (for /, /=) or `mv a0, t2` (for %, %=).
#
# Divide-by-zero: follows RISC-V M-extension convention (quotient = -1,
# remainder = dividend) because r=0 stays 0 against divisor=0, so all
# 32 quotient bits are set (-1 signed) and r=|dividend| then gets the
# dividend's sign back.
#
# Multi-caller. Call sites:
#   0: edmb_cdiv_ret     (compile_mul '/' loop)
#   1: edmb_cmod_ret     (compile_mul '%' loop)
#   2: edmb_cs_div_ret   (compile_stmt '/=')
#   3: edmb_cs_mod_ret   (compile_stmt '%=')
#   4: edmb_cep_div_ret  (compile_expr_p '/' Pratt op)
#   5: edmb_cep_mod_ret  (compile_expr_p '%' Pratt op)
# ══════════════════════════════════════════════════════════════════════════════
emit_divmod_body:
	addi	sp, sp, -4
	sw	gp, 0(sp)
	# Same as emit_mul: the divmod template expects the dividend in t0,
	# but the value-stack scheme has it in sN. Emit a `mv t0, sN` prefix.
	addi	t2, s5, 4
	lla	t3, bin_end
	lw	t3, 0(t3)
	bgeu	t2, t3, bin_full
	lla	t0, popped_src_reg
	lw	t0, 0(t0)
	slli	t0, t0, 15
	lui	a0, 0
	addi	a0, a0, 0x293
	or	a0, a0, t0
	sw	a0, 0(s5)
	addi	s5, s5, 4
	lla	t0, divmod_code
	lla	t1, divmod_code_end
edmb_loop:
	bge	t0, t1, edmb_done
	lw	a0, 0(t0)
	addi	sp, sp, -8
	sw	t0, 0(sp)
	sw	t1, 4(sp)
	addi	gp, zero, 27		# ew site 27 = ew_divmod
	j	emit_word
ew_divmod:
	lw	t0, 0(sp)
	lw	t1, 4(sp)
	addi	sp, sp, 8
	addi	t0, t0, 4
	j	edmb_loop
edmb_done:
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	emit_divmod_body_disp

emit_divmod_body_disp:
	bnez	gp, edmb_d1
	j	edmb_cdiv_ret
edmb_d1:
	addi	gp, gp, -1
	bnez	gp, edmb_d2
	j	edmb_cmod_ret
edmb_d2:
	addi	gp, gp, -1
	bnez	gp, edmb_d3
	j	edmb_cs_div_ret
edmb_d3:
	addi	gp, gp, -1
	bnez	gp, edmb_d4
	j	edmb_cs_mod_ret
edmb_d4:
	addi	gp, gp, -1
	bnez	gp, edmb_d5
	j	edmb_cep_div_ret
edmb_d5:
	j	edmb_cep_mod_ret

# The compiled-program divmod loop template (24 instructions).
# Layout (byte offsets inside the emitted block):
#    0:  srai  t5, t0, 31         # t5 = lhs sign mask
#    4:  srai  t6, a0, 31         # t6 = rhs sign mask
#    8:  xor   t0, t0, t5
#   12:  sub   t0, t0, t5         # t0 = |LHS|
#   16:  xor   a0, a0, t6
#   20:  sub   a0, a0, t6         # a0 = |RHS|
#   24:  addi  t1, zero, 0        # q = 0
#   28:  addi  t2, zero, 0        # r = 0
#   32:  addi  t3, zero, 32       # counter
#   36:  srli  t4, t0, 31         ← LOOP
#   40:  slli  t2, t2, 1          # r <<= 1
#   44:  or    t2, t2, t4         # r |= top bit
#   48:  slli  t0, t0, 1          # dividend <<= 1
#   52:  slli  t1, t1, 1          # q <<= 1
#   56:  bltu  t2, a0, +12        # if r<divisor skip sub/set
#   60:  sub   t2, t2, a0
#   64:  addi  t1, t1, 1
#   68:  addi  t3, t3, -1
#   72:  bnez  t3, -36            # loop back
#   76:  xor   t4, t5, t6         # quotient sign = lhs_sign ^ rhs_sign
#   80:  xor   t1, t1, t4
#   84:  sub   t1, t1, t4         # signed quotient
#   88:  xor   t2, t2, t5         # remainder sign = lhs_sign
#   92:  sub   t2, t2, t5         # signed remainder
divmod_code:
	.word	0x41F2DF13
	.word	0x41F55F93
	.word	0x01E2C2B3
	.word	0x41E282B3
	.word	0x01F54533
	.word	0x41F50533
# udivmod_start: unsigned divmod body starts here. Re-used by emit_udivmod_body
# for '/u' and '%u'. The 13 words in this range compute q = t0/a0, r = t0%a0
# using an unsigned shift-and-subtract loop; signed wrappers around the edge
# (above and below) handle absolute value and sign fixup.
udivmod_start:
	.word	0x00000313
	.word	0x00000393
	.word	0x02000E13
	.word	0x01F2DE93
	.word	0x00139393
	.word	0x01D3E3B3
	.word	0x00129293
	.word	0x00131313
	.word	0x00A3E663
	.word	0x40A383B3
	.word	0x00130313
	.word	0xFFFE0E13
	.word	0xFC0E1EE3
udivmod_end:
	.word	0x01FF4EB3
	.word	0x01D34333
	.word	0x41D30333
	.word	0x01E3C3B3
	.word	0x41E383B3
divmod_code_end:

# ══════════════════════════════════════════════════════════════════════════════
# emit_udivmod_body — emit the 13-instruction unsigned divmod body.
#
# Runtime contract:
#   t0 = LHS (dividend), a0 = RHS (divisor), both interpreted as unsigned.
#   On exit: t1 = quotient, t2 = remainder (both unsigned).
#   Clobbers: t0, a0, t3, t4.
#
# Emits the middle range of divmod_code (from udivmod_start to udivmod_end),
# which is exactly the init + unsigned shift-and-subtract loop with no sign
# handling. After this helper, the caller emits one `mv a0, t1` (for /u) or
# `mv a0, t2` (for %u).
#
# Multi-caller. Call sites:
#   0: eudmb_cdivu_ret    (compile_mul '/u' loop)
#   1: eudmb_cmodu_ret    (compile_mul '%u' loop)
#   2: eudmb_cep_divu_ret (compile_expr_p '/u' Pratt op)
#   3: eudmb_cep_modu_ret (compile_expr_p '%u' Pratt op)
# ══════════════════════════════════════════════════════════════════════════════
emit_udivmod_body:
	addi	sp, sp, -4
	sw	gp, 0(sp)
	# Same prefix as emit_divmod_body: materialize sN into t0.
	addi	t2, s5, 4
	lla	t3, bin_end
	lw	t3, 0(t3)
	bgeu	t2, t3, bin_full
	lla	t0, popped_src_reg
	lw	t0, 0(t0)
	slli	t0, t0, 15
	lui	a0, 0
	addi	a0, a0, 0x293
	or	a0, a0, t0
	sw	a0, 0(s5)
	addi	s5, s5, 4
	lla	t0, udivmod_start
	lla	t1, udivmod_end
eudmb_loop:
	bge	t0, t1, eudmb_done
	lw	a0, 0(t0)
	addi	sp, sp, -8
	sw	t0, 0(sp)
	sw	t1, 4(sp)
	addi	gp, zero, 28		# ew site 28 = ew_udivmod
	j	emit_word
ew_udivmod:
	lw	t0, 0(sp)
	lw	t1, 4(sp)
	addi	sp, sp, 8
	addi	t0, t0, 4
	j	eudmb_loop
eudmb_done:
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	emit_udivmod_body_disp

emit_udivmod_body_disp:
	bnez	gp, eudmb_d1
	j	eudmb_cdivu_ret
eudmb_d1:
	addi	gp, gp, -1
	bnez	gp, eudmb_d2
	j	eudmb_cmodu_ret
eudmb_d2:
	addi	gp, gp, -1
	bnez	gp, eudmb_d3
	j	eudmb_cep_divu_ret
eudmb_d3:
	j	eudmb_cep_modu_ret

# ══════════════════════════════════════════════════════════════════════════════
# patch_jtype — OR the J-type offset bits for `(t6 - t5)` into the word at t5.
#
# Inputs (famc registers):
#   t5 = address of the jal instruction in famc memory (inside compiled bin)
#   t6 = target address in famc memory
# Clobbers: t0, t1, t2
#
# The placeholder was emitted with imm=0, so OR-ing the offset bits into the
# existing word is sufficient (no need to clear first). J-type's 21-bit signed
# range gives ±1 MiB reach, comfortably more than a single RHS will need.
#
# Multi-caller. Call sites:
#   0: pjt_cland_sf  (compile_land — jal to SHORT_FALSE)
#   1: pjt_cland_end (compile_land — jal to END)
#   2: pjt_clor_st   (compile_expr/|| — jal to SHORT_TRUE)
#   3: pjt_clor_end  (compile_expr/|| — jal to END)
#   4: pjt_ctern_else (compile_expr ternary — jal to ELSE block)
#   5: pjt_ctern_end  (compile_expr ternary — jal to END)
#   6: pjt_cep_land_sf  (compile_expr_p '&&' — jal to SHORT_FALSE)
#   7: pjt_cep_land_end (compile_expr_p '&&' — jal to END)
#   8: pjt_cep_lor_st   (compile_expr_p '||' — jal to SHORT_TRUE)
#   9: pjt_cep_lor_end  (compile_expr_p '||' — jal to END)
#  10: pjt_cep_tern_else (compile_expr_p '?' — jal to ELSE)
#  11: pjt_cep_tern_end  (compile_expr_p '?' — jal to END)
# ══════════════════════════════════════════════════════════════════════════════
patch_jtype:
	addi	sp, sp, -4
	sw	gp, 0(sp)
	# Patching a jal creates a new incoming control-flow edge at the
	# patch target. If that target is the current s5 (a join point at
	# the emit cursor) the previous instruction is no longer the sole
	# producer of a0 — clear all leaf markers AND a0_known_zero so
	# downstream peepholes don't act on stale single-path information.
	lla	t0, push_safe_marker
	sw	zero, 0(t0)
	lla	t0, last_li_marker
	sw	zero, 0(t0)
	lla	t0, a0_known_zero
	sw	zero, 0(t0)
	sub	t2, t6, t5		# offset = target - addr
	# J-type range check: 21-bit signed (±1 MiB). Sign-extend bit 20 back
	# up and compare against the original; mismatch means the offset
	# doesn't fit and we'd silently truncate bits.
	slli	t0, t2, 11
	srai	t0, t0, 11
	bne	t0, t2, fix_off_oor
	lw	t0, 0(t5)

	# imm[20] at bit 31
	srli	t1, t2, 20
	andi	t1, t1, 1
	slli	t1, t1, 31
	or	t0, t0, t1

	# imm[19:12] at bits 19:12
	srli	t1, t2, 12
	andi	t1, t1, 0xFF
	slli	t1, t1, 12
	or	t0, t0, t1

	# imm[11] at bit 20
	srli	t1, t2, 11
	andi	t1, t1, 1
	slli	t1, t1, 20
	or	t0, t0, t1

	# imm[10:1] at bits 30:21
	srli	t1, t2, 1
	andi	t1, t1, 0x3FF
	slli	t1, t1, 21
	or	t0, t0, t1

	sw	t0, 0(t5)
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	patch_jtype_disp

patch_jtype_disp:
	bnez	gp, pjt_d1
	j	pjt_cland_sf
pjt_d1:
	addi	gp, gp, -1
	bnez	gp, pjt_d2
	j	pjt_cland_end
pjt_d2:
	addi	gp, gp, -1
	bnez	gp, pjt_d3
	j	pjt_clor_st
pjt_d3:
	addi	gp, gp, -1
	bnez	gp, pjt_d4
	j	pjt_clor_end
pjt_d4:
	addi	gp, gp, -1
	bnez	gp, pjt_d5
	j	pjt_ctern_else
pjt_d5:
	addi	gp, gp, -1
	bnez	gp, pjt_d6
	j	pjt_ctern_end
pjt_d6:
	addi	gp, gp, -1
	bnez	gp, pjt_d7
	j	pjt_cep_land_sf
pjt_d7:
	addi	gp, gp, -1
	bnez	gp, pjt_d8
	j	pjt_cep_land_end
pjt_d8:
	addi	gp, gp, -1
	bnez	gp, pjt_d9
	j	pjt_cep_lor_st
pjt_d9:
	addi	gp, gp, -1
	bnez	gp, pjt_d10
	j	pjt_cep_lor_end
pjt_d10:
	addi	gp, gp, -1
	bnez	gp, pjt_d11
	j	pjt_cep_tern_else
pjt_d11:
	addi	gp, gp, -1
	bnez	gp, pjt_d12
	j	pjt_cep_tern_end
pjt_d12:
	addi	gp, gp, -1
	bnez	gp, pjt_d13
	j	pjt_ct_loop_back
pjt_d13:
	addi	gp, gp, -1
	bnez	gp, pjt_d14
	j	pjt_ct_loop_break
pjt_d14:
	addi	gp, gp, -1
	bnez	gp, pjt_d15
	j	pjt_ct_continue
pjt_d15:
	addi	gp, gp, -1
	bnez	gp, pjt_d16
	j	pjt_ct_for_back
pjt_d16:
	addi	gp, gp, -1
	bnez	gp, pjt_d17
	j	pjt_ct_for_break
pjt_d17:
	addi	gp, gp, -1
	bnez	gp, pjt_d18
	j	pjt_cs_fn_ret
pjt_d18:
	addi	gp, gp, -1
	bnez	gp, pjt_d19
	j	pjt_cs_fn_skip
pjt_d19:
	addi	gp, gp, -1
	bnez	gp, pjt_d20
	j	pjt_ct_call_jal
pjt_d20:
	addi	gp, gp, -1
	bnez	gp, pjt_d21
	j	pjt_md_patch
pjt_d21:
	addi	gp, gp, -1
	bnez	gp, pjt_d22
	j	pjt_asm_fn_skip
pjt_d22:
	addi	gp, gp, -1
	bnez	gp, pjt_d23
	j	pjt_cs_fn_save_back
pjt_d23:
	addi	gp, gp, -1
	bnez	gp, pjt_d24
	j	pjt_cs_fn_restore_back
pjt_d24:
	addi	gp, gp, -1
	bnez	gp, pjt_d25
	j	pjt_cs_fn_save_jal
pjt_d25:
	j	pjt_cs_fn_restore_jal

# ══════════════════════════════════════════════════════════════════════════════
# Error reporting. On any parse error, the site sets a0 = error code and jumps
# to report_err, which prints
#
#     Error:<line>:<col> Expected <X> found '<Y>'
#     Error:<line>:<col> Expected <X> at end of input
#     Error:<line>:<col> <raw message>
#
# and then poweroffs. Line/col is computed on demand by walking s1..s2.
#
# Error-code table `err_tbl` has 32-byte slots indexed by code:
#   byte 0: kind  (0 = "Expected X found Y", 1 = raw phrase)
#   byte 1: len   (length of template/phrase text)
#   bytes 2..: text (up to 30 chars, rest zero-padded)
#
# ee_str / emit_dec are helpers used by report_err (and nothing else).
# ══════════════════════════════════════════════════════════════════════════════

# ── ee_str — emit `a1` bytes from `a0` to UART, return via gp dispatch ───────
ee_str:
ee_loop:
	beqz	a1, ee_done
ee_wait:
	lbu	t0, 5(s6)
	andi	t0, t0, 0x20
	beqz	t0, ee_wait
	lbu	t0, 0(a0)
	sb	t0, 0(s6)
	addi	a0, a0, 1
	addi	a1, a1, -1
	j	ee_loop
ee_done:
	j	ee_disp

ee_disp:
	bnez	gp, ee_d1
	j	ee_dec_ret
ee_d1:
	addi	gp, gp, -1
	bnez	gp, ee_d2
	j	re_after_error
ee_d2:
	addi	gp, gp, -1
	bnez	gp, ee_d3
	j	re_after_colon
ee_d3:
	addi	gp, gp, -1
	bnez	gp, ee_d4
	j	re_after_expected
ee_d4:
	addi	gp, gp, -1
	bnez	gp, ee_d5
	j	re_after_template
ee_d5:
	addi	gp, gp, -1
	bnez	gp, ee_d6
	j	re_after_found
ee_d6:
	addi	gp, gp, -1
	bnez	gp, ee_d7
	j	re_after_char
ee_d7:
	addi	gp, gp, -1
	bnez	gp, ee_d8
	j	re_after_tail
ee_d8:
	addi	gp, gp, -1
	bnez	gp, ee_d9
	j	re_after_eof
ee_d9:
	addi	gp, gp, -1
	bnez	gp, ee_d10
	j	re_after_raw_space
ee_d10:
	addi	gp, gp, -1
	bnez	gp, ee_d11
	j	re_after_raw_text
ee_d11:
	addi	gp, gp, -1
	bnez	gp, ee_d12
	j	re_after_raw_nl
ee_d12:
	addi	gp, gp, -1
	bnez	gp, ee_d13
	j	re_after_fname_space
ee_d13:
	addi	gp, gp, -1
	bnez	gp, ee_d14
	j	re_after_fname
ee_d14:
	j	re_after_fname_colon

# ── emit_dec — emit unsigned a0 as decimal digits, return via gp dispatch ────
# Uses a stack buffer to reverse digits, then calls ee_str to print them.
emit_dec:
	addi	sp, sp, -20
	sw	gp, 0(sp)
	addi	t3, sp, 16		# write ptr = end of 12-byte buffer
	bnez	a0, ed_conv
	# Special case: a0 == 0 → emit single '0'.
	addi	t0, zero, '0'
	addi	t3, t3, -1
	sb	t0, 0(t3)
	j	ed_done
ed_conv:
ed_loop:
	# Divide a0 by 10 via repeated subtraction.
	addi	t5, zero, 0		# quotient
ed_d10:
	addi	t1, a0, -10
	bltz	t1, ed_d10_done
	addi	a0, a0, -10
	addi	t5, t5, 1
	j	ed_d10
ed_d10_done:
	# a0 = remainder (0..9), t5 = quotient.
	addi	t0, a0, 48		# '0' + digit
	addi	t3, t3, -1
	sb	t0, 0(t3)
	addi	a0, t5, 0
	bnez	a0, ed_loop
ed_done:
	# Digit string at [t3 .. sp+16). Emit via ee_str.
	addi	a0, t3, 0
	addi	t4, sp, 16
	sub	a1, t4, t3
	addi	gp, zero, 0		# ee_str site 0 = ee_dec_ret
	j	ee_str
ee_dec_ret:
	lw	gp, 0(sp)
	addi	sp, sp, 20
	bnez	gp, ed_r1
	j	re_after_line
ed_r1:
	j	re_after_col

# ── report_err — format and print the error, then poweroff ───────────────────
# Input: a0 = error code (1..N, see err_tbl).
report_err:
	addi	sp, sp, -16
	sw	a0, 0(sp)		# [0]: err_code

	# Walk (file_line_base or s1) .. s2 counting newlines to compute
	# line/col. Using file_line_base makes the line count restart at
	# the most recent FILE: directive's comment opener.
	lla	t2, file_line_base
	lw	t2, 0(t2)
	bnez	t2, lc_have_base
	addi	t2, s1, 0
lc_have_base:
	addi	t3, zero, 1		# line
	addi	t4, zero, 1		# col
lc_loop:
	bge	t2, s2, lc_done
	lbu	t0, 0(t2)
	addi	t1, zero, 10
	beq	t0, t1, lc_nl
	addi	t4, t4, 1
	j	lc_next
lc_nl:
	addi	t3, t3, 1
	addi	t4, zero, 1
lc_next:
	addi	t2, t2, 1
	j	lc_loop
lc_done:
	sw	t3, 4(sp)		# [4]: line
	sw	t4, 8(sp)		# [8]: col

	# Emit "Error:"
	lla	a0, es_error
	addi	a1, zero, 6
	addi	gp, zero, 1		# ee_str site 1
	j	ee_str
re_after_error:
	# If a FILE: directive set a filename, emit " NAME:" between
	# "Error:" and the line number.
	lla	t0, file_name_len
	lw	a1, 0(t0)
	beqz	a1, re_skip_fname
	lla	a0, es_space
	addi	a1, zero, 1
	addi	gp, zero, 12		# ee_str site 12 = re_after_fname_space
	j	ee_str
re_after_fname_space:
	lla	t0, file_name_len
	lw	a1, 0(t0)
	lla	t0, file_name_ptr
	lw	a0, 0(t0)
	addi	gp, zero, 13		# ee_str site 13 = re_after_fname
	j	ee_str
re_after_fname:
	lla	a0, es_colon
	addi	a1, zero, 1
	addi	gp, zero, 14		# ee_str site 14 = re_after_fname_colon
	j	ee_str
re_after_fname_colon:
re_skip_fname:
	# Emit line number.
	lw	a0, 4(sp)
	addi	gp, zero, 0		# emit_dec site 0
	j	emit_dec
re_after_line:
	# Emit ":"
	lla	a0, es_colon
	addi	a1, zero, 1
	addi	gp, zero, 2		# ee_str site 2
	j	ee_str
re_after_colon:
	# Emit col number.
	lw	a0, 8(sp)
	addi	gp, zero, 1		# emit_dec site 1
	j	emit_dec
re_after_col:
	# Look up error-table slot: err_tbl + (err_code << 5).
	lw	t5, 0(sp)
	slli	t5, t5, 5
	lla	t0, err_tbl
	add	t5, t0, t5
	lbu	t1, 0(t5)		# kind
	# Branch on kind: raw (1) skips the " Expected " prefix.
	bnez	t1, re_raw_msg

	# ── Expected/found path ─────────────────────────────────────────
	lla	a0, es_expected
	addi	a1, zero, 10
	addi	gp, zero, 3		# ee_str site 3
	j	ee_str
re_after_expected:
	# Emit template text (from slot[2..2+len]).
	lw	t5, 0(sp)
	slli	t5, t5, 5
	lla	t0, err_tbl
	add	t5, t0, t5
	lbu	a1, 1(t5)
	addi	a0, t5, 2
	addi	gp, zero, 4		# ee_str site 4
	j	ee_str
re_after_template:
	# Decide between " found 'X'" and " at end of input".
	bge	s2, s3, re_eof_path
	lla	a0, es_found
	addi	a1, zero, 8
	addi	gp, zero, 5		# ee_str site 5
	j	ee_str
re_after_found:
	# Emit the offending char (a copy buffered at 12(sp)).
	lbu	t0, 0(s2)
	sb	t0, 12(sp)
	addi	a0, sp, 12
	addi	a1, zero, 1
	addi	gp, zero, 6		# ee_str site 6
	j	ee_str
re_after_char:
	lla	a0, es_tail
	addi	a1, zero, 2
	addi	gp, zero, 7		# ee_str site 7
	j	ee_str
re_after_tail:
	j	poweroff

re_eof_path:
	lla	a0, es_eof
	addi	a1, zero, 17
	addi	gp, zero, 8		# ee_str site 8
	j	ee_str
re_after_eof:
	j	poweroff

	# ── Raw message path ────────────────────────────────────────────
re_raw_msg:
	lla	a0, es_space
	addi	a1, zero, 1
	addi	gp, zero, 9		# ee_str site 9
	j	ee_str
re_after_raw_space:
	lw	t5, 0(sp)
	slli	t5, t5, 5
	lla	t0, err_tbl
	add	t5, t0, t5
	lbu	a1, 1(t5)
	addi	a0, t5, 2
	addi	gp, zero, 10		# ee_str site 10
	j	ee_str
re_after_raw_text:
	lla	a0, es_nl
	addi	a1, zero, 1
	addi	gp, zero, 11		# ee_str site 11
	j	ee_str
re_after_raw_nl:
	j	poweroff

# ══════════════════════════════════════════════════════════════════════════════
# Lvalue marker — written by compile_unary at the end of each primary parse,
# read by the Pratt compile_expr's assignment handler.
#
#   lv_kind:  0 = not an lvalue (literal, paren-arith, ~/-, ++/-- result, …)
#             1 = local variable; the slot offset is in lv_slot
#             2 = byte deref; address was left in a0 before the `lbu` we just
#                 emitted (so un-emitting the lbu restores the address)
#             3 = word deref; same but with `lw`
#
# Binary/ternary/assignment operators in compile_expr reset lv_kind to 0 after
# their post-rhs emit, because arithmetic results are never lvalues.
# ══════════════════════════════════════════════════════════════════════════════
lv_kind:
	.word	0
lv_slot:
	.word	0

# Position of the most recent parse_ident call's starting s2. Saved at each
# parse_ident entry so that an "undefined variable" error can rewind s2 and
# report the column at the identifier's start rather than one past it.
ident_start:
	.word	0

# ── FILE: directive state ───────────────────────────────────────────────
# Lets multiple source files be concatenated through the UART with error
# reporting that references the original file name and line number.
#
# When skip_ws encounters a comment containing the directive "FILE: NAME"
# (block- or line-comment), it stores:
#   file_name_ptr / file_name_len: where in the input buffer the filename
#                                  text lives (pointer + length).
#   file_line_base:               pointer to the '/' that opened the
#                                  comment containing the directive; this
#                                  becomes the "start of line 1" for
#                                  subsequent error reporting.
# report_err uses file_line_base (if non-zero) instead of s1 as the start
# of the newline walk, so the computed line number is relative to the
# last FILE: directive. It also prints "NAME:" before "Error:".
file_name_ptr:
	.word	0
file_name_len:
	.word	0
file_line_base:
	.word	0

# Pointer to the most recent symtab entry returned by lookup/lookup_or_alloc.
# Used by the assignment handler to read/write the mutability flag (byte 37).
last_ident_entry:
	.word	0
last_was_brace:
	.word	0

# Upper bound for the compiled-binary write pointer s5. Set once in Phase 1
# (after `s4 = s3`) to s4 + 16 MiB. Every emit path checks s5 against this
# before writing, so a runaway compile fails loudly instead of scribbling
# past the output region.
bin_end:
	.word	0

# Upper bound for the heap bump pointer `tp`. Set once at startup to
# sp_initial - 4 MiB, leaving a 4 MiB safety margin below famc's stack.
# Every `tp += N` table-grow path checks this before bumping so the heap
# can't silently collide with famc's own stack.
heap_end:
	.word	0

# ── Macro symtab and expansion state ────────────────────────────────────────
# Each entry is 320 bytes:
#    0..31: name (null-padded, up to 32 chars)
#   32..35: body_start (source ptr)
#   36..39: body_end   (source ptr; one past the last body char)
#   40    : num_args   (byte, 0..8)
#   41..43: pad
#   44..299: arg names (8 × 32 bytes)
#  300..319: pad
macro_base:
	.word	0
macro_top:
	.word	0
macro_end:
	.word	0

# Expansion stack: each entry is 12 bytes  (saved s2, saved s3, saved
# scratch_top). Push on cs_macro_call / cs_kw_rept entry; pop in
# compile_loop's EOI hook. Capped at 16 entries (depth limit).
#   stack empty  ⇔  macro_stack_top == macro_stack_base
macro_stack_base:
	.word	0
macro_stack_top:
	.word	0
macro_stack_end:
	.word	0

# Scratch buffer for expanded macro/rept bodies (4 KiB). Each expansion
# writes from `macro_scratch_top` upward, advancing it. On EOI the
# previous scratch_top is restored — that "frees" the just-drained
# region, so deeply nested expansions reuse the same buffer.
macro_scratch:
	.word	0
macro_scratch_top:
	.word	0
macro_scratch_end:
	.word	0

# ── Value-stack state (Phase 1 register-pool codegen) ────────────────────────
# Every push (binop save, function-call arg, etc.) takes a slot from
# s2..s10 (9 registers, callee-saved per ABI). expr_depth tracks how many
# slots are currently in use; expr_max_depth is the high-water mark for
# the current function, used at fn epilogue time to emit the right number
# of save/restore instructions.
expr_depth:
	.word	0
expr_max_depth:
	.word	0
# popped_src_reg = the register number (18..26 = s2..s10) of the most
# recent emit_pop_t0. Set by emit_pop_t0 instead of emitting `mv t0, sN`,
# read by the binop emit helpers (emit_add etc.) so they can use sN as
# rs1 directly. Saves one instruction per binop.
popped_src_reg:
	.word	0
# push_safe_marker — set to current s5 by "safe leaf" emitters (emit_li,
# emit_lw_sp) right after they finish emitting; cleared by emit_word's
# epilogue on every other call. emit_push_a0 reads this and, if it equals
# the current s5, knows the previous instruction is a single-producer
# literal/local load whose rd field can be safely rewritten from a0 to
# s[2+depth] in place — saving one `mv sN, a0`.
push_safe_marker:
	.word	0
# last_li_value — the immediate (full 32-bit value) of the most recent
# emit_li call. Used by const-binding peepholes that want to record a
# literal initializer without re-decoding the emitted instruction(s).
# Only valid when push_safe_marker == s5 (i.e. the previous emit was an
# emit_li and nothing has been emitted or patched since).
last_li_value:
	.word	0
# last_li_start — the s5 address right before the most recent emit_li
# began emitting. Lets a const-folding caller rewind s5 to drop the
# entire li sequence (1 or 2 instructions) by setting s5 = last_li_start.
last_li_start:
	.word	0
# last_li_marker — set to the post-emit s5 by emit_li only (not by
# emit_lw_sp). Lets a const-folding caller distinguish "last emit was a
# literal" from "last emit was a local load". Cleared by emit_word's
# epilogue alongside push_safe_marker.
last_li_marker:
	.word	0
# a0_known_zero — sticky flag set when a0 is known (at compile time)
# to hold the literal value 0. Set by emit_li 0. Cleared by emit_word
# only when the just-emitted instruction writes rd=a0(=10). Lets
# emit_sw_sp emit `sw zero, off(fp)` even across multi-store chains
# like `x := y := z := 0;` (sw doesn't clobber a0, so the flag stays
# set across consecutive store emissions).
a0_known_zero:
	.word	0
# expr_value_discarded — set to 1 by cs_fb (expression-statement
# fallback) before compiling the statement's expression, restored to
# 0 after. cep_pre_tern reads it: if set AND the ternary has no else
# clause, the false-tail `addi a0, zero, 0` is dead (no consumer for
# the value 0) and is skipped, along with the jal_end that would
# normally jump over it.
expr_value_discarded:
	.word	0

# Flag set before lookup_or_alloc to indicate whether the upcoming
# assignment is mutable (:=) or immutable (=). Read in la_cs to
# set byte 37 of the symtab entry and enforce rules.
#   0 = immutable (via '=')
#   1 = mutable   (via ':=')
assign_is_mut:
	.word	0

# Set to 1 by la_new (new entry created), 0 by la_match (existing found).
# Read after lookup_or_alloc returns to distinguish new vs existing.
lookup_was_new:
	.word	0

panic_handler_addr:
	.word	0

# ── Function compilation state ─────────────────────────────────────────────
# Function symtab: separate growable table, independent of the variable
# symtab so that functions and locals share a namespace without stepping on
# each other's entry formats.
#
# Entry layout (40 bytes, same as variable symtab for code reuse):
#    0..31: name (null-padded, up to 32 chars)
#   32..35: entry_addr (compiled-program address of function entry)
#   36    : num_params (byte, 0..8)
#   37..39: reserved
#
# fn_base / fn_top / fn_end grow just like s7 / s8 / s0 — on alloc, if
# fn_top == fn_end we double-and-copy to a fresh heap block.
fn_base:
	.word	0
fn_top:
	.word	0
fn_end:
	.word	0

# Ret-site list: one entry per function call site in the program, indexed by
# the site's ret_id. Each entry holds the compiled-program address of the
# instruction immediately after the `jal zero, entry` — which is where
# master_dispatch should land when this call returns. Grows dynamically.
ret_base:
	.word	0
ret_top:
	.word	0
ret_end:
	.word	0

# Per-function "return" placeholder list. `return expr;` emits a jal zero,
# <placeholder>; the placeholder's address is recorded here. When the
# function body finishes compiling, the epilogue address is known and all
# placeholders are patched to jump to it. Only valid while a function body
# is being compiled.
ret_list_base:
	.word	0
ret_list_top:
	.word	0
ret_list_end:
	.word	0

# Master-dispatch jal-patch list: every function's epilogue emits a final
# `jal zero, <master_dispatch>` whose target isn't known until all code has
# been compiled. We collect those placeholder addresses here and patch them
# once master_dispatch is emitted at the end of Phase 3.
md_patch_base:
	.word	0
md_patch_top:
	.word	0
md_patch_end:
	.word	0

# ── Asm label table ────────────────────────────────────────────────────────
# Global symbolic labels defined in asm blocks. Entries are 40 bytes:
#   0..31: name (null-padded)
#   32..35: address in compiled output
#   36..39: flags (unused)
asm_lbl_base:
	.word	0
asm_lbl_top:
	.word	0
asm_lbl_end:
	.word	0

# ── Asm numeric label table ────────────────────────────────────────────────
# Reusable numeric labels (0-9). Each entry is 8 bytes:
#   0..3: number (0-9)
#   4..7: address in compiled output
# Entries are appended in emission order; multiple entries per number allowed.
asm_nlbl_base:
	.word	0
asm_nlbl_top:
	.word	0
asm_nlbl_end:
	.word	0

# ── Asm fixup list ─────────────────────────────────────────────────────────
# Entries for forward-reference label uses, resolved at end of compilation.
# Layout (40 bytes):
#   0..31: target label name (null-padded) for symbolic, or number at 0..3 for numeric
#   32..35: fixup_addr (address in compiled output to patch)
#   36..39: kind: 0=B-type sym, 1=J-type sym, 2=B-type num fwd, 3=J-type num fwd
asm_fix_base:
	.word	0
asm_fix_top:
	.word	0
asm_fix_end:
	.word	0

# Currently-compiling function — 0 means top-level. A non-zero value means
# we're inside a function body (so `return` is legal and the epilogue can
# be located). Stores the function's entry_addr for diagnostic purposes.
current_fn:
	.word	0

# Non-zero while compiling the body of a named `asm name { ... }` function.
# Used by asm_end to decide between inline asm cleanup (just cs_done) and
# asm function cleanup (emit epilogue, patch skip-over, restore state).
current_asm_fn:
	.word	0

# ── Struct symtab ──────────────────────────────────────────────────────────
# Growable table of struct definitions.
#
# Entry layout (320 bytes):
#    0..31: struct name (null-padded)
#    32..35: field count (1..16)
#    36..39: reserved
#   40..55: field 0 name (16 bytes, null-padded)
#   56..71: field 1 name
#   ... up to 16 fields ...
#   280..295: field 15 name
#   296..319: reserved
#
# Every field is 4 bytes (a word). Field i's byte-offset within an instance
# is `i * 4`. Struct instance size is `count * 4`.
struct_base:
	.word	0
struct_top:
	.word	0
struct_end:
	.word	0

# ── Loop / break / continue tracking ────────────────────────────────────────
# break_base: pointer into famc's own stack at the current innermost loop's
#             break-address array, or 0 outside any loop.
# break_count: how many entries of that array are currently filled.
# loop_start: compiled-code address of the current innermost loop's top,
#             used by `continue` to emit an immediate backward jal.
#             0 outside any loop. break_base's nonzero-ness is the canonical
#             "am I in a loop" check for both `break` and `continue`.
# Nested loops save/restore all three in their own stack frame on entry/exit.
break_base:
	.word	0
break_count:
	.word	0
loop_start:
	.word	0

# ── Error message literals ──────────────────────────────────────────────────
es_error:
	.ascii	"Error:"
es_colon:
	.ascii	":"
es_expected:
	.ascii	" Expected "
es_found:
	.ascii	" found '"
es_tail:
	.ascii	"'\n"
es_eof:
	.ascii	" at end of input\n"
es_space:
	.ascii	" "
es_nl:
	.ascii	"\n"

# ── Error code table ────────────────────────────────────────────────────────
# 32-byte slots indexed by error code. Slot layout:
#   byte 0: kind   (0 = "Expected X found Y", 1 = raw phrase)
#   byte 1: len    (length of template/phrase text)
#   bytes 2..:     text, zero-padded to 32 bytes total
#
# Codes:
#    0  reserved (unused)
#    1  ';'
#    2  ')'
#    3  '}' or ';'
#    4  ':'
#    5  expression
#    6  identifier
#    7  '=' or compound-assign operator
#    8  end of statement
#   20  raw: assignment target is not an lvalue
#   21  raw: cannot '++' or '--' a literal
#   22  raw: '*'/'@' deref cannot combine with '++' or '--'
err_tbl:
	# slot 0 — reserved
	.byte	0, 0
	.zero	30
	# slot 1 — ';'
	.byte	0, 3
	.ascii	"';'"
	.zero	27
	# slot 2 — ')'
	.byte	0, 3
	.ascii	"')'"
	.zero	27
	# slot 3 — '}' or ';'
	.byte	0, 10
	.ascii	"'}' or ';'"
	.zero	20
	# slot 4 — ':'
	.byte	0, 3
	.ascii	"':'"
	.zero	27
	# slot 5 — expression
	.byte	0, 10
	.ascii	"expression"
	.zero	20
	# slot 6 — identifier
	.byte	0, 10
	.ascii	"identifier"
	.zero	20
	# slot 7 — '=' or compound-assign operator
	.byte	0, 25
	.ascii	"'=' or compound-assign op"
	.zero	5
	# slot 8 — end of statement
	.byte	0, 16
	.ascii	"end of statement"
	.zero	14
	# slot 9 — '{'
	.byte	0, 3
	.ascii	"'{'"
	.zero	27
	# slot 10 — 'in'
	.byte	0, 4
	.ascii	"'in'"
	.zero	26
	# slot 11 — '..' or '..='
	.byte	0, 12
	.ascii	"'..' / '..='"
	.zero	18
	# slot 12 — '('
	.byte	0, 3
	.ascii	"'('"
	.zero	27
	# slots 13..19 — reserved
	.zero	224
	# slot 20 — raw: not an lvalue
	.byte	1, 28
	.ascii	"left of '=' is not an lvalue"
	.zero	2
	# slot 21 — raw: literal ++/--
	.byte	1, 28
	.ascii	"'++'/'--' requires an lvalue"
	.zero	2
	# slot 22 — raw: combo
	.byte	1, 30
	.ascii	"cannot combine deref and ++/--"
	.zero	0
	# slots 23..29 — reserved
	.zero	224
	# slot 30 — raw: too many breaks in loop (>32)
	.byte	1, 26
	.ascii	"loop has too many 'break's"
	.zero	4
	# slot 31 — raw: break outside loop
	.byte	1, 22
	.ascii	"'break' outside a loop"
	.zero	8
	# slot 32 — raw: compound assign on deref target (not yet supported)
	.byte	1, 28
	.ascii	"compound '+=' needs an ident"
	.zero	2
	# slot 33 — raw: continue outside a loop
	.byte	1, 25
	.ascii	"'continue' outside a loop"
	.zero	5
	# slot 34 — raw: unknown escape sequence
	.byte	1, 23
	.ascii	"unknown escape sequence"
	.zero	7
	# slot 35 — raw: undefined variable
	.byte	1, 18
	.ascii	"undefined variable"
	.zero	12
	# slot 36 — raw: unterminated block comment
	.byte	1, 26
	.ascii	"unterminated block comment"
	.zero	4
	# slot 37 — raw: nested function definition (not supported)
	.byte	1, 28
	.ascii	"nested 'fn' is not supported"
	.zero	2
	# slot 38 — raw: function has more than 8 params
	.byte	1, 25
	.ascii	"'fn' takes at most 8 args"
	.zero	5
	# slot 39 — raw: function already defined
	.byte	1, 20
	.ascii	"'fn' already defined"
	.zero	10
	# slot 40 — raw: function frame too large
	.byte	1, 20
	.ascii	"'fn' frame too large"
	.zero	10
	# slot 41 — raw: undefined function
	.byte	1, 18
	.ascii	"undefined function"
	.zero	12
	# slot 42 — raw: wrong number of arguments
	.byte	1, 25
	.ascii	"wrong number of arguments"
	.zero	5
	# slot 43 — raw: return outside function
	.byte	1, 25
	.ascii	"'return' outside function"
	.zero	5
	# slot 44 — ']'
	.byte	0, 3
	.ascii	"']'"
	.zero	27
	# slot 45 — raw: variable already defined
	.byte	1, 15
	.ascii	"already defined"
	.zero	15
	# slot 46 — raw: array size must be a compile-time literal
	.byte	1, 28
	.ascii	"array size must be a literal"
	.zero	2
	# slot 47 — raw: too many fields in a struct (>16)
	.byte	1, 26
	.ascii	"struct has too many fields"
	.zero	4
	# slot 48 — expected ',' or '}' (struct field list)
	.byte	0, 10
	.ascii	"',' or '}'"
	.zero	20
	# slot 49 — raw: struct used outside literal or access
	.byte	1, 26
	.ascii	"bare struct name not valid"
	.zero	4
	# slot 50 — raw: unknown field name in struct literal / access
	.byte	1, 18
	.ascii	"unknown field name"
	.zero	12
	# slot 51 — raw: too many initializer values
	.byte	1, 22
	.ascii	"too many struct values"
	.zero	8
	# slot 52 — expected '.'
	.byte	0, 3
	.ascii	"'.'"
	.zero	27
	# slot 53 — raw: sizeof needs a struct type
	.byte	1, 26
	.ascii	"sizeof needs a struct type"
	.zero	4
	# slot 54 — raw: unknown struct type (used in @access)
	.byte	1, 19
	.ascii	"unknown struct type"
	.zero	11
	# slot 55 — raw: immutable variable reassignment
	.byte	1, 25
	.ascii	"cannot reassign immutable"
	.zero	5
	# slot 56 — raw: unterminated string literal
	.byte	1, 19
	.ascii	"unterminated string"
	.zero	11
	# slot 57 — raw: invalid escape in string literal
	.byte	1, 21
	.ascii	"invalid string escape"
	.zero	9
	# slot 58 — raw: unterminated asm block
	.byte	1, 18
	.ascii	"unterminated asm"
	.zero	14
	# slot 59 — raw: bad asm mnemonic or register
	.byte	1, 22
	.ascii	"bad asm mnemonic/reg"
	.zero	10
	# slot 60 — raw: expected ',' in asm operands
	.byte	1, 23
	.ascii	"asm expected ','"
	.zero	14
	# slot 61 — raw: malformed asm binding
	.byte	1, 24
	.ascii	"malformed asm binding"
	.zero	9
	# slot 62 — raw: malformed asm memop
	.byte	1, 23
	.ascii	"asm expected imm(reg)"
	.zero	9
	# slot 63 — raw: duplicate asm label
	.byte	1, 19
	.ascii	"duplicate asm label"
	.zero	11
	# slot 64 — raw: too many asm labels
	.byte	1, 19
	.ascii	"too many asm labels"
	.zero	11
	# slot 65 — raw: too many asm fixups
	.byte	1, 19
	.ascii	"too many asm fixups"
	.zero	11
	# slot 66 — raw: undefined asm label
	.byte	1, 15
	.ascii	"undefined label"
	.zero	15
	# slot 67 — raw: too many numeric labels
	.byte	1, 27
	.ascii	"too many asm numeric labels"
	.zero	3
	# slot 68 — raw: bad asm directive
	.byte	1, 17
	.ascii	"bad asm directive"
	.zero	13
	# slot 69 — raw: identifier too long (>32 chars)
	.byte	1, 19
	.ascii	"identifier too long"
	.zero	11
	# slot 70 — raw: branch offset out of range
	.byte	1, 26
	.ascii	"branch offset out of range"
	.zero	4
	# slot 71 — raw: compiled binary exceeds 16 MiB cap
	.byte	1, 23
	.ascii	"binary output too large"
	.zero	7
	# slot 72 — raw: compiler heap exhausted (would collide with stack)
	.byte	1, 23
	.ascii	"compiler heap exhausted"
	.zero	7
	# slot 73 — raw: integer literal overflows 32 bits
	.byte	1, 24
	.ascii	"integer literal overflow"
	.zero	6
	# slot 74 — raw: input source exceeds 16 MiB cap
	.byte	1, 16
	.ascii	"source too large"
	.zero	14
	# slot 75 — raw: asm lui/auipc imm exceeds 20 bits
	.byte	1, 22
	.ascii	"asm U-type imm too big"
	.zero	8
	# slot 76 — raw: asm addi/li/etc imm exceeds 12 bits (or shift ≥ 32)
	.byte	1, 22
	.ascii	"asm I-type imm too big"
	.zero	8
	# slot 77 — raw: bad macro name
	.byte	1, 14
	.ascii	"bad macro name"
	.zero	16
	# slot 78 — raw: macro already defined
	.byte	1, 21
	.ascii	"macro already defined"
	.zero	9
	# slot 79 — raw: too many macro args
	.byte	1, 19
	.ascii	"too many macro args"
	.zero	11
	# slot 80 — raw: macro arg count mismatch
	.byte	1, 24
	.ascii	"macro arg count mismatch"
	.zero	6
	# slot 81 — raw: macro/rept expansion stack overflow (max 16 deep)
	.byte	1, 27
	.ascii	"expansion nested too deeply"
	.zero	3
	# slot 82 — raw: bad macro substitution
	.byte	1, 22
	.ascii	"bad macro substitution"
	.zero	8
	# slot 83 — raw: macro scratch buffer overflow
	.byte	1, 22
	.ascii	"macro scratch overflow"
	.zero	8
	# slot 84 — raw: rept count out of range (0..4096)
	.byte	1, 23
	.ascii	"rept count out of range"
	.zero	7
	# slot 85 — raw: bad rept substitution
	.byte	1, 21
	.ascii	"bad rept substitution"
	.zero	9
	# slot 86 — (reserved)
	.byte	0, 0
	.zero	30
	# slot 87 — raw: expression too deep (>9 nested pushes)
	.byte	1, 19
	.ascii	"expression too deep"
	.zero	11
	# slot 88 — raw: value-stack pop underflow (compiler bug)
	.byte	1, 25
	.ascii	"value-stack pop underflow"
	.zero	5

# ══════════════════════════════════════════════════════════════════════════════
# Register name tables for asm blocks.
# Each entry is a 4-byte word containing the register name (null-padded to 4).
# Table index = register number (0-31).
# asm_abi_names: ABI names (zero, ra, sp, gp, tp, t0-t6, s0-s11, a0-a7).
# asm_x_names: x-prefixed names (x0-x31).
# Note: "fp" (alternate for s0/x8) is handled as a special case, not in tables.
# ══════════════════════════════════════════════════════════════════════════════
asm_abi_names:
	.word	0x6F72657A
	.word	0x00006172
	.word	0x00007073
	.word	0x00007067
	.word	0x00007074
	.word	0x00003074
	.word	0x00003174
	.word	0x00003274
	.word	0x00003073
	.word	0x00003173
	.word	0x00003061
	.word	0x00003161
	.word	0x00003261
	.word	0x00003361
	.word	0x00003461
	.word	0x00003561
	.word	0x00003661
	.word	0x00003761
	.word	0x00003273
	.word	0x00003373
	.word	0x00003473
	.word	0x00003573
	.word	0x00003673
	.word	0x00003773
	.word	0x00003873
	.word	0x00003973
	.word	0x00303173
	.word	0x00313173
	.word	0x00003374
	.word	0x00003474
	.word	0x00003574
	.word	0x00003674
asm_x_names:
	.word	0x00003078
	.word	0x00003178
	.word	0x00003278
	.word	0x00003378
	.word	0x00003478
	.word	0x00003578
	.word	0x00003678
	.word	0x00003778
	.word	0x00003878
	.word	0x00003978
	.word	0x00303178
	.word	0x00313178
	.word	0x00323178
	.word	0x00333178
	.word	0x00343178
	.word	0x00353178
	.word	0x00363178
	.word	0x00373178
	.word	0x00383178
	.word	0x00393178
	.word	0x00303278
	.word	0x00313278
	.word	0x00323278
	.word	0x00333278
	.word	0x00343278
	.word	0x00353278
	.word	0x00363278
	.word	0x00373278
	.word	0x00383278
	.word	0x00393278
	.word	0x00303378
	.word	0x00313378

# ══════════════════════════════════════════════════════════════════════════════
# End of famc image.  `tp` is initialized from this label at startup — every
# heap allocation (symtab, future dynamic state) bumps `tp` forward from here.
# Naturally 4-byte aligned because every preceding instruction is exactly 4 B.
# ══════════════════════════════════════════════════════════════════════════════
data:
