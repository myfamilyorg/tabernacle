# ══════════════════════════════════════════════════════════════════════════════
# parse_ident — reads an identifier at s2 into token buffer.
#   Call sites:  0: pi_ct    (compile_unary — IDENT primary)
#                1: pi_cs    (compile_stmt — IDENT-LHS dispatch)
#                2: pi_cs_pp (compile_stmt — '++IDENT;')
#                3: pi_cs_mm (compile_stmt — '--IDENT;')
# ══════════════════════════════════════════════════════════════════════════════
parse_ident:
	# Stash the token start so that a subsequent lookup failure (undefined
	# variable) can rewind s2 and report the error at the token start
	# rather than one past it.
	lla	t0, ident_start
	sw	s2, 0(t0)
	addi	s11, zero, 0
pi_loop:
	bge	s2, s3, pi_done
	lbu	t0, 0(s2)
	addi	t1, zero, 'a'
	blt	t0, t1, pi_uc
	addi	t1, zero, 123
	blt	t0, t1, pi_take
pi_uc:
	addi	t1, zero, 'A'
	blt	t0, t1, pi_dig
	addi	t1, zero, 91
	blt	t0, t1, pi_take
pi_dig:
	addi	t1, zero, '0'
	blt	t0, t1, pi_us
	addi	t1, zero, 58
	blt	t0, t1, pi_take
pi_us:
	addi	t1, zero, '_'
	beq	t0, t1, pi_take
	j	pi_done
pi_take:
	addi	t2, zero, 32
	bge	s11, t2, pi_too_long
	add	t2, s10, s11
	sb	t0, 0(t2)
	addi	s11, s11, 1
	addi	s2, s2, 1
	j	pi_loop
pi_too_long:
	addi	a0, zero, 69		# err 69: identifier too long
	j	report_err
pi_done:
	j	parse_ident_disp

parse_ident_disp:
	bnez	gp, pid_1
	j	pi_ct
pid_1:
	addi	gp, gp, -1
	bnez	gp, pid_2
	j	pi_cs
pid_2:
