# ══════════════════════════════════════════════════════════════════════════════
# famc.fam3 — first-pass reference compiler (rewrite, pass 1)
# ══════════════════════════════════════════════════════════════════════════════
#
# Grammar:
#   program := stmt*
#   stmt    := lvalue '=' expr ';'
#   lvalue  := IDENT | '*' expr | '@' expr
#   expr    := term ('+' term)*
#   term    := derefop? primary
#   derefop := '*' | '@'                # '*' = word, '@' = byte
#   primary := NUM | IDENT
#   IDENT   := [a-zA-Z_][a-zA-Z_0-9]*
#   NUM     := dec | 0[xX][0-9a-fA-F]+
#
# Example source:
#   x = 1;
#   y = x + 48;
#   @0x10000000 = y;                  # writes byte '1' to the UART
#
# Compiled-program prologue (11 instructions, 44 bytes):
#
#   0:  nop                           # q32 magic
#   4:  auipc gp, 0                   # gp = &auipc
#   8:  addi  gp, gp, <patched>       # gp = data_end  (patched by Phase 5)
#  12:  addi  gp, gp, 3                # align ...
#  16:  andi  gp, gp, -4                # ... to 4 bytes
#  20:  lui   sp, 0x10                  # sp = 0x10000 (= 64 KiB)
#  24:  add   sp, sp, gp                # sp = gp + 64 KiB (stack top)
#  28:  lui   t0, <patched hi20>        # frame allocator, upper 20 bits
#  32:  addi  t0, t0, <patched lo12>    # frame allocator, lower 12 bits
#  36:  sub   sp, sp, t0                # sp -= frame_size (reserve locals)
#  40:  addi  fp, sp, 0                 # fp = sp (fp pinned to base of frame)
#  44:  <compiled statements ...>
#   N:  lui   t0, 0x100                  # QEMU poweroff sequence:
# N+4:  lui   t1, 0x5                    #   *0x100000 = 0x5555
# N+8:  addi  t1, t1, 0x555
# N+12: sw    t1, 0(t0)
# N+16: jal   zero, 0                   # safety hang after poweroff
# N+20: data_end:
#
# Patch points (all applied in Phase 5 after compile_loop ends):
#   offset 8   addi gp imm12  → (data_end - auipc_pc)
#   offset 28  lui  t0 imm20  → upper20 of frame_size
#   offset 32  addi t0 imm12  → lower12 of frame_size (sign-extended)
#
# The frame allocator is always 3 instructions regardless of frame size, so it
# handles anything from 0 bytes up to ~2 GiB without a special case. Pass 2
# can replace tiny frames with a single `addi sp, sp, -N` as an optimization.
#
# Design contract:
#   - famc's prologue sets gp = data_end, sp = top of stack, fp = base of frame.
#   - Frame size is computed dynamically from variable declarations and
#     patched into the prologue's lui/addi pair at end of compilation. No
#     hard-coded 2 KiB ceiling — arrays and large structs will Just Work.
#   - No alloc / no heap manager baked in; dynamic allocation is stdlib's job.
#   - famc itself uses a stack + a bump-allocated heap (pointed to by tp).
#   - No ret / jalr / jr in any of our outputs. Static dispatch only.
#
# Variables live at POSITIVE offsets from fp:
#   offset 0(fp) = first local, 4(fp) = second, ..., (frame_size-4)(fp) = last.
# fp does not move after the prologue; sp moves freely below fp during
# expression evaluation (stack-machine push/pop). Since sp < fp throughout,
# pushes never collide with the variable frame.
#
# Compiled-program register usage:
#   a0  — current expression value
#   t0  — pop destination in the stack-machine pop pattern
#   fp  — frame pointer (s0; base of the current function's locals)
#   gp  — data_end pointer (reserved for stdlib/user — famc doesn't touch it)
#   sp  — expression spill stack; moves freely below fp
#
# ── famc's own runtime layout ──────────────────────────────────────────────
#
#   [high RAM]
#         │  [output buffer — grows up]        s4 = s3 after read
#         │  [input buffer  — grows up]        s1 = sp_initial
#   sp_0  ├──  `lui sp, 0x4000; add sp, sp, tp`   (sp = tp + 64 MiB)
#         │  [token buffer, 32 B on stack]     s10 = sp after `addi sp, sp, -32`
#         │  [free stack, grows down ...]
#         ┆                                     (dispatch gp save/restore)
#         │  [free heap ...]                   (grows upward)
#         │  [symtab — 32 entries initially]    s7, s8 write ptr, s0 end ptr
#   tp_0  ├──  `lla tp, data` then `andi tp, tp, -4`
#         │  [famc code + data, label `data:` at the end]
#   0x80000000
#
# ── famc's own runtime registers ───────────────────────────────────────────
#   s0  = symtab end ptr (= s7 + capacity_in_bytes; triggers grow when s8 hits)
#   s1  = input buf base           s2  = input read ptr
#   s3  = input end ptr            s4  = output buf base
#   s5  = output write ptr         s6  = UART base
#   s7  = symtab base              s8  = symtab write ptr
#   s9  = current frame size in bytes (= next free byte offset for new locals)
#                                     s10 = token buf base
#   s11 = current token length     sp  = famc's stack
#   tp  = heap bump pointer (famc's heap — initially `data`, grows upward)
#   gp  = return-site id (dispatch — same convention as fam2/fam3)
# ══════════════════════════════════════════════════════════════════════════════

.equ SYMTAB_INIT_BYTES, 1280	# 32 entries × 40 bytes

_start:
	nop				# q32 magic for fam3's own output

	# ── Set up heap and stack ─────────────────────────────────────────
	lla	tp, data		# tp = end of famc image
	addi	tp, tp, 3
	andi	tp, tp, -4		# 4-byte align
	lui	sp, 0x4000		# 0x04000000 = 64 MiB
	add	sp, sp, tp		# sp = tp + 64 MiB

	# heap_end = sp_initial - 4 MiB. Every `tp +=` grow path checks this
	# to keep the heap from walking into famc's own stack.
	lui	t0, 0x400		# 0x00400000 = 4 MiB
	sub	t0, sp, t0
	lla	t1, heap_end
	sw	t0, 0(t1)

	lui	s6, 0x10000		# UART

	# ── Input buffer = initial sp, grows upward ───────────────────────
	addi	s1, sp, 0
	addi	s2, s1, 0

	# ── Token buffer: 32 bytes on the stack ──────────────────────────
	addi	sp, sp, -32
	addi	s10, sp, 0

	# ── Symtab: initial 32 entries on the heap at tp ─────────────────
	addi	s7, tp, 0		# symtab base
	addi	s8, s7, 0		# symtab write ptr
	addi	t0, zero, SYMTAB_INIT_BYTES
	add	tp, tp, t0		# bump heap
	addi	s0, s7, SYMTAB_INIT_BYTES	# symtab end (capacity marker)

	# ── Function symtab: initial 16 entries × 40 bytes on the heap ──
	lla	t1, fn_base
	sw	tp, 0(t1)
	lla	t1, fn_top
	sw	tp, 0(t1)
	addi	t0, zero, 640		# 16 × 40
	add	t2, tp, t0
	lla	t1, fn_end
	sw	t2, 0(t1)
	addi	tp, t2, 0

	# ── Ret-site list: initial 64 × 4-byte entries ─────────────────
	lla	t1, ret_base
	sw	tp, 0(t1)
	lla	t1, ret_top
	sw	tp, 0(t1)
	addi	t0, zero, 256		# 64 × 4
	add	t2, tp, t0
	lla	t1, ret_end
	sw	t2, 0(t1)
	addi	tp, t2, 0

	# ── Return-placeholder list for the currently-compiling function:
	#    initial 32 × 4-byte entries ────────────────────────────────
	lla	t1, ret_list_base
	sw	tp, 0(t1)
	lla	t1, ret_list_top
	sw	tp, 0(t1)
	addi	t0, zero, 128		# 32 × 4
	add	t2, tp, t0
	lla	t1, ret_list_end
	sw	t2, 0(t1)
	addi	tp, t2, 0

	# ── Master-dispatch patch list: initial 32 × 4-byte entries ────
	lla	t1, md_patch_base
	sw	tp, 0(t1)
	lla	t1, md_patch_top
	sw	tp, 0(t1)
	addi	t0, zero, 128		# 32 × 4
	add	t2, tp, t0
	lla	t1, md_patch_end
	sw	t2, 0(t1)
	addi	tp, t2, 0

	# ── Struct symtab: initial 16 entries × 320 bytes = 5120 bytes ─
	lla	t1, struct_base
	sw	tp, 0(t1)
	lla	t1, struct_top
	sw	tp, 0(t1)
	addi	t0, zero, 1280		# 1280 bytes per group of 4 entries
	add	t2, tp, t0
	add	t2, t2, t0
	add	t2, t2, t0
	add	t2, t2, t0		# total: 5120 bytes = 16 entries
	lla	t1, struct_end
	sw	t2, 0(t1)
	addi	tp, t2, 0

	# ── Asm label table: 64 entries × 40 bytes = 2560 bytes ────────
	lla	t1, asm_lbl_base
	sw	tp, 0(t1)
	lla	t1, asm_lbl_top
	sw	tp, 0(t1)
	addi	t0, zero, 1280		# 2 × 1280 = 2560 bytes
	add	t2, tp, t0
	add	t2, t2, t0
	lla	t1, asm_lbl_end
	sw	t2, 0(t1)
	addi	tp, t2, 0

	# ── Asm numeric label list: 64 entries × 8 bytes = 512 bytes ────
	lla	t1, asm_nlbl_base
	sw	tp, 0(t1)
	lla	t1, asm_nlbl_top
	sw	tp, 0(t1)
	addi	t0, zero, 512
	add	t2, tp, t0
	lla	t1, asm_nlbl_end
	sw	t2, 0(t1)
	addi	tp, t2, 0

	# ── Asm fixup list: 64 entries × 40 bytes = 2560 bytes ─────────
	lla	t1, asm_fix_base
	sw	tp, 0(t1)
	lla	t1, asm_fix_top
	sw	tp, 0(t1)
	addi	t0, zero, 1280
	add	t2, tp, t0
	add	t2, t2, t0
	lla	t1, asm_fix_end
	sw	t2, 0(t1)
	addi	tp, t2, 0

	# ── Macro symtab: 16 entries × 320 bytes = 5120 bytes ──────────
	lla	t1, macro_base
	sw	tp, 0(t1)
	lla	t1, macro_top
	sw	tp, 0(t1)
	addi	t0, zero, 1280
	add	t2, tp, t0
	add	t2, t2, t0
	add	t2, t2, t0
	add	t2, t2, t0		# 4 × 1280 = 5120
	lla	t1, macro_end
	sw	t2, 0(t1)
	addi	tp, t2, 0

	# ── Macro expansion scratch: 4 KiB ─────────────────────────────
	lla	t1, macro_scratch
	sw	tp, 0(t1)
	lla	t1, macro_scratch_top
	sw	tp, 0(t1)		# bump pointer = scratch start
	lui	t0, 0x1			# 4 KiB
	add	t2, tp, t0
	lla	t1, macro_scratch_end
	sw	t2, 0(t1)
	addi	tp, t2, 0

	# ── Macro expansion stack: 16 entries × 12 bytes = 192 bytes ──
	lla	t1, macro_stack_base
	sw	tp, 0(t1)
	lla	t1, macro_stack_top
	sw	tp, 0(t1)
	addi	t0, zero, 192
	add	t2, tp, t0
	lla	t1, macro_stack_end
	sw	t2, 0(t1)
	addi	tp, t2, 0

	addi	s9, zero, 0		# next var slot
	addi	s11, zero, 0		# token length

# ── Phase 1: read all source text from UART into input buffer ──────────────
	# Cap source size at 16 MiB: anything larger would leave no room for
	# the output binary below bin_end, and the buffer is unbounded otherwise.
	addi	s3, s1, 0
	lui	t3, 0x1000		# 16 MiB
	add	t3, s1, t3		# source upper bound
rd_loop:
	lbu	t1, 5(s6)
	andi	t1, t1, 1
	beqz	t1, rd_loop
	lbu	t0, 0(s6)
	addi	t2, zero, 4
	beq	t0, t2, rd_done
	bgeu	s3, t3, rd_too_big
	sb	t0, 0(s3)
	addi	s3, s3, 1
	j	rd_loop
rd_too_big:
	addi	a0, zero, 74		# err 74: source too large
	j	report_err
rd_done:
	# Output buffer starts immediately after input
	addi	s4, s3, 0
	addi	s5, s4, 0
	# bin_end = s4 + 16 MiB (0x01000000). The whole emit pipeline checks
	# s5 against this so a runaway compile errors out cleanly.
	lui	t0, 0x1000
	add	t0, s4, t0
	lla	t1, bin_end
	sw	t0, 0(t1)

# ── Phase 2: emit prologue (7 words, 28 bytes) ──────────────────────────────
	# nop = addi x0, x0, 0 = 0x00000013
	lui	a0, 0
	addi	a0, a0, 0x13
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# auipc gp, 0    →  opcode=0x17, rd=gp=3, imm20=0
	# word = (0 << 12) | (3 << 7) | 0x17 = 0x00000197
	lui	a0, 0
	addi	a0, a0, 0x197
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# addi gp, gp, 0     (immediate patched later to reach data_end)
	# opcode=0x13, rd=gp=3, rs1=gp=3, f3=0, imm=0
	# word = (0 << 20) | (3 << 15) | (0 << 12) | (3 << 7) | 0x13
	#      = 0x00018193
	lui	a0, 0x18
	addi	a0, a0, 0x193
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# addi gp, gp, 3     (align up)
	# word = (3 << 20) | (3 << 15) | 0 | (3 << 7) | 0x13 = 0x00318193
	lui	a0, 0x318
	addi	a0, a0, 0x193
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# andi gp, gp, -4    (align down to 4)
	# opcode=0x13, f3=7, rd=3, rs1=3, imm=-4 (=0xFFC in 12-bit)
	# word = (0xFFC << 20) | (3 << 15) | (7 << 12) | (3 << 7) | 0x13
	#      = 0xFFC << 20 = 0xFFC00000
	#      | 0x18000 | 0x7000 | 0x180 | 0x13
	#      = 0xFFC00000 | 0x0001F193
	#      = 0xFFC1F193
	lui	a0, 0xFFC1F
	addi	a0, a0, 0x193
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# lui sp, 0x10      →  opcode=0x37, rd=sp=2, imm20=0x10
	# word = (0x10 << 12) | (2 << 7) | 0x37
	#      = 0x00010000 | 0x100 | 0x37 = 0x00010137
	lui	a0, 0x10
	addi	a0, a0, 0x137
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# add sp, sp, gp    →  R-type, opcode=0x33, f3=0, f7=0,
	#                       rd=sp=2, rs1=sp=2, rs2=gp=3
	# word = (3 << 20) | (2 << 15) | (0 << 12) | (2 << 7) | 0x33
	#      = 0x00300000 | 0x10000 | 0x100 | 0x33
	#      = 0x00310133
	lui	a0, 0x310
	addi	a0, a0, 0x133
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# Shadow stack for return IDs — tp = gp + 32 KiB. Grows downward,
	# separate from the main data stack (sp). Buffer overflows on sp
	# can't reach return IDs stored on tp.
	#
	#   lui  tp, 0x8       # tp = 0x8000 = 32 KiB
	#   add  tp, tp, gp   # tp = gp + 32 KiB

	# lui tp, 0x8 → opcode=0x37, rd=tp=4, imm20=0x8
	# word = 0x37 | (4 << 7) | (0x8 << 12) = 0x37 | 0x200 | 0x8000 = 0x00008237
	lui	a0, 0x8
	addi	a0, a0, 0x237
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# add tp, tp, gp → rd=tp=4, rs1=tp=4, rs2=gp=3
	# word = 0x33 | (4 << 7) | (4 << 15) | (3 << 20)
	#      = 0x33 | 0x200 | 0x20000 | 0x300000 = 0x00320233
	lui	a0, 0x320
	addi	a0, a0, 0x233
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# Frame allocator — 3 instructions, always emitted, always patched in
	# Phase 5 with the real frame_size computed during statement compilation.
	#
	#   lui  t0, 0           # 0x000002B7 (imm20 patched to upper20(frame))
	#   addi t0, t0, 0       # 0x00028293 (imm12 patched to lower12(frame))
	#   sub  sp, sp, t0      # 0x40510133
	#
	# With t0 = frame_size (as loaded by the patched lui+addi), we reserve
	# frame_size bytes below the current sp. The pattern handles any size
	# from 0 to ~2 GiB without a special case.

	# lui t0, 0          →  opcode=0x37, rd=t0=5, imm20=0
	#   word = 0x37 | (5 << 7) = 0x000002B7
	lui	a0, 0
	addi	a0, a0, 0x2B7
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# addi t0, t0, 0     →  opcode=0x13, rd=t0=5, rs1=t0=5, f3=0, imm=0
	#   word = 0x13 | (5 << 7) | (5 << 15) = 0x13 | 0x280 | 0x28000 = 0x00028293
	lui	a0, 0x28
	addi	a0, a0, 0x293
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# sub sp, sp, t0     →  R-type, opcode=0x33, f3=0, f7=0x20,
	#                        rd=sp=2, rs1=sp=2, rs2=t0=5
	#   word = 0x33 | (2<<7) | (2<<15) | (5<<20) | (0x20<<25)
	#        = 0x33 | 0x100 | 0x10000 | 0x500000 | 0x40000000
	#        = 0x40510133
	lui	a0, 0x40510
	addi	a0, a0, 0x133
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# addi fp, sp, 0     →  fp = sp (fp pinned to base of frame)
	#   opcode=0x13, rd=s0=8, rs1=sp=2, f3=0, imm=0
	#   word = 0x13 | (8<<7) | (2<<15) = 0x13 | 0x400 | 0x10000 = 0x00010413
	lui	a0, 0x10
	addi	a0, a0, 0x413
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# addi s1, zero, 0   →  stack guard disabled (s1=0 means no check)
	#   opcode=0x13, rd=s1=9, rs1=zero=0, f3=0, imm=0
	#   word = 0x13 | (9<<7) = 0x00000493
	lui	a0, 0
	addi	a0, a0, 0x493
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# j past_panic — skip over the inline panic handler
	# jal zero, offset   opcode=0x6F, rd=0 → base word 0x0000006F
	# offset = 11 instructions * 4 = 44 bytes (the panic handler is 10 insns)
	# J-type encoding for imm=44 (0x2C):
	#   imm[20|10:1|11|19:12]  → 44 = 0b...0_0000101100
	#   imm[10:1]=0b0000010110 → bits[30:21]=0x16 → 0x16<<21 = 0x02C00000
	#   all other imm bits are 0
	#   word = 0x02C0006F
	lui	a0, 0x2C00
	addi	a0, a0, 0x06F
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# ── Inline panic handler (10 instructions) ──
	# Entered via bltu sp, s1 from any stack-check site.
	# Writes "S\n" to UART at 0x10000000, then powers off QEMU.
	lla	t0, panic_handler_addr
	sw	s5, 0(t0)		# record address for bltu encoding

	# lui t0, 0x10000   →  t0 = 0x10000000 (UART)  word = 0x100002B7
	lui	a0, 0x10000
	addi	a0, a0, 0x2B7
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# addi t1, zero, 0x53   →  t1 = 'S'  word = 0x05300313
	lui	a0, 0x5300
	addi	a0, a0, 0x313
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# sb t1, 0(t0)   →  word = 0x00628023
	lui	a0, 0x628
	addi	a0, a0, 0x023
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# addi t1, zero, 0x0A   →  t1 = '\n'  word = 0x00A00313
	lui	a0, 0xA00
	addi	a0, a0, 0x313
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# sb t1, 0(t0)   →  word = 0x00628023
	lui	a0, 0x628
	addi	a0, a0, 0x023
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# Poweroff: lui t0, 0x100 → 0x001002B7
	lui	a0, 0x100
	addi	a0, a0, 0x2B7
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# lui t1, 0x5 → 0x00005337
	lui	a0, 0x5
	addi	a0, a0, 0x337
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# addi t1, t1, 0x555 → 0x55530313
	lui	a0, 0x55530
	addi	a0, a0, 0x313
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# sw t1, 0(t0) → 0x0062A023
	lui	a0, 0x62A
	addi	a0, a0, 0x023
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# jal zero, 0 (hang) → 0x0000006F
	lui	a0, 0
	addi	a0, a0, 0x6F
	sw	a0, 0(s5)
	addi	s5, s5, 4

# ── Phase 3: compile all statements ────────────────────────────────────────
compile_loop:
	addi	gp, zero, 0
	j	skip_ws
sw_cl:
	bge	s2, s3, sw_cl_eoi
	j	compile_stmt
sw_cl_eoi:
	# End of input. If the expansion stack is non-empty, the current
	# scratch region just drained: pop the saved (s2, s3, scratch_top)
	# and keep going.
	lla	t0, macro_stack_top
	lw	t1, 0(t0)
	lla	t2, macro_stack_base
	lw	t3, 0(t2)
	beq	t1, t3, compile_done
	addi	t1, t1, -12
	sw	t1, 0(t0)
	lw	s2, 0(t1)
	lw	s3, 4(t1)
	lw	t4, 8(t1)
	lla	t0, macro_scratch_top
	sw	t4, 0(t0)
	j	compile_loop
cs_after:
	j	compile_loop
compile_done:

# ── Phase 4: emit epilogue — QEMU-virt poweroff + safety hang ──────────────
# Writes the magic value 0x5555 to the "test" device at 0x00100000, which
# causes qemu-system-riscv32 -machine virt to exit.  Followed by `j .` as a
# safety net in case we're running on something that doesn't honour the test
# device (the CPU will then just park there).
#
#   lui  t0, 0x100        # t0 = 0x00100000 (test device)     0x001002B7
#   lui  t1, 0x5          # t1 = 0x00005000                    0x00005337
#   addi t1, t1, 0x555    # t1 = 0x00005555                    0x55530313
#   sw   t1, 0(t0)                                             0x0062A023
#   jal  zero, 0          # j .  (safety hang)                 0x0000006F

	# lui t0, 0x100
	lui	a0, 0x100
	addi	a0, a0, 0x2B7
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# lui t1, 0x5
	lui	a0, 0x5
	addi	a0, a0, 0x337
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# addi t1, t1, 0x555
	lui	a0, 0x55530
	addi	a0, a0, 0x313
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# sw t1, 0(t0)
	lui	a0, 0x62A
	addi	a0, a0, 0x023
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# jal zero, 0 — safety hang
	lui	a0, 0
	addi	a0, a0, 0x6F
	sw	a0, 0(s5)
	addi	s5, s5, 4

# ── Phase 4.5: emit master_dispatch + patch function epilogue jals ─────────
# Every function's epilogue ends with a `jal zero, 0` whose target isn't
# known until now (we need to point them all at master_dispatch). We also
# emit the dispatch chain itself, which indexes ret_base by ra and jumps
# to the recorded ret_site for that id.
#
# Dispatch shape (uniform 3 instr/entry, with a +1 adjust up front so the
# entries can use a uniform `addi ra,ra,-1; bnez ra,next; jal zero, site`
# template):
#
#     addi ra, ra, 1          ; shift to 1-indexed for uniform decrement
#   md_entry_0:
#     addi ra, ra, -1
#     bnez ra, md_entry_1
#     jal  zero, ret_site_0
#   md_entry_1:
#     addi ra, ra, -1
#     bnez ra, md_entry_2
#     jal  zero, ret_site_1
#     ...
#   md_trap:
#     jal  zero, md_trap      ; unreached fall-through sentinel

	# master_dispatch addr = current s5. Patch all function-epilogue jals.
	# patch_jtype clobbers t-regs, so we stash the loop state (t1 cursor,
	# t2 end) on famc's own stack around each call.
	lla	t0, md_patch_base
	lw	t1, 0(t0)
	lla	t0, md_patch_top
	lw	t2, 0(t0)
md_patch_loop:
	beq	t1, t2, md_patch_done
	lw	t5, 0(t1)
	addi	t6, s5, 0
	addi	sp, sp, -8
	sw	t1, 0(sp)
	sw	t2, 4(sp)
	addi	gp, zero, 20		# patch_jtype site 20 = pjt_md_patch
	j	patch_jtype
pjt_md_patch:
	lw	t1, 0(sp)
	lw	t2, 4(sp)
	addi	sp, sp, 8
	addi	t1, t1, 4
	j	md_patch_loop
md_patch_done:
	# Preamble: addi ra, ra, 1   word 0x00108093
	lui	a0, 0x108
	addi	a0, a0, 0x93
	sw	a0, 0(s5)
	addi	s5, s5, 4

	# Emit one entry per ret_site.
	lla	t0, ret_base
	lw	t1, 0(t0)
	lla	t0, ret_top
	lw	t2, 0(t0)
md_emit_loop:
	beq	t1, t2, md_emit_done
	# addi ra, ra, -1   word 0xFFF08093
	lui	a0, 0xFFF08
	addi	a0, a0, 0x93
	sw	a0, 0(s5)
	addi	s5, s5, 4
	# bnez ra, +8   word 0x00009463
	lui	a0, 0x9
	addi	a0, a0, 0x463
	sw	a0, 0(s5)
	addi	s5, s5, 4
	# jal zero, 0 — placeholder, patched immediately below.
	lui	a0, 0
	addi	a0, a0, 0x6F
	sw	a0, 0(s5)
	addi	s5, s5, 4
	# Patch the jal to target the ret_site.
	addi	t3, s5, -4		# jal addr
	lw	t4, 0(t1)		# target ret_site
	sub	t5, t4, t3		# offset
	# Build the jal-encoded immediate bits into t0 and OR into the word.
	lw	t0, 0(t3)		# current jal word (0x0000006F)
	# imm[20]  → bit 31
	srli	a0, t5, 20
	andi	a0, a0, 1
	slli	a0, a0, 31
	or	t0, t0, a0
	# imm[19:12] → bits 19:12
	srli	a0, t5, 12
	andi	a0, a0, 0xFF
	slli	a0, a0, 12
	or	t0, t0, a0
	# imm[11] → bit 20
	srli	a0, t5, 11
	andi	a0, a0, 1
	slli	a0, a0, 20
	or	t0, t0, a0
	# imm[10:1] → bits 30:21
	srli	a0, t5, 1
	andi	a0, a0, 0x3FF
	slli	a0, a0, 21
	or	t0, t0, a0
	sw	t0, 0(t3)
	addi	t1, t1, 4
	j	md_emit_loop
md_emit_done:
	# md_trap: `jal zero, 0` → infinite loop at itself (safety).
	lui	a0, 0
	addi	a0, a0, 0x6F
	sw	a0, 0(s5)
	addi	s5, s5, 4

# ── Phase 4.6: resolve asm label fixups ────────────────────────────────────
# Walk the fixup list. For each entry, look up the target label (symbolic or
# numeric, forward or backward), compute the offset, and patch the placeholder
# word at fixup_addr using B-type, J-type, or LLA encoding.
#
# Fixup kinds:
#   0 = B-type symbolic   1 = J-type symbolic
#   2 = B-type num fwd    3 = J-type num fwd
#   4 = B-type num bwd    5 = J-type num bwd
#   6 = LLA  symbolic (auipc + addi pair, label - auipc_pc)
	lla	t0, asm_fix_base
	lw	t1, 0(t0)		# fix ptr
	lla	t0, asm_fix_top
	lw	t2, 0(t0)		# fix end
fix_loop:
	beq	t1, t2, fix_done
	lw	a4, 36(t1)		# kind
	addi	a5, zero, 6
	beq	a4, a5, fix_lla_sym
	addi	a5, zero, 2
	bge	a4, a5, fix_numeric
	# Symbolic: look up name in label table
	lla	t0, asm_lbl_base
	lw	t3, 0(t0)
	lla	t0, asm_lbl_top
	lw	t4, 0(t0)
fix_lbl_scan:
	beq	t3, t4, fix_undef
	addi	t5, zero, 0
fix_cmp:
	addi	t6, zero, 32
	beq	t5, t6, fix_found
	add	a0, t1, t5
	lbu	a1, 0(a0)
	add	a0, t3, t5
	lbu	a2, 0(a0)
	bne	a1, a2, fix_lbl_next
	addi	t5, t5, 1
	j	fix_cmp
fix_lbl_next:
	addi	t3, t3, 40
	j	fix_lbl_scan
fix_found:
	lw	a2, 32(t3)		# label address
	j	fix_have_addr
fix_numeric:
	# Numeric fixup: number at 0(t1), kind 2/3=fwd, 4/5=bwd
	lw	a0, 0(t1)		# number
	lw	a3, 32(t1)		# fixup_addr
	addi	a5, zero, 4
	bge	a4, a5, fix_num_bwd
	# Forward: find smallest numeric label addr > fixup_addr with number=a0
	lla	t0, asm_nlbl_base
	lw	t3, 0(t0)
	lla	t0, asm_nlbl_top
	lw	t4, 0(t0)
	addi	a2, zero, 0		# best address (0 = none yet)
fix_nf_scan:
	beq	t3, t4, fix_nf_done
	lw	t5, 0(t3)		# number
	bne	t5, a0, fix_nf_next
	lw	t6, 4(t3)		# address
	bgeu	a3, t6, fix_nf_next	# must be > fixup_addr (unsigned)
	# Candidate. Is it better than current best?
	beqz	a2, fix_nf_take
	bgeu	t6, a2, fix_nf_next	# not better (unsigned)
fix_nf_take:
	addi	a2, t6, 0
fix_nf_next:
	addi	t3, t3, 8
	j	fix_nf_scan
fix_nf_done:
	beqz	a2, fix_undef
	j	fix_have_addr
fix_num_bwd:
	# Backward: find largest numeric label addr <= fixup_addr with number=a0
	lla	t0, asm_nlbl_base
	lw	t3, 0(t0)
	lla	t0, asm_nlbl_top
	lw	t4, 0(t0)
	addi	a2, zero, 0		# best address
fix_nb_scan:
	beq	t3, t4, fix_nb_done
	lw	t5, 0(t3)		# number
	bne	t5, a0, fix_nb_next
	lw	t6, 4(t3)		# address
	bltu	a3, t6, fix_nb_next	# must be <= fixup_addr (unsigned)
	bgeu	t6, a2, fix_nb_take	# take if >= current best (unsigned)
	j	fix_nb_next
fix_nb_take:
	addi	a2, t6, 0
fix_nb_next:
	addi	t3, t3, 8
	j	fix_nb_scan
fix_nb_done:
	beqz	a2, fix_undef
	j	fix_have_addr
fix_have_addr:
	# a2 = label address; fixup_addr at 32(t1); kind in a4
	lw	a3, 32(t1)		# fixup_addr
	sub	a2, a2, a3		# offset = label - fixup_addr
	# Dispatch: kind 6 = LLA (auipc+addi pair); else B/J based on bit 0.
	addi	a5, zero, 6
	beq	a4, a5, fix_emit_lla
	andi	a5, a4, 1
	bnez	a5, fix_emit_jtype
	# B-type: 13-bit signed offset. Check range by sign-extending bit 12
	# and comparing against the original.
	slli	a5, a2, 19
	srai	a5, a5, 19
	bne	a5, a2, fix_off_oor
	# B-type encoding
	lw	a5, 0(a3)		# existing placeholder word
	# offset[4:1] → bits[11:8]
	srli	a6, a2, 1
	andi	a6, a6, 0xF
	slli	a6, a6, 8
	or	a5, a5, a6
	# offset[10:5] → bits[30:25]
	srli	a6, a2, 5
	andi	a6, a6, 0x3F
	slli	a6, a6, 25
	or	a5, a5, a6
	# offset[11] → bit[7]
	srli	a6, a2, 11
	andi	a6, a6, 1
	slli	a6, a6, 7
	or	a5, a5, a6
	# offset[12] → bit[31]
	srli	a6, a2, 12
	andi	a6, a6, 1
	slli	a6, a6, 31
	or	a5, a5, a6
	sw	a5, 0(a3)
	j	fix_next
fix_emit_jtype:
	# J-type: 21-bit signed offset. Check range.
	slli	a5, a2, 11
	srai	a5, a5, 11
	bne	a5, a2, fix_off_oor
	lw	a5, 0(a3)
	# offset[10:1] → bits[30:21]
	srli	a6, a2, 1
	andi	a6, a6, 0x3FF
	slli	a6, a6, 21
	or	a5, a5, a6
	# offset[11] → bit[20]
	srli	a6, a2, 11
	andi	a6, a6, 1
	slli	a6, a6, 20
	or	a5, a5, a6
	# offset[19:12] → bits[19:12]
	srli	a6, a2, 12
	andi	a6, a6, 0xFF
	slli	a6, a6, 12
	or	a5, a5, a6
	# offset[20] → bit[31]
	srli	a6, a2, 20
	andi	a6, a6, 1
	slli	a6, a6, 31
	or	a5, a5, a6
	sw	a5, 0(a3)
	j	fix_next
fix_lla_sym:
	# Symbolic lookup for LLA (kind 6). Identical scan to the kind-0/1
	# symbolic path; on success we land in fix_have_addr which then
	# routes to fix_emit_lla.
	lla	t0, asm_lbl_base
	lw	t3, 0(t0)
	lla	t0, asm_lbl_top
	lw	t4, 0(t0)
fix_lla_lbl_scan:
	beq	t3, t4, fix_undef
	addi	t5, zero, 0
fix_lla_lbl_cmp:
	addi	t6, zero, 32
	beq	t5, t6, fix_lla_lbl_found
	add	a0, t1, t5
	lbu	a1, 0(a0)
	add	a0, t3, t5
	lbu	a2, 0(a0)
	bne	a1, a2, fix_lla_lbl_next
	addi	t5, t5, 1
	j	fix_lla_lbl_cmp
fix_lla_lbl_next:
	addi	t3, t3, 40
	j	fix_lla_lbl_scan
fix_lla_lbl_found:
	lw	a2, 32(t3)		# label addr
	j	fix_have_addr
fix_emit_lla:
	# offset in a2, fixup_addr (= auipc PC) in a3.
	# lower12 = sign_extend_12(offset)
	# upper20 = (offset - lower12) >> 12
	# Patch auipc word at a3 (OR upper20 into bits 31:12).
	# Patch addi  word at a3+4 (OR lower12 into bits 31:20, masked).
	slli	a5, a2, 20
	srai	a5, a5, 20		# a5 = lower12
	sub	a6, a2, a5
	srai	a6, a6, 12		# a6 = upper20
	lw	t0, 0(a3)
	slli	t5, a6, 12
	or	t0, t0, t5
	sw	t0, 0(a3)
	lw	t0, 4(a3)
	andi	t5, a5, 0xFFF
	slli	t5, t5, 20
	or	t0, t0, t5
	sw	t0, 4(a3)
fix_next:
	addi	t1, t1, 40
	j	fix_loop
fix_undef:
	# Unresolved asm label fixup — report error (line/col will point at EOF
	# since we've lost the source location of the original reference).
	addi	a0, zero, 66
	j	report_err
fix_off_oor:
	addi	a0, zero, 70		# err 70: branch/jump offset out of range
	j	report_err
fix_done:

# ── Phase 5: patch the prologue (data_end + frame_size) ────────────────────

	# Patch 1 — auipc gp, upper20  at prologue offset 4
	# Patch 2 — addi  gp, gp, lo12 at prologue offset 8
	# Together they set gp = data_end (= s5).
	#
	# offset = s5 - auipc_pc = s5 - (s4 + 4)
	# lower12 = sign_extend_12(offset)
	# upper20 = (offset - lower12) >> 12
	#
	# The old single-addi patch silently truncated offsets above 2047 —
	# harmless only because famc itself never reads gp, but any compiled
	# program that uses gp as a data_end pointer would have its gp set to
	# the wrong address for any binary larger than ~2 KiB.
	sub	t0, s5, s4
	addi	t0, t0, -4		# t0 = offset (data_end - auipc_pc)
	slli	t1, t0, 20
	srai	t1, t1, 20		# t1 = lower12 (sign-extended)
	sub	t2, t0, t1
	srai	t2, t2, 12		# t2 = upper20

	# Patch auipc: OR (upper20 << 12) into the existing 0x00000197 word.
	lw	t3, 4(s4)
	slli	t4, t2, 12
	or	t3, t3, t4
	sw	t3, 4(s4)

	# Patch addi: OR (lower12 << 20) into the existing 0x00018193 word.
	lw	t3, 8(s4)
	slli	t4, t1, 20
	or	t3, t3, t4
	sw	t3, 8(s4)

	# Patch 2 — lui  t0, upper20  at prologue offset 28
	# Patch 3 — addi t0, t0, lo12 at prologue offset 32
	# Together they set t0 = s9 = frame_size in bytes.
	#
	#   lower12 = sign-extended low 12 bits of s9
	#   upper20 = (s9 - lower12) >> 12
	#
	# For s9 = 0 the pair becomes `lui 0 ; addi t0, 0` which is a no-op (t0=0),
	# and `sub sp, sp, t0` leaves sp alone — correct for a zero-local program.
	slli	t0, s9, 20		# t0 = s9 << 20 (bits 31:20 = low 12 of s9)
	srai	t0, t0, 20		# t0 = lower12 (sign-extended to 32)
	sub	t1, s9, t0		# t1 = s9 - lower12  (always a multiple of 4096)
	srai	t1, t1, 12		# t1 = upper20

	# lui t0, upper20 word:  (upper20 << 12) | 0x000002B7
	slli	t2, t1, 12
	addi	t3, zero, 0x2B7
	or	t2, t2, t3
	sw	t2, 36(s4)		# offset 36 (shifted +8 for shadow stack init)

	# addi t0, t0, lower12 word:  (lower12 << 20) | 0x00028293
	# (slli naturally keeps only the low 12 bits of t0 in the imm slot)
	slli	t2, t0, 20
	lui	t3, 0x28
	addi	t3, t3, 0x293
	or	t2, t2, t3
	sw	t2, 40(s4)		# offset 40 (shifted +8 for shadow stack init)

# ── Phase 6: stream output buffer to UART, then poweroff ───────────────────
out_loop:
	beq	s4, s5, poweroff
	lbu	t0, 0(s4)
	addi	s4, s4, 1
tx_wait:
	lbu	t1, 5(s6)
	andi	t1, t1, 0x20
	beqz	t1, tx_wait
	sb	t0, 0(s6)
	j	out_loop

poweroff:
	lui	t0, 0x100
	lui	t1, 0x5
	addi	t1, t1, 0x555
	sw	t1, 0(t0)
pwr_hang:
	j	pwr_hang

halt_err:
	j	halt_err

# ══════════════════════════════════════════════════════════════════════════════
# list_append_word — append a0's value to the growable word-list whose
# (base, top, end) globals are at addresses a1, a2, a3. Doubles capacity
# and copies on growth. No in-place free — old block is leaked (bump-alloc).
#
# Inputs:  a0 = value, a1 = &base_global, a2 = &top_global, a3 = &end_global
# Clobbers: t0..t6, a4, a5, a6
# Return: via gp dispatch.
# ══════════════════════════════════════════════════════════════════════════════
list_append_word:
	addi	sp, sp, -4
	sw	gp, 0(sp)
	lw	t0, 0(a2)		# top
	lw	t1, 0(a3)		# end
	bne	t0, t1, la_space_ok
	# Grow: new_cap = 2 * old_cap, new_base = tp.
	lw	t2, 0(a1)		# base
	sub	t3, t1, t2		# cap (bytes)
	slli	t4, t3, 1		# new_cap
	# heap_end check: tp + new_cap must fit below heap_end.
	add	t5, tp, t4
	lla	t6, heap_end
	lw	t6, 0(t6)
	bgeu	t5, t6, heap_full
	addi	t5, tp, 0		# new_base
	addi	t6, t2, 0		# src
	addi	a4, t5, 0		# dst
la_copy:
	beq	t6, t0, la_copy_done
	lw	a5, 0(t6)
	sw	a5, 0(a4)
	addi	t6, t6, 4
	addi	a4, a4, 4
	j	la_copy
la_copy_done:
	# Publish the new array and bump tp past new_cap.
	sw	t5, 0(a1)
	add	a4, t5, t3		# new_top = new_base + old_cap
	sw	a4, 0(a2)
	add	t0, t5, t4		# new_end = new_base + new_cap
	sw	t0, 0(a3)
	add	tp, tp, t4
	# Reload top for the store below.
	lw	t0, 0(a2)
la_space_ok:
	sw	a0, 0(t0)
	addi	t0, t0, 4
	sw	t0, 0(a2)
	lw	gp, 0(sp)
	addi	sp, sp, 4
	j	list_append_word_disp

list_append_word_disp:
	bnez	gp, law_d1
	j	law_ret_ret_site
law_d1:
	addi	gp, gp, -1
	bnez	gp, law_d2
	j	law_ret_return_list
law_d2:
	addi	gp, gp, -1
	bnez	gp, law_d3
	j	law_ret_md_patch
law_d3:
	j	law_ret_md_asm

# ══════════════════════════════════════════════════════════════════════════════
# skip_ws — advance s2 past chars with code < 33.
#
# Call sites (each has a uniquely-named return label):
#   0: sw_cl          (compile_loop top)
#   1: sw_ct_pre      (compile_term — initial ws skip)
#   2: sw_ct_star     (compile_term — after consuming '*')
#   3: sw_ct_at       (compile_term — after consuming '@')
#   4: sw_ca_plus     (compile_add — before checking for '+'/'-')
#   5: sw_cs_eq1      (compile_stmt — after IDENT, before '=')
#   6: sw_cs_semi1    (compile_stmt — after IDENT/expr, before ';')
#   7: sw_cs_eq2      (compile_stmt — '*' path, after addr expr, before '=')
#   8: sw_cs_semi2    (compile_stmt — '*' path, after store, before ';')
#   9: sw_cs_eq3      (compile_stmt — '@' path, after addr expr, before '=')
#  10: sw_cs_semi3    (compile_stmt — '@' path, after store, before ';')
#  11: sw_ce_xor      (compile_expr — before checking for '^')
#  12: sw_ct_pp       (compile_unary — after consuming prefix '++')
#  13: sw_ct_mm       (compile_unary — after consuming prefix '--')
#  14: sw_ct_post     (compile_unary — after IDENT+lw, before peek postfix)
#  15: sw_cs_semi_stmt (compile_stmt — before trailing ';' for compound/inc-dec stmts)
#  16: sw_cs_pp_id    (compile_stmt — after bare '++', before IDENT)
#  17: sw_cs_mm_id    (compile_stmt — after bare '--', before IDENT)
#  18: sw_csh_op      (compile_shift — before peeking for '<<' or '>>')
#  19: sw_cand_and    (compile_and — before peeking for '&')
#  20: sw_cor_or      (compile_expr/or — before peeking for '|')
#  21: sw_ct_rparen   (compile_unary — after parenthesized expr, before ')')
#  22: sw_ccmp_op     (compile_rel — before peeking for relational op)
#  23: sw_ceq_op      (compile_expr — before peeking for '==' / '!=')
#  24: sw_cmul_op     (compile_mul — before peeking for '*')
#  25: sw_cland_op    (compile_land — before peeking for '&&')
#  26: sw_clor_op     (compile_expr — before peeking for '||')
#  27: sw_ctern_op    (compile_expr — after || loop, before peeking '?')
#  28: sw_ctern_colon (compile_expr — after middle, before peeking ':')
#  29: sw_cep_op      (compile_expr_p — at loop top, before peeking binop)
#  30: sw_cep_tern_colon (compile_expr_p — after ternary middle, before ':')
# ══════════════════════════════════════════════════════════════════════════════
skip_ws:
sw_loop:
	bge	s2, s3, sw_done
	lbu	t0, 0(s2)
	addi	t1, zero, 33
	bge	t0, t1, sw_chk_comment
	addi	s2, s2, 1
	j	sw_loop
sw_chk_comment:
	# Non-whitespace. Check for '/' followed by '/' (line comment) or '*'
	# (block comment, nestable). A lone '/' is the division operator —
	# we return without consuming it so the caller's dispatcher sees it.
	addi	t1, zero, '/'
	bne	t0, t1, sw_done
	addi	t2, s2, 1
	bge	t2, s3, sw_done
	lbu	t3, 0(t2)
	addi	t1, zero, '/'
	beq	t3, t1, sw_line_comment
	addi	t1, zero, '*'
	beq	t3, t1, sw_block_comment
	j	sw_done
sw_line_comment:
	# '//' ... '\n' (or EOF). Consume opening '//' then everything up to
	# and including the newline (the main ws loop will eat the '\n'
	# naturally, so we just stop at it).
	# t5 = position of the '/' that opens this comment — used if a
	# FILE: directive is found inside to reset the line-count base.
	addi	t5, s2, 0
	addi	s2, s2, 2
sw_lc_loop:
	bge	s2, s3, sw_loop
	lbu	t0, 0(s2)
	addi	t1, zero, 10
	beq	t0, t1, sw_loop
	addi	t1, zero, 'F'
	beq	t0, t1, sw_lc_file_chk
sw_lc_adv:
	addi	s2, s2, 1
	j	sw_lc_loop
sw_lc_file_chk:
	# Check for "FILE: " starting at s2 (6 chars).
	addi	t2, s2, 6
	bgt	t2, s3, sw_lc_adv
	lbu	t0, 1(s2)
	addi	t1, zero, 'I'
	bne	t0, t1, sw_lc_adv
	lbu	t0, 2(s2)
	addi	t1, zero, 'L'
	bne	t0, t1, sw_lc_adv
	lbu	t0, 3(s2)
	addi	t1, zero, 'E'
	bne	t0, t1, sw_lc_adv
	lbu	t0, 4(s2)
	addi	t1, zero, ':'
	bne	t0, t1, sw_lc_adv
	lbu	t0, 5(s2)
	addi	t1, zero, ' '
	bne	t0, t1, sw_lc_adv
	# Match — read filename until newline or EOF.
	addi	s2, s2, 6		# skip "FILE: "
	addi	t2, s2, 0		# name start
sw_lc_file_read:
	bge	s2, s3, sw_lc_file_done
	lbu	t0, 0(s2)
	addi	t1, zero, 10
	beq	t0, t1, sw_lc_file_done
	addi	s2, s2, 1
	j	sw_lc_file_read
sw_lc_file_done:
	# Trim trailing whitespace (< 33) from t2..s2 → name end in t3.
	addi	t3, s2, 0
sw_lc_file_trim:
	beq	t3, t2, sw_lc_file_store
	addi	t1, t3, -1
	lbu	t0, 0(t1)
	addi	t6, zero, 33
	bge	t0, t6, sw_lc_file_store
	addi	t3, t1, 0
	j	sw_lc_file_trim
sw_lc_file_store:
	lla	t0, file_name_ptr
	sw	t2, 0(t0)
	sub	t0, t3, t2
	lla	t1, file_name_len
	sw	t0, 0(t1)
	lla	t0, file_line_base
	sw	t5, 0(t0)
	j	sw_lc_loop
sw_block_comment:
	# '/*' ... '*/'. Nestable: track depth in t4.
	# t5 = position of the '/' that opens this comment — used if a
	# FILE: directive is found inside to reset the line-count base.
	addi	t5, s2, 0
	addi	s2, s2, 2
	addi	t4, zero, 1
sw_bc_loop:
	beqz	t4, sw_loop
	bge	s2, s3, sw_bc_eof
	lbu	t0, 0(s2)
	addi	t1, zero, '/'
	beq	t0, t1, sw_bc_slash
	addi	t1, zero, '*'
	beq	t0, t1, sw_bc_star
	addi	t1, zero, 'F'
	beq	t0, t1, sw_bc_file_chk
sw_bc_adv:
	addi	s2, s2, 1
	j	sw_bc_loop
sw_bc_file_chk:
	# Check for "FILE: " starting at s2 (6 chars).
	addi	t2, s2, 6
	bgt	t2, s3, sw_bc_adv
	lbu	t0, 1(s2)
	addi	t1, zero, 'I'
	bne	t0, t1, sw_bc_adv
	lbu	t0, 2(s2)
	addi	t1, zero, 'L'
	bne	t0, t1, sw_bc_adv
	lbu	t0, 3(s2)
	addi	t1, zero, 'E'
	bne	t0, t1, sw_bc_adv
	lbu	t0, 4(s2)
	addi	t1, zero, ':'
	bne	t0, t1, sw_bc_adv
	lbu	t0, 5(s2)
	addi	t1, zero, ' '
	bne	t0, t1, sw_bc_adv
	# Match — read filename until newline, '*' (possibly start of */),
	# or EOF.
	addi	s2, s2, 6
	addi	t2, s2, 0
sw_bc_file_read:
	bge	s2, s3, sw_bc_file_done
	lbu	t0, 0(s2)
	addi	t1, zero, 10
	beq	t0, t1, sw_bc_file_done
	addi	t1, zero, '*'
	beq	t0, t1, sw_bc_file_done
	addi	s2, s2, 1
	j	sw_bc_file_read
sw_bc_file_done:
	# Trim trailing whitespace.
	addi	t3, s2, 0
sw_bc_file_trim:
	beq	t3, t2, sw_bc_file_store
	addi	t1, t3, -1
	lbu	t0, 0(t1)
	addi	t6, zero, 33
	bge	t0, t6, sw_bc_file_store
	addi	t3, t1, 0
	j	sw_bc_file_trim
sw_bc_file_store:
	lla	t0, file_name_ptr
	sw	t2, 0(t0)
	sub	t0, t3, t2
	lla	t1, file_name_len
	sw	t0, 0(t1)
	lla	t0, file_line_base
	sw	t5, 0(t0)
	j	sw_bc_loop
sw_bc_slash:
	# Possible nested '/*' open.
	addi	t2, s2, 1
	bge	t2, s3, sw_bc_adv1
	lbu	t3, 0(t2)
	addi	t1, zero, '*'
	beq	t3, t1, sw_bc_open
sw_bc_adv1:
	addi	s2, s2, 1
	j	sw_bc_loop
sw_bc_open:
	addi	s2, s2, 2
	addi	t4, t4, 1
	j	sw_bc_loop
sw_bc_star:
	# Possible '*/' close.
	addi	t2, s2, 1
	bge	t2, s3, sw_bc_adv2
	lbu	t3, 0(t2)
	addi	t1, zero, '/'
	beq	t3, t1, sw_bc_close
sw_bc_adv2:
	addi	s2, s2, 1
	j	sw_bc_loop
sw_bc_close:
	addi	s2, s2, 2
	addi	t4, t4, -1
	j	sw_bc_loop
sw_bc_eof:
	addi	a0, zero, 36		# err 36: unterminated block comment
	j	report_err
sw_done:
	j	skip_ws_disp

skip_ws_disp:
	bnez	gp, sw_d1
	j	sw_cl
sw_d1:
	addi	gp, gp, -1
	bnez	gp, sw_d2
	j	sw_ct_pre
sw_d2:
	addi	gp, gp, -1
	bnez	gp, sw_d3
	j	sw_ct_star
sw_d3:
	addi	gp, gp, -1
	bnez	gp, sw_d4
	j	sw_ct_at
sw_d4:
	addi	gp, gp, -1
	bnez	gp, sw_d5
	j	sw_ca_plus
sw_d5:
	addi	gp, gp, -1
	bnez	gp, sw_d6
	j	sw_cs_eq1
sw_d6:
