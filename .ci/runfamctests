echo "=== Limits and error detection ==="

# Each limit has a pair of tests: the exact limit works, one-over errors.
# This anchors the current behavior so future refactors/optimizations that
# change the limits fail loudly instead of silently shrinking them.

# ── Identifier length (max 32 chars) ────────────────────────────────────────
test_output  "identifier 32 chars (max)" \
	"fn main() { aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa := 65; @0x10000000 = aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa; } main();" "A"
