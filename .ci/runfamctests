#!/usr/bin/env bash
# Test runner for famc compiler (pass-1 reference implementation).
# Usage: .ci/runtests [--verbose]
#
# Covers the features famc currently supports:
#   - decimal and hex integer literals
#   - variable definition, reference, reassignment (one slot per name)
#   - binary addition with stack-machine codegen
#   - byte dereference  @addr  (read and write)
#   - word dereference  *addr  (read and write)
#   - multi-statement programs terminated by ';'
#
# Every compiled binary is also checked with tools/no-jalr — any test that
# emits a real jalr instruction counts as a failure. This enforces the
# "static jumps only" invariant across the whole stack (famc itself and
# every program it produces).
set -u

DIR="$(cd "$(dirname "$0")/.." && pwd)"
FAMC="$DIR/bin/famc"
NO_JALR="$DIR/tools/no-jalr"
TMPDIR=$(mktemp -d)

cleanup() {
	kill $(jobs -p) 2>/dev/null || true
	wait 2>/dev/null || true
	rm -rf "$TMPDIR"
}
trap cleanup EXIT INT TERM

VERBOSE=0
[[ "${1:-}" == "--verbose" ]] && VERBOSE=1

PASS=0
FAIL=0
TOTAL=0

QCPU='rv32,m=false,a=false,f=false,d=false,c=false,zawrs=false,zfa=false,zfh=false,zfhmin=false,zcb=false,zcd=false,zcf=false,zcmp=false,zcmt=false,zicsr=false,zifencei=false'

# compile: feed source to famc via stdin, write the generated binary to stdout.
compile() {
	(echo "$1"; printf '\004') | timeout -k 2 10 qemu-system-riscv32 \
		-machine virt \
		-cpu "$QCPU" \
		-nographic -bios none \
		-device loader,file="$FAMC",addr=0x80000000 \
		-serial mon:stdio 2>/dev/null
}

# run_bin: execute a compiled binary in qemu, write UART output to stdout.
#   Relies on the program's poweroff epilogue to terminate the qemu process.
run_bin() {
	timeout -k 2 10 qemu-system-riscv32 \
		-machine virt \
		-cpu "$QCPU" \
		-nographic -bios none \
		-device loader,file="$1",addr=0x80000000 \
		-serial stdio -monitor none < /dev/null 2>/dev/null
}

# check_bin: verify the file is a valid famc binary (first byte 0x13 q32 nop)
#   and contains no jalr instructions.  Returns 0 on success, 1 on failure.
check_bin() {
	local bin="$1"
	local first
	first=$(xxd -l1 -p "$bin" 2>/dev/null || echo "")
	[[ "$first" == "13" ]] || return 1
	"$NO_JALR" "$bin" > /dev/null 2>&1 || return 2
	return 0
}

# test_compiles: source must compile to a valid, jalr-free binary.
test_compiles() {
	TOTAL=$((TOTAL + 1))
	local name="$1" src="$2"
	local bin="$TMPDIR/test_${TOTAL}.bin"
	compile "$src" > "$bin" 2>&1 || true
	case "$(check_bin "$bin"; echo $?)" in
		0)
			PASS=$((PASS + 1))
			[[ $VERBOSE -eq 1 ]] && echo "  PASS  $name"
			;;
		1)
			FAIL=$((FAIL + 1))
			echo "  FAIL  $name (no valid binary: $(head -c40 "$bin" | xxd -p))"
			;;
		2)
			FAIL=$((FAIL + 1))
			echo "  FAIL  $name (contains jalr)"
			;;
	esac
}

# test_runs: source must compile AND execute to clean exit (rc 0, via poweroff).
test_runs() {
	TOTAL=$((TOTAL + 1))
	local name="$1" src="$2"
	local bin="$TMPDIR/test_${TOTAL}.bin"
	compile "$src" > "$bin" 2>&1 || true
	case "$(check_bin "$bin"; echo $?)" in
		1)  FAIL=$((FAIL + 1))
		    echo "  FAIL  $name (no valid binary: $(head -c40 "$bin" | xxd -p))"
		    return ;;
		2)  FAIL=$((FAIL + 1))
		    echo "  FAIL  $name (contains jalr)"
		    return ;;
	esac
	local rc=0
	run_bin "$bin" > /dev/null || rc=$?
	if [[ $rc -eq 0 ]]; then
		PASS=$((PASS + 1))
		[[ $VERBOSE -eq 1 ]] && echo "  PASS  $name"
	else
		FAIL=$((FAIL + 1))
		echo "  FAIL  $name (run exited with $rc)"
	fi
}

# test_output: source compiles, runs, and UART output matches $expected exactly.
test_output() {
	TOTAL=$((TOTAL + 1))
	local name="$1" src="$2" expected="$3"
	local bin="$TMPDIR/test_${TOTAL}.bin"
	compile "$src" > "$bin" 2>&1 || true
	case "$(check_bin "$bin"; echo $?)" in
		1)  FAIL=$((FAIL + 1))
		    echo "  FAIL  $name (no valid binary: $(head -c40 "$bin" | xxd -p))"
		    return ;;
		2)  FAIL=$((FAIL + 1))
		    echo "  FAIL  $name (contains jalr)"
		    return ;;
	esac
	local actual
	actual=$(run_bin "$bin" || true)
	if [[ "$actual" == "$expected" ]]; then
		PASS=$((PASS + 1))
		[[ $VERBOSE -eq 1 ]] && echo "  PASS  $name"
	else
		FAIL=$((FAIL + 1))
		printf "  FAIL  %s (expected %q, got %q)\n" "$name" "$expected" "$actual"
	fi
}

# test_gp_matches_size: compile+run $src (which must print gp as 8 hex digits
# to UART), then verify gp == 0x80000000 + aligned_binary_size. Locks in the
# famc invariant that gp points to the first 4-byte-aligned address past the
# compiled binary — nodes rely on this to compute their own base via gp-BIN_SIZE
# without needing an image_base builtin.
test_gp_matches_size() {
	TOTAL=$((TOTAL + 1))
	local name="$1" src="$2"
	local bin="$TMPDIR/test_${TOTAL}.bin"
	compile "$src" > "$bin" 2>&1 || true
	case "$(check_bin "$bin"; echo $?)" in
		1)  FAIL=$((FAIL + 1))
		    echo "  FAIL  $name (no valid binary: $(head -c40 "$bin" | xxd -p))"
		    return ;;
		2)  FAIL=$((FAIL + 1))
		    echo "  FAIL  $name (contains jalr)"
		    return ;;
	esac
	local size aligned expected actual
	size=$(wc -c < "$bin")
	aligned=$(( (size + 3) & ~3 ))
	expected=$(printf '%08X' $((0x80000000 + aligned)))
	actual=$(run_bin "$bin" || true)
	if [[ "$actual" == "$expected" ]]; then
		PASS=$((PASS + 1))
		[[ $VERBOSE -eq 1 ]] && echo "  PASS  $name"
	else
		FAIL=$((FAIL + 1))
		printf "  FAIL  %s (expected gp=%s, got %q; bin size %d aligned %d)\n" \
			"$name" "$expected" "$actual" "$size" "$aligned"
	fi
}

# test_error: source must fail to compile, producing an error message on stdout
# that exactly matches $expected. The "binary" famc emits on error is just the
# error text (not a valid compiled binary).
test_error() {
	TOTAL=$((TOTAL + 1))
	local name="$1" src="$2" expected="$3"
	local bin="$TMPDIR/test_${TOTAL}.out"
	compile "$src" > "$bin" 2>&1 || true
	local actual
	# Error output is terminated by poweroff; strip any trailing whitespace
	# and extract the first line (the formatted error).
	actual=$(head -c 256 "$bin" 2>/dev/null | tr -d '\0' | head -n1 | tr -d '\r')
	if [[ "$actual" == "$expected" ]]; then
		PASS=$((PASS + 1))
		[[ $VERBOSE -eq 1 ]] && echo "  PASS  $name"
	else
		FAIL=$((FAIL + 1))
		printf "  FAIL  %s (expected %q, got %q)\n" "$name" "$expected" "$actual"
	fi
}

# ============================================================================
echo "Building..."
if ! (cd "$DIR" && bash ./scripts/build.sh) > /dev/null 2>&1; then
	echo "Build failed!"
	exit 1
fi

# The no-jalr audit is meaningful only if bin/famc itself is clean.
# Catch regressions in famc.fam3 early.
if ! "$NO_JALR" "$FAMC" > /dev/null 2>&1; then
	echo "bin/famc contains jalr — stack invariant broken!"
	"$NO_JALR" "$FAMC"
	exit 1
fi

# Smoke test: simplest valid program must compile, run, and exit cleanly.
echo "Smoke test..."
compile "fn main() { x = 0; } main();" > "$TMPDIR/smoke.bin" 2>&1 || true
if ! check_bin "$TMPDIR/smoke.bin"; then
	echo "Smoke test failed: $(head -c40 "$TMPDIR/smoke.bin" | xxd -p)"
	exit 1
fi
if ! run_bin "$TMPDIR/smoke.bin" > /dev/null; then
	echo "Smoke test failed: compiled binary didn't exit cleanly"
	exit 1
fi
echo ""

# ============================================================================
echo "=== Literals ==="
test_output  "decimal literal"       "@0x10000000 = 65;"   "A"
test_output  "decimal 48 (zero digit)" "@0x10000000 = 48;" "0"
test_output  "hex literal (lower x)" "@0x10000000 = 0x41;" "A"
test_output  "hex literal (upper X)" "@0x10000000 = 0X41;" "A"
test_output  "small decimal"         "@0x10000000 = 9;"    $'\t'
test_output  "two-digit hex"         "@0x10000000 = 0x42;" "B"

# ============================================================================
echo "=== Variables ==="
test_output  "assign and use"        "fn main() { x = 65; @0x10000000 = x; } main();"                "A"
test_output  "reassign same slot"    "fn main() { x := 1; x := 65; @0x10000000 = x; } main();"         "A"
test_output  "two variables"         "fn main() { x = 60; y = 5; @0x10000000 = x + y; } main();"     "A"
test_output  "var copies other"      "fn main() { x = 65; y = x; @0x10000000 = y; } main();"         "A"
test_output  "underscore in ident"   "fn main() { my_var = 65; @0x10000000 = my_var; } main();"      "A"
test_output  "digits in ident"       "fn main() { x1 = 60; x2 = 5; @0x10000000 = x1 + x2; } main();" "A"
test_output  "uppercase in ident"    "fn main() { Foo = 65; @0x10000000 = Foo; } main();"            "A"

# ============================================================================
echo "=== Addition ==="
test_output  "literal + literal"     "@0x10000000 = 60 + 5;"                             "A"
test_output  "var + literal"         "fn main() { x = 60; @0x10000000 = x + 5; } main();"                      "A"
test_output  "literal + var"         "fn main() { x = 5; @0x10000000 = 60 + x; } main();"                      "A"
test_output  "var + var"             "fn main() { x = 60; y = 5; @0x10000000 = x + y; } main();"               "A"
test_output  "3-operand chain"       "fn main() { a = 10; b = 40; c = 15; @0x10000000 = a + b + c; } main();"  "A"
test_output  "4-operand chain"       "fn main() { a = 10; b = 20; c = 15; d = 20; @0x10000000 = a + b + c + d; } main();"  "A"
test_output  "8-operand chain" \
	"fn main() { a = 10; b = 10; c = 10; d = 10; e = 10; f = 5; g = 5; h = 5; @0x10000000 = a + b + c + d + e + f + g + h; } main();" "A"
test_output  "nested temps" \
	"fn main() { a = 10; b = 20; c = 15; d = 20; e = a + b; f = c + d; @0x10000000 = e + f; } main();"  "A"

# ============================================================================
echo "=== Byte deref (@) ==="
test_output  "byte store literal"    "@0x10000000 = 65;"                       "A"
test_output  "byte store via var"    "fn main() { p = 0x10000000; @p = 65; } main();"                "A"
test_output  "byte store with expr"  "fn main() { p = 0x10000000; @p = 60 + 5; } main();"            "A"
test_output  "byte round-trip RAM"   "fn main() { p = 0x80200000; @p = 65; @0x10000000 = @p; } main();"  "A"
test_output  "byte load into var"    "fn main() { @0x80200000 = 65; x = @0x80200000; @0x10000000 = x; } main();"  "A"
test_output  "byte arithmetic"       "@0x80200000 = 60; @0x10000000 = @0x80200000 + 5;"    "A"

# ============================================================================
echo "=== Word deref (*) ==="
test_compiles "word store literal"   "*0x80200000 = 65;"
test_compiles "word store via var"   "fn main() { p = 0x80200000; *p = 65; } main();"
test_output  "word round-trip"       "fn main() { p = 0x80200000; *p = 65; @0x10000000 = *p; } main();"         "A"
test_output  "word then byte read"   "*0x80200000 = 65; @0x10000000 = @0x80200000;"       "A"
test_output  "word store with expr"  "fn main() { p = 0x80200000; *p = 60 + 5; @0x10000000 = @p; } main();"     "A"

# ============================================================================
echo "=== Multi-statement output ==="
test_output  "two chars"             "@0x10000000 = 72; @0x10000000 = 105;"                              "Hi"
test_output  "five chars (Hello)" \
	"@0x10000000 = 72; @0x10000000 = 101; @0x10000000 = 108; @0x10000000 = 108; @0x10000000 = 111;"      "Hello"
test_output  "uart via variable" \
	"fn main() { u = 0x10000000; @u = 72; @u = 105; } main();" "Hi"
test_output  "the pass-1 example"    "fn main() { x = 1; y = x + 48; @0x10000000 = y; } main();" "1"

# ============================================================================
echo "=== Stack machine stress ==="
# Many sequential stores, each with their own + chain. Exercises the stack
# machine push/pop pattern plus variable slot reuse.
test_output  "sequential ascii 0..9" \
	"fn main() { b = 48; @0x10000000 = b + 0; @0x10000000 = b + 1; @0x10000000 = b + 2; @0x10000000 = b + 3; @0x10000000 = b + 4; @0x10000000 = b + 5; @0x10000000 = b + 6; @0x10000000 = b + 7; @0x10000000 = b + 8; @0x10000000 = b + 9; } main();" \
	"0123456789"

# Long + chain that definitely exceeds what a one-temp accumulator could
# handle (the old code would have clobbered an LHS). 16 operands.
test_output  "16-operand add chain" \
	"fn main() { a = 4; b = 4; c = 4; d = 4; e = 4; f = 4; g = 4; h = 4; i = 4; j = 4; k = 4; l = 4; m = 4; n = 4; o = 4; p = 5; @0x10000000 = a + b + c + d + e + f + g + h + i + j + k + l + m + n + o + p; } main();" \
	"A"

# Many variables — we have 512 slots, this uses 32.
test_output  "32 variable slots" \
	"fn main() { v0 = 33; v1 = 0; v2 = 0; v3 = 0; v4 = 0; v5 = 0; v6 = 0; v7 = 0; v8 = 0; v9 = 0; v10 = 0; v11 = 0; v12 = 0; v13 = 0; v14 = 0; v15 = 0; v16 = 0; v17 = 0; v18 = 0; v19 = 0; v20 = 0; v21 = 0; v22 = 0; v23 = 0; v24 = 0; v25 = 0; v26 = 0; v27 = 0; v28 = 0; v29 = 0; v30 = 0; v31 = 32; @0x10000000 = v0 + v31; } main();" \
	"A"

# ============================================================================
echo "=== Xor (^) ==="
test_output  "xor literals" \
	"@0x10000000 = 0x50 ^ 0x11;" "A"
test_output  "xor variables" \
	"fn main() { a = 0x41; b = 0x05; @0x10000000 = a ^ b ^ b; } main();" "A"
test_output  "xor three-operand chain" \
	"@0x10000000 = 65 ^ 7 ^ 7;" "A"
# '+' binds tighter than '^': (60+5) ^ 0 = 65 = 'A'.
test_output  "xor lower precedence than add" \
	"@0x10000000 = 60 + 5 ^ 0;" "A"
test_output  "xor mixed with subtraction" \
	"@0x10000000 = 70 - 1 ^ 4;" "A"

# ============================================================================
echo "=== Prefix/postfix ++ -- ==="
# Prefix ++: value after increment.
test_output  "prefix ++ yields new value" \
	"fn main() { x := 50; @0x10000000 = ++x; } main();" "3"
# Postfix ++: value is old, variable updated.
test_output  "postfix ++ yields old value" \
	"fn main() { x := 50; @0x10000000 = x++; @0x10000000 = x; } main();" "23"
# Prefix --.
test_output  "prefix -- yields new value" \
	"fn main() { x := 52; @0x10000000 = --x; } main();" "3"
# Postfix --.
test_output  "postfix -- yields old value" \
	"fn main() { x := 52; @0x10000000 = x--; @0x10000000 = x; } main();" "43"
# Mixed postfix ++ with '+': (60) + (5) = 65='A', and a,b updated.
test_output  "postfix ++ in add expression" \
	"fn main() { a := 60; b := 5; @0x10000000 = a++ + b++; } main();" "A"
# Two postfix increments in sequence, variable fully updated.
test_output  "repeated postfix ++ updates variable" \
	"fn main() { x := 63; @0x10000000 = x++; @0x10000000 = x++; @0x10000000 = x; } main();" "?@A"
# Prefix ++ inside a longer add chain: (1+1)+(50)+12 = 64='@', x=2 after.
test_output  "prefix ++ inside add chain" \
	"fn main() { x := 1; @0x10000000 = ++x + 50 + 12; } main();" "@"

# ============================================================================
echo "=== Compound assignments ==="
test_output  "x += literal" \
	"fn main() { x := 60; x += 5; @0x10000000 = x; } main();" "A"
test_output  "x += expr" \
	"fn main() { x := 60; y = 3; x += y + 2; @0x10000000 = x; } main();" "A"
test_output  "x -= literal" \
	"fn main() { x := 70; x -= 5; @0x10000000 = x; } main();" "A"
test_output  "x ^= literal" \
	"fn main() { x := 0x43; x ^= 0x02; @0x10000000 = x; } main();" "A"
test_output  "chained compound assigns" \
	"fn main() { x := 10; x += 20; x += 30; x += 5; @0x10000000 = x; } main();" "A"
# The case that triggered the original hang report.
test_output  "the x += 1 repro" \
	"fn main() { x := 2; x += 1; y = x + 48; @0x10000000 = y; } main();" "3"

# ============================================================================
echo "=== Bare inc/dec statements ==="
test_output  "bare ++x statement" \
	"fn main() { x := 64; ++x; @0x10000000 = x; } main();" "A"
test_output  "bare x++ statement" \
	"fn main() { x := 64; x++; @0x10000000 = x; } main();" "A"
test_output  "bare --x statement" \
	"fn main() { x := 66; --x; @0x10000000 = x; } main();" "A"
test_output  "bare x-- statement" \
	"fn main() { x := 66; x--; @0x10000000 = x; } main();" "A"
test_output  "repeated bare ++x" \
	"fn main() { x := 60; ++x; ++x; ++x; ++x; ++x; @0x10000000 = x; } main();" "A"

# ============================================================================
echo "=== Shifts (<< >>) ==="
test_output  "lshift literal" \
	"@0x10000000 = 1 << 6;" "@"
test_output  "rshift literal (arith, positive)" \
	"@0x10000000 = 130 >> 1;" "A"
test_output  "lshift zero is identity" \
	"@0x10000000 = 0x41 << 0;" "A"
# Signed right shift on a negative value sign-extends.
# -128 = 0xFFFFFF80, >> 1 = 0xFFFFFFC0 = -64. Then +193 = 129.
# Use a byte write so we get the low 8 bits: 0xC0 + 0xC1 ... careful.
# Simpler: -64 & 0xff = 0xC0. For an ASCII test, use a non-negative case.
test_output  "chained rshift" \
	"@0x10000000 = 256 >> 1 >> 1;" "@"
# Precedence: '+' tighter than '<<'.  1 << (2+4) = 1<<6 = 64='@'.
test_output  "shift lower precedence than add (rhs)" \
	"@0x10000000 = 1 << 2 + 4;" "@"
# (1+2) << 4 = 48 = '0'.
test_output  "shift lower precedence than add (lhs)" \
	"@0x10000000 = 1 + 2 << 4;" "0"
# '^' is lower than '<<': 0x40 ^ (1<<0) = 0x40 ^ 1 = 0x41 = 'A'.
test_output  "xor lower precedence than shift" \
	"@0x10000000 = 0x40 ^ 1 << 0;" "A"
test_output  "compound <<= " \
	"fn main() { x := 8; x <<= 3; @0x10000000 = x; } main();" "@"
test_output  "compound >>= " \
	"fn main() { x := 260; x >>= 2; @0x10000000 = x; } main();" "A"
test_output  "compound <<= then >>=" \
	"fn main() { x := 1; x <<= 6; x <<= 1; x >>= 1; @0x10000000 = x; } main();" "@"
test_output  "shift with variable rhs" \
	"fn main() { x = 1; n = 6; @0x10000000 = x << n; } main();" "@"

# ============================================================================
echo "=== Bitwise AND (&) ==="
test_output  "and literal masks low bits" \
	"@0x10000000 = 0x4F & 0x41;" "A"
test_output  "and literal masks upper bits" \
	"@0x10000000 = 0xFF & 65;" "A"
test_output  "compound &=" \
	"fn main() { x := 0x47; x &= 0x41; @0x10000000 = x; } main();" "A"
# '&' binds tighter than '^': (0x41 & 0x0F) ^ 0x4E = 0x01 ^ 0x4E = 0x4F = 'O'.
# If '^' were tighter: 0x41 & (0x0F ^ 0x4E) = 0x41 & 0x41 = 0x41 = 'A'.
# So a result of 'O' confirms Rust precedence (& > ^).
test_output  "and tighter than xor (rust precedence)" \
	"@0x10000000 = 0x41 & 0x0F ^ 0x4E;" "O"
test_output  "and tighter than xor — commuted" \
	"@0x10000000 = 0x4E ^ 0x41 & 0x0F;" "O"
# '<<' tighter than '&': (1 << 6) & 0x7F = 64 & 0x7F = 64 = '@'.
test_output  "shift tighter than and" \
	"@0x10000000 = 1 << 6 & 0x7F;" "@"

# ============================================================================
echo "=== Bitwise OR (|) ==="
test_output  "or literal" \
	"@0x10000000 = 0x40 | 1;" "A"
test_output  "or literal commuted" \
	"@0x10000000 = 0x01 | 0x40;" "A"
test_output  "compound |=" \
	"fn main() { x := 0x40; x |= 1; @0x10000000 = x; } main();" "A"
# '^' tighter than '|': 0x40 | (1 ^ 0) = 0x40 | 1 = 0x41 = 'A'.
test_output  "xor tighter than or" \
	"@0x10000000 = 0x40 | 1 ^ 0;" "A"
# '<<' tighter than '|': (1 << 6) | 1 = 65 = 'A'.
test_output  "shift tighter than or" \
	"@0x10000000 = 1 << 6 | 1;" "A"
# '&' tighter than '|': (0x45 & 0x40) | 1 = 0x40 | 1 = 'A'.
test_output  "and tighter than or" \
	"@0x10000000 = 0x45 & 0x40 | 1;" "A"
# Full sanity mix: bitfield composition.
test_output  "or many bits together" \
	"@0x10000000 = 1 | 64;" "A"

# ============================================================================
echo "=== Unary ~ and - ==="
# ~0xBE = 0xFFFFFF41; low byte is 0x41='A'.
test_output  "unary ~ literal" \
	"@0x10000000 = ~0xBE;" "A"
# Double NOT is identity.
test_output  "unary ~ chained" \
	"@0x10000000 = ~~65;" "A"
# Unary '-' on a variable.
test_output  "unary - variable" \
	"fn main() { x = 1; @0x10000000 = -x + 66; } main();" "A"
# Adding a negative.
test_output  "unary - in add chain" \
	"fn main() { x = 10; @0x10000000 = 75 + -x; } main();" "A"
# Subtracting a negative.
test_output  "unary - under subtraction" \
	"fn main() { x = 5; @0x10000000 = 60 - -x; } main();" "A"
# Chaining: -(~64) = -(-65) = 65 = 'A'.
test_output  "unary - applied to ~" \
	"@0x10000000 = -~64;" "A"
# Double unary - with whitespace: - -x = x.
test_output  "double unary - with space" \
	"fn main() { x = 65; @0x10000000 = - -x; } main();" "A"
# ~x is -x-1. -(-x-1) = x+1. So with x=64, result = 65 = 'A'.
test_output  "neg of not of variable" \
	"fn main() { x = 64; @0x10000000 = -~x; } main();" "A"

# ============================================================================
echo "=== Parens ==="
test_output  "paren around literal" \
	"@0x10000000 = (65);" "A"
