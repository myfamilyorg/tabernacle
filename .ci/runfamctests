# rewriting write_self.fam3 in famc.
#
# (1) `!=` as a ternary condition selected the wrong branch.  Root cause:
#     peephole B in cep_pre_tern mapped `slt[u]` funct3 to its branch funct3
#     by `+2`, which only works for slt(2)→blt(4); for sltu(3) it produced
#     bge(5) instead of bltu(6). `!=` lowers to `xor; sltu a0, zero, a0` and
#     hit this peephole. Fixed by `funct3 << 1` (slt→blt, sltu→bltu).
test_output  "ternary with != condition, true case (value)" \
	"fn main() { x := 1; @0x10000000 = x != 0 ? 'A' : 'B'; } main();" "A"
test_output  "ternary with != condition, false case (value)" \
	"fn main() { x := 0; @0x10000000 = x != 0 ? 'B' : 'A'; } main();" "A"
test_output  "ternary with <u condition, true case" \
	"fn main() { x := 5; @0x10000000 = x <u 10 ? 'A' : 'B'; } main();" "A"
test_output  "ternary with <u condition, false case" \
	"fn main() { x := 10; @0x10000000 = x <u 5 ? 'B' : 'A'; } main();" "A"
test_output  "ternary with >=u condition, true case" \
	"fn main() { x := 10; @0x10000000 = x >=u 5 ? 'A' : 'B'; } main();" "A"
# (2) Two-armed ternary with fn calls in BOTH branches always returned the
#     false-branch value.  Root cause: ce_cep_tern_mid had a peephole that
#     skipped emitting jal_end when the middle's last insn was an
#     unconditional jal — intended for `break`/`return` (which don't fall
#     through), but `f()` also ends in a jal that *does* fall through (to
#     the post-call return site). Fixed by removing that peephole; an extra
#     jal_end gets emitted in the break/return cases but it's just
#     unreachable padding (one word).
test_output  "ternary with fn calls in both branches, true case" \
	"fn f() { 65 } fn g() { 66 } @0x10000000 = 1 ? f() : g();" "A"
test_output  "ternary with fn calls in both branches, false case" \
	"fn f() { 65 } fn g() { 66 } @0x10000000 = 0 ? f() : g();" "B"
test_output  "ternary with fn call only in then, runtime cond" \
	"fn f() { 65 } fn main() { x := 1; @0x10000000 = x ? f() : 66; } main();" "A"
test_output  "ternary with fn call only in else, runtime cond" \
	"fn g() { 66 } fn main() { x := 0; @0x10000000 = x ? 65 : g(); } main();" "B"
test_output  "nested ternary with fn calls in branches" \
	"fn a() { 65 } fn b() { 66 } fn c() { 67 } @0x10000000 = 1 ? a() : 0 ? b() : c();" "A"
# (3) `asm { ... }` was only recognized as a top-level statement; using it
#     inside a block expression (or any nested context) errored out as
#     "undefined variable" because the block parser tried to look up `asm`
#     in the var symtab. Fixed by teaching ct_lbrace's leading-ident scan
#     to recognize the `asm` keyword and divert to cs_kw_asm.
test_output  "asm inside block expression" \
	"fn main() { x := 0; { asm { (x = gp) }; 0 }; @0x10000000 = x != 0 ? 'A' : 'N'; } main();" "A"
test_output  "asm inside fn body" \
