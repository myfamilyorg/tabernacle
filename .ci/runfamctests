# ── Var-register-allocation safety tests (semantic invariants) ──────────────
# These tests pin down behavior that any "variables in registers" allocator
# must preserve. They pass with the current memory-resident model and must
# keep passing after the refactor.
#
# Test 1: caller's locals survive a callee that uses many of its own locals.
# Verifies the save/restore trailer covers var-home regs, not just expr stack.
test_output  "caller vars survive callee with many vars" \
	"fn cle() { a := 99; b := 99; c := 99; d := 99; a+b+c+d } fn cer() { w := 10; x := 20; y := 15; z := 20; cle(); w+x+y+z } @0x10000000 = cer();" "A"
# Test 2: var carried across loop back-edge stays live.
test_output  "var live across loop back-edge" \
	"fn main() { x := 5; y := 0; loop { x == 0 ? break 0; y += x; x -= 1; }; @0x10000000 = y + 50; } main();" "A"
# Test 3: var conditionally updated via one-armed ternary, then read.
# Ensures the var's value at the join is consistent regardless of branch.
test_output  "var read after one-armed ternary update" \
	"fn main() { x := 60; y := 1; y > 0 ? x += 5; @0x10000000 = x; } main();" "A"
# Test 4: many vars (stresses the var-register pool) used in deep expression.
# Mixes register-homed vars with expression-stack pressure.
test_output  "5 vars in deeply nested add" \
	"fn main() { a := 1; b := 2; c := 3; d := 4; e := 5; @0x10000000 = a+(b+(c+(d+(e+50)))); } main();" "A"
# Test 5: 11 vars — exceeds any plausible reg pool, forcing spill-to-frame
# alongside reg-homed vars in the same expression.
test_output  "11 vars summed (mixed reg + frame homes)" \
	"fn main() { a := 1; b := 2; c := 3; d := 4; e := 5; f := 6; g := 7; h := 8; i := 9; j := 10; k := 10; @0x10000000 = a+b+c+d+e+f+g+h+i+j+k; } main();" "A"
# Test 6: function with 8 args + 4 locals, exercising arg-to-reg moves and
# local register allocation simultaneously.
test_output  "fn with 8 args + 4 locals" \
	"fn many(a,b,c,d,e,f,g,h) { x := 1; y := 2; z := 3; w := 4; a+b+c+d+e+f+g+h+x+y+z+w } @0x10000000 = many(1,2,3,4,5,6,7,8) + 19;" "A"
# Symtab growth across fn bodies: two back-to-back fns each with enough
# locals to trigger a symtab reallocation (>32 entries). Before the fix,
# the stack-saved s8 and fn_scope_base were absolute pointers that went
# stale after a grow, causing the next fn's locals to be written into
# abandoned memory — which happened to overlap fn_symtab and silently
# corrupted earlier fn name entries. Keep two fns × 40 locals.
test_output  "symtab-grow spanning two fns (40 locals each)" \
	"$(python3 -c "
for fi in range(2):
    print(f'fn g{fi}(x) {{', end=' ')
    for i in range(40):
        print(f'C{i} = {i+1};', end=' ')
    print('x + 1 }', end=' ')
print('@0x10000000 = g0(32) + g1(31);')
")" "A"

