echo "=== gp points to end of binary (node base calc depends on this) ==="
# Nodes compute their base address as `gp - BIN_SIZE` rather than via a
# dedicated image-base builtin. This only works if gp is set to exactly
# align_up(binary_base + binary_size, 4). Test that invariant directly:
# compile a small program, read its gp, and compare against the measured
# binary size on disk.
test_gp_matches_size "gp == base + aligned_size (minimal)" "$(cat <<'EOT'
fn main() {
g := 0;
asm { (g = gp) }
for i in 0..8 {
    n := (g >>u ((7 - i) << 2)) & 0xF;
    @0x10000000 = n < 10 ? '0' + n : 'A' + n - 10;
};
}
main();
EOT
)"
# Same invariant, larger binary (more instructions emitted).
test_gp_matches_size "gp == base + aligned_size (with fn + loop)" "$(cat <<'EOT'
fn emit_hex(v) {
    for i in 0..8 {
        n := (v >>u ((7 - i) << 2)) & 0xF;
        @0x10000000 = n < 10 ? '0' + n : 'A' + n - 10;
    };
    0
}
fn main() {
g := 0;
asm { (g = gp) }
emit_hex(g);
}
main();
EOT
)"

