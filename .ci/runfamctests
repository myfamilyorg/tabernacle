# correctly as both rvalue and lvalue at statement top level and within
# expression context.
test_output  "@fn() rvalue" \
	"fn addr() { 0x80100000 } fn main() { p := 0x80100000; @p = 65; @0x10000000 = @addr(); } main();" "A"
test_output  "@fn() = value (assignment target)" \
