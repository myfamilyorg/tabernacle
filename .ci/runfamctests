echo "=== Known C-semantics quirks (documented, not bugs) ==="
# Shifts mask the shift amount to its low 5 bits (RISC-V SLLI/SRLI
# convention). Not a bug — matches the underlying hardware — but worth
# locking in so a refactor can't silently change it.
test_output  "1 << 32 == 1 (RISC-V mask)" \
	"fn main() { v := 1 << 32; @0x10000000 = v == 1 ? 'A' : 'N'; } main();" "A"
test_output  "1 << 33 == 2 (RISC-V mask)" \
	"fn main() { v := 1 << 33; @0x10000000 = v == 2 ? 'A' : 'N'; } main();" "A"
test_output  "1 << 64 == 1 (mask again)" \
	"fn main() { v := 1 << 64; @0x10000000 = v == 1 ? 'A' : 'N'; } main();" "A"
# Division/modulo by zero returns M-extension sentinel values.
test_output  "5 / 0 == -1 (M-ext convention)" \
	"fn main() { v := 5 / 0; @0x10000000 = v == -1 ? 'A' : 'N'; } main();" "A"
test_output  "5 % 0 == 5 (remainder is dividend)" \
	"fn main() { v := 5 % 0; @0x10000000 = v == 5 ? 'A' : 'N'; } main();" "A"
test_output  "5 /u 0 == -1" \
	"fn main() { v := 5 /u 0; @0x10000000 = v == -1 ? 'A' : 'N'; } main();" "A"
# Chained comparisons lower left-associatively (C semantics, not math).
# `3 < 2 < 1` is `(3<2)<1` = `0<1` = 1 (true), NOT "is 2 between 3 and 1".
test_output  "chained comparison — C-style left-assoc" \
	"@0x10000000 = (3 < 2 < 1) == 1 ? 'A' : 'N';" "A"
# Short-circuit skips RHS side effects.
test_output  "&& short-circuits division by zero on LHS=0" \
	"fn main() { x := 0; r := (x != 0) && (10 / x > 0); @0x10000000 = r == 0 ? 'A' : 'N'; } main();" "A"
test_output  "|| short-circuits division by zero when LHS true" \
	"fn main() { x := 0; r := (x == 0) || (10 / x > 0); @0x10000000 = r == 1 ? 'A' : 'N'; } main();" "A"

