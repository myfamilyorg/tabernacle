# test_node.fam3 — minimal payload for famchain disk-path testing.
# Prints 'L' (= "Loaded successfully") to UART and halts.
# Position-independent: uses only absolute MMIO addresses.

.equ	UART,	0x10000000
.equ	HALT,	0x00100000

_start:
	li	t0, UART
	li	t1, 'L'
	sb	t1, 0(t0)
	li	t0, HALT
	li	t1, 0x5555
	sw	t1, 0(t0)
done:
	wfi
	j	done
